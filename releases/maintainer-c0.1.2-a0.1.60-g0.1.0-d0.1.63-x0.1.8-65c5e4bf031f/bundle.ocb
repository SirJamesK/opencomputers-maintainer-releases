local probe = require("oc.ae2.probe")
probe.print()
#!/bin/lua
local craft = require("oc.ae2.craft")
local args = {...}

if args[1] ~= "--offline" then
  io.write("Refused: ae2-craft-probe can enumerate the live AE2 grid. Run ae2-craft-probe --offline [filter] only during planned diagnostics.\n")
  return
end
craft.print(args[2], { offline = true })
#!/bin/lua
local daemon = require("oc.ae2.maintainer_daemon")
local daemonConfig = require("oc.ae2.maintainer_daemon_config")
local maintainer = require("oc.ae2.maintainer")
local args = {...}
local mode = args[1] == "--armed" and "armed" or "observe"
local PLAN_INTERVAL = 600
local POLL_INTERVAL = 600

if args[1] == "-h" or args[1] == "--help" then
  io.write("usage: ae2-maintainer [--armed|--daemon [duration]]\n")
  io.write("default observe mode prints decisions without crafting\n")
  io.write("--daemon submits armed workflow queue requests every 600s by default; duration accepts s/m/h/d/w\n")
  return
end

if args[1] == "--daemon" then
  local interval = daemonConfig.clampInterval(args[2] or PLAN_INTERVAL, PLAN_INTERVAL)
  io.write("AE2 maintainer daemon interval=" .. tostring(interval) .. "s\n")
  return daemon.run({ interval = interval, pollInterval = POLL_INTERVAL })
end

maintainer.print(maintainer.run({ mode = mode }))
#!/bin/lua
local workflows = require("oc.ae2.workflows")
local args = {...}

local function printHelp()
  io.write("usage: ae2-workflow [--list|--show-bind|--migrate [CONFIRM]|--recover CONFIRM|--bind <index> <item|fluid> <namespace:path> <damage|->|--rebind <index> <item|fluid> <namespace:path> <damage|-> CONFIRM|--auto <label>]\n")
  workflows.printBindHelp()
end

local function failExit()
  if os and type(os.exit) == "function" then os.exit(1) end
end

local function printMigration(status)
  status = status or {}
  io.write(string.format("workflow config: %s (%s bytes, %s source rows; %s active rows; %s unbound, %s tagged)\n",
    tostring(status.state or "unknown"), tostring(status.bytes or 0), tostring(status.sourceRows or 0),
    tostring(status.rows or 0), tostring(status.unbound or 0), tostring(status.tagged or 0)))
  if status.compacted and status.compacted > 0 then
    io.write("duplicate candidates retained during format-only migration: " .. tostring(status.compacted) .. "\n")
  end
end

if args[1] == "--help" or args[1] == "-h" then
  printHelp()
elseif args[1] == "--list" then
  if args[2] then
    io.write("error: --list takes no additional arguments\n")
    printHelp()
  else
    workflows.print()
  end
elseif args[1] == "--show-bind" then
  if args[2] then
    io.write("error: --show-bind takes no additional arguments\n")
    printHelp()
  else
    workflows.printBindings()
  end
elseif args[1] == "--migrate" then
  if args[2] and (args[2] ~= "CONFIRM" or args[3]) then
    io.write("error: --migrate accepts only the final CONFIRM token\n")
    printHelp()
    failExit()
  elseif not args[2] then
    printMigration(workflows.migrationStatus())
    io.write("review the file and run ae2-workflow --migrate CONFIRM with the daemon stopped and oc-dashboard closed\n")
  else
    local daemonConfig = require("oc.ae2.maintainer_daemon_config")
    if daemonConfig.load().enabled then
      io.write("error: stop the maintainer daemon before converting workflow policy\n")
      failExit()
    else
      local ok, reason, status = workflows.migrate()
      if not ok then
        io.write("error: " .. tostring(reason) .. "\n")
        failExit()
      else
        printMigration(status)
        io.write("ok: formatted workflow policy; raw source archived at " .. tostring(status.archive or "(not needed)") .. "\n")
      end
    end
  end
elseif args[1] == "--recover" then
  if args[2] ~= "CONFIRM" or args[3] then
    io.write("error: --recover requires the final CONFIRM token\n")
    printHelp()
    failExit()
  else
    local daemonConfig = require("oc.ae2.maintainer_daemon_config")
    if daemonConfig.load().enabled then
      io.write("error: stop the maintainer daemon before recovering workflow policy\n")
      failExit()
    else
      local ok, reason, status = workflows.recover()
      if not ok then
        io.write("error: " .. tostring(reason) .. "\n")
        failExit()
      else
        printMigration(workflows.migrationStatus())
        io.write("ok: workflow transaction recovery complete; " .. tostring(status.action or "already clean") .. "\n")
      end
    end
  end
elseif args[1] == "--bind" then
  if not (args[2] and args[3] and args[4] and args[5]) or args[6] then
    io.write("error: --bind requires index, kind, registry name, and damage or -\n")
    printHelp()
    failExit()
  else
    local ok, reason, _, binding = workflows.bindExact(args[2], args[3], args[4], args[5])
    if not ok then
      io.write("error: " .. tostring(reason) .. "\n")
      failExit()
    else
      io.write(string.format("ok: bound #%02d %s -> %s %s dmg=%s; policy preserved and row remains disarmed\n",
        binding.index, tostring(binding.label or "workflow"), binding.kind, binding.name,
        binding.kind == "fluid" and "-" or tostring(binding.damage)))
    end
  end
elseif args[1] == "--rebind" then
  if not (args[2] and args[3] and args[4] and args[5]) or args[7] or args[6] ~= "CONFIRM" then
    io.write("error: --rebind requires index, kind, registry name, damage or -, and final CONFIRM\n")
    printHelp()
    failExit()
  else
    local ok, reason, _, binding = workflows.rebindExact(args[2], args[3], args[4], args[5], args[6])
    if not ok then
      io.write("error: " .. tostring(reason) .. "\n")
      failExit()
    else
      io.write(string.format("ok: rebound #%02d %s -> %s %s dmg=%s; policy preserved and row remains disarmed\n",
        binding.index, tostring(binding.label or "workflow"), binding.kind, binding.name,
        binding.kind == "fluid" and "-" or tostring(binding.damage)))
    end
  end
elseif args[1] == "--manual" then
  io.write("BIND EXACT TARGET REQUIRED: label-only targets cannot submit. --manual labels are disabled; use an exact configured Flow/Daemon target. Exact untagged identities use bounded direct binding, never a grid scan.\n")
elseif args[1] == "--auto" then
  local label = table.concat(args, " ", 2)
  workflows.toggleAuto({ label = label })
  io.write("toggled auto for " .. label .. "\n")
else
  workflows.print()
end
local logger = require("oc.core.logger")
local monitor = require("oc.ae2.monitor")

local args = {...}
local command = args[1] or "start"
local log = logger.new("/var/oc/ae2.log", "info", 8192)

if command == "start" then
  local snapshot = monitor.snapshot()
  if snapshot.available then
    log:write("info", "ae2 available via " .. snapshot.primary.type .. " " .. snapshot.primary.address)
  else
    log:write("warn", "ae2 unavailable: " .. tostring(snapshot.reason))
  end
  return true
elseif command == "stop" then
  log:write("info", "ae2 stop")
  return true
end

io.stderr:write("usage: oc-ae2.lua start|stop\n")
return falselocal component = require("component")

local adapter = {}

adapter.storedMethods = { "getStoredEU", "getStoredEUString", "getEnergyStored", "getStoredEnergy", "getStoredPower" }
adapter.maxMethods = { "getEUCapacity", "getEUCapacityString", "getMaxEnergyStored", "getMaxStoredEnergy", "getMaxStoredPower" }

adapter.detailMethods = {
  avgIn = { "getAverageElectricInput", "getEUInputAverage" },
  avgOut = { "getAverageElectricOutput", "getEUOutputAverage" },
  inV = { "getEUInputVoltage" },
  inA = { "getEUInputAmperage" },
  outV = { "getEUOutputVoltage" },
  outA = { "getEUOutputAmperage" },
  sensor = { "getSensorInformation" },
  name = { "getName", "getOwnerName" },
  active = { "isMachineActive" },
  allowed = { "isWorkAllowed" },
  progress = { "getWorkProgress" },
  maxProgress = { "getWorkMaxProgress" }
}

local function methods(address)
  local ok, result = pcall(component.methods, address)
  if ok and type(result) == "table" then return result end
  return {}
end

local function firstMethod(available, names)
  for _, name in ipairs(names) do
    if available[name] ~= nil then
      return name
    end
  end
  return nil
end

local function matchingMethods(available, names)
  local result = {}
  for _, name in ipairs(names) do
    if available[name] ~= nil then
      result[#result + 1] = name
    end
  end
  return result
end

local function safeCall(address, methodName)
  if not methodName then return nil, nil end
  local ok, value = pcall(component.invoke, address, methodName)
  if ok then return value, nil end
  return nil, tostring(value)
end

local function parseNumber(text)
  local raw = tostring(text or ""):match("([%d][%d,%.]*)")
  if not raw then return nil end
  return tonumber((raw:gsub(",", "")))
end

local function cleanText(value)
  local text = tostring(value or "")
  text = text:gsub(string.char(194, 167) .. ".", "")
  text = text:gsub(string.char(167) .. ".", "")
  return text:gsub("^%s+", ""):gsub("%s+$", "")
end

local function numericValue(value)
  if type(value) == "number" then return value end
  if type(value) == "string" then return parseNumber(value) end
  return nil
end

local function isFiveSecondAverage(lower)
  return lower:find("last 5 seconds") ~= nil or lower:find("last 5 second") ~= nil
end

local function assignAverage(result, field, text, lower)
  local value = parseNumber(text)
  if value == nil then return end
  local window = isFiveSecondAverage(lower) and "5s" or "other"
  if field == "avgIn" then
    if window == "5s" or result.avgIn == nil then
      result.avgIn = value
      result.avgInWindow = window
    end
  elseif field == "avgOut" then
    if window == "5s" or result.avgOut == nil then
      result.avgOut = value
      result.avgOutWindow = window
    end
  end
end

local function readBest(address, names)
  local fallbackValue, fallbackMethod, fallbackError
  for _, methodName in ipairs(names or {}) do
    local value, err = safeCall(address, methodName)
    local numeric = numericValue(value)
    if type(numeric) == "number" and numeric > 0 then
      return numeric, methodName, err
    elseif numeric ~= nil and fallbackValue == nil then
      fallbackValue, fallbackMethod, fallbackError = numeric, methodName, err
    elseif value ~= nil and fallbackValue == nil then
      fallbackValue, fallbackMethod, fallbackError = value, methodName, err
    elseif err and not fallbackError then
      fallbackMethod, fallbackError = methodName, err
    end
  end
  return fallbackValue, fallbackMethod, fallbackError
end

function adapter.parseSensor(sensor)
  local result = {}
  local lines = {}
  if type(sensor) == "table" then
    lines = sensor
  elseif sensor ~= nil then
    lines = { sensor }
  end

  for _, line in ipairs(lines) do
    local text = cleanText(line)
    local lower = text:lower()
    if text ~= "" and not result.title then
      result.title = text
    end
    if lower:find("eu stored") then
      result.stored = parseNumber(text)
    elseif lower:find("eu capacity") or lower:find("capacity") then
      result.max = parseNumber(text)
    elseif lower:find("avg eu in") or lower:find("average electric input") then
      assignAverage(result, "avgIn", text, lower)
    elseif lower:find("avg eu out") or lower:find("average electric output") then
      assignAverage(result, "avgOut", text, lower)
    end
  end
  return result
end

function adapter.rank(kind)
  if kind == "gt_machine" then return 1 end
  return 9
end

function adapter.acceptType(kind)
  if type(kind) ~= "string" then return false end
  if kind:sub(1, 3) == "me_" then return false end
  return kind:sub(1, 3) == "gt_"
end

function adapter.discover()
  local found = {}
  for address, kind in component.list() do
    local available = methods(address)
    local storedMethod = firstMethod(available, adapter.storedMethods)
    local maxMethod = firstMethod(available, adapter.maxMethods)
    if adapter.acceptType(kind) and (kind == "gt_machine" or storedMethod or maxMethod) then
      local storedMethods = matchingMethods(available, adapter.storedMethods)
      local maxMethods = matchingMethods(available, adapter.maxMethods)
      local detail = {}
      for field, names in pairs(adapter.detailMethods) do
        detail[field] = firstMethod(available, names)
      end
      found[#found + 1] = {
        address = address,
        type = kind,
        storedMethod = storedMethod,
        maxMethod = maxMethod,
        storedMethods = storedMethods,
        maxMethods = maxMethods,
        detailMethods = detail
      }
    end
  end
  table.sort(found, function(a, b)
    local ar = adapter.rank(a.type)
    local br = adapter.rank(b.type)
    if ar ~= br then return ar < br end
    if a.type ~= b.type then return a.type < b.type end
    return a.address < b.address
  end)
  return found
end

function adapter.read(node, options)
  options = options or {}
  local stored, storedMethod, storedError = readBest(node.address, node.storedMethods or { node.storedMethod })
  local max, maxMethod, maxError = readBest(node.address, node.maxMethods or { node.maxMethod })

  local reading = {
    address = node.address,
    type = node.type,
    stored = stored,
    max = max
  }
  reading.storedMethod = storedMethod
  reading.maxMethod = maxMethod
  reading.storedError = storedError
  reading.maxError = maxError

  if options.sensor or options.detail then
    local methodName = node.detailMethods and node.detailMethods.sensor
    local value, err = safeCall(node.address, methodName)
    reading.sensor = value
    reading.sensorMethod = methodName
    reading.sensorError = err
    local parsed = adapter.parseSensor(value)
    reading.sensorStored = parsed.stored
    reading.sensorMax = parsed.max
    reading.sensorAvgIn = parsed.avgIn
    reading.sensorAvgOut = parsed.avgOut
    reading.avgInWindow = parsed.avgInWindow
    reading.avgOutWindow = parsed.avgOutWindow
    reading.sensorTitle = parsed.title
  end

  if options.detail then
    for field in pairs(adapter.detailMethods) do
      if field ~= "sensor" then
        local methodName = node.detailMethods and node.detailMethods[field]
        local value, err = safeCall(node.address, methodName)
        reading[field] = value
        reading[field .. "Method"] = methodName
        reading[field .. "Error"] = err
      end
    end
  end

  reading.effectiveStored = reading.stored
  reading.effectiveMax = reading.max
  if (not reading.effectiveStored or reading.effectiveStored == 0) and reading.sensorStored then
    reading.effectiveStored = reading.sensorStored
  end
  if (not reading.effectiveMax or reading.effectiveMax == 0) and reading.sensorMax then
    reading.effectiveMax = reading.sensorMax
  end
  reading.effectiveAvgIn = reading.sensorAvgIn or reading.avgIn
  reading.effectiveAvgOut = reading.sensorAvgOut or reading.avgOut

  if type(reading.effectiveStored) == "number" and type(reading.effectiveMax) == "number" and reading.effectiveMax > 0 then
    reading.ratio = reading.effectiveStored / reading.effectiveMax
  elseif type(reading.stored) == "number" and type(reading.max) == "number" and reading.max > 0 then
    reading.ratio = reading.stored / reading.max
  end

  if options.detail then
    reading.stored = reading.effectiveStored
    reading.max = reading.effectiveMax
  end

  return reading
end

return adapter
local adapter = require("oc.gt_power.adapter")

local monitor = {}

local function summarize(value)
  if type(value) == "table" then
    return tostring(value[1] or value.text or "table#" .. tostring(#value))
  elseif value == nil then
    return "n/a"
  end
  return tostring(value)
end

function monitor.evaluate(reading, warningRatio, criticalRatio)
  warningRatio = warningRatio or 0.25
  criticalRatio = criticalRatio or 0.10

  if type(reading.ratio) ~= "number" then
    return "unknown"
  elseif reading.ratio <= criticalRatio then
    return "critical"
  elseif reading.ratio <= warningRatio then
    return "warning"
  end
  return "ok"
end

function monitor.reason(reading)
  if type(reading.ratio) == "number" then return "ready" end
  if not reading.maxMethod then return "missing capacity method" end
  if reading.effectiveMax == 0 or reading.max == 0 then return "zero capacity" end
  if reading.sensorError and not reading.sensorStored then return "sensor unreadable" end
  return "no usable stored/max"
end

function monitor.isUsable(reading)
  return type(reading.ratio) == "number"
    and type(reading.type) == "string"
    and reading.type:sub(1, 3) == "gt_"
end

function monitor.discover()
  return adapter.discover()
end

local function readingScore(reading)
  local valid = monitor.isUsable(reading)
  if valid and reading.type == "gt_machine" then return 1 end
  if valid then return 2 end
  if reading.type == "gt_machine" then return 3 end
  return 4
end

function monitor.snapshot(options)
  options = options or {}
  local nodes = options.nodes or monitor.discover()
  local readings = {}
  local scanLimit = options.scanLimit or #nodes
  for i, node in ipairs(nodes) do
    if i > scanLimit then break end
    local reading = adapter.read(node, {
      detail = options.detail,
      sensor = options.sensor
    })
    reading.status = monitor.evaluate(reading, options.warningRatio, options.criticalRatio)
    reading.reason = monitor.reason(reading)
    readings[#readings + 1] = reading
  end
  table.sort(readings, function(a, b)
    local ar = readingScore(a)
    local br = readingScore(b)
    if ar ~= br then return ar < br end
    return tostring(a.address) < tostring(b.address)
  end)
  if options.usableOnly then
    local usable = {}
    for _, reading in ipairs(readings) do
      if monitor.isUsable(reading) then
        usable[#usable + 1] = reading
      end
    end
    if #usable > 0 then readings = usable end
  end
  local limit = options.limit or #readings
  while #readings > limit do
    readings[#readings] = nil
  end

  return {
    available = #readings > 0,
    count = #readings,
    readings = readings
  }
end

function monitor.print(snapshot)
  snapshot = snapshot or monitor.snapshot({ detail = true, sensor = true })
  if not snapshot.available then
    io.write("power telemetry unavailable\n")
    return
  end

  io.write(string.format("power telemetry nodes: %d\n", snapshot.count))
  for _, reading in ipairs(snapshot.readings) do
    local percent = "n/a"
    if reading.ratio then
      percent = string.format("%.1f%%", reading.ratio * 100)
    end
    io.write(string.format("%s %s stored=%s max=%s fill=%s status=%s\n",
      reading.type,
      reading.address,
      tostring(reading.stored),
      tostring(reading.max),
      percent,
      reading.status))
    if reading.sensorStored then
      io.write(string.format("  sensorStored=%s sensorMax=%s sensorAvgIn=%s sensorAvgOut=%s\n",
        summarize(reading.sensorStored),
        summarize(reading.sensorMax),
        summarize(reading.sensorAvgIn),
        summarize(reading.sensorAvgOut)))
      io.write(string.format("  avgInWindow=%s avgOutWindow=%s\n",
        summarize(reading.avgInWindow),
        summarize(reading.avgOutWindow)))
    end
    io.write("  sensorTitle=" .. summarize(reading.sensorTitle) .. "\n")
    io.write(string.format("  methods stored=%s max=%s errors=%s %s\n",
      summarize(reading.storedMethod),
      summarize(reading.maxMethod),
      summarize(reading.storedError),
      summarize(reading.maxError)))
    io.write(string.format("  avgIn=%s avgOut=%s inV=%s inA=%s outV=%s outA=%s\n",
      summarize(reading.avgIn),
      summarize(reading.avgOut),
      summarize(reading.inV),
      summarize(reading.inA),
      summarize(reading.outV),
      summarize(reading.outA)))
    io.write("  sensor=" .. summarize(reading.sensor) .. "\n")
  end
end

return monitor
local component = require("component")
local adapter = require("oc.gt_power.adapter")

local probe = {}

local interesting = {
  "getStoredEU",
  "getStoredEUString",
  "getEUCapacity",
  "getEUCapacityString",
  "getAverageElectricInput",
  "getAverageElectricOutput",
  "getSensorInformation"
}

local function methods(address)
  local ok, result = pcall(component.methods, address)
  if ok and type(result) == "table" then return result end
  return {}
end

local function safeCall(address, methodName)
  if not methodName then return nil, nil end
  local ok, value = pcall(component.invoke, address, methodName)
  if ok then return value, nil end
  return nil, tostring(value)
end

local function methodSummary(available)
  local names = {}
  for _, name in ipairs(interesting) do
    if available[name] ~= nil then names[#names + 1] = name end
  end
  if #names == 0 then return "none" end
  return table.concat(names, ",")
end

function probe.list()
  local rows = {}
  for address, kind in component.list() do
    if type(kind) == "string" and kind:sub(1, 3) == "gt_" then
      local available = methods(address)
      local sensorMethod = available.getSensorInformation and "getSensorInformation" or nil
      local sensor = safeCall(address, sensorMethod)
      local parsed = adapter.parseSensor(sensor)
      rows[#rows + 1] = {
        address = address,
        type = kind,
        title = parsed.title,
        stored = parsed.stored,
        max = parsed.max,
        avgIn = parsed.avgIn,
        avgOut = parsed.avgOut,
        methods = methodSummary(available)
      }
    end
  end
  table.sort(rows, function(a, b)
    if a.type ~= b.type then return a.type < b.type end
    return a.address < b.address
  end)
  return rows
end

function probe.print(rows)
  rows = rows or probe.list()
  io.write("GT components visible: " .. tostring(#rows) .. "\n")
  if #rows == 0 then
    io.write("Move an Adapter so it touches the LSC controller, then connect OC cable.\n")
    return
  end
  for _, row in ipairs(rows) do
    io.write(string.format("%s %s\n", row.type, row.address))
    io.write("  title: " .. tostring(row.title or "n/a") .. "\n")
    io.write("  EU: " .. tostring(row.stored or "n/a") .. " / " .. tostring(row.max or "n/a") .. "\n")
    io.write("  avg: " .. tostring(row.avgIn or "n/a") .. " / " .. tostring(row.avgOut or "n/a") .. "\n")
    io.write("  methods: " .. row.methods .. "\n")
  end
end

return probe
#!/bin/lua
local probe = require("oc.gt_power.probe")
probe.print()
#!/bin/lua
local monitor = require("oc.gt_power.monitor")
monitor.print(monitor.snapshot({ detail = true, sensor = true, usableOnly = true }))
local logger = require("oc.core.logger")
local monitor = require("oc.gt_power.monitor")

local args = {...}
local command = args[1] or "start"
local log = logger.new("/var/oc/gt_power.log", "info", 8192)

if command == "start" then
  local snapshot = monitor.snapshot()
  log:write("info", "gt_power telemetry nodes: " .. tostring(snapshot.count))
  return true
elseif command == "stop" then
  log:write("info", "gt_power stop")
  return true
end

io.stderr:write("usage: oc-gt-power.lua start|stop\n")
return falselocal event = require("event")
local keyboard = require("keyboard")

local data = require("oc.dashboard.data")
local screen = require("oc.dashboard.screen")
local style = require("oc.dashboard.style")
local initiativeEditor = require("oc.dashboard.initiative_editor")
local maintainerUi = require("oc.dashboard.maintainer_ui")
local opsPage = require("oc.dashboard.ops_page")
local stock = require("oc.dashboard.stock")
local subtabs = require("oc.dashboard.subtabs")
local tabs = require("oc.dashboard.tabs")
local powerTitleEditor = require("oc.dashboard.power_title_editor")
local titleEditor = require("oc.dashboard.title_editor")
local views = require("oc.dashboard.views")
local workflowData = require("oc.dashboard.workflow_data")
local workflowUi = require("oc.dashboard.workflow_ui")

local dashboard = {}
local CTRL_Q = 17
local CTRL_R = 18

local function configureScreen()
  local ok, _, info = screen.apply()
  if ok and info then return info.width, info.height end
  return 80, 25
end

local function clearTransientInput(state)
  views.closeSearchPopup(state)
end

local function leaveWorkflowCatalog(state, nextView)
  local current = state.view
  local staysInFlow = nextView == "ae2_workflows" or nextView == "ae2_workflow"
  if (current == "ae2_workflows" or current == "ae2_workflow") and not staysInFlow then
    return workflowData.dispose(state) ~= false
  end
  return true
end

local function pageDelta(state, delta)
  clearTransientInput(state)
  local nextView = tabs.move(state.view, delta)
  if not leaveWorkflowCatalog(state, nextView) then return false end
  state.view = nextView
  return true
end

local function setView(state, view)
  local nextView = tabs.normalize(view)
  if state.view == nextView then return false end
  clearTransientInput(state)
  if not leaveWorkflowCatalog(state, nextView) then return false end
  state.view = nextView
  return true
end

local function isCtrlShortcut(char, lowerChar, controlChar)
  if char == controlChar then return true end
  if not (keyboard.isControlDown and keyboard.isControlDown()) then return false end
  return char == lowerChar or char == lowerChar - 32
end

local function handleActiveSearchKey(state, char, code)
  if state.view == "ae2_counts" and state.stockSearchActive then return true, stock.handleKey(state, char, code, keyboard) end
  if state.view == "ae2_workflows" and state.ae2WorkflowSearchActive then return true, workflowUi.handleKey(state, char, code, keyboard) end
  if state.view == "ae2_maintain" and state.ae2MaintainSearchActive then return true, maintainerUi.handleKey(state, char, code, keyboard) end
  return false, false
end

local function handleActiveSearchClipboard(state, value)
  if state.view == "ae2_counts" then return stock.handleClipboard(state, value) end
  if state.view == "ae2_workflows" or state.view == "ae2_workflow" then return workflowUi.handleClipboard(state, value) end
  if state.view == "ae2_maintain" then return maintainerUi.handleClipboard(state, value) end
  return false
end

local function handleKey(state, char, code)
  local tabCode = keyboard.keys and keyboard.keys.tab
  if type(workflowUi.setupActive) == "function" and workflowUi.setupActive(state) then
    if isCtrlShortcut(char, string.byte("q"), CTRL_Q) then
      return false, type(workflowUi.cancelSetup) == "function" and workflowUi.cancelSetup(state)
    end
    return false, workflowUi.handleKey(state, char, code, keyboard)
  end
  if isCtrlShortcut(char, string.byte("q"), CTRL_Q) then
    style.clear()
    return true, false
  elseif isCtrlShortcut(char, string.byte("r"), CTRL_R) then
    data.refresh(state, true)
    return false, true
  end
  local searchHandled, searchDirty = handleActiveSearchKey(state, char, code)
  if searchHandled then return false, searchDirty end
  if stock.handleKey(state, char, code, keyboard) then
    return false, true
  elseif maintainerUi.handleKey(state, char, code, keyboard) then
    return false, true
  elseif workflowUi.handleKey(state, char, code, keyboard) then
    return false, true
  elseif (char == 9 or code == tabCode) and keyboard.isControlDown and keyboard.isControlDown() then
    pageDelta(state, (keyboard.isShiftDown and keyboard.isShiftDown()) and -1 or 1)
    return false, true
  elseif char == string.byte("h") or char == string.byte("H") then
    return false, setView(state, "initiatives")
  elseif char == string.byte("c") then
    return false, setView(state, "ops_links")
  elseif char == string.byte("a") or char == string.byte("A") then
    return false, setView(state, "ae2")
  elseif char == string.byte("i") or char == string.byte("I") then
    return false, setView(state, "ae2_counts")
  elseif char == string.byte("u") or char == string.byte("U") then
    return false, setView(state, "ae2_cpus")
  elseif char == string.byte("k") or char == string.byte("K") then
    return false, setView(state, "ae2_maintain")
  elseif char == string.byte("p") or char == string.byte("P") then
    return false, setView(state, "power")
  elseif char == string.byte("n") or char == string.byte("N") then
    return false, setView(state, "next")
  elseif char == string.byte("o") or char == string.byte("O") then
    return false, setView(state, "diagnostics")
  elseif char == string.byte("v") or char == string.byte("V") then
    return false, setView(state, "overview")
  elseif (char == string.byte("t") or char == string.byte("T")) and state.view == "initiatives" then
    initiativeEditor.open(state)
    return false, true
  elseif char == string.byte("[") or char == string.byte(",") then
    pageDelta(state, -1)
    return false, true
  elseif char == string.byte("]") or char == string.byte(".") or char == 9 then
    pageDelta(state, 1)
    return false, true
  end
  return false, false
end

local function handleTouch(state, x, y)
  if type(workflowUi.setupActive) == "function" and workflowUi.setupActive(state) then
    workflowUi.handleTouch(state, x, y)
    return true
  end
  if views.searchPopupOpen(state) then
    if views.searchPopupHit(state, x, y) then return true end
    return views.closeSearchPopup(state)
  end
  if titleEditor.hit(state, x, y) then return titleEditor.open(state) end
  if powerTitleEditor.hit(state, x, y) then return powerTitleEditor.open(state) end
  local view = tabs.hit(state, x, y)
  if view then return setView(state, view) end
  view = subtabs.hit(state, x, y)
  if view then return setView(state, view) end
  if maintainerUi.hitSearch(state, x, y) then return maintainerUi.setSearchActive(state, true) end
  if maintainerUi.handleTouch(state, x, y) then return true end
  if workflowUi.hitSearch(state, x, y) then return workflowUi.setSearchActive(state, true) end
  if workflowUi.handleTouch(state, x, y) then return true end
  if stock.hitSearch(state, x, y) then return stock.setSearchActive(state, true) end
  if stock.handleTouch(state, x, y) then return true end
  if opsPage.handleTouch(state, x, y) then return true end
  return false
end

function dashboard.run(initialView)
  local W, H = configureScreen()
  local state = data.newState(W, H)
  state.view = tabs.normalize(initialView or state.view)

  data.refresh(state, true)
  views.draw(state)
  while true do
    local ev = { event.pull(data.nextDelay(state)) }
    local inputDirty = false
    if ev[1] then
      if state.dashboardTitleEditor then
        inputDirty = titleEditor.handle(state, ev)
      elseif state.powerTitleEditor then
        inputDirty = powerTitleEditor.handle(state, ev)
      elseif state.initiativeEditor then
        inputDirty = initiativeEditor.handle(state, ev)
      elseif ev[1] == "clipboard" then
        inputDirty = handleActiveSearchClipboard(state, ev[3])
      elseif ev[1] == "key_down" then
        local quit, keyDirty = handleKey(state, ev[3], ev[4])
        if quit then return true end
        inputDirty = keyDirty
      elseif ev[1] == "touch" then
        inputDirty = handleTouch(state, ev[3], ev[4])
      end
    end
    local dirty = inputDirty
    if not ev[1] then
      dirty = data.refresh(state, false)
      if dirty then state._initiativeEditorOverlayOnly = false end
    end
    if dirty then
      views.draw(state)
    end
  end
end

return dashboard
local cache = {}

function cache.panelChanged(state, name, key)
  state._panelKeys = state._panelKeys or {}
  if state._forcePaint or state._panelKeys[name] ~= key then
    state._panelKeys[name] = key
    return true
  end
  return false
end

function cache.powerKey(snapshot)
  if not snapshot.available then return "missing" end
  local first = snapshot.readings[1] or {}
  return table.concat({
    tostring(snapshot.count),
    tostring(first.type),
    tostring(first.address),
    tostring(first.status),
    tostring(first.ratio),
    tostring(first.stored),
    tostring(first.max),
    tostring(first.sensorTitle),
    tostring(first.effectiveAvgIn or first.avgIn),
    tostring(first.effectiveAvgOut or first.avgOut),
    tostring(first.reason)
  }, "|")
end

function cache.ae2Key(snapshot)
  if not snapshot.available then return "missing" end
  local parts = {
    snapshot.primary.type,
    snapshot.primary.address,
    tostring(snapshot.cpus.count)
  }
  for _, cpu in ipairs((snapshot.cpus and snapshot.cpus.cpus) or {}) do
    parts[#parts + 1] = cpu.busy and "busy" or "ready"
  end
  return table.concat(parts, "|")
end

function cache.componentsKey(rows)
  local counts, kinds = {}, {}
  for _, row in ipairs(rows or {}) do
    local kind = tostring(row and row.ctype or "unknown")
    if not counts[kind] then kinds[#kinds + 1] = kind end
    counts[kind] = (counts[kind] or 0) + 1
  end
  table.sort(kinds)
  local parts = { tostring(#(rows or {})) }
  for _, kind in ipairs(kinds) do
    parts[#parts + 1] = kind .. ":" .. tostring(counts[kind])
  end
  return table.concat(parts, "|")
end

function cache.initiativePreviewKey(state)
  return tostring(state.initiativePage) .. "|" .. table.concat(state.initiatives or {}, "|")
end

return cache
-- Safe promotion primitives for human-owned Maintainer /etc conversion.
-- Runtime journals, logs, locks, and remote-computer policy never use this.
local filesystem = require("filesystem")
local serialization = require("serialization")
local readable = require("oc.core.config")

local ioStore = {}

local function exists(path)
  local ok, found, reason = pcall(filesystem.exists, path)
  if not ok then return nil, tostring(found) end
  if type(found) ~= "boolean" then return nil, tostring(reason or "could not inspect " .. tostring(path)) end
  return found
end

local function remove(path)
  local found, existsReason = exists(path)
  if found == nil then return false, existsReason end
  if not found then return true end
  local ok, result, reason = pcall(filesystem.remove, path)
  if not ok or result ~= true then return false, tostring(reason or result or "remove failed") end
  return true
end

local function rename(from, to)
  local ok, result, reason = pcall(filesystem.rename, from, to)
  if not ok or result ~= true then return false, tostring(reason or result or "rename failed") end
  return true
end

local function write(path, body)
  local opened, handle, openReason = pcall(io.open, path, "w")
  if not opened then return false, tostring(handle) end
  if not handle then return false, tostring(openReason or "could not write " .. tostring(path)) end
  local writeOk, wrote, writeReason = pcall(function() return handle:write(body) end)
  local closeOk, closed, closeReason = pcall(function() return handle:close() end)
  if not writeOk or wrote == nil or wrote == false then return false, tostring(writeReason or wrote or "write failed") end
  if not closeOk or closed == false then return false, tostring(closeReason or closed or "close failed") end
  return true
end

function ioStore.exists(path) return exists(path) end

function ioStore.read(path)
  local present, presentReason = exists(path)
  if present == nil then return nil, presentReason, nil end
  if not present then return nil, nil, false end
  local opened, handle, openReason = pcall(io.open, path, "r")
  if not opened then return nil, tostring(handle), true end
  if not handle then return nil, tostring(openReason or "could not open " .. tostring(path)), true end
  local readOk, text, readReason = pcall(function() return handle:read("*a") end)
  local closeOk, closed, closeReason = pcall(function() return handle:close() end)
  if not readOk then return nil, tostring(readReason or text), true end
  if not closeOk or closed == false then return nil, tostring(closeReason or closed or "could not close " .. tostring(path)), true end
  return text or "", nil, true
end

function ioStore.inspect(path, allowScalar)
  local text, readReason, present = ioStore.read(path)
  if text == nil then
    return { path = path, state = present and "unreadable" or "missing", reason = readReason }
  end
  local ok, value = pcall(serialization.unserialize, text)
  if not ok or (type(value) ~= "table" and not (allowScalar == true and type(value) == "string")) then
    return { path = path, state = "invalid", bytes = #text, reason = tostring(value or "not a table") }
  end
  local logical = text:gsub("[\r\n]+$", "")
  return { path = path, state = logical:find("[\r\n]") and "readable" or "legacy_one_line", bytes = #text,
    value = value, raw = text }
end

local function valid(status)
  return status and (status.state == "legacy_one_line" or status.state == "readable")
end

-- A resolver handles only deterministic interrupted transaction states. It
-- never discards a valid staged value while a valid primary also exists.
function ioStore.recoveryStatus(path, allowScalar)
  local primary = ioStore.inspect(path, allowScalar)
  local staged = ioStore.inspect(path .. ".new", allowScalar)
  local previous = ioStore.inspect(path .. ".previous", allowScalar)
  local status = { path = path, primary = primary, staged = staged, previous = previous }
  if primary.state == "unreadable" or staged.state == "unreadable" or previous.state == "unreadable" then
    status.state, status.reason = "io_error", primary.reason or staged.reason or previous.reason
  elseif staged.state == "missing" and previous.state == "missing" then
    if primary.state == "invalid" then
      status.state, status.reason = "invalid_primary", primary.reason
    else
      status.state = "clean"
    end
  elseif valid(primary) and valid(previous) and staged.state == "missing" then
    status.state, status.action = "cleanup_previous", "cleanup_previous"
  elseif primary.state == "missing" and valid(previous) and staged.state == "missing" then
    status.state, status.action = "restore_previous", "restore_previous"
  elseif primary.state == "missing" and valid(staged) and (previous.state == "missing" or valid(previous)) then
    status.state, status.action = "promote_staged", "promote_staged"
  else
    status.state, status.reason = "manual_recovery", "staged config files are ambiguous or invalid"
  end
  return status
end

function ioStore.recover(path, allowScalar)
  local status = ioStore.recoveryStatus(path, allowScalar)
  if status.state == "clean" then return true, nil, status end
  if status.state == "cleanup_previous" then
    local cleaned, reason = remove(path .. ".previous")
    if not cleaned then return false, reason, status end
  elseif status.state == "restore_previous" then
    local restored, reason = rename(path .. ".previous", path)
    if not restored then return false, reason, status end
  elseif status.state == "promote_staged" then
    local promoted, reason = rename(path .. ".new", path)
    if not promoted then return false, reason, status end
    if valid(status.previous) then
      local cleaned, cleanupReason = remove(path .. ".previous")
      if not cleaned then return false, cleanupReason, ioStore.recoveryStatus(path, allowScalar) end
    end
  else
    return false, status.reason or "manual recovery required", status
  end
  local after = ioStore.recoveryStatus(path, allowScalar)
  if after.state ~= "clean" then return false, "recovery remains unresolved: " .. tostring(after.state), after end
  return true, nil, after
end

function ioStore.archiveRaw(path, raw)
  local archive = path .. ".pre-migrate.bak"
  local existing, existingReason, present = ioStore.read(archive)
  if present == nil then return false, existingReason end
  if present then
    if existing == (raw or "") then return true, nil, archive end
    return false, "refusing to overwrite a different migration archive " .. archive
  end
  local wrote, reason = write(archive, raw or "")
  if not wrote then return false, reason end
  local copied, copyReason = ioStore.read(archive)
  if copied ~= (raw or "") then
    remove(archive)
    return false, copyReason or "migration archive verification failed"
  end
  return true, nil, archive
end

function ioStore.promote(path, value, allowScalar)
  local body, renderReason = readable.render(value)
  if not body then return false, renderReason end
  local staged, previous = path .. ".new", path .. ".previous"
  local recovery = ioStore.recoveryStatus(path, allowScalar)
  if recovery.state ~= "clean" then
    return false, "configuration requires recovery before promotion: " .. tostring(recovery.state)
  end
  local stagedPresent, stagedReason = exists(staged)
  if stagedPresent == nil then return false, stagedReason end
  local previousPresent, previousReason = exists(previous)
  if previousPresent == nil then return false, previousReason end
  if stagedPresent or previousPresent then
    return false, "configuration has an unresolved staged or prior file at " .. path
  end
  local wrote, writeReason = write(staged, body .. "\n")
  if not wrote then remove(staged); return false, writeReason end
  local verified, verifyReason = ioStore.inspect(staged, allowScalar)
  if verified.state == "invalid" or verified.state == "unreadable" or verified.state == "missing" then
    remove(staged)
    return false, "staged config verification failed: " .. tostring(verified.reason or verifyReason)
  end
  local moved = false
  if recovery.primary.state ~= "missing" then
    local moveOk, moveReason = rename(path, previous)
    if not moveOk then remove(staged); return false, "could not preserve prior config: " .. tostring(moveReason) end
    moved = true
  end
  local promoted, promoteReason = rename(staged, path)
  if not promoted then
    if moved then rename(previous, path) end
    remove(staged)
    return false, "could not promote staged config: " .. tostring(promoteReason)
  end
  if moved then
    local cleaned, cleanupReason = remove(previous)
    if not cleaned then
      return false, "config promoted but prior cleanup requires recovery: " .. tostring(cleanupReason)
    end
  end
  return true
end

function ioStore.retire(path)
  local present, presentReason = exists(path)
  if present == nil then return false, presentReason end
  if not present then return true, nil, nil end
  local retired = path .. ".retired"
  local retiredPresent, retiredReason = exists(retired)
  if retiredPresent == nil then return false, retiredReason end
  if retiredPresent then return false, "refusing to overwrite existing retired archive " .. retired end
  local ok, reason = rename(path, retired)
  return ok, reason, retired
end

return ioStore
-- The durable config surfaces owned by the central readability conversion.
-- Kept separate from orchestration so both files remain hand-paste sized.
local daemonConfig = require("oc.ae2.maintainer_daemon_config")
local initiatives = require("oc.dashboard.initiatives")
local powerTitle = require("oc.dashboard.power_title")
local screen = require("oc.dashboard.screen")
local title = require("oc.dashboard.title")

local policy = {}

policy.legacyMaintainerPath = "/etc/oc-ae2-maintainer.cfg"
policy.unownedLegacyPaths = {
  "/etc/oc/core.cfg",
  "/etc/oc/ae2.cfg",
  "/etc/oc/gt_power.cfg"
}

function policy.initiativeValue(value)
  -- Domain policy can contain more rows or metadata than the current view
  -- exposes. Keep it byte-for-value intact during a format-only conversion.
  return value
end

local function titleValue(value)
  -- A table is already an addressable title policy. Scalar legacy titles are
  -- the one schema lift; renderer normalization remains a later UI concern.
  if type(value) == "table" then return value end
  return { name = value }
end

function policy.definitions()
  return {
    -- The daemon normalizer is for an explicit operator edit. Migration is
    -- identity-preserving so unknown future fields do not disappear.
    { label = "Daemon desired state", path = daemonConfig.path, transform = function(value) return value end },
    { label = "Dashboard title", path = title.path, allowScalar = true, transform = titleValue },
    { label = "Power title", path = powerTitle.path, allowScalar = true, transform = titleValue },
    { label = "Screen pin", path = screen.configPath, transform = function(value) return value end },
    { label = "Domain", path = initiatives.path, transform = policy.initiativeValue }
  }
end

return policy
-- One deliberate, reviewable migration for durable Maintainer-owned config.
-- It never touches /var state, logs, locks, or another computer's policy.
local daemonConfig = require("oc.ae2.maintainer_daemon_config")
-- Shell migration uses workflow persistence only; never load the interactive editor.
local workflows = require("oc.ae2.workflow_store")
local initiatives = require("oc.dashboard.initiatives")
local ioStore = require("oc.dashboard.config_migration_io")
local policy = require("oc.dashboard.config_migration_policy")
local migration = {}
migration.legacyMaintainerPath, migration.unownedLegacyPaths = policy.legacyMaintainerPath, policy.unownedLegacyPaths

local function add(report, label, state, detail)
  report.entries[#report.entries + 1] = { label = label, state = state, detail = detail }
end

local function fail(report, label, reason)
  add(report, label, "preserved", reason); report.failed[#report.failed + 1] = label .. ": " .. tostring(reason)
end

local function inspectSimple(report, label, path, allowScalar)
  local status = ioStore.inspect(path, allowScalar); add(report, label, status.state, status.bytes or status.reason); return status
end

local function recoveryProblem(report, label, path, allowScalar)
  local status = ioStore.recoveryStatus(path, allowScalar)
  if status.state == "clean" then return true end
  fail(report, label, "recovery required: " .. tostring(status.state) .. "; " .. tostring(status.reason or "run --recover CONFIRM"))
  return false
end

-- This file is a retired shadow authority, not a runtime fallback. An
-- unreadable primary with no transaction artifacts cannot be repaired by the
-- deterministic resolver, but it can be preserved byte-for-byte as .retired
-- once canonical workflows are verified. Anything involving .new/.previous
-- remains a hard stop.
local function staleMaintainerRecoveryProblem(report)
  local status = ioStore.recoveryStatus(migration.legacyMaintainerPath)
  if status.state == "clean" or status.state == "invalid_primary" then return true end
  fail(report, "Legacy maintainer", "recovery required: " .. tostring(status.state)
    .. "; " .. tostring(status.reason or "run --recover CONFIRM"))
  return false
end

local function archiveReady(report, label, status)
  if status.state ~= "legacy_one_line" then return true end
  local archive = status.path .. ".pre-migrate.bak"
  local archived, reason, present = ioStore.read(archive)
  if present == nil or (present == true and archived == nil) then
    fail(report, label, "could not inspect migration archive " .. archive .. ": " .. tostring(reason))
    return false
  end
  if present == true and archived ~= status.raw then
    fail(report, label, "refusing to overwrite a different migration archive " .. archive)
    return false
  end
  return true
end

local function retirementReady(report, label, path)
  local source = ioStore.inspect(path)
  if source.state == "missing" then return true end
  local retired = path .. ".retired"
  local present, reason = ioStore.exists(retired)
  if present == nil then
    fail(report, label, "could not inspect retired archive " .. retired .. ": " .. tostring(reason))
    return false
  end
  if present then
    fail(report, label, "refusing to overwrite existing retired archive " .. retired)
    return false
  end
  return true
end

local function migrateSimple(report, label, path, transform, allowScalar)
  local status = ioStore.inspect(path, allowScalar)
  if status.state == "missing" or status.state == "readable" then
    add(report, label, status.state, status.bytes)
    return true
  end
  if status.state ~= "legacy_one_line" then fail(report, label, status.reason); return false end
  local ok, value = pcall(transform, status.value)
  if not ok or type(value) ~= "table" then
    fail(report, label, value or "migration transform did not return a table")
    return false
  end
  local archived, archiveReason, archive = ioStore.archiveRaw(path, status.raw)
  if not archived then fail(report, label, archiveReason); return false end
  local promoted, promoteReason = ioStore.promote(path, value, allowScalar)
  if not promoted then fail(report, label, promoteReason); return false end
  add(report, label, "converted", archive)
  return true
end

local function migrateInitiatives(report)
  local current = ioStore.inspect(initiatives.path)
  local legacy = ioStore.inspect(initiatives.legacyPath)
  if current.state == "missing" and (legacy.state == "legacy_one_line" or legacy.state == "readable") then
    local ok, value = pcall(policy.initiativeValue, legacy.value)
    if not ok then fail(report, "Domain legacy", value); return false end
    local promoted, reason = ioStore.promote(initiatives.path, value)
    if not promoted then fail(report, "Domain", reason); return false end
    local retired, retireReason, archive = ioStore.retire(initiatives.legacyPath)
    if not retired then fail(report, "Domain legacy", retireReason); return false end
    add(report, "Domain", "converted legacy tasks", archive)
    return true
  end
  local ok = migrateSimple(report, "Domain", initiatives.path, policy.initiativeValue)
  if not ok then return false end
  if legacy.state == "missing" then return ok end
  if legacy.state == "invalid" or legacy.state == "unreadable" then
    fail(report, "Domain legacy", legacy.reason)
    return false
  end
  local retired, retireReason, archive = ioStore.retire(initiatives.legacyPath)
  if not retired then fail(report, "Domain legacy", retireReason); return false end
  add(report, "Domain legacy", "retired", archive)
  return ok
end

local function retireLegacyMaintainer(report, workflowVerified)
  local legacy = ioStore.inspect(migration.legacyMaintainerPath)
  if legacy.state == "missing" then add(report, "Legacy maintainer", "missing"); return true end
  if workflowVerified ~= true then
    fail(report, "Legacy maintainer", "workflow policy is not a valid canonical authority")
    return false
  end
  local retired, reason, archive = ioStore.retire(migration.legacyMaintainerPath)
  if not retired then fail(report, "Legacy maintainer", reason); return false end
  add(report, "Legacy maintainer", "retired", archive)
  return true
end

local function preflight(report)
  local clean = true
  local workflow = workflows.migrationStatus()
  if workflow.state ~= "missing" and workflow.state ~= "readable" and workflow.state ~= "legacy_one_line" then
    fail(report, "AE2 workflows", workflow.reason or ("workflow state is " .. tostring(workflow.state))); clean = false
  elseif not archiveReady(report, "AE2 workflows", workflow) then clean = false end
  for _, definition in ipairs(policy.definitions()) do
    if not recoveryProblem(report, definition.label, definition.path, definition.allowScalar) then clean = false end
    local status = ioStore.inspect(definition.path, definition.allowScalar)
    if not archiveReady(report, definition.label, status) then clean = false end
  end
  if not recoveryProblem(report, "Domain legacy", initiatives.legacyPath) then clean = false end
  if not retirementReady(report, "Domain legacy", initiatives.legacyPath) then clean = false end
  if not staleMaintainerRecoveryProblem(report) then clean = false end
  -- The retired maintainer file can still be the only known policy on an
  -- incomplete/old install.  Do not format unrelated settings and then fail
  -- late: require a canonical workflow authority before any mutation.
  local legacyMaintainer = ioStore.inspect(migration.legacyMaintainerPath)
  if legacyMaintainer.state ~= "missing"
      and workflow.state ~= "legacy_one_line" and workflow.state ~= "readable" then
    fail(report, "Legacy maintainer", "canonical AE2 workflow authority is missing; preserve this policy until it exists")
    clean = false
  end
  if not retirementReady(report, "Legacy maintainer", migration.legacyMaintainerPath) then clean = false end
  return clean
end

local function recoverSimple(report, label, path, allowScalar)
  local ok, reason, status = ioStore.recover(path, allowScalar)
  if not ok then fail(report, label, reason); return false end
  add(report, label, status.state == "clean" and "recovered" or status.state, status.action or "clean")
  return true
end

local function recoverStaleMaintainer(report)
  local status = ioStore.recoveryStatus(migration.legacyMaintainerPath)
  if status.state == "invalid_primary" then
    add(report, "Legacy maintainer", "retire_on_apply", "invalid stale policy has no staged transaction artifacts")
    return true
  end
  return recoverSimple(report, "Legacy maintainer", migration.legacyMaintainerPath)
end

function migration.plan()
  local report = { entries = {}, failed = {} }
  local workflow = workflows.migrationStatus()
  add(report, "AE2 workflows", workflow.state, workflow.bytes or workflow.reason)
  archiveReady(report, "AE2 workflows", workflow)
  if workflows.backupPath then
    local fallback = ioStore.inspect(workflows.backupPath)
    add(report, "Workflow fallback backup", "fallback_" .. tostring(fallback.state), fallback.bytes or fallback.reason)
  end
  for _, definition in ipairs(policy.definitions()) do
    local status = inspectSimple(report, definition.label, definition.path, definition.allowScalar)
    local recovery = ioStore.recoveryStatus(definition.path, definition.allowScalar)
    if recovery.state ~= "clean" then add(report, definition.label .. " recovery", recovery.state, recovery.reason or recovery.action) end
    archiveReady(report, definition.label, status)
  end
  inspectSimple(report, "Domain legacy", initiatives.legacyPath)
  inspectSimple(report, "Legacy maintainer", migration.legacyMaintainerPath)
  for _, legacy in ipairs({
    { label = "Domain legacy", path = initiatives.legacyPath },
    { label = "Legacy maintainer", path = migration.legacyMaintainerPath }
  }) do
    local recovery = ioStore.recoveryStatus(legacy.path)
    if recovery.state ~= "clean" then
      local recoverableRetirement = legacy.label == "Legacy maintainer" and recovery.state == "invalid_primary"
      add(report, legacy.label .. " recovery", recoverableRetirement and "retire_on_apply" or recovery.state,
        recoverableRetirement and "invalid stale bytes will be preserved as .retired" or recovery.reason or recovery.action)
    end
  end
  retirementReady(report, "Domain legacy", initiatives.legacyPath)
  retirementReady(report, "Legacy maintainer", migration.legacyMaintainerPath)
  for _, path in ipairs(migration.unownedLegacyPaths) do
    local legacy = ioStore.inspect(path)
    add(report, "Unowned legacy", "unowned_" .. tostring(legacy.state), path)
  end
  return report
end

function migration.recover()
  if daemonConfig.load().enabled then return false, "stop the maintainer daemon and close oc-dashboard before config recovery" end
  local report = { entries = {}, failed = {} }
  local workflowOk, workflowReason, workflow = workflows.recover()
  if workflowOk then add(report, "AE2 workflows", "recovered", workflow and workflow.action or "clean")
  else fail(report, "AE2 workflows", workflowReason) end
  for _, definition in ipairs(policy.definitions()) do
    recoverSimple(report, definition.label, definition.path, definition.allowScalar)
  end
  recoverSimple(report, "Domain legacy", initiatives.legacyPath)
  recoverStaleMaintainer(report)
  if #report.failed > 0 then return false, table.concat(report.failed, "; "), report end
  return true, nil, report
end

function migration.apply()
  if daemonConfig.load().enabled then return false, "stop the maintainer daemon and close oc-dashboard before config migration" end
  local report = { entries = {}, failed = {} }
  if not preflight(report) then
    return false, "resolve every reported recovery/invalid state before conversion", report
  end
  local workflowOk, workflowReason, workflow = workflows.migrate()
  if not workflowOk then
    fail(report, "AE2 workflows", workflowReason)
    return false, table.concat(report.failed, "; "), report
  end
  add(report, "AE2 workflows", workflow.state, workflow.archive or workflow.bytes)
  for _, definition in ipairs(policy.definitions()) do
    if not migrateSimple(report, definition.label, definition.path, definition.transform, definition.allowScalar) then
      return false, table.concat(report.failed, "; "), report
    end
  end
  if not migrateInitiatives(report) then return false, table.concat(report.failed, "; "), report end
  local workflowPost = workflows.migrationStatus()
  local workflowVerified = workflowOk == true and workflowPost.state == "readable"
  retireLegacyMaintainer(report, workflowVerified)
  if #report.failed > 0 then return false, table.concat(report.failed, "; "), report end
  return true, nil, report
end

return migration
-- Retained dashboard painter. It records the frame as operations instead of a
-- per-cell buffer, then commits only operations whose visible output changed.
-- This keeps a large OpenComputers screen responsive without consuming a
-- workstation-sized framebuffer on the dashboard node.
local canvas = {}

local separator = "\30"

local function part(value)
  return tostring(value or "")
end

local function keyFor(state, kind, x, y)
  local base = table.concat({ kind, part(x), part(y) }, separator)
  local count = (state.counts[base] or 0) + 1
  state.counts[base] = count
  return base .. separator .. tostring(count)
end

local function signature(kind, foreground, background, width, height, value)
  if kind == "fill" then
    return table.concat({ kind, part(background), part(width), part(height), part(value) }, separator)
  end
  return table.concat({ kind, part(foreground), part(background), part(value) }, separator)
end

local function colors(gpu, foreground, background)
  if foreground ~= nil then pcall(gpu.setForeground, foreground) end
  if background ~= nil then pcall(gpu.setBackground, background) end
end

local function contracts(previous, current)
  if previous.kind == "set" then
    return #current.value < #previous.value
  end
  return current.width < previous.width or current.height < previous.height
end

local function erase(gpu, operation)
  colors(gpu, operation.foreground, operation.background)
  pcall(gpu.fill, operation.x, operation.y, operation.width, operation.height, " ")
end

local function hasFrameBase(state)
  local first = state.current[state.order[1]]
  return first and first.kind == "fill" and first.x == 1 and first.y == 1 and first.value == " "
end

function canvas.new(gpu)
  local state = {
    gpu = gpu,
    foreground = nil,
    background = nil,
    previous = {},
    current = {},
    order = {},
    counts = {},
    scene = nil
  }

  local function record(kind, x, y, width, height, value)
    local key = keyFor(state, kind, x, y)
    local text = tostring(value or (kind == "fill" and " " or ""))
    state.current[key] = {
      kind = kind,
      x = x,
      y = y,
      width = width,
      height = height,
      value = text,
      foreground = state.foreground,
      background = state.background,
      signature = signature(kind, state.foreground, state.background, width, height, text)
    }
    state.order[#state.order + 1] = key
    return true
  end

  local proxy = {}
  function proxy.setForeground(value) state.foreground = value; return true end
  function proxy.setBackground(value) state.background = value; return true end
  function proxy.fill(x, y, width, height, value)
    return record("fill", x, y, width, height, value)
  end
  function proxy.set(x, y, value)
    local text = tostring(value or "")
    return record("set", x, y, #text, 1, text)
  end

  local instance = { proxy = proxy }

  function instance:begin(scene)
    if state.scene ~= scene then state.previous = {} end
    state.scene = scene
    state.current, state.order, state.counts = {}, {}, {}
  end

  function instance:invalidate()
    state.previous = {}
  end

  function instance:flush()
    -- A removed operation or a smaller operation exposes pixels from an older
    -- layer. Replaying the ordered scene is the only generally correct way to
    -- restore the layer below it. Normal value changes still update one op.
    local replay = false
    for key, previous in pairs(state.previous) do
      local current = state.current[key]
      if current == nil or contracts(previous, current) then
        -- Dashboard frames begin with a full background layer. It will erase
        -- this bound during replay, so avoid a visible intermediate blank.
        -- Keep a bounded fallback for direct canvas callers without that base.
        if not hasFrameBase(state) then erase(state.gpu, previous) end
        replay = true
      end
    end
    if replay then state.previous = {} end
    for _, key in ipairs(state.order) do
      local current = state.current[key]
      local previous = state.previous[key]
      if not previous or previous.signature ~= current.signature then
        colors(state.gpu, current.foreground, current.background)
        if current.kind == "fill" then
          pcall(state.gpu.fill, current.x, current.y, current.width, current.height, current.value)
        else
          pcall(state.gpu.set, current.x, current.y, current.value)
        end
      end
    end
    state.previous = state.current
  end

  return instance
end

return canvas
local computer = require("computer")

local dataAe2 = require("oc.dashboard.data_ae2")
local dataCore = require("oc.dashboard.data_core")
local dataPower = require("oc.dashboard.data_power")
local dataSchedule = require("oc.dashboard.data_schedule")
local dataState = require("oc.dashboard.data_state")

local data = {}

data.intervals = {
  clock = 1,
  health = 30,
  ae2 = 30,
  ae2Cpus = 10,
  ae2Stock = 60,
  ae2Maintain = 600,
  ae2MaintainChunkDelay = 2,
  ae2MaintainTargetLimit = 8,
  ae2Logs = 30,
  ae2WorkflowSave = 1,
  ae2WorkflowRefresh = 60,
  ae2WorkflowSetupControlInterval = 1,
  ae2WorkflowSetupStopTimeout = 120,
  ae2WorkflowSetupChunkDelay = 2,
  ae2WorkflowSetupScanLimit = 384,
  ae2WorkflowSetupMaxCandidates = 32,
  power = 2,
  powerDiscover = 60,
  components = 30,
  maxSleep = 30
}

function data.newState(width, height)
  return dataState.new(width, height)
end

function data.lockPowerNode(state, snapshot)
  return dataPower.lockPowerNode(state, snapshot)
end

function data.advanceInitiativePage(state)
  return dataState.advanceInitiativePage(state)
end

function data.applyAe2Snapshot(state, snapshot)
  return dataAe2.applySnapshot(state, snapshot)
end

function data.refresh(state, force)
  local now = computer.uptime()
  local changed = false
  changed = dataCore.refresh(state, force, now, data.intervals) or changed
  changed = dataAe2.refresh(state, force, now, data.intervals) or changed
  changed = dataPower.refresh(state, force, now, data.intervals) or changed
  return changed
end

function data.nextDelay(state)
  return dataSchedule.nextDelay(state, computer.uptime(), data.intervals)
end

return data
local monitor, budget = require("oc.ae2.monitor"), require("oc.ae2.budget")
local cacheEpoch = require("oc.ae2.cache_epoch")
local maintainerLog = require("oc.ae2.maintainer_log")
local binding, stockMemory = require("oc.ae2.request_binding"), require("oc.ae2.stock_memory")
local workflows = require("oc.ae2.workflows")
local maintainerData, manualMemory = require("oc.dashboard.data_ae2_maintainer"), require("oc.dashboard.manual_request_memory")
local workflowData = require("oc.dashboard.workflow_data")
local workflowSetup = require("oc.dashboard.workflow_setup")
local ae2Data = {}
local function deckVisible(state)
  return state.view == "overview"
end
-- Domain, Ops, and Battery screens do not need an AE2 network summary just
-- because the dashboard process is alive. Keeping that polling scope tight
-- prevents an unrelated, potentially expensive component refresh from
-- interrupting text entry or repainting a non-AE2 operator screen.
local function summaryVisible(state)
  local view = state and state.view
  return view == "overview" or view == "ae2" or view == "ae2_counts" or view == "ae2_cpus"
end
local function workflowVisible(state)
  return state.view == "ae2_workflows" or state.view == "ae2_workflow"
end

local function workflowCatalogVisible(state)
  return state.view == "ae2_workflows"
end

local function workflowInputActive(state)
  return state.view == "ae2_workflows" and state.ae2WorkflowSearchActive
end

local function logsVisible(state)
  return state.view == "ae2_logs"
end

local function flushWorkflowSave(state, force, now, intervals)
  if not workflowData.hasPending(state) then return false end
  local maintainerDue = state.nextAe2MaintainRefresh and now >= state.nextAe2MaintainRefresh
  if force or maintainerDue then return workflowData.flushPending(state) end
  if not state.nextAe2WorkflowSave then
    state.nextAe2WorkflowSave = now + (intervals.ae2WorkflowSave or 1)
    return false
  end
  if not force and now < state.nextAe2WorkflowSave then return false end
  return workflowData.flushPending(state)
end

function ae2Data.applySnapshot(state, snapshot)
  if not snapshot then return end
  if snapshot.primary then
    cacheEpoch.recordNodes({ ae2Primary = snapshot.primary })
    if type(snapshot.primary.address) == "string" and snapshot.primary.address ~= "" then
      state.ae2StockAddress = snapshot.primary.address
    end
  end
  if snapshot.counts then
    state.ae2Counts = snapshot.counts
  elseif state.ae2Counts and snapshot.available then
    snapshot.counts = state.ae2Counts
  end
  if state.ae2 and state.ae2.stock and not snapshot.stock then
    snapshot.stock = state.ae2.stock
  end
  if state.ae2ManualRequest then snapshot.manualRequest = state.ae2ManualRequest end
  state.ae2 = snapshot
end

local function holdAe2Refresh(state, field, now, info)
  local wait = math.max(0.1, tonumber(info and info.wait) or 1)
  state[field] = now + wait
  return true
end

local function refreshSummary(state, force, now, intervals)
  if not summaryVisible(state) then return false end
  if force or now >= state.nextAe2Refresh then
    local kind = force and "manual_action" or deckVisible(state) and "passive_cache" or "visible_refresh"
    local ok, info = budget.trySpend(kind, { now = now, cost = 1 })
    if not ok then return holdAe2Refresh(state, "nextAe2Refresh", now, info) end
    ae2Data.applySnapshot(state, monitor.snapshot({ detail = false }))
    state.nextAe2Refresh = now + intervals.ae2
    state.nextAe2CpuRefresh = now + intervals.ae2Cpus
    return true
  end
  if state.view == "ae2_cpus" and now >= state.nextAe2CpuRefresh then
    local ok, info = budget.trySpend("visible_refresh", { now = now, cost = 1 })
    if not ok then return holdAe2Refresh(state, "nextAe2CpuRefresh", now, info) end
    if monitor.cpuSnapshot then
      ae2Data.applySnapshot(state, monitor.cpuSnapshot(state.ae2))
    else
      ae2Data.applySnapshot(state, monitor.snapshot({ detail = false }))
    end
    state.nextAe2CpuRefresh = now + intervals.ae2Cpus
    return true
  end
  return false
end

local function statusRows(report)
  local indexed = {}
  for _, row in ipairs((report and report.targets) or {}) do
    indexed[row.targetKey or cacheEpoch.targetKey(row)] = row
  end
  return indexed
end

local function missingState(target, row, warming)
  local bindErr = binding.error(target)
  if bindErr then return "blocked", bindErr end
  if row and row.status == "partial" then return "warming", row.reason or "warming exact stock" end
  local err = row and (row.error or row.stockMemoryReason)
  if err then return "error", tostring(err) end
  if warming then return "warming", "waiting for bounded exact-stock slice" end
  return "error", "exact stock value unavailable"
end

local function retainedEntry(target, entry, now)
  local fresh, reason, age = true, nil, stockMemory.age(entry, now)
  if stockMemory.isFresh then fresh, reason, age = stockMemory.isFresh(entry, { at = now }) end
  return {
    label = entry.label or target.label or entry.name or "target", rawLabel = entry.rawLabel or target.rawLabel,
    name = entry.name or target.name, damage = entry.damage ~= nil and entry.damage or target.damage,
    hasTag = entry.hasTag ~= nil and entry.hasTag or target.hasTag, kind = entry.kind or target.kind,
    isFluid = entry.isFluid ~= nil and entry.isFluid or target.isFluid,
    craftBinding = target.craftBinding, size = entry.current,
    source = entry.source, at = entry.at, age = age, retained = true,
    stockState = fresh and "ready" or "stale", reason = reason
  }
end

local function refreshStock(state, force, now, intervals)
  if state.view ~= "ae2_counts" or (not force and now < state.nextAe2StockRefresh) then return false end
  local rows = statusRows(state.ae2Maintain)
  local primary = state.ae2 and state.ae2.primary
  local currentAddress = type(primary) == "table" and primary.address or state.ae2StockAddress
  if type(currentAddress) ~= "string" or currentAddress == "" then currentAddress = nil end
  if currentAddress then state.ae2StockAddress = currentAddress end
  local loaded, config = pcall(workflows.load)
  local targetOk, targets = false, nil
  if loaded then targetOk, targets = pcall(workflows.asTargets, config) end
  if not targetOk or type(targets) ~= "table" then
    local previous = state.ae2StockCache or { entries = {}, total = 0, retainedTotal = 0, complete = true }
    previous.error = "Workflow config unavailable: " .. tostring(loaded and targets or config)
    previous.notice = previous.error
    state.ae2StockCache, state.ae2 = previous, state.ae2 or {}
    state.ae2.stock, state.nextAe2StockRefresh = previous, now + intervals.ae2Stock
    return true
  end
  local warming = ((state.ae2Maintain or {}).status or {}).complete == false
  local entries, retainedTotal, staleTotal, blockedTotal, warmingTotal, errorTotal = {}, 0, 0, 0, 0, 0
  local firstIssue
  for _, target in ipairs(targets) do
    local key = cacheEpoch.targetKey(target)
    local entry = currentAddress and stockMemory.lookup(target, { address = currentAddress }) or nil
    if entry then
      local projected = retainedEntry(target, entry, now)
      entries[#entries + 1], retainedTotal = projected, retainedTotal + 1
      if projected.stockState == "stale" then staleTotal = staleTotal + 1; firstIssue = firstIssue or projected end
    else
      local stockState, reason = missingState(target, rows[key], warming)
      entries[#entries + 1] = {
        label = target.label or target.name or "target", rawLabel = target.rawLabel, name = target.name,
        damage = target.damage, hasTag = target.hasTag, kind = target.kind, isFluid = target.isFluid,
        craftBinding = target.craftBinding, source = "unavailable", missing = true,
        retained = false, stockState = stockState, reason = reason
      }
      if stockState == "blocked" then blockedTotal = blockedTotal + 1
      elseif stockState == "warming" then warmingTotal = warmingTotal + 1 else errorTotal = errorTotal + 1 end
      firstIssue = firstIssue or entries[#entries]
    end
  end
  table.sort(entries, function(a, b) return tostring(a.label) < tostring(b.label) end)
  local nextCache = {
    entries = entries, total = #entries, retainedTotal = retainedTotal, staleTotal = staleTotal,
    blockedTotal = blockedTotal, warmingTotal = warmingTotal, errorTotal = errorTotal,
    complete = not warming,
    scope = "retained-target-stock",
    source = "exact-target",
    error = #entries == 0 and "No configured auto targets" or nil,
    notice = firstIssue and (tostring(firstIssue.label) .. ": " .. tostring(firstIssue.reason or firstIssue.stockState)) or nil
  }
  state.ae2StockCache = nextCache
  state.ae2 = state.ae2 or {}
  state.ae2.stock = nextCache
  state.nextAe2StockRefresh = now + intervals.ae2Stock
  return true
end

local function refreshLogs(state, force, now, intervals)
  if not logsVisible(state) or (not force and now < state.nextAe2LogRefresh) then return false end
  local ok, page = pcall(function()
    return maintainerLog.page(state.ae2LogPage or 1, 25)
  end)
  if ok then
    state.ae2Logs = page
    state.ae2LogPage = page.page or state.ae2LogPage or 1
  else
    state.ae2Logs = { rows = {}, page = state.ae2LogPage or 1, pages = 1, total = 0, path = maintainerLog.path, error = tostring(page) }
  end
  state.nextAe2LogRefresh = now + (intervals.ae2Logs or 30)
  return true
end

local function refreshDeckLogs(state, force, now, intervals)
  if not deckVisible(state) or (not force and now < state.nextAe2DeckLogRefresh) then return false end
  local ok, page = pcall(function()
    return maintainerLog.page(1, 24)
  end)
  if ok then
    state.ae2DeckLogs = page
  else
    state.ae2DeckLogs = { rows = {}, page = 1, pages = 1, total = 0, path = maintainerLog.path, error = tostring(page) }
  end
  state.nextAe2DeckLogRefresh = now + (intervals.ae2Logs or 30)
  return true
end

local function syncDeckQueueWithLogs(state, force, now)
  if deckVisible(state) and (force or now >= state.nextAe2DeckLogRefresh) then
    state.nextAe2DaemonRefresh = 0
  end
end

function ae2Data.refresh(state, force, now, intervals)
  local changed = flushWorkflowSave(state, force, now, intervals)
  changed = manualMemory.refresh(state, now) or changed
  changed = maintainerData.refreshDaemonBulk(state, now) or changed
  changed = refreshSummary(state, force, now, intervals) or changed
  changed = maintainerData.refreshMaintainer(state, force, now, intervals) or changed
  changed = refreshStock(state, force, now, intervals) or changed
  changed = maintainerData.refreshDaemonPage(state, force, now, intervals) or changed
  syncDeckQueueWithLogs(state, force, now)
  changed = maintainerData.refreshDaemonDeck(state, force, now, intervals) or changed
  changed = refreshLogs(state, force, now, intervals) or changed
  changed = refreshDeckLogs(state, force, now, intervals) or changed
  changed = workflowSetup.refresh(state, now, intervals) or changed
  if workflowCatalogVisible(state) and not workflowSetup.active(state)
    and (force or now >= state.nextAe2WorkflowRefresh) then
    if not force and workflowInputActive(state) then
      state.nextAe2WorkflowRefresh = now + intervals.ae2WorkflowRefresh
    else
      changed = workflowData.refresh(state, force, now, intervals) or changed
    end
  end
  return changed
end

ae2Data.maintainVisible = maintainerData.maintainVisible
ae2Data.daemonPageVisible = maintainerData.daemonPageVisible
ae2Data.workflowVisible = workflowVisible
ae2Data.logsVisible = logsVisible
ae2Data.deckVisible = deckVisible
ae2Data.summaryVisible = summaryVisible

return ae2Data
local maintainer = require("oc.ae2.maintainer")
local budget = require("oc.ae2.budget")
local cacheEpoch = require("oc.ae2.cache_epoch")
local maintainerDaemon = require("oc.ae2.maintainer_daemon_control")
local maintainerBulk = require("oc.dashboard.maintainer_ui_bulk")
local performance = require("oc.dashboard.performance")
local support = require("oc.dashboard.data_ae2_maintainer_support")
local workflows = require("oc.ae2.workflows")
local data = {}
function data.maintainVisible(state)
  return state.view == "ae2_maintain" or state.view == "ae2_counts"
end
function data.daemonPageVisible(state)
  return state.view == "ae2_daemon"
end
local reportStamp = support.reportStamp
local foregroundStamp = support.foregroundStamp
local stampForeground = support.stampForeground
local clearManualPatchIfCovered = support.clearManualPatchIfCovered
local autoRestoreDelay = support.autoRestoreDelay
local startingRefreshDelay = support.startingRefreshDelay
local hasStatusRows = support.hasStatusRows
local publishWarmStock = support.publishWarmStock
local noteForegroundStock = support.noteForegroundStock
local validateWarmReport = support.validateWarmReport
local function warmReport(daemonStatus, state, now)
  local report = daemonStatus and daemonStatus.warmReport
  if daemonStatus and daemonStatus.fresh == true and report and report.status and report.status.complete == true then
    daemonStatus.warmReportStale = nil
    daemonStatus.warmReportManualStale = nil
    daemonStatus.warmReportStockStale = nil
    daemonStatus.warmReportForegroundStale = nil
    daemonStatus.warmReportPolicyStale = nil
    daemonStatus.warmReportFuture = nil
    daemonStatus.warmReportPrimaryStale = nil
    daemonStatus.warmReportRowsStale = nil
    local ok, config = pcall(workflows.load)
    if not ok or type(config) ~= "table" then daemonStatus.warmReportStale = true; return nil end
    local targetOk, targets = pcall(function() return workflows.asTargets(config) end)
    if not targetOk or type(targets) ~= "table" then daemonStatus.warmReportStale = true; return nil end
    local currentSignature = cacheEpoch.targetSignature(targets)
    local valid, reason, stamp = validateWarmReport(state, report, config, targets, now)
    if not valid then
      daemonStatus.warmReportStale = true
      if reason == "policy" then daemonStatus.warmReportPolicyStale = true
      elseif reason == "future" or reason == "timestamp" then daemonStatus.warmReportFuture = true
      elseif reason == "primary" then daemonStatus.warmReportPrimaryStale = true
      elseif reason == "rows" then daemonStatus.warmReportRowsStale = true end
      return nil
    end
    local foregroundAt = foregroundStamp(state, currentSignature)
    if foregroundAt and (not stamp or stamp < foregroundAt) then
      daemonStatus.warmReportForegroundStale = true
      return nil
    end
    local manualAt = tonumber(state and state.ae2MaintainManualPatchAt)
    if manualAt and (not stamp or stamp < manualAt) then
      daemonStatus.warmReportManualStale = true
      return nil
    end
    local stockAt = tonumber(state and state.ae2StockMemorySeen)
    if stockAt and (not stamp or stamp < stockAt) then
      daemonStatus.warmReportStockStale = true
      daemonStatus.warmReportStale = true
      return nil
    end
    return report, targets
  end
  return nil
end
local function readDaemonStatus(options)
  options = options or {}
  if options.ensure == false then return maintainerDaemon.status() end
  if maintainerDaemon.ensureRunning then
    local ok, err, status = maintainerDaemon.ensureRunning({
      deferFirstTick = options.deferFirstTick == true,
      deferSeconds = options.deferSeconds
    })
    status = status or {}
    if not ok and err then status.ensureError = tostring(err) end
    return status
  end
  return maintainerDaemon.status()
end
local function daemonOwnsWarm(daemonStatus)
  return daemonStatus and daemonStatus.desiredEnabled == true
end
local function daemonRefreshDelay(daemonStatus, force, intervals)
  if force and daemonStatus and daemonStatus.desiredEnabled and daemonStatus.fresh ~= true then return 1 end
  local starting = startingRefreshDelay(daemonStatus)
  if starting then return starting end
  if daemonStatus and daemonStatus.desiredEnabled and daemonStatus.fresh ~= true then return 1 end
  return tonumber(intervals and intervals.ae2Maintain) or 600
end
local function deckDaemonRefreshDelay(daemonStatus, force, intervals)
  if force and daemonStatus and daemonStatus.desiredEnabled and daemonStatus.fresh ~= true then return 1 end
  local starting = startingRefreshDelay(daemonStatus)
  if starting then return starting end
  if daemonStatus and daemonStatus.desiredEnabled and daemonStatus.fresh ~= true then return 1 end
  return tonumber(intervals and intervals.ae2Logs) or 30
end
local function daemonWarmDelay(daemonStatus, force, intervals)
  if force and daemonStatus and daemonStatus.desiredEnabled and daemonStatus.fresh ~= true then return 1 end
  local starting = startingRefreshDelay(daemonStatus)
  if starting then return starting end
  if daemonStatus and daemonStatus.desiredEnabled and daemonStatus.fresh ~= true then return 1 end
  local nextIn = tonumber(daemonStatus and daemonStatus.nextIn)
  if nextIn and nextIn > 0 then return math.max(1, nextIn) end
  return autoRestoreDelay(intervals)
end
local function holdExistingForDaemon(state, daemonStatus, now, intervals, force)
  if not hasStatusRows(state.ae2Maintain) then return false end
  state.ae2MaintainDaemon = daemonStatus
  state.ae2MaintainerMode = state.ae2Maintain.status and state.ae2Maintain.status.mode or state.ae2MaintainerMode
  state.ae2MaintainDirty = false
  state.ae2MaintainDirtyReason = nil
  state.ae2MaintainStockMemoryHandoff = nil
  state.nextAe2MaintainRefresh = now + daemonWarmDelay(daemonStatus, force, intervals)
  return true
end
local function holdExistingForDaemonPage(state, daemonStatus, now, intervals, force)
  if not hasStatusRows(state.ae2Maintain) then return false end
  state.ae2MaintainDaemon = daemonStatus
  state.ae2MaintainerMode = state.ae2Maintain.status and state.ae2Maintain.status.mode or state.ae2MaintainerMode
  state.nextAe2DaemonRefresh = now + daemonRefreshDelay(daemonStatus, force, intervals)
  return true
end
local function applyWarmReport(state, daemonStatus, report, targets, now, intervals)
  state.ae2MaintainDaemon = daemonStatus
  state.ae2Maintain = report
  state.ae2MaintainerMode = report.status and report.status.mode or state.ae2MaintainerMode
  if report.cache then state.ae2MaintainCache = report.cache end
  publishWarmStock(state, report, targets, now)
  performance.recordCache(state, "Daemon warm", report.cache)
  state.ae2MaintainDirty = false
  state.ae2MaintainDirtyReason = nil
  state.ae2MaintainStockMemoryHandoff = nil
  clearManualPatchIfCovered(state, report)
  state.nextAe2MaintainRefresh = state.view == "ae2_counts"
    and now + (tonumber(intervals and intervals.ae2Stock) or 60) or math.huge
end
local function disconnected(report)
  local status = (report and report.status) or {}
  if status.ae2Online == false then return true end
  local power = status.power
  return type(power) == "table" and power.available == false
end

local function holdMaintainer(state, daemonStatus, now, info)
  local wait = math.max(0.1, tonumber(info and info.wait) or 1)
  state.ae2MaintainDaemon = daemonStatus
  state.ae2Maintain = state.ae2Maintain or { targets = {}, status = {} }
  state.ae2Maintain.status = state.ae2Maintain.status or {}
  state.ae2Maintain.status.complete = false
  state.ae2Maintain.status.status = "budget"
  state.ae2Maintain.message = "Maintainer held: " .. tostring(info and info.reason or "AE2 budget cooling down")
  state.nextAe2MaintainRefresh = now + wait
  return true
end

function data.refreshMaintainer(state, force, now, intervals)
  local stockVisible = state.view == "ae2_counts"
  local nextRefresh = tonumber(state.nextAe2MaintainRefresh) or 0
  local enteringStockFromDormant = stockVisible and nextRefresh == math.huge
  if not data.maintainVisible(state)
    or (not force and now < nextRefresh and not enteringStockFromDormant) then return false end
  local daemonStatus = readDaemonStatus({ ensure = not force, deferFirstTick = true, deferSeconds = autoRestoreDelay(intervals) })
  local dirty = state.ae2MaintainDirty == true
  local stockDirty = dirty and state.ae2MaintainDirtyReason == "stock_memory"
  if stockDirty then state.ae2MaintainStockMemoryHandoff = true end
  local stockHandoff = state.ae2MaintainStockMemoryHandoff == true
  local warm, warmTargets
  if not stockHandoff then
    local candidate, candidateTargets = warmReport(daemonStatus, state, now)
    if not force then warm, warmTargets = candidate, candidateTargets end
  end
  local consumedAt = tonumber(state.ae2StockDaemonReportAt)
  if stockVisible and warm and consumedAt and (reportStamp(warm) or -math.huge) <= consumedAt then warm = nil end
  if warm then applyWarmReport(state, daemonStatus, warm, warmTargets, now, intervals); return true end
  local cacheIncomplete = state.ae2MaintainCache and state.ae2MaintainCache.complete == false
  if not force and not stockVisible and not stockHandoff
    and daemonOwnsWarm(daemonStatus) and not daemonStatus.warmReportStale then
    -- Prefer the daemon's completed warm report and preserve already-useful
    -- rows, but do not leave a cold Maintainer page on config placeholders
    -- while the daemon's deliberately deferred first plan is still starting.
    -- The normal foreground path below is observe-only and target-bounded.
    if not cacheIncomplete and holdExistingForDaemon(state, daemonStatus, now, intervals, force) then return true end
  end
  local kind = (force or dirty) and "manual_action" or cacheIncomplete and "warm_continuation" or "visible_refresh"
  local budgetOk, budgetInfo = budget.trySpend(kind, { now = now })
  if not budgetOk then return holdMaintainer(state, daemonStatus, now, budgetInfo) end
  local restart = (force or stockVisible or disconnected(state.ae2Maintain)) and not cacheIncomplete
  local cursorBefore = tonumber(state.ae2MaintainCache and state.ae2MaintainCache.targetCursor) or 1
  local scope = stockVisible and "Stock" or "Maintainer"
  local targetLimit = performance.targetLimit(state, scope, intervals.ae2MaintainTargetLimit, restart)
  local startedAt = performance.now()
  state.ae2Maintain = stampForeground(maintainer.snapshot({
    requestReady = false,
    cache = state.ae2MaintainCache,
    restart = restart,
    dirty = dirty,
    targetLimit = targetLimit
  }), now)
  local calls = noteForegroundStock(state, state.ae2Maintain, now)
  performance.recordChunk(state, scope, startedAt, performance.now(), calls, state.ae2Maintain.cache, {
    scope = scope,
    targetLimit = targetLimit,
    baseTargetLimit = intervals.ae2MaintainTargetLimit,
    ok = true,
    cursorBefore = cursorBefore
  })
  state.ae2MaintainDirty = false
  state.ae2MaintainDirtyReason = nil
  state.ae2MaintainCache = state.ae2Maintain.cache
  state.ae2MaintainDaemon = daemonStatus
  state.ae2MaintainerMode = state.ae2Maintain.status and state.ae2Maintain.status.mode or state.ae2MaintainerMode
  if (state.ae2Maintain.status or {}).complete ~= false then state.ae2MaintainStockMemoryHandoff = nil end
  if (state.ae2Maintain.status or {}).complete ~= false then state.ae2MaintainManualPatchAt = nil end
  local delay = (state.ae2Maintain.status or {}).complete == false and (tonumber(intervals.ae2MaintainChunkDelay) or 2)
    or disconnected(state.ae2Maintain) and intervals.ae2Maintain
    or stockVisible and (tonumber(intervals.ae2Stock) or 60) or math.huge
  state.nextAe2MaintainRefresh = now + delay
  return true
end

function data.refreshDaemonPage(state, force, now, intervals)
  if not data.daemonPageVisible(state) or (not force and now < state.nextAe2DaemonRefresh) then return false end
  local daemonStatus = readDaemonStatus({ ensure = not force, deferFirstTick = true, deferSeconds = autoRestoreDelay(intervals) })
  local warm, warmTargets = warmReport(daemonStatus, state, now)
  state.ae2MaintainDaemon = daemonStatus
  if warm then
    state.ae2Maintain = warm
    state.ae2MaintainerMode = state.ae2Maintain.status and state.ae2Maintain.status.mode or state.ae2MaintainerMode
    publishWarmStock(state, warm, warmTargets, now)
    clearManualPatchIfCovered(state, warm)
  elseif not holdExistingForDaemonPage(state, daemonStatus, now, intervals, force) then
    state.ae2Maintain = maintainer.configSnapshot()
    state.ae2MaintainerMode = state.ae2Maintain.status and state.ae2Maintain.status.mode or state.ae2MaintainerMode
  end
  state.nextAe2DaemonRefresh = now + daemonRefreshDelay(daemonStatus, force, intervals)
  return true
end

function data.refreshDaemonDeck(state, force, now, intervals)
  if state.view ~= "overview" or (not force and now < state.nextAe2DaemonRefresh) then return false end
  state.ae2MaintainDaemon = readDaemonStatus({ ensure = not force, deferFirstTick = true, deferSeconds = autoRestoreDelay(intervals) })
  local daemonStatus = state.ae2MaintainDaemon or {}
  state.nextAe2DaemonRefresh = now + deckDaemonRefreshDelay(daemonStatus, force, intervals)
  return true
end

function data.refreshDaemonBulk(state, now)
  return maintainerBulk.continue(state, now)
end

return data
local cacheEpoch = require("oc.ae2.cache_epoch")
local binding = require("oc.ae2.request_binding")
local stateIdentity = require("oc.ae2.maintainer_state_identity")
local stockMemory = require("oc.ae2.stock_memory")

local support = {}
local MAX_FUTURE_SKEW = 5

local function finite(value)
  return type(value) == "number" and value == value and value > -math.huge and value < math.huge
end

function support.reportStamp(report)
  return tonumber(report and (report.savedAt or report.manualPatchAt
    or (report.cache and report.cache.savedAt)))
end

function support.reportTargetSignature(report)
  return report and (report.targetSignature or (report.cache and report.cache.targetSignature))
end

function support.reportPolicySignature(report)
  return report and (report.policySignature or (report.cache and report.cache.policySignature))
end

function support.reportPrimaryAddress(report)
  local primary = report and report.status and report.status.ae2Primary
  local address = type(primary) == "table" and primary.address or nil
  if type(address) ~= "string" or address == "" then return nil end
  return address
end

function support.statePrimaryAddress(state)
  local primary = state and state.ae2 and state.ae2.primary
  local address = type(primary) == "table" and primary.address or nil
  if type(address) == "string" and address ~= "" then return address end
  address = state and state.ae2StockAddress
  if type(address) == "string" and address ~= "" then return address end
  return nil
end

function support.validReportStamp(report, now)
  local stamp = support.reportStamp(report)
  if not finite(stamp) or stamp < 0 then return nil, "timestamp" end
  local current = tonumber(now)
  if finite(current) and stamp > current + MAX_FUTURE_SKEW then return nil, "future" end
  return stamp
end

function support.validateWarmReport(state, report, config, targets, now)
  if not (report and report.status and report.status.complete == true) then return false, "incomplete" end
  local stamp, stampErr = support.validReportStamp(report, now)
  if not stamp then return false, stampErr end
  targets = targets or {}
  if support.reportTargetSignature(report) ~= cacheEpoch.targetSignature(targets) then return false, "targets" end
  if support.reportPolicySignature(report) ~= stateIdentity.configSignature(targets) then return false, "policy" end
  if report.status.autoEnabled ~= ((config or {}).autoEnabled ~= false) then return false, "policy" end
  if type(report.targets) ~= "table" or #report.targets ~= #targets then return false, "rows" end
  for index, target in ipairs(targets) do
    local row = report.targets[index]
    local expected = cacheEpoch.targetKey(target)
    if type(row) ~= "table" or row.targetKey ~= expected or cacheEpoch.targetKey(row) ~= expected then
      return false, "rows"
    end
  end
  local reportAddress = support.reportPrimaryAddress(report)
  if not reportAddress then return false, "primary" end
  local currentAddress = support.statePrimaryAddress(state)
  if currentAddress and currentAddress ~= reportAddress then return false, "primary" end
  return true, nil, stamp, reportAddress
end

function support.foregroundStamp(state, currentSignature)
  local report = state and state.ae2Maintain
  if not (report and report.status and report.status.complete == true and type(report.targets) == "table"
      and #report.targets > 0) then return nil end
  local signature = support.reportTargetSignature(report) or cacheEpoch.targetSignature(report.targets)
  if signature ~= currentSignature then return nil end
  return support.reportStamp(report)
end

function support.stampForeground(report, now)
  if type(report) == "table" then report.savedAt = tonumber(now) or report.savedAt end
  return report
end

local function newerStamp(first, second)
  first, second = tonumber(first), tonumber(second)
  if first == nil then return second end
  if second == nil then return first end
  return math.max(first, second)
end

-- Daemon and dashboard are separate Lua processes, so their stock_memory
-- tables are not shared. A validated completed report is the durable handoff:
-- copy only exact numeric rows and never infer an identity from a label.
function support.publishWarmStock(state, report, targets, now)
  if not (report and report.status and report.status.complete == true) then return 0 end
  local stamp = support.validReportStamp(report, now)
  local reportAddress = support.reportPrimaryAddress(report)
  local currentAddress = support.statePrimaryAddress(state)
  if not stamp or not reportAddress or not currentAddress or reportAddress ~= currentAddress then return 0 end
  local published = 0
  for index, target in ipairs(targets or {}) do
    local key = cacheEpoch.targetKey(target)
    local row = (report.targets or {})[index]
    local current = row and row.current
    local exactTarget = binding.error(target) == nil
    local exactRow = binding.error(row) == nil
    local sameKey = row and row.targetKey == key and cacheEpoch.targetKey(row) == key
    if exactTarget and exactRow and sameKey and finite(current) and current >= 0 then
      local accepted = stockMemory.remember(target, row, {
        key = key, address = reportAddress, source = "daemon-warm", at = stamp
      })
      if accepted then published = published + 1 end
    end
  end
  if published > 0 then
    state.ae2StockDaemonReportAt = newerStamp(state.ae2StockDaemonReportAt, stamp)
    state.ae2StockMemorySeen = newerStamp(state.ae2StockMemorySeen, stamp)
    state.ae2StockAddress = reportAddress
  end
  state.nextAe2StockRefresh = 0
  return published
end

function support.noteForegroundStock(state, report, now)
  local calls, observed, succeeded = 0, false, false
  for _, row in ipairs((report and report.targets) or {}) do
    if row.stockDirectCalls ~= nil then observed = true end
    local rowCalls = math.max(0, tonumber(row.stockDirectCalls) or 0)
    calls = calls + rowCalls
    if rowCalls > 0 and row.stockMemoryFresh == true and tonumber(row.current) ~= nil then succeeded = true end
  end
  if succeeded then
    state.ae2StockMemorySeen = newerStamp(state.ae2StockMemorySeen, now)
    state.ae2StockAddress = support.reportPrimaryAddress(report) or state.ae2StockAddress
  end
  state.nextAe2StockRefresh = 0
  return observed and calls or nil
end

function support.clearManualPatchIfCovered(state, report)
  local manualAt = tonumber(state and state.ae2MaintainManualPatchAt)
  if not manualAt then return end
  local stamp = support.reportStamp(report)
  if stamp and stamp >= manualAt then state.ae2MaintainManualPatchAt = nil end
end

function support.autoRestoreDelay(intervals)
  return math.max(600, tonumber(intervals and intervals.ae2Maintain) or 600)
end

function support.startingRefreshDelay(daemonStatus)
  if not (daemonStatus and daemonStatus.starting == true) then return nil end
  local remaining = tonumber(daemonStatus.startupRemaining)
  if remaining and remaining > 0 then return math.min(30, math.max(5, remaining)) end
  return 1
end

function support.hasStatusRows(report)
  local status, targets = report and report.status, report and report.targets
  return type(status) == "table" and status.complete ~= nil and type(targets) == "table" and #targets > 0
end

return support
local component = require("component")

local health = require("oc.core.health")
local dataState = require("oc.dashboard.data_state")

local coreData = {}

local function componentsVisible(state)
  local view = state and state.view
  return view == "overview" or view == "ops_links"
end

local function healthVisible(state)
  local view = state and state.view
  return view == "overview" or view == "ops_health" or view == "ops_perf"
end

local function collectComponentRows()
  local counts = {}
  local rows = {}
  for address, ctype in component.list() do
    counts[ctype] = (counts[ctype] or 0) + 1
    rows[#rows + 1] = { address = address, ctype = ctype }
  end
  table.sort(rows, function(a, b)
    if a.ctype == b.ctype then return a.address < b.address end
    return a.ctype < b.ctype
  end)
  return rows, counts
end

function coreData.refresh(state, force, now, intervals)
  local changed = false
  if healthVisible(state) and (force or now >= state.nextHealthRefresh) then
    state.health = health.snapshot({
      includeComponents = false,
      componentCounts = state.health and state.health.components
    })
    if state.view == "overview" then dataState.advanceInitiativePage(state) end
    state.nextHealthRefresh = now + intervals.health
    changed = true
  end
  if state.view == "overview" and (force or now >= state.nextClockRefresh) then
    state.health.uptime = now
    state.nextClockRefresh = now + intervals.clock
    changed = true
  end
  if componentsVisible(state) and (force or now >= state.nextSlowRefresh) then
    state.components, state.componentCounts = collectComponentRows()
    state.nextSlowRefresh = now + intervals.components
    changed = true
  end
  return changed
end

coreData.collectComponentRows = collectComponentRows
coreData.componentsVisible = componentsVisible
coreData.healthVisible = healthVisible

return coreData
local cacheEpoch = require("oc.ae2.cache_epoch")
local powerMonitor = require("oc.gt_power.monitor")

local powerData = {}

function powerData.lockPowerNode(state, snapshot)
  if state.powerLocked or not snapshot.available then return false end
  for _, reading in ipairs(snapshot.readings or {}) do
    if powerMonitor.isUsable(reading) then
      for _, node in ipairs(state.powerNodes or {}) do
        if node.address == reading.address then
          state.powerNodes = { node }
          state.powerLocked = true
          state.nextPowerDiscover = math.huge
          return true
        end
      end
    end
  end
  return false
end

function powerData.refresh(state, force, now, intervals)
  local changed = false
  local powerDetail = state.view == "power"
  local powerSummary = state.view == "overview" or state.view == "power_alarms"
  local powerVisible = powerDetail or powerSummary
  -- Discovery walks component candidates. Keep it on screens that actually
  -- render Battery telemetry; an overdue discovery timer must not wake the
  -- Domain editor or an unrelated operator page.
  if powerVisible and not state.powerLocked and (force or now >= state.nextPowerDiscover) then
    state.powerNodes = powerMonitor.discover()
    state.nextPowerDiscover = now + intervals.powerDiscover
    changed = true
  end
  if powerVisible and (force or now >= state.nextPowerRefresh) then
    state.power = powerMonitor.snapshot({
      nodes = state.powerNodes,
      detail = powerDetail,
      sensor = powerDetail or powerSummary,
      scanLimit = powerDetail and nil or 3,
      usableOnly = true,
      limit = powerDetail and nil or 1
    })
    cacheEpoch.recordNodes({ batteryNode = state.power.readings and state.power.readings[1] })
    state.nextPowerRefresh = now + intervals.power
    powerData.lockPowerNode(state, state.power)
    changed = true
  end
  return changed
end

return powerData
local schedule = {}

function schedule.nextDelay(state, now, intervals)
  local nextClock = state.view == "overview" and state.nextClockRefresh or now + intervals.maxSleep
  local healthVisible = state.view == "overview" or state.view == "ops_health" or state.view == "ops_perf"
  local nextHealth = healthVisible and state.nextHealthRefresh or now + intervals.maxSleep
  local summaryVisible = state.view == "overview" or state.view == "ae2"
    or state.view == "ae2_counts" or state.view == "ae2_cpus"
  local nextAe2Summary = summaryVisible and state.nextAe2Refresh or now + intervals.maxSleep
  local nextAe2Cpu = state.view == "ae2_cpus" and state.nextAe2CpuRefresh or now + intervals.maxSleep
  local nextAe2Stock = state.view == "ae2_counts" and state.nextAe2StockRefresh or now + intervals.maxSleep
  local maintainerVisible = state.view == "ae2_maintain" or state.view == "ae2_counts"
  local daemonPageVisible = state.view == "ae2_daemon"
  local nextAe2Maintain = maintainerVisible and state.nextAe2MaintainRefresh or now + intervals.maxSleep
  local nextAe2Daemon = (state.view == "overview" or daemonPageVisible) and state.nextAe2DaemonRefresh or now + intervals.maxSleep
  local nextAe2Logs = state.view == "ae2_logs" and state.nextAe2LogRefresh or now + intervals.maxSleep
  local nextAe2DeckLogs = state.view == "overview" and state.nextAe2DeckLogRefresh or now + intervals.maxSleep
  local workflowCatalogVisible = state.view == "ae2_workflows"
  local workflowInputReady = not (state.view == "ae2_workflows" and state.ae2WorkflowSearchActive)
  local nextAe2WorkflowSave = state.ae2WorkflowSavePending
    and (state.nextAe2WorkflowSave or now + (intervals.ae2WorkflowSave or 1))
    or now + intervals.maxSleep
  local nextAe2Workflow = workflowCatalogVisible and workflowInputReady and state.nextAe2WorkflowRefresh or now + intervals.maxSleep
  local workflowSetup = state.ae2WorkflowSetup
  local setupStage = workflowSetup and workflowSetup.stage
  local setupWorking = setupStage == "stopping" or setupStage == "scanning"
    or setupStage == "committing" or setupStage == "restoring"
  local nextAe2WorkflowSetup = setupWorking
    and (workflowSetup.nextAt or now) or now + intervals.maxSleep
  local nextAe2DaemonBulk = state.ae2DaemonBulk and state.ae2DaemonBulk.nextAt or now + intervals.maxSleep
  local manualRequest = state.ae2ManualRequest
  local manualActive = type(manualRequest) == "table" and (manualRequest.recordPending == true
    or (manualRequest.trackable == true and manualRequest.requestState == "running"))
  local nextAe2ManualRequest = manualActive and (tonumber(manualRequest.nextPollAt) or now) or now + intervals.maxSleep
  local powerVisible = state.view == "overview" or state.view == "power" or state.view == "power_alarms"
  local nextPower = powerVisible and (state.nextPowerRefresh or now + intervals.maxSleep) or now + intervals.maxSleep
  local nextPowerDiscover = powerVisible and (state.nextPowerDiscover or now + intervals.maxSleep) or now + intervals.maxSleep
  local componentsVisible = state.view == "overview" or state.view == "ops_links"
  local nextComponents = componentsVisible and state.nextSlowRefresh or now + intervals.maxSleep
  local nextAt = math.min(
    nextClock,
    nextHealth,
    nextAe2Summary,
    nextAe2Cpu,
    nextAe2Stock,
    nextAe2Maintain,
    nextAe2Daemon,
    nextAe2Logs,
    nextAe2DeckLogs,
    nextAe2WorkflowSave,
    nextAe2Workflow,
    nextAe2WorkflowSetup,
    nextAe2DaemonBulk,
    nextAe2ManualRequest,
    nextPower,
    nextPowerDiscover,
    nextComponents)
  local delay = nextAt - now
  if delay < 0.1 then return 0.1 end
  if delay > intervals.maxSleep then return intervals.maxSleep end
  return delay
end

return schedule
local maintainer = require("oc.ae2.maintainer")
local initiativeStore = require("oc.dashboard.initiatives")
local powerTitle = require("oc.dashboard.power_title")
local title = require("oc.dashboard.title")

local dataState = {}

function dataState.new(width, height)
  return {
    W = width,
    H = height,
    view = "overview",
    nextClockRefresh = 0,
    nextHealthRefresh = 0,
    nextAe2Refresh = 0,
    nextAe2CpuRefresh = 0,
    nextAe2StockRefresh = 0,
    nextAe2MaintainRefresh = 0,
    nextAe2DaemonRefresh = 0,
    nextAe2LogRefresh = 0,
    nextAe2DeckLogRefresh = 0,
    nextAe2WorkflowSave = nil,
    nextAe2WorkflowRefresh = 0,
    nextPowerRefresh = 0,
    nextPowerDiscover = 0,
    nextSlowRefresh = 0,
    powerNodes = nil,
    powerLocked = false,
    initiatives = initiativeStore.load(),
    dashboardName = title.load(),
    powerStorageName = powerTitle.load(),
    ae2Counts = nil,
    ae2StockCache = nil,
    ae2StockMemorySeen = nil,
    ae2StockDaemonReportAt = nil,
    ae2StockAddress = nil,
    ae2CraftCache = nil,
    ae2Workflow = {},
    ae2WorkflowQuery = "",
    ae2WorkflowSearchActive = false,
    ae2WorkflowSetup = nil,
    ae2WorkflowSavePending = false,
    ae2WorkflowSelected = 1,
    ae2WorkflowPage = 1,
    ae2LogPage = 1,
    initiativePage = 1,
    initiativePageReady = false,
    components = {},
    componentCounts = {},
    health = {},
    ae2 = {},
    ae2Maintain = {},
    ae2MaintainCache = nil,
    ae2MaintainDirty = false,
    ae2Logs = {},
    ae2DeckLogs = {},
    ae2MaintainerMode = maintainer.config().mode,
    power = {}
  }
end

function dataState.advanceInitiativePage(state)
  local pages = initiativeStore.pageCount(state.initiatives)
  if not state.initiativePageReady then
    state.initiativePage = 1
    state.initiativePageReady = true
  else
    state.initiativePage = (state.initiativePage % pages) + 1
  end
end

return dataState
local serialization = require("serialization")
local readable = require("oc.core.config")

local title = {}

title.path = "/etc/oc/dashboard-title.cfg"
title.defaultName = "Click Me To Edit Name"
title.maxLength = 30

local function trim(value)
  value = tostring(value or "")
  value = value:gsub("^%s+", ""):gsub("%s+$", "")
  return value:gsub("[%c]", "")
end

function title.normalize(value)
  value = trim(value)
  if value == "" then value = title.defaultName end
  return value:sub(1, title.maxLength)
end

function title.load()
  local ok, handle = pcall(io.open, title.path, "r")
  if not ok or not handle then return title.defaultName end
  local body = handle:read("*a") or ""
  handle:close()
  local decodedOk, value = pcall(serialization.unserialize, body)
  if decodedOk and type(value) == "table" then
    return title.normalize(value.name)
  elseif decodedOk and type(value) == "string" then
    return title.normalize(value)
  end
  return title.defaultName
end

function title.save(name)
  local normalized = title.normalize(name)
  local saved, saveReason = readable.save(title.path, { name = normalized })
  if not saved then return false, saveReason end
  return true, nil, normalized
end

return title
local title = require("oc.dashboard.title")

local editor = {}

local function currentName(state)
  return title.normalize((state and state.dashboardName) or title.defaultName)
end

local function appendText(state, value)
  local session = state.dashboardTitleEditor
  if not session then return false end
  value = tostring(value or ""):gsub("[%c]", "")
  local current = tostring(session.value or "")
  local room = title.maxLength - #current
  if room <= 0 then return false end
  session.value = current .. value:sub(1, room)
  return true
end

local function save(state)
  local session = state.dashboardTitleEditor
  if not session then return false end
  local ok, err, normalized = title.save(session.value)
  if ok then
    state.dashboardName = normalized
    state.dashboardTitleEditor = nil
    state.dashboardTitleMessage = "Command deck name saved."
  else
    state.dashboardTitleMessage = err
  end
  return true
end

function editor.open(state)
  state.dashboardTitleEditor = { value = currentName(state) }
  state.dashboardTitleMessage = "Type name; Ctrl+S or Enter saves."
  return true
end

function editor.hit(state, x, y)
  return y == state.dashboardTitleY
    and x >= (state.dashboardTitleX or 3)
    and x < (state.dashboardTitleX or 3) + math.max(1, state.dashboardTitleW or 1)
end

function editor.handle(state, ev)
  local session = state.dashboardTitleEditor
  if not session then return false end
  if ev[1] == "clipboard" then
    return appendText(state, ev[3])
  elseif ev[1] == "key_down" then
    local char = ev[3]
    if char == 19 or char == 13 then
      return save(state)
    elseif char == 8 or char == 127 then
      local value = tostring(session.value or "")
      if value == "" then return false end
      session.value = value:sub(1, math.max(0, #value - 1))
      return true
    elseif char and char >= 32 and char <= 126 then
      return appendText(state, string.char(char))
    end
  elseif ev[1] == "touch" and editor.hit(state, ev[3], ev[4]) then
    return true
  end
  return false
end

return editor
local serialization = require("serialization")
local readable = require("oc.core.config")

local title = {}

title.path = "/etc/oc/dashboard-power-title.cfg"
title.defaultName = "Click Me To Name Storage"
title.maxLength = 32

local function trim(value)
  value = tostring(value or "")
  value = value:gsub("^%s+", ""):gsub("%s+$", "")
  return value:gsub("[%c]", "")
end

function title.normalize(value)
  value = trim(value)
  if value == "" then value = title.defaultName end
  return value:sub(1, title.maxLength)
end

function title.load()
  local ok, handle = pcall(io.open, title.path, "r")
  if not ok or not handle then return title.defaultName end
  local body = handle:read("*a") or ""
  handle:close()
  local decodedOk, value = pcall(serialization.unserialize, body)
  if decodedOk and type(value) == "table" then
    return title.normalize(value.name)
  elseif decodedOk and type(value) == "string" then
    return title.normalize(value)
  end
  return title.defaultName
end

function title.save(name)
  local normalized = title.normalize(name)
  local saved, saveReason = readable.save(title.path, { name = normalized })
  if not saved then return false, saveReason end
  return true, nil, normalized
end

return title
local powerTitle = require("oc.dashboard.power_title")

local editor = {}

local function currentName(state)
  return powerTitle.normalize((state and state.powerStorageName) or powerTitle.defaultName)
end

local function appendText(state, value)
  local session = state.powerTitleEditor
  if not session then return false end
  value = tostring(value or ""):gsub("[%c]", "")
  local current = tostring(session.value or "")
  local room = powerTitle.maxLength - #current
  if room <= 0 then return false end
  session.value = current .. value:sub(1, room)
  return true
end

local function save(state)
  local session = state.powerTitleEditor
  if not session then return false end
  local ok, err, normalized = powerTitle.save(session.value)
  if ok then
    state.powerStorageName = normalized
    state.powerTitleEditor = nil
    state.powerTitleMessage = "Battery storage name saved."
  else
    state.powerTitleMessage = err
  end
  return true
end

function editor.open(state)
  state.powerTitleEditor = { value = currentName(state) }
  state.powerTitleMessage = "Type storage name; Ctrl+S or Enter saves."
  return true
end

function editor.hit(state, x, y)
  return state.view == "power"
    and y == state.powerTitleY
    and x >= (state.powerTitleX or 3)
    and x < (state.powerTitleX or 3) + math.max(1, state.powerTitleW or 1)
end

function editor.handle(state, ev)
  local session = state.powerTitleEditor
  if not session then return false end
  if ev[1] == "clipboard" then
    return appendText(state, ev[3])
  elseif ev[1] == "key_down" then
    local char = ev[3]
    if char == 19 or char == 13 then
      return save(state)
    elseif char == 8 or char == 127 then
      local value = tostring(session.value or "")
      if value == "" then return false end
      session.value = value:sub(1, math.max(0, #value - 1))
      return true
    elseif char and char >= 32 and char <= 126 then
      return appendText(state, string.char(char))
    end
  elseif ev[1] == "touch" and editor.hit(state, ev[3], ev[4]) then
    return true
  end
  return false
end

return editor
local workflows = require("oc.ae2.workflows")
local workflowSetup = require("oc.dashboard.workflow_setup")

local workflowData = {}

function workflowData.hasPending(state)
  return state.ae2WorkflowSavePending == true or (workflows.hasPending and workflows.hasPending())
end

function workflowData.flushPending(state)
  local ok, saveOk, saveErr = pcall(workflows.flushPending)
  if not ok then
    saveErr = saveOk
    saveOk = false
  end
  state.ae2WorkflowSaveError = saveOk and nil or tostring(saveErr)
  state.ae2WorkflowSavePending = not saveOk
  state.nextAe2WorkflowSave = nil
  return saveOk
end

local function selectedCraftId(state)
  local entries = state.ae2Workflow and state.ae2Workflow.entries
  local entry = entries and entries[state.ae2WorkflowSelected or 1]
  return entry and (entry.craftId or entry.craftIndex)
end

local function labelKey(entry)
  return tostring(entry and (entry.label or entry.rawLabel or entry.name) or ""):lower()
end

local function entryKey(entry)
  if not entry then return nil end
  if entry.name then
    return tostring(entry.kind or (entry.isFluid and "fluid" or "item")) .. ":"
      .. tostring(entry.name) .. ":" .. tostring(entry.damage or "") .. ":"
      .. tostring(entry.hasTag == true) .. ":" .. labelKey(entry)
  end
  return labelKey(entry)
end

local function selectedCraftKey(state)
  local entries = state.ae2Workflow and state.ae2Workflow.entries
  return entryKey(entries and entries[state.ae2WorkflowSelected or 1])
end

local function selectIndex(state, index)
  state.ae2WorkflowSelected = index
  if state.ae2WorkflowPerPage then
    state.ae2WorkflowPage = math.max(1, math.ceil(index / math.max(1, state.ae2WorkflowPerPage)))
  end
end

local function restoreSelection(state, craftId, craftKey)
  if not craftId and not craftKey then return end
  if craftId ~= nil then
    for index, entry in ipairs((state.ae2Workflow and state.ae2Workflow.entries) or {}) do
      if (entry.craftId or entry.craftIndex) == craftId then
        selectIndex(state, index)
        return
      end
    end
  end
  for index, entry in ipairs((state.ae2Workflow and state.ae2Workflow.entries) or {}) do
    if craftKey and entryKey(entry) == craftKey then
      selectIndex(state, index)
      return
    end
  end
end

local function clearCraftSearch(state)
  if state.ae2CraftCache and type(workflows.disposeCatalog) == "function" then
    pcall(workflows.disposeCatalog, state.ae2CraftCache)
  end
  state.ae2CraftCache = nil
  state.ae2Workflow = { entries = {}, complete = true, error = "Managed targets will load when this page opens." }
  state.ae2WorkflowSelected = 1
  state.ae2WorkflowPage = 1
end

function workflowData.dispose(state)
  if workflowSetup.active(state) then
    workflowSetup.cancel(state)
    if workflowSetup.active(state) then return false end
  end
  clearCraftSearch(state)
  return true
end

function workflowData.refresh(state, force, now, intervals)
  workflowData.flushPending(state)
  local craftId = selectedCraftId(state)
  local craftKey = selectedCraftKey(state)
  local ok, report = pcall(workflows.catalog, state.ae2CraftCache, {
    query = state.ae2WorkflowQuery
  })
  if ok and type(report) == "table" then
    state.ae2Workflow = report
    restoreSelection(state, craftId, craftKey)
    state.ae2CraftCache = report.cache
  else
    state.ae2Workflow = state.ae2Workflow or { entries = {}, cache = state.ae2CraftCache or {} }
    state.ae2Workflow.cache = state.ae2CraftCache or state.ae2Workflow.cache or {}
    state.ae2Workflow.error = "craft catalog refresh failed: " .. tostring(report)
  end
  state.nextAe2WorkflowRefresh = now + (tonumber(intervals and intervals.ae2WorkflowRefresh) or 30)
  return true
end

return workflowData
local workflows = require("oc.ae2.workflows")
local binding = require("oc.ae2.request_binding")
local setupInput = require("oc.dashboard.workflow_setup_input")
local lifecycle = require("oc.dashboard.workflow_setup_lifecycle")

local setup = {}
setup.maxQuery = 64
setup.defaultScanLimit = 384
setup.defaultMaxCandidates = 32
setup.defaultChunkDelay = 2
local function trim(value)
  value = tostring(value or "")
  return value:gsub("^%s+", ""):gsub("%s+$", "")
end

local function wizard(state)
  return state and state.ae2WorkflowSetup
end

local function selectedEntry(state)
  local entries = state and state.ae2Workflow and state.ae2Workflow.entries or {}
  return entries[state and state.ae2WorkflowSelected or 1]
end

local function entryLabel(entry)
  return tostring(entry and (entry.label or entry.rawLabel or entry.name) or "")
end

local function disposeSession(value)
  if not value or not value.session or type(workflows.disposeOnboarding) ~= "function" then return true end
  local ok, result = pcall(workflows.disposeOnboarding, value.session)
  value.session = nil
  return ok and result ~= false
end

local function candidates(value)
  if not value then return {} end
  if value.report and type(value.report.candidates) == "table" then return value.report.candidates end
  if value.session and type(value.session.candidates) == "table" then return value.session.candidates end
  return {}
end

local function clampSelection(value)
  local rows = candidates(value)
  if #rows == 0 then value.selected = 1; return end
  value.selected = math.max(1, math.min(#rows, tonumber(value.selected) or 1))
end

function setup.active(state)
  return wizard(state) ~= nil
end

function setup.open(state, entry)
  if not state then return false end
  if wizard(state) then return false end
  entry = entry or nil
  local value = {
    mode = entry and "bind" or "add",
    targetConfigIndex = entry and entry.configIndex or nil,
    targetLabel = entryLabel(entry),
    query = entryLabel(entry),
    returnView = state.view,
    stage = "stopping",
    selected = 1,
    scanned = 0,
    complete = false,
    nextAt = nil,
    error = nil
  }
  state.ae2WorkflowSearchActive = false
  state.ae2WorkflowSetup = value
  lifecycle.prepare(value)
  return true
end

function setup.openSelected(state)
  return setup.open(state, selectedEntry(state))
end

function setup.cancel(state)
  local value = wizard(state)
  if not value then return false end
  disposeSession(value)
  return lifecycle.cancel(state, value)
end

function setup.review(state)
  local value = wizard(state)
  if not value then return false end
  local query = trim(value.query)
  if query == "" then
    value.error = "Enter part of the recipe output label or registry name before scanning."
    return true
  end
  value.query = query
  value.error = nil
  value.stage = "confirm"
  return true
end

function setup.start(state)
  local value = wizard(state)
  if not value then return false end
  local query = trim(value.query)
  if query == "" then return setup.review(state) end
  disposeSession(value)
  local ok, session, reason = pcall(workflows.beginOnboarding, query, value.targetConfigIndex, value.authority)
  if not ok then reason, session = session, nil end
  if type(session) ~= "table" then
    value.stage = "confirm"
    value.error = tostring(reason or "recipe discovery could not start")
    return true
  end
  value.query = query
  value.session = session
  value.report = nil
  value.stage = "scanning"
  value.selected = 1
  value.scanned = 0
  value.complete = false
  value.error = nil
  value.nextAt = 0
  return true
end

function setup.refresh(state, now, intervals)
  local value = wizard(state)
  if not value then return false end
  now = tonumber(now) or 0
  if value.stage == "stopping" then return lifecycle.refreshPreparation(state, value, now, intervals) end
  if value.stage == "restoring" then return lifecycle.refreshRestore(state, value, now, intervals) end
  if value.stage == "committing" then return setup.commitNow(state) end
  if value.stage ~= "scanning" or not value.session then return false end
  if value.nextAt and now < value.nextAt then return false end
  intervals = intervals or {}
  local options = {
    scanLimit = tonumber(intervals.ae2WorkflowSetupScanLimit) or setup.defaultScanLimit,
    maxCandidates = tonumber(intervals.ae2WorkflowSetupMaxCandidates) or setup.defaultMaxCandidates
  }
  value.scanLimit, value.chunkDelay = options.scanLimit, tonumber(intervals.ae2WorkflowSetupChunkDelay) or setup.defaultChunkDelay
  local ok, report, reason = pcall(workflows.stepOnboarding, value.session, options)
  if not ok then reason, report = report, nil end
  if type(report) ~= "table" then
    disposeSession(value)
    value.stage = "confirm"
    value.error = tostring(reason or "recipe discovery failed")
    return true
  end
  value.report, value.session = report, report.session or value.session
  value.scanned = tonumber(report.scanned) or tonumber(value.session.scanned) or value.scanned or 0
  value.complete = report.complete == true or value.session.complete == true
  value.error = report.error
  clampSelection(value)
  local progressState = type(report.progress) == "table" and report.progress.state or nil
  if value.error and progressState == "error" then
    disposeSession(value)
    value.stage = "confirm"
    value.nextAt = nil
    return true
  end
  if value.complete or report.capped == true then
    value.stage = "results"
    value.nextAt = nil
  else
    value.nextAt = now + value.chunkDelay
  end
  return true
end

function setup.moveSelection(state, delta)
  local value = wizard(state)
  if not value or value.stage ~= "results" then return false end
  local count = #candidates(value)
  if count == 0 then return true end
  value.selected, value.error = ((tonumber(value.selected) or 1) - 1 + delta) % count + 1, nil
  return true
end

function setup.selectedCandidateError(state)
  local value = wizard(state)
  local row = value and candidates(value)[tonumber(value.selected) or 1]
  if not row then return "No exact recipe candidate is selected. Refine the query and scan again." end
  return binding.onboardingError(row)
end

function setup.commit(state)
  local value = wizard(state)
  if not value or value.stage ~= "results" then return false end
  clampSelection(value)
  local reason = setup.selectedCandidateError(state)
  if reason then value.error = reason; return true end
  value.stage, value.error, value.nextAt = "committing", nil, 0
  return true
end

function setup.commitNow(state)
  local value = wizard(state)
  if not value or value.stage ~= "committing" then return false end
  local ok, saved, reason, receipt = pcall(workflows.commitOnboarding, value.session, value.selected)
  if not ok then reason, saved, receipt = saved, false, nil end
  if saved ~= true then
    value.stage = "results"
    value.error = tostring(reason or "recipe setup was not saved")
    return true
  end
  value.receipt, value.saved = receipt, true
  disposeSession(value)
  local reloaded, reloadReason = lifecycle.reloadCatalog(state, receipt)
  if not reloaded then
    state.nextAe2WorkflowRefresh = 0
    return lifecycle.beginRestore(state, value, { view = "ae2_workflows", message = reloadReason })
  end
  local action = receipt and receipt.action or value.mode == "bind" and "bound" or "added"
  return lifecycle.beginRestore(state, value, {
    view = "ae2_workflow",
    message = "Recipe " .. tostring(action) .. " disarmed; review Flow, then arm deliberately."
  })
end

function setup.editQuery(state)
  local value = wizard(state)
  if not value then return false end
  value.stage, value.error = "input", nil
  return true
end

function setup.rescan(state)
  local value = wizard(state)
  if not value then return false end
  disposeSession(value)
  value.stage, value.error, value.nextAt = "confirm", nil, nil
  return true
end

function setup.retryLifecycle(state)
  local value = wizard(state)
  return value and lifecycle.retry(value) or false
end

function setup.leaveDaemonOff(state)
  local value = wizard(state)
  if not value then return false end
  disposeSession(value)
  return lifecycle.leaveOff(state, value)
end

function setup.handleClipboard(state, text) return setupInput.handleClipboard(setup, state, text) end
function setup.handleKey(state, char, code, keyboard) return setupInput.handleKey(setup, state, char, code, keyboard) end
function setup.handleTouch(state, x, y) return setupInput.handleTouch(setup, state, x, y) end

function setup.candidates(state)
  return candidates(wizard(state))
end

return setup
-- Automatic ownership interlock for Add/Bind Recipe.  The backend receipt is
-- generation-scoped, so this UI never treats a cosmetic desired-OFF status as
-- proof that an older Maintainer worker has finished.
local workflows = require("oc.ae2.workflows")

local lifecycle = {}
lifecycle.defaultControlInterval = 1
lifecycle.defaultStopTimeout = 120

local function report(value, status)
  value.lifecycle = type(status) == "table" and status or value.lifecycle or {}
  return value.lifecycle
end

local function finish(state, value)
  local completion = value.completion or {}
  if completion.message then state.ae2WorkflowMessage = completion.message end
  if completion.view then state.view = completion.view end
  state.ae2WorkflowSetup = nil
  return true
end

local function controlDelay(intervals)
  return tonumber(intervals and intervals.ae2WorkflowSetupControlInterval)
    or lifecycle.defaultControlInterval
end

function lifecycle.reloadCatalog(state, receipt)
  local ok, catalog = pcall(workflows.catalog, state.ae2CraftCache, { query = state.ae2WorkflowQuery })
  if not ok or type(catalog) ~= "table" then
    return false, "recipe saved, but Managed Targets reload failed: " .. tostring(catalog)
  end
  state.ae2Workflow, state.ae2CraftCache = catalog, catalog.cache
  local wanted = receipt and tonumber(receipt.index)
  if wanted then
    for index, entry in ipairs(catalog.entries or {}) do
      if tonumber(entry.configIndex) == wanted then
        state.ae2WorkflowSelected = index
        local perPage = math.max(1, state.ae2WorkflowPerPage or 16)
        state.ae2WorkflowPage = math.max(1, math.ceil(index / perPage))
        return true
      end
    end
  end
  local count = #(catalog.entries or {})
  state.ae2WorkflowSelected = math.max(1, math.min(count, state.ae2WorkflowSelected or 1))
  return true
end

function lifecycle.prepare(value)
  value.error, value.nextAt = nil, 0
  local called, ticket, reason, status = pcall(workflows.prepareOnboarding)
  if not called then reason, ticket, status = ticket, nil, nil end
  if type(ticket) ~= "table" then
    value.authority = nil
    value.stage = "stop_failed"
    value.error = tostring(reason or "Maintainer shutdown transaction could not start")
    report(value, status)
    return false
  end
  value.authority = ticket
  value.restoreRequired = ticket.restoreRequired == true
  local current = report(value, status)
  if current.ready == true or current.quiescent == true then
    value.stage, value.nextAt = "input", nil
  else
    value.stage = "stopping"
  end
  return true
end

function lifecycle.beginRestore(state, value, completion)
  value.completion = completion or value.completion or {
    view = value.returnView,
    message = "Recipe setup canceled."
  }
  value.cancelPending = nil
  value.error = nil
  if value.restoreRequired ~= true then return finish(state, value) end
  value.stage, value.nextAt = "restoring", 0
  return true
end

function lifecycle.cancel(state, value)
  value.completion = value.completion or {
    view = value.returnView,
    message = value.restoreRequired == true
      and "Recipe setup canceled; Maintainer restored to its prior ON state."
      or "Recipe setup canceled; Maintainer remains OFF as it was before setup."
  }
  if value.stage == "stopping" then
    value.cancelPending = true
    value.error = nil
    return true
  end
  if value.stage == "stop_failed" and not value.authority then
    value.completion.message = "Recipe setup canceled; Maintainer state was not changed."
    return finish(state, value)
  end
  return lifecycle.beginRestore(state, value, value.completion)
end

function lifecycle.refreshPreparation(state, value, now, intervals)
  if value.nextAt and now < value.nextAt then return false end
  local called, ready, reason, status = pcall(workflows.pollOnboardingPreparation, value.authority)
  if not called then reason, ready, status = ready, false, nil end
  local current = report(value, status)
  if ready == true or current.ready == true or current.quiescent == true then
    value.nextAt = nil
    if value.cancelPending then return lifecycle.beginRestore(state, value, value.completion) end
    value.stage, value.error = "input", nil
    return true
  end
  if reason then
    value.stage, value.nextAt = "stop_failed", nil
    value.error = tostring(reason)
    return true
  end
  local preparedAt = tonumber(value.authority and value.authority.preparedAt)
  local timeout = tonumber(intervals and intervals.ae2WorkflowSetupStopTimeout) or lifecycle.defaultStopTimeout
  if preparedAt and now - preparedAt >= timeout then
    value.stage, value.nextAt = "stop_failed", nil
    value.error = "Worker exit proof timed out after " .. tostring(timeout)
      .. "s. Maintainer remains OFF; no recipe scan was started."
    return true
  end
  value.nextAt = now + controlDelay(intervals)
  return true
end

function lifecycle.refreshRestore(state, value, now, intervals)
  if value.nextAt and now < value.nextAt then return false end
  local called, restored, reason, status = pcall(workflows.restoreOnboarding, value.authority)
  if not called then reason, restored, status = restored, false, nil end
  report(value, status)
  if restored == true then return finish(state, value) end
  if reason then
    value.stage, value.nextAt = "restore_failed", nil
    value.error = tostring(reason)
    return true
  end
  value.nextAt = now + controlDelay(intervals)
  return true
end

function lifecycle.retry(value)
  if value.stage == "stop_failed" then
    value.authority, value.restoreRequired = nil, nil
    return lifecycle.prepare(value)
  elseif value.stage == "restore_failed" then
    value.stage, value.error, value.nextAt = "restoring", nil, 0
    return true
  end
  return false
end

function lifecycle.leaveOff(state, value)
  if value.stage == "stop_failed" and not value.authority then
    state.ae2WorkflowMessage = "Recipe setup canceled; Maintainer state was not changed."
  elseif value.stage == "restore_failed" then
    state.ae2WorkflowMessage = "Recipe setup closed; Maintainer remains OFF. Restart it from AE2 > Daemon when ready."
  else
    state.ae2WorkflowMessage = "Recipe setup closed without discovery; inspect AE2 > Daemon before continuing."
  end
  state.view = value.returnView or state.view
  state.ae2WorkflowSetup = nil
  return true
end

return lifecycle
local input = {}

local function wizard(state)
  return state and state.ae2WorkflowSetup
end

local function hitAction(state, group, x, y)
  local groups = state and state.dashboardActionBars
  for _, hit in ipairs(groups and groups[group] or {}) do
    if y == hit.y and x >= hit.x and x < hit.x + hit.w then return hit.action end
  end
  return nil
end

local function isCtrlC(char, code, keyboard)
  if char == 3 then return true end
  local keys = keyboard and keyboard.keys or {}
  local cCode = keys.c or 46
  if code ~= cCode or type(keyboard and keyboard.isControlDown) ~= "function" then return false end
  local ok, held = pcall(keyboard.isControlDown)
  return ok and held == true
end

function input.handleClipboard(api, state, text)
  local value = wizard(state)
  if not value or value.stage ~= "input" then return false end
  value.query = (tostring(value.query or "") .. tostring(text or "")):gsub("[%c]", ""):sub(1, api.maxQuery)
  value.error = nil
  return true
end

function input.handleKey(api, state, char, code, keyboard)
  local value = wizard(state)
  if not value then return false end
  keyboard = keyboard or require("keyboard")
  local keys = keyboard.keys or {}
  local cancel = isCtrlC(char, code, keyboard)
  if value.stage == "stop_failed" or value.stage == "restore_failed" then
    if char == 19 then return api.retryLifecycle(state) end
    if cancel then return api.leaveDaemonOff(state) end
    return true
  elseif value.stage == "restoring" or value.stage == "committing" then
    return true
  elseif value.stage == "stopping" then
    if cancel then return api.cancel(state) end
    return true
  end
  if cancel then return api.cancel(state) end
  if value.stage == "input" then
    if char == 13 then return api.review(state) end
    if char == 8 or char == 127 then
      value.query = tostring(value.query or ""):sub(1, -2)
      value.error = nil
      return true
    end
    if char and char >= 32 and char <= 126 then
      value.query = (tostring(value.query or "") .. string.char(char)):sub(1, api.maxQuery)
      value.error = nil
      return true
    end
    return true
  elseif value.stage == "confirm" then
    if char == 19 then return api.start(state) end
    if char == 13 or code == keys.left then return api.editQuery(state) end
    return true
  elseif value.stage == "scanning" then
    return true
  elseif value.stage == "results" then
    if code == keys.up or code == keys.left then return api.moveSelection(state, -1) end
    if code == keys.down or code == keys.right then return api.moveSelection(state, 1) end
    if char == 19 then return api.commit(state) end
    if char == string.byte("R") then return api.rescan(state) end
    return true
  end
  return true
end

function input.handleTouch(api, state, x, y)
  local value = wizard(state)
  if not value then return false end
  if value.stage == "results" then
    for _, hit in ipairs(value.candidateHits or {}) do
      if y == hit.y and x >= hit.x and x < hit.x + hit.w then
        value.selected, value.error = hit.index, nil
        return true
      end
    end
  end
  local action = hitAction(state, "workflow_setup", x, y)
  if action == "cancel" then return api.cancel(state) end
  if action == "review" then return api.review(state) end
  if action == "edit" then return api.editQuery(state) end
  if action == "start" then return api.start(state) end
  if action == "previous" then return api.moveSelection(state, -1) end
  if action == "next" then return api.moveSelection(state, 1) end
  if action == "commit" then return api.commit(state) end
  if action == "rescan" then return api.rescan(state) end
  if action == "retry_lifecycle" then return api.retryLifecycle(state) end
  if action == "leave_off" then return api.leaveDaemonOff(state) end
  return false
end

return input
local component = require("component")
local term = require("term")
local config = require("oc.core.config")

local screen = {}
screen.configPath = "/etc/oc/dashboard-screen.cfg"

local function activeScreen()
  local ok, address = pcall(function() return term.screen() end)
  if ok and address then return address end
  for address in component.list("screen") do return address end
  return nil
end

local function safeProxy(address)
  local ok, proxy = pcall(component.proxy, address)
  if ok then return proxy end
  return nil
end

local function loadConfig()
  local loaded = config.load(screen.configPath, {})
  if type(loaded) == "table" then return loaded end
  return {}
end

local function resolveAddress(kind, value)
  local wanted = tostring(value or "")
  if wanted == "" then return nil end
  local found = nil
  for address in component.list(kind) do
    if address == wanted or address:sub(1, #wanted) == wanted then
      if found then return nil, "ambiguous " .. kind .. " prefix: " .. wanted end
      found = address
    end
  end
  return found
end

local function safeBind(gpu, screenAddress)
  if not (gpu and screenAddress) then return false end
  local ok, result = pcall(function() return gpu.bind(screenAddress, false) end)
  return ok and result ~= false
end

local function safeDepth(gpu)
  local ok, depth = pcall(function() return gpu.maxDepth() end)
  return ok and tonumber(depth) or 0
end

local function safeResolution(gpu)
  local ok, width, height = pcall(function() return gpu.maxResolution() end)
  if ok then return tonumber(width) or 0, tonumber(height) or 0 end
  return 0, 0
end

local function gpuScore(gpu)
  local width, height = safeResolution(gpu)
  local depth = safeDepth(gpu)
  return (width * height * 10) + depth, width, height, depth
end

local function configuredScreen(config)
  return resolveAddress("screen", config.screen or config.preferredScreen) or activeScreen()
end

local function configuredGpu(config, screenAddress)
  local address, reason = resolveAddress("gpu", config.gpu or config.preferredGpu)
  if not address then return nil, reason end
  local gpu = safeProxy(address)
  if not gpu then return nil, "configured gpu unavailable" end
  if screenAddress and not safeBind(gpu, screenAddress) then return nil, "configured gpu bind failed" end
  local score, width, height, depth = gpuScore(gpu)
  if score <= 0 then return nil, "configured gpu unusable" end
  return { address = address, gpu = gpu, score = score, width = width, height = height, depth = depth, source = "config" }
end

local function bestGpu(screenAddress)
  local best = nil
  for address in component.list("gpu") do
    local gpu = safeProxy(address)
    if gpu then
      safeBind(gpu, screenAddress)
      local score, width, height, depth = gpuScore(gpu)
      if score > 0 and (not best or score > best.score or (score == best.score and address < best.address)) then
        best = { address = address, gpu = gpu, score = score, width = width, height = height, depth = depth, source = "heuristic" }
      end
    end
  end
  return best
end

function screen.apply()
  local screenConfig = loadConfig()
  local screenAddress = configuredScreen(screenConfig)
  local best, configErr = configuredGpu(screenConfig, screenAddress)
  if not best then best = bestGpu(screenAddress) end
  if not best then return false, "no gpu" end
  if screenAddress then pcall(function() return best.gpu.bind(screenAddress, false) end) end
  if screenAddress then pcall(function() component.setPrimary("screen", screenAddress) end) end
  pcall(function() component.setPrimary("gpu", best.address) end)
  pcall(function() term.bind(best.gpu) end)
  local gpu = best.gpu
  local okMax, maxW, maxH = pcall(function() return gpu.maxResolution() end)
  if not okMax then return false, tostring(maxW) end
  local okDepth, maxDepth = pcall(function() return gpu.maxDepth() end)
  if okDepth then pcall(function() gpu.setDepth(maxDepth) end) end
  local okSet, err = pcall(function() return gpu.setResolution(maxW, maxH) end)
  if not okSet then return false, tostring(err) end
  local okRes, width, height = pcall(function() return gpu.getResolution() end)
  return true, nil, {
    gpu = best.address,
    screen = screenAddress,
    width = okRes and width or maxW,
    height = okRes and height or maxH,
    maxWidth = maxW,
    maxHeight = maxH,
    depth = maxDepth,
    source = best.source,
    configPath = screen.configPath,
    configError = configErr
  }
end

return screen
local alerts = require("oc.dashboard.alerts")
local style = require("oc.dashboard.style")
local initiativeStore = require("oc.dashboard.initiatives")
local maintainerPage = require("oc.dashboard.maintainer_page")
local daemonPage = require("oc.dashboard.maintainer_daemon_page")
local numbers = require("oc.dashboard.number_format")
local opsPage = require("oc.dashboard.ops_page")
local ae2 = require("oc.dashboard.pages_ae2")
local subtabs = require("oc.dashboard.subtabs")
local workflowPage = require("oc.dashboard.workflow_page")
local pages = {}
local colors = style.colors

local function pct(value)
  if type(value) ~= "number" then return "n/a" end
  return string.format("%.1f%%", value * 100)
end

local function euPair(a, b)
  return numbers.quantity(a) .. " / " .. numbers.quantity(b) .. " EU"
end

local function euRatePair(a, b)
  return numbers.quantity(a) .. " in / " .. numbers.quantity(b) .. " out EU/t"
end

local function readingEu(reading)
  return euPair(reading.effectiveStored or reading.stored, reading.effectiveMax or reading.max)
    .. " " .. pct(reading.ratio)
end

local function usageText(reading)
  return euRatePair(reading.effectiveAvgIn or reading.avgIn, reading.effectiveAvgOut or reading.avgOut)
end

local function readingTitle(reading)
  return reading.sensorTitle or reading.name or reading.type or "GT"
end

local function initiativeTitle(state)
  return "DOMAIN INITIATIVES "
    .. numbers.countRatio(initiativeStore.count(state.initiatives), initiativeStore.maxInitiatives)
end

function pages.drawAe2(panel, snapshot) return ae2.draw(panel, snapshot) end
function pages.drawAe2Counts(panel, state) return ae2.drawCounts(panel, state) end
function pages.drawAe2Cpus(panel, snapshot) return ae2.drawCpus(panel, snapshot) end

function pages.drawPower(panel, state)
  local snapshot = state.power or {}
  local editor = state.powerTitleEditor
  local storageName = tostring((editor and editor.value) or state.powerStorageName or "Click Me To Name Storage")
  local shownStorage = editor and ("[" .. storageName .. "_]") or storageName
  style.box(panel.x, panel.y, panel.w, panel.h, "BATTERY 5000")
  subtabs.draw(style, panel, "power")
  style.text(panel.x + 2, panel.y + 2, "Battery 5000", colors.good, colors.panel, panel.w - 4)
  state.powerTitleX, state.powerTitleY, state.powerTitleW = panel.x + 2, panel.y + 3, #shownStorage
  style.text(panel.x + 2, panel.y + 3, shownStorage, colors.text, colors.panel, panel.w - 4)
  if not snapshot.available then
    style.text(panel.x + 2, panel.y + 4, "Telemetry unavailable", colors.warn, colors.panel, panel.w - 4)
    return
  end
  local first = snapshot.readings[1] or {}
  style.text(panel.x + 2, panel.y + 4, readingEu(first), style.statusColor(first.status), colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 5, usageText(first), colors.text, colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 6, tostring(first.status or "ready") .. " | " .. readingTitle(first), style.statusColor(first.status), colors.panel, panel.w - 4)
end
local function initiativeValue(list, index)
  local value = list and list[index] or ""
  if value == "" then return "open slot" end
  return value
end

function pages.drawInitiatives(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, initiativeTitle(state))
  style.text(panel.x + 2, panel.y + 2, "[T] edit; open slot means just start typing your initiative", colors.muted, colors.panel, panel.w - 4)
  for i = 1, initiativeStore.maxInitiatives do
    local y = panel.y + 3 + i
    if y >= panel.y + panel.h - 1 then break end
    local value = state.initiatives and state.initiatives[i] or ""
    local color = value ~= "" and colors.good or colors.muted
    style.text(panel.x + 2, y, tostring(i) .. ". " .. initiativeValue(state.initiatives, i), color, colors.panel, panel.w - 4)
  end
end

function pages.drawInitiativePreview(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, initiativeTitle(state))
  local page = state.initiativePage or 1
  local startIndex = ((page - 1) * initiativeStore.previewCount) + 1
  for offset = 0, math.min(initiativeStore.previewCount, math.max(1, panel.h - 3)) - 1 do
    local index = startIndex + offset
    local y = panel.y + 1 + offset
    if y >= panel.y + panel.h - 1 then break end
    local value = state.initiatives and state.initiatives[index] or ""
    local color = value ~= "" and colors.good or colors.muted
    style.text(panel.x + 2, y, tostring(index) .. ". " .. initiativeValue(state.initiatives, index), color, colors.panel, panel.w - 4)
  end
  if panel.h > 5 then
    style.text(panel.x + 2, panel.y + panel.h - 2, "H:Domain  T:Edit", colors.muted, colors.panel, panel.w - 4)
  end
end

function pages.drawInitiativeEditor(state)
  local panel = { x = 5, y = 5, w = state.W - 8, h = math.min(30, state.H - 7) }
  local editor = state.initiativeEditor
  if not editor then return end
  style.box(panel.x, panel.y, panel.w, panel.h, "DOMAIN INITIATIVE EDITOR")
  style.text(panel.x + 2, panel.y + 2, "Click a line; open slot means just start typing your initiative.", colors.text, colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 3, "Ctrl+S save  Ctrl+X cut  Ctrl+C copy  Ctrl+V paste  60 chars max", colors.muted, colors.panel, panel.w - 4)
  for i = 1, initiativeStore.maxInitiatives do
    local y = 8 + i
    if y >= panel.y + panel.h - 1 then break end
    local active = editor.selected == i
    local prefix = active and "> " or "  "
    local fg = active and colors.bg or colors.text
    local bg = active and colors.accent or colors.panel
    style.text(panel.x + 2, y, prefix .. tostring(i) .. ". " .. initiativeValue(editor.draft, i), fg, bg, panel.w - 4)
  end
end

function pages.canDraw(view)
  return view == "ae2" or view == "ae2_counts" or view == "ae2_cpus"
    or view == "ae2_workflows" or view == "ae2_workflow" or view == "ae2_maintain" or view == "ae2_daemon"
    or view == "ae2_logs"
    or view == "power" or view == "power_alarms" or view == "diagnostics" or view == "ops_health"
    or view == "ops_links" or view == "ops_perf"
end

function pages.draw(view, panel, state)
  if view == "ae2_counts" then return pages.drawAe2Counts(panel, state) end
  if view == "ae2_cpus" then return pages.drawAe2Cpus(panel, state.ae2) end
  if view == "ae2_workflows" then return workflowPage.drawList(panel, state) end
  if view == "ae2_workflow" then return workflowPage.drawDetail(panel, state) end
  if view == "ae2_maintain" then return maintainerPage.draw(panel, state) end
  if view == "ae2_daemon" then return daemonPage.draw(panel, state) end
  if view == "ae2_logs" then return maintainerPage.drawLogs(panel, state) end
  if view == "power" then return pages.drawPower(panel, state) end
  if view == "power_alarms" then return alerts.draw(panel, state) end
  if view == "diagnostics" or view == "ops_health" or view == "ops_links" or view == "ops_perf" then return opsPage.draw(view, panel, state) end
  return pages.drawAe2(panel, state.ae2)
end

return pages
local actionBar = require("oc.dashboard.action_bar")
local numbers = require("oc.dashboard.number_format")
local operatorStatus = require("oc.dashboard.operator_status")
local sections = require("oc.dashboard.ae2_page_sections")
local stock = require("oc.dashboard.stock")
local style = require("oc.dashboard.style")
local subtabs = require("oc.dashboard.subtabs")

local ae2 = {}
local colors = style.colors
local stockColumnSpec = { { label = "Stock", width = 14 }, { label = "Kind", width = 6 } }

local function line(panel, y, label, value, color)
  local text = type(value) == "number" and numbers.quantity(value) or tostring(value or "n/a")
  style.textBlock(panel.x + 2, y, label .. ": " .. text, color or colors.text, colors.panel, panel.w - 4, 1)
end

local function readyCpus(snapshot)
  local cpus = (snapshot.cpus and snapshot.cpus.cpus) or {}
  local ready = 0
  for _, cpu in ipairs(cpus) do if not cpu.busy then ready = ready + 1 end end
  return ready, snapshot.cpus and snapshot.cpus.count or 0
end

local function header(panel, snapshot, title, view)
  style.box(panel.x, panel.y, panel.w, panel.h, title)
  subtabs.draw(style, panel, view)
  if not snapshot.available then
    local stockState = view == "ae2_counts" and snapshot.stock
    if stockState and #(stockState.entries or {}) > 0 then
      sections.band(panel, panel.y + 2, "Exact Target Stock", "offline | retained values")
      return true
    end
    line(panel, panel.y + 2, "AE2", "Unavailable", colors.warn)
    return false
  end
  local label = view == "ae2_counts" and "Exact Target Stock" or view == "ae2_cpus" and "CPU Jobs" or "AE2 Network"
  sections.band(panel, panel.y + 2, label, "online")
  return true
end

local function stockAmountText(item)
  if item and item.missing == true then
    if item.stockState == "blocked" then return "BIND" end
    if item.stockState == "warming" then return "WARM" end
    if item.stockState == "error" then return "ERR" end
    return "n/a"
  end
  local value = item and (item.size ~= nil and item.size or item.amount)
  if item and (item.isFluid == true or item.kind == "fluid") then
    return numbers.quantity(value) .. " mB"
  end
  return numbers.quantity(value) .. " x"
end

local function kind(item)
  return item and (item.isFluid == true or item.kind == "fluid") and "fluid" or "item"
end

local function drawStockRow(x, y, width, item)
  local leftWidth, rightWidth = sections.split(width, stockColumnSpec, 18)
  local color = item.stockState == "blocked" or item.stockState == "error" or item.stockState == "stale"
    and colors.warn or item.stockState == "warming" and colors.accent or colors.text
  if rightWidth <= 0 then
    style.text(x, y, stockAmountText(item) .. " " .. tostring(item.label), color, colors.panel, width)
    return
  end
  style.textBlock(x, y, tostring(item.label), color, colors.panel, leftWidth, 1)
  sections.values(x + leftWidth + 1, y, { stockAmountText(item), kind(item) }, stockColumnSpec, color)
end

local function drawCpuHeader(x, y, width, outputW, qtyW, showQty)
  style.fill(x, y, width, 1, colors.border)
  style.text(x, y, "CPU#", colors.bg, colors.accent, 5)
  style.text(x + 6, y, "Status", colors.text, colors.border, 9)
  style.text(x + 16, y, "Output", colors.text, colors.border, outputW)
  if showQty then style.text(x + width - qtyW, y, "Qty", colors.text, colors.border, qtyW) end
end

local function requestStrip(request)
  if type(request) ~= "table" then return nil end
  local amount = numbers.quantity(request.amount) .. (request.isFluid and " mB " or "x ")
  local target = amount .. tostring(request.label or "target")
  local state, phase = request.requestState, request.requestPhase
  if state == "running" and phase == "computing" then
    return "PLANNING " .. target .. " (not on a CPU yet)", colors.accent
  elseif state == "running" and phase == "submitted" then
    return "ACCEPTED " .. target .. " (CPU witness pending)", colors.good
  elseif state == "done" then return "COMPLETED " .. target, colors.good
  elseif state == "accepted" then return "UNCONFIRMED " .. target, colors.warn
  elseif state == "blocked" then return "BLOCKED " .. target .. ": " .. tostring(request.requestStatusReason or "blocked"), colors.warn
  elseif state == "canceled" then return "CANCELED " .. target, colors.warn
  elseif state == "failed" then return "FAILED " .. target .. ": " .. tostring(request.requestStatusReason or "unknown"), colors.bad end
  return tostring(state or "UNKNOWN") .. " " .. target, colors.muted
end

function ae2.draw(panel, snapshot)
  if not header(panel, snapshot, "AE2", "ae2") then return end
  local ready, total = readyCpus(snapshot)
  local counts = snapshot.counts or {}
  line(panel, panel.y + 3, "CPUs", numbers.countRatio(ready, total) .. " Ready")
  line(panel, panel.y + 4, "Items", counts.items)
  line(panel, panel.y + 5, "Fluids", counts.fluids)
  line(panel, panel.y + 6, "Craftables", counts.craftables)
  line(panel, panel.y + 7, "Status", "ready for orders", colors.good)
end

local function filterLabel(value)
  local query = tostring(value or "")
  if query == "" then return "Filter" end
  if #query > 18 then query = query:sub(1, 15) .. "..." end
  return "Filter: " .. query
end

function ae2.drawCounts(panel, state)
  if not header(panel, state.ae2, "TARGET STOCK", "ae2_counts") then return end
  local stockState = state.ae2.stock or {}
  local rows = math.max(1, panel.h - 6)
  state.stockPerPage = rows * 2
  local entries, matched, pages = stock.pageEntries(state, state.stockPerPage)
  local retained = tonumber(stockState.retainedTotal) or tonumber(stockState.total) or 0
  local phase = stockState.complete == false and "WARMING" or (tonumber(stockState.errorTotal) or 0) > 0 and "ATTENTION" or "READY"
  sections.band(panel, panel.y + 2, "Exact Stock " .. phase, "Targets " .. numbers.countRatio(matched, stockState.total or matched)
    .. " | read " .. numbers.countRatio(retained, stockState.total or retained)
    .. " | bind " .. numbers.integer(stockState.blockedTotal or 0)
    .. " | err " .. numbers.integer(stockState.errorTotal or 0)
    .. " | Page " .. numbers.countRatio(state.stockPage, pages))
  state.stockButtonY = panel.y + 3
  local listY = actionBar.draw(state, "stock", panel.x + 2, state.stockButtonY, panel.w - 4, {
    { key = "<", label = "Prev", action = "prev" },
    { label = filterLabel(state.stockQuery), action = "search", good = state.stockSearchActive },
    { key = ">", label = "Next", action = "next" }
  })
  local colWidth = math.floor((panel.w - 5) / 2)
  sections.headerAt(panel.x + 2, listY, colWidth - 1, stockColumnSpec, 18, "Target")
  sections.headerAt(panel.x + 2 + colWidth, listY, colWidth - 1, stockColumnSpec, 18, "Target")
  listY = listY + 1
  for i, item in ipairs(entries) do
    local col = math.floor((i - 1) / rows)
    local row = (i - 1) % rows
    local x = panel.x + 2 + (col * colWidth)
    local y = listY + row
    if y < panel.y + panel.h - 1 and x < panel.x + panel.w - 4 then drawStockRow(x, y, colWidth - 1, item) end
  end
  if #entries == 0 then
    style.textBlock(panel.x + 2, listY, stockState.error or "warming stock cache", colors.warn, colors.panel, panel.w - 4, 2)
  elseif panel.h >= 12 then
    local notice = stockState.notice or (stockState.complete == false
      and "Read-only exact warming is active; Ctrl+R restarts one bounded pass."
      or "Read-only exact target values; broad grid scans and craft requests stay disabled.")
    style.textBlock(panel.x + 2, panel.y + panel.h - 2, notice, colors.muted, colors.panel, panel.w - 4, 1)
  end
end

function ae2.drawCpus(panel, snapshot)
  if not header(panel, snapshot, "JOBS", "ae2_cpus") then return end
  local cpuSummary = snapshot.cpus or {}
  local cpus = cpuSummary.cpus or {}
  line(panel, panel.y + 3, "Jobs", numbers.integer(cpuSummary.count or 0) .. " crafting CPUs")
  local requestText, requestColor = requestStrip(snapshot.manualRequest)
  if requestText then line(panel, panel.y + 4, "Request", requestText, requestColor) end
  local startY = panel.y + 5
  local stacks = panel.w >= 72 and 2 or 1
  local gap = stacks == 2 and 2 or 0
  local stackW = math.max(24, math.floor((panel.w - 4 - gap) / stacks))
  local qtyW = 8
  local showQty = stackW >= 34
  local outputW = showQty and math.max(1, stackW - 16 - qtyW - 1) or stackW - 16
  local maxRows = math.max(1, panel.h - 7)
  local rows = maxRows
  for stack = 1, stacks do
    local x = panel.x + 2 + ((stack - 1) * (stackW + gap))
    drawCpuHeader(x, startY, stackW, outputW, qtyW, showQty)
    for row = 1, rows do
      local i = ((stack - 1) * rows) + row
      local cpu = cpus[i]
      local y = startY + row
      if cpu and y < panel.y + panel.h - 1 and x < panel.x + panel.w - 4 then
        local id, state, output, qty = operatorStatus.cpuJobColumns(cpu, i)
        local active = cpu.busy or cpu.finalOutputStack or cpu.finalOutputLabels or cpu.finalOutputError
        local color = active and colors.warn or colors.good
        style.text(x, y, id, color, colors.panel, 5)
        style.text(x + 6, y, state, color, colors.panel, 9)
        style.text(x + 16, y, output, color, colors.panel, outputW)
        if showQty then style.text(x + stackW - qtyW, y, qty or "", color, colors.panel, qtyW) end
      end
    end
  end
end

return ae2
local component = require("component")
local term = require("term")
local canvas = require("oc.dashboard.canvas")

local style = {}

local activeCanvas = nil
local activeGpu = nil
local canvasGpu = nil
local canvasScreen = nil

style.colors = {
  bg = 0x0b0f14,
  panel = 0x18202a,
  border = 0x30363d,
  text = 0xe6edf3,
  muted = 0x8b949e,
  accent = 0x58a6ff,
  good = 0x3fb950,
  warn = 0xd29922,
  bad = 0xf85149
}

local function clamp(value, low, high)
  return math.max(low, math.min(high, value))
end

local function currentGpu()
  return activeGpu or component.gpu
end

function style.beginFrame(scene)
  local gpu = component.gpu
  local screen = nil
  local ok, address = pcall(gpu.getScreen)
  if ok then screen = address end
  -- A GPU proxy survives rebinding. Treat a changed screen as a new canvas so
  -- its first frame is complete instead of trusting pixels painted on the old
  -- screen.
  if canvasGpu ~= gpu or canvasScreen ~= screen then
    activeCanvas = canvas.new(gpu)
    canvasGpu = gpu
    canvasScreen = screen
  end
  activeCanvas:begin(scene)
  activeGpu = activeCanvas.proxy
end

function style.endFrame()
  local painter = activeCanvas
  activeGpu = nil
  if painter then painter:flush() end
end

function style.set(fg, bg)
  local gpu = currentGpu()
  if fg then gpu.setForeground(fg) end
  if bg then gpu.setBackground(bg) end
end

function style.clear()
  local gpu = component.gpu
  gpu.setForeground(style.colors.text)
  gpu.setBackground(style.colors.bg)
  term.clear()
  if activeCanvas then activeCanvas:invalidate() end
end

function style.fill(x, y, w, h, bg)
  if w <= 0 or h <= 0 then return end
  local gpu = currentGpu()
  gpu.setBackground(bg)
  gpu.fill(x, y, w, h, " ")
end

function style.text(x, y, value, fg, bg, maxWidth)
  local textValue = tostring(value or "")
  local width = tonumber(maxWidth)
  if width and width > 0 and #textValue > width then
    if width <= 3 then
      textValue = textValue:sub(1, width)
    else
      textValue = textValue:sub(1, width - 3) .. "..."
    end
  end
  if width and width > 0 and #textValue < width then
    textValue = textValue .. string.rep(" ", width - #textValue)
  end
  style.set(fg or style.colors.text, bg or style.colors.bg)
  local gpu = currentGpu()
  gpu.set(x, y, textValue)
end

function style.wrap(value, width)
  width = math.floor(tonumber(width) or 0)
  if width <= 0 then return { "" } end
  local lines = {}
  local function add(line) lines[#lines + 1] = line end
  for raw in (tostring(value or "") .. "\n"):gmatch("([^\n]*)\n") do
    local line = ""
    for word in raw:gmatch("%S+") do
      local remaining = word
      while #remaining > width do
        if line ~= "" then add(line); line = "" end
        add(remaining:sub(1, width))
        remaining = remaining:sub(width + 1)
      end
      if line == "" then
        line = remaining
      elseif #line + #remaining + 1 <= width then
        line = line .. " " .. remaining
      else
        add(line)
        line = remaining
      end
    end
    if line ~= "" or raw == "" then add(line) end
  end
  if #lines == 0 then add("") end
  return lines
end

function style.textBlock(x, y, value, fg, bg, width, maxLines)
  width = math.floor(tonumber(width) or 0)
  if width <= 0 then return y, 0, 0 end
  local lines = style.wrap(value, width)
  local limit = math.floor(tonumber(maxLines) or #lines)
  limit = math.max(0, math.min(#lines, limit))
  for i = 1, limit do
    local textValue = lines[i]
    if i == limit and limit < #lines then
      if width <= 3 then
        textValue = string.rep(".", width)
      else
        textValue = textValue:sub(1, math.max(0, width - 3)) .. "..."
      end
    end
    style.text(x, y + i - 1, textValue, fg, bg, width)
  end
  return y + limit, limit, #lines
end

function style.box(x, y, w, h, title)
  if w < 4 or h < 3 then return end
  local gpu = currentGpu()
  style.fill(x, y, w, h, style.colors.panel)
  style.set(style.colors.accent, style.colors.panel)
  gpu.set(x, y, "+" .. string.rep("-", w - 2) .. "+")
  for row = y + 1, y + h - 2 do
    gpu.set(x, row, "|")
    gpu.set(x + w - 1, row, "|")
  end
  gpu.set(x, y + h - 1, "+" .. string.rep("-", w - 2) .. "+")
  if title then
    style.text(x + 2, y, " " .. title .. " ", style.colors.accent, style.colors.panel, w - 4)
  end
end

function style.bar(x, y, w, pct, fg)
  pct = clamp(pct or 0, 0, 1)
  local filled = math.floor(w * pct + 0.5)
  style.fill(x, y, filled, 1, fg)
  style.fill(x + filled, y, w - filled, 1, style.colors.border)
end

function style.statusColor(status)
  if status == "ok" or status == true then return style.colors.good end
  if status == "warning" or status == "unknown" then return style.colors.warn end
  if status == "critical" or status == false then return style.colors.bad end
  return style.colors.muted
end

return style
local format = {}

local suffixes = {
  { 1e18, "E" },
  { 1e15, "P" },
  { 1e12, "T" },
  { 1e9, "B" },
  { 1e6, "M" },
  { 1e3, "K" }
}

local function fallback(value, default)
  if default ~= nil then return tostring(default) end
  if value == nil then return "n/a" end
  return tostring(value)
end

local function trim(value)
  local text = string.format("%.3f", value)
  text = text:gsub("0+$", ""):gsub("%.$", "")
  return text
end

function format.integer(value, default)
  local number = tonumber(value)
  if not number then return fallback(value, default) end
  local sign = number < 0 and "-" or ""
  local text = tostring(math.floor(math.abs(number) + 0.5))
  local out = {}
  while #text > 3 do
    table.insert(out, 1, text:sub(-3))
    text = text:sub(1, -4)
  end
  table.insert(out, 1, text)
  return sign .. table.concat(out, ",")
end

function format.quantity(value, default)
  local number = tonumber(value)
  if not number then return fallback(value, default) end
  local abs = math.abs(number)
  for _, suffix in ipairs(suffixes) do
    if abs >= suffix[1] then return trim(number / suffix[1]) .. suffix[2] end
  end
  return format.integer(number)
end

function format.ratio(current, target)
  return format.quantity(current) .. "/" .. format.quantity(target)
end

function format.countRatio(current, target)
  return format.integer(current) .. "/" .. format.integer(target)
end

function format.seconds(value)
  local number = tonumber(value)
  if not number then return "n/a" end
  local abs = math.abs(number)
  local units = { { 604800, "w" }, { 86400, "d" }, { 3600, "h" }, { 60, "m" } }
  for _, unit in ipairs(units) do
    if abs >= unit[1] then return trim(number / unit[1]) .. unit[2] end
  end
  return format.integer(number) .. "s"
end

return format
local style = require("oc.dashboard.style")

local actionBar = {}
local colors = style.colors

local function textFor(button)
  local key = button.key and (tostring(button.key) .. " ") or ""
  return " " .. key .. tostring(button.label or "") .. " "
end

local function register(state, group, hit)
  state.dashboardActionBars = state.dashboardActionBars or {}
  state.dashboardActionBars[group] = state.dashboardActionBars[group] or {}
  local hits = state.dashboardActionBars[group]
  hits[#hits + 1] = hit
end

local function reset(state, group)
  state.dashboardActionBars = state.dashboardActionBars or {}
  state.dashboardActionBars[group] = {}
end

local function buttonColors(button)
  if button.disabled then return colors.muted, colors.border end
  if button.danger then return colors.bg, colors.bad end
  if button.warn then return colors.bg, colors.warn end
  if button.good then return colors.bg, colors.good end
  return colors.bg, colors.accent
end

function actionBar.draw(state, group, x, y, w, buttons)
  reset(state, group)
  local cx, row = x, y
  local right = x + math.max(1, w) - 1
  for _, button in ipairs(buttons or {}) do
    local text = textFor(button)
    local bw = #text
    if cx > x and cx + bw - 1 > right then
      row = row + 1
      cx = x
    end
    if bw <= w then
      local fg, bg = buttonColors(button)
      style.text(cx, row, text, fg, bg, bw)
      if not button.disabled then register(state, group, { x = cx, y = row, w = bw, action = button.action }) end
      cx = cx + bw + 1
    end
  end
  return row + 1
end

function actionBar.hit(state, group, x, y)
  local groups = state and state.dashboardActionBars
  local hits = groups and groups[group]
  if not hits then return nil end
  for _, hit in ipairs(hits) do
    if y == hit.y and x >= hit.x and x < hit.x + hit.w then
      return hit.action
    end
  end
  return nil
end

return actionBar
local style = require("oc.dashboard.style")
local time = require("oc.ae2.time")
local numbers = require("oc.dashboard.number_format")
local cpuOutput = require("oc.dashboard.operator_status_cpu")

local status = {}
local colors = style.colors

local function inFlight(row)
  return row and (row.requestState == "running" or row.requestState == "accepted"
    or row.requestState == "in_flight" or row.requestPhase == "cpu_final_output")
end

local function stateWord(row, lower)
  local word = row and row.requestState == "failed" and "FAILED" or inFlight(row) and "IN-FLIGHT"
    or ((row and row.ready) and "READY" or "BLOCKED")
  return lower and word:lower() or word
end

local function detailText(row)
  if not row then return nil end
  if row.requestState == "failed" then return row.requestError end
  if row.ready == false then return row.reason end
  return nil
end

local function kindText(entry)
  return (entry and (entry.isFluid == true or entry.kind == "fluid")) and "fluid" or "item"
end

local function amountText(entry)
  if kindText(entry) == "fluid" then return numbers.quantity(entry.amount or entry.size, "?") .. " mB" end
  return numbers.quantity(entry and entry.size or 1) .. "x"
end

local function queueAmount(row)
  return tonumber(row and (row.requestedAmount or row.amount or row.batch)) or 0
end

local function queueStock(row)
  row = row or {}
  local target = row.min
  if target == nil then target = row.stockBelow or row.craftTo end
  if row.current ~= nil or target ~= nil then return numbers.ratio(row.current, target) end
  local currentText, targetText = tostring(row.reason or row.statusReason or ""):match("stock%s+([^%s;]+)%s+below%s+([^%s;]+)")
  if currentText and targetText then return currentText .. "/" .. targetText end
  return ""
end

local function queueState(row)
  local text = tostring(row and row.status or "unknown")
  if row and row.phase and row.phase ~= "" then text = text .. " " .. tostring(row.phase) end
  return text
end

function status.statusText(label, value)
  return tostring(label) .. " " .. tostring(value == nil and "n/a" or value)
end

function status.summaryStrip(parts)
  local out = {}
  for _, part in ipairs(parts or {}) do
    if type(part) == "table" then
      local label = part[1] or part.label
      local value = part[2]
      if value == nil then value = part.value end
      out[#out + 1] = status.statusText(label, value)
    else
      out[#out + 1] = tostring(part)
    end
  end
  return table.concat(out, " | ")
end

function status.cpuJob(cpu, index)
  local cpuNo, state, output = status.cpuJobColumns(cpu, index)
  return output ~= "" and (cpuNo .. " " .. state .. " " .. output) or (cpuNo .. " " .. state)
end

function status.cpuJobColumns(cpu, index)
  cpu = cpu or {}
  local label = cpuOutput.output(cpu)
  local qty = cpuOutput.quantity(cpu)
  local working = cpu.busy or label ~= nil
  local output = label or ""
  if output == "" and cpu.finalOutputError then output = "err " .. tostring(cpu.finalOutputError) end
  if output == "" and cpu.busy then output = "n/a" end
  return string.format("%02d", index), working and "Working" or "Ready", output, qty
end

function status.targetRow(row, options)
  row, options = row or {}, options or {}
  if options.workflow then
    local flow = row.workflow or {}
    local mode = row.mode == "auto" and "AUTO" or "MANUAL"
    local armed = flow.armed and "ARMED" or "safe"
    local index = row.craftIndex and ("  craft #" .. numbers.integer(row.craftIndex)) or ""
    return mode .. "/" .. armed .. "  " .. kindText(row) .. " " .. amountText(row)
      .. "  " .. tostring(row.label or "unknown") .. index
  end
  local sep = options.separator or "  "
  local lower = options.lowerLabels == true
  local stockLabel = options.stockLabel or (lower and "stock " or "Stock ")
  local batchLabel = options.batchLabel or (lower and "max " or "Max ")
  local stock = stockLabel .. numbers.ratio(row.current, row.min)
  local batch = batchLabel .. numbers.quantity(row.maxRequest or row.batch or row.request or 0)
  local nextLabel = options.nextLabel or (lower and "next @" or "next @")
  local nextText = row.nextEligibleAt and (nextLabel .. time.short(row.nextEligibleAt)) or nil
  local detail = detailText(row)
  local armed = row.armed and (options.armedText or "ARMED") or (options.disarmedText or "DISARMED")
  local ready = stateWord(row, options.lowerState == true)
  local parts
  if options.selected then
    parts = { tostring(options.prefix or "") .. tostring(row.label or "target"), armed, stock, batch, ready }
  else
    parts = { armed .. " " .. ready, tostring(row.label or "target"), stock, batch }
    if not options.omitCraft then parts[#parts + 1] = "Craft " .. (row.craftable and "yes" or "no") end
  end
  if nextText then parts[#parts + 1] = nextText end
  if detail then parts[#parts + 1] = tostring(detail) end
  return table.concat(parts, sep)
end

local function targetStateParts(row, options)
  row, options = row or {}, options or {}
  local armed = row.armed and (options.armedText or "ARMED") or (options.disarmedText or "DISARMED")
  local ready = stateWord(row, options.lowerState == true)
  if not row.armed then ready = nil end
  return armed, ready or "", detailText(row) or ""
end

function status.targetState(row, options)
  local armed, ready, detail = targetStateParts(row, options)
  local text = armed .. (ready ~= "" and (" " .. ready) or "")
  if detail ~= "" then text = text .. " - " .. detail end
  return text
end

function status.targetColumns(row, options)
  row, options = row or {}, options or {}
  local targetState = status.targetState(row, options)
  local left = tostring(row.label or "target")
  if not options.statusColumn then left = targetState .. "  " .. left end

  local stock = numbers.ratio(row.current, row.min)
  local max = numbers.quantity(row.maxRequest or row.batch or row.request or 0)
  local columns = { stock, max }
  if options.splitStatusColumns then
    local armed, ready, detail = targetStateParts(row, options)
    columns = { armed, ready, detail, stock, max }
  elseif options.statusColumn then table.insert(columns, 1, targetState) end
  if not options.omitCraft then columns[#columns + 1] = row.craftable and "yes" or "no" end
  if row.nextEligibleAt then
    columns[#columns + 1] = time.short(row.nextEligibleAt)
  end
  return left, columns
end

function status.targetRowParts(row, options)
  local left, columns = status.targetColumns(row, options)
  return left, table.concat(columns, options and options.infoSeparator or " | ")
end

function status.logColumns(row)
  row = row or {}
  local stamp = row.uptime and time.short(row.uptime) or tostring(row.stamp or "?")
  local left = stamp .. "  " .. tostring(row.label or "target")
  local columns = { numbers.quantity(row.amount or 0), row.current and numbers.ratio(row.current, row.min) or "" }
  return left, columns
end

function status.logRowParts(row)
  local left, columns = status.logColumns(row)
  return left, table.concat(columns, " | ")
end

function status.queueColumns(row)
  row = row or {}
  local left = tostring(row.label or "target") .. " " .. queueState(row)
  local detail = row.statusReason or row.reason
  if detail and not tostring(detail):find("^stock%s+") then left = left .. " - " .. tostring(detail) end
  return left, { numbers.quantity(queueAmount(row)), queueStock(row) }
end

function status.queueRowParts(row)
  local left, columns = status.queueColumns(row)
  return left, table.concat(columns, " | ")
end

function status.stateColor(row, selected, context)
  context = context or {}
  if selected then return colors.accent end
  if context.workflow then
    local flow = row and row.workflow or {}
    if row and row.mode == "auto" and flow.armed then return colors.good end
    return colors.text
  end
  if not (row and row.armed) then return colors.muted end
  if row.requestState == "failed" or not row.ready then return colors.warn end
  if context.daemonRequired and not (context.daemon and context.daemon.fresh) then return colors.warn end
  if context.warnWhenArmed then return colors.warn end
  return colors.good
end

return status
local numbers = require("oc.dashboard.number_format")
local match = require("oc.ae2.request_match")

local cpu = {}

local function normalizedStack(value)
  if type(value) ~= "table" then return nil end
  local ok, out = pcall(match.normalizeStack, value)
  return ok and type(out) == "table" and out or nil
end

local function outputLabel(value)
  local stack = type(value) == "table" and value or { label = value }
  local raw = type(value) == "table" and (value.label or value.name) or value
  local out = normalizedStack(stack)
  if raw == nil and not match.nestedFluid(stack) then return nil end
  local label = out and out.label or tostring(raw)
  if label == "" then return tostring(raw) end
  return label
end

local function addLabel(labels, seen, value)
  local label = outputLabel(value)
  if label and not seen[label] then labels[#labels + 1] = label; seen[label] = true end
end

local function stackQuantity(value)
  if type(value) ~= "table" then return nil end
  local normalized = normalizedStack(value)
  local fluid = normalized and (normalized.kind == "fluid" or normalized.isFluid == true)
  local qty
  if fluid then
    -- AE2FC exposes a fluid as one wrapper item whose nested amount is the
    -- actual fluid quantity. Never let wrapper size=1 mask that amount.
    qty = tonumber(normalized.amount or normalized.size)
  else
    qty = tonumber((normalized and normalized.size) or value.size or value.amount or value.count)
  end
  if qty and qty > 0 then return qty end
  if value.label ~= nil or value.name ~= nil then return 1 end
  return nil
end

local function addQuantity(qtys, value)
  local qty = stackQuantity(value)
  if qty then qtys[#qtys + 1] = numbers.quantity(qty) end
end

local function collectLabels(labels, seen, values)
  if type(values) ~= "table" then return end
  if values.label ~= nil or values.name ~= nil or match.nestedFluid(values) then
    addLabel(labels, seen, values); return
  end
  local indexed, reported = {}, math.max(tonumber(values.n) or 0, #values)
  for index = 1, reported do
    if values[index] ~= nil then indexed[index] = true; addLabel(labels, seen, values[index]) end
  end
  for key, value in pairs(values) do
    if key ~= "n" and not indexed[key] then
      addLabel(labels, seen, value == true and type(key) == "string" and key or value)
    end
  end
end

local function collectQuantities(qtys, values)
  if type(values) ~= "table" then return end
  if values.label ~= nil or values.name ~= nil or match.nestedFluid(values) then
    addQuantity(qtys, values); return
  end
  local indexed, reported = {}, math.max(tonumber(values.n) or 0, #values)
  for index = 1, reported do
    if values[index] ~= nil then indexed[index] = true; addQuantity(qtys, values[index]) end
  end
  for key, value in pairs(values) do
    if key ~= "n" and not indexed[key] then addQuantity(qtys, value) end
  end
end

function cpu.output(value)
  local labels, seen = {}, {}
  -- The structured stack retains nested AE2FC fluid identity; labels are a
  -- lossy compatibility snapshot and must remain fallback-only.
  collectLabels(labels, seen, value and value.finalOutputStack)
  if #labels == 0 then collectLabels(labels, seen, value and value.finalOutputLabels) end
  if #labels == 0 then return nil, 0 end
  return table.concat(labels, ", "), #labels
end

function cpu.quantity(value)
  local qtys = {}
  collectQuantities(qtys, value and value.finalOutputStack)
  return #qtys == 0 and "" or table.concat(qtys, ",")
end

return cpu
local style = require("oc.dashboard.style")
local columns = require("oc.dashboard.workflow_page_detail_columns")

local sections = {}
local colors = style.colors

local function clip(value, width)
  value = tostring(value or "")
  width = math.max(0, tonumber(width) or 0)
  if #value > width then return value:sub(1, width) end
  return value
end

function sections.band(panel, y, label, text)
  local width = math.max(1, panel.w - 2)
  style.fill(panel.x + 1, y, width, 1, colors.border)
  local title = " " .. tostring(label or "") .. " "
  local titleWidth = math.min(panel.w - 4, #title)
  if titleWidth > 0 then style.text(panel.x + 2, y, clip(title, titleWidth), colors.bg, colors.accent, titleWidth) end
  local remaining = panel.w - 4 - titleWidth
  if remaining > 0 and text and text ~= "" then
    style.text(panel.x + 2 + titleWidth, y, clip(text, remaining), colors.text, colors.border, remaining)
  end
  return y + 1
end

function sections.headerAt(x, y, width, spec, minLeft, leftLabel)
  local leftWidth, rightWidth = columns.split(width, spec, minLeft)
  style.fill(x, y, width, 1, colors.border)
  local title = " " .. tostring(leftLabel or "Condition") .. " "
  if rightWidth <= 0 then
    style.text(x, y, clip(title, width), colors.bg, colors.accent, math.min(width, #title))
    return y + 1
  end
  style.text(x, y, clip(title, leftWidth), colors.bg, colors.accent, math.min(leftWidth, #title))
  columns.drawValues(x + leftWidth + 1, y, columns.labels(spec), spec, colors.text, colors.border)
  return y + 1
end

function sections.split(width, spec, minLeft)
  return columns.split(width, spec, minLeft)
end

function sections.values(x, y, values, spec, color, bg)
  return columns.drawValues(x, y, values, spec, color, bg)
end

function sections.labels(spec)
  return columns.labels(spec)
end

return sections
local numbers = require("oc.dashboard.number_format")
local operatorStatus = require("oc.dashboard.operator_status")

local cpuStatus = {}

local function eachCpu(cpus, fn)
  local seen = {}
  local reported = math.max(tonumber(cpus and cpus.n) or 0, #(cpus or {}))
  for index = 1, reported do
    if cpus[index] ~= nil then
      seen[index] = true
      fn(cpus[index], index)
    end
  end
  for key, row in pairs(cpus or {}) do
    if key ~= "n" and not seen[key] then fn(row, key) end
  end
end

local function finalOutputText(summary)
  local scanned = tonumber(summary and summary.scanned) or tonumber(summary and summary.total) or 0
  if scanned <= 0 then return nil end
  local finals = tonumber(summary and summary.finals) or 0
  local errors = tonumber(summary and summary.errors) or 0
  local unknown = tonumber(summary and summary.unknown) or 0
  local text = unknown > 0 and finals == 0 and errors == 0
    and "Finals: n/a" or ("Finals: " .. numbers.countRatio(finals, scanned))
  if errors > 0 then text = text .. " err " .. numbers.integer(errors) end
  if unknown > 0 then text = text .. " (" .. numbers.integer(unknown) .. " working n/a)" end
  return text
end

function cpuStatus.fromAe2(ae2)
  local cpuSummary = ae2 and ae2.cpus
  if type(cpuSummary) ~= "table" then return nil end
  local cpus = cpuSummary.cpus or {}
  local total = math.max(tonumber(cpuSummary.count) or 0, tonumber(cpus.n) or 0, #cpus)
  local scanned, ready, finals, errors, unknown = 0, 0, 0, 0, 0
  eachCpu(cpus, function(row, index)
    scanned = scanned + 1
    local _, state, output = operatorStatus.cpuJobColumns(row, index)
    if state == "Ready" then ready = ready + 1 end
    if output ~= "" and output ~= "n/a" then
      if tostring(output):find("^err ") then errors = errors + 1 else finals = finals + 1 end
    elseif output == "n/a" then
      unknown = unknown + 1
    end
  end)
  if total <= 0 and scanned <= 0 then return nil end
  total = math.max(total, scanned)
  return { ready = ready, total = total, scanned = math.max(scanned, total), finals = finals, errors = errors, unknown = unknown }
end

local function fromStatus(status)
  status = status or {}
  local finals = tonumber(status.activeCraftFinalOutputs or status.activeCraftCount) or 0
  local errors = tonumber(status.activeCraftFinalOutputErrors) or 0
  local busy = tonumber(status.activeCraftBusyCpus) or 0
  return {
    ready = tonumber(status.readyCpus) or 0,
    total = tonumber(status.totalCpus) or 0,
    scanned = tonumber(status.activeCraftScannedCpus) or tonumber(status.totalCpus) or 0,
    finals = finals,
    errors = errors,
    unknown = math.max(0, busy - finals - errors)
  }
end

local function selectSummary(state, status)
  return cpuStatus.fromAe2(state and state.ae2) or fromStatus(status)
end

function cpuStatus.maintainerLine(state, status)
  status = status or {}
  local summary = selectSummary(state, status)
  local text = "CPUs: " .. numbers.countRatio(summary.ready, summary.total)
    .. " Ready; wants " .. tostring(status.cpuPolicy or "any ready CPU")
  local finals = finalOutputText(summary)
  if finals then text = text .. " | " .. finals end
  return text
end

function cpuStatus.daemonParts(state, status, fallbackCpuText)
  local live = cpuStatus.fromAe2(state and state.ae2)
  if live then return numbers.countRatio(live.ready, live.total), finalOutputText(live) end
  local summary = fromStatus(status)
  local cpuText = fallbackCpuText or numbers.countRatio(summary.ready, summary.total)
  return cpuText, finalOutputText(summary)
end

return cpuStatus
local cacheEpoch = require("oc.ae2.cache_epoch")
local computer = require("computer")
local daemonControl = require("oc.ae2.maintainer_daemon_control")
local time = require("oc.ae2.time")
local numbers = require("oc.dashboard.number_format")
local workflows = require("oc.ae2.workflows")

local memory = {}

local function field(value, key)
  if value and value[key] ~= nil then return value[key] end
  local flow = value and value.workflow
  if type(flow) == "table" then return flow[key] end
  return nil
end

local function labelKey(value)
  return tostring(field(value, "label") or field(value, "rawLabel") or field(value, "name") or ""):lower()
end

local function targetFor(value)
  return {
    label = field(value, "label"),
    rawLabel = field(value, "rawLabel"),
    name = field(value, "name"),
    damage = field(value, "damage"),
    hasTag = field(value, "hasTag"),
    kind = field(value, "kind"),
    isFluid = field(value, "isFluid"),
    amount = field(value, "amount"),
    filter = field(value, "filter"),
    craftBinding = field(value, "craftBinding")
  }
end

local function keyFor(value)
  return cacheEpoch.targetKey(targetFor(value))
end

local function requestAmount(entry)
  return tonumber(field(entry, "maxRequest") or field(entry, "batch") or field(entry, "request") or field(entry, "craftTo")) or 1
end

local function failedState(value)
  local state = value and value.requestState
  return state == "blocked" or state == "failed" or state == "canceled"
end

local function confirmedState(value)
  return value and value.requestState == "running" and value.requestPhase == "submitted"
end

local function stateText(value, err)
  local state, phase = value and value.requestState, value and value.requestPhase
  local reason = value and value.requestStatusReason or err
  if state == "running" and phase == "computing" then
    return "AE2 is calculating the recipe; no crafting CPU is assigned yet"
  elseif state == "running" and phase == "submitted" then
    return "AE2 accepted the craft; Jobs CPU witness is pending"
  elseif state == "done" then return "AE2 reports the craft completed"
  elseif state == "accepted" then return "request returned; CPU confirmation unavailable"
  elseif state == "blocked" then return tostring(reason or "request blocked")
  elseif state == "canceled" then return tostring(reason or "request canceled")
  elseif state == "failed" then return tostring(reason or "request failed") end
  return tostring(reason or "manual request state unavailable")
end

memory.statusText = stateText

function memory.receiptPrefix(ok, report)
  local state, phase = report and report.requestState, report and report.requestPhase
  if state == "running" and phase == "computing" then return "Manual request calculating: " end
  if state == "running" and phase == "submitted" then return "Manual request accepted by AE2: " end
  if state == "done" then return "Manual request completed: " end
  if state == "accepted" then return "Manual request returned (confirmation unavailable): " end
  if state == "blocked" then return "Manual request blocked: " end
  if state == "canceled" then return "Manual request canceled: " end
  return ok and "Manual request accepted: " or "Manual request failed for "
end

local function receipt(record)
  local shown = numbers.quantity(record.amount) .. (record.isFluid and " mB " or "x ")
  return memory.receiptPrefix(not failedState(record), record) .. shown .. tostring(record.label or "target")
    .. " @" .. time.short() .. ". " .. stateText(record)
end

function memory.queueDaemonHeartbeat(state)
  state.nextAe2DaemonRefresh = 0
  if state.ae2MaintainDaemon and state.ae2MaintainDaemon.fresh == true then return end
  local ok, status = pcall(daemonControl.status)
  if ok and type(status) == "table" then state.ae2MaintainDaemon = status end
end

local function requestReason(ok, err, report)
  if report and report.requestState then return stateText(report, err) end
  if err then return tostring(err) end
  if report and report.error then return tostring(report.error) end
  return ok and "manual request accepted; confirmation unavailable" or "manual request failed"
end

local function patchRow(row, entry, ok, err, report, now)
  if not row then return end
  local reason = requestReason(ok, err, report)
  row.request = requestAmount(entry)
  row.requested = confirmedState(report) or (report == nil and ok == true)
  row.requestState = (report and report.requestState) or (ok and "running" or "failed")
  row.requestPhase = (report and report.requestPhase) or (ok and "manual" or "failed")
  row.requestKey = report and report.requestKey or row.requestKey
  row.requestStatusReason = reason
  row.requestError = (failedState(report) or not ok) and reason or nil
  row.ready = false
  row.reason = reason
  row.manualPatchAt = now
end

local function matchedRowsIn(rows, entry)
  if not rows then return {} end
  local wanted, fallback = keyFor(entry), labelKey(entry)
  local named = field(entry, "name") ~= nil
  local out, fallbackRow, fallbackCount = {}, nil, 0
  for _, row in ipairs(rows) do
    if named and field(row, "name") and keyFor(row) == wanted then
      out[#out + 1] = row
    elseif named and not field(row, "name") and labelKey(row) == fallback then
      fallbackRow, fallbackCount = row, fallbackCount + 1
    elseif not named and not field(row, "name") and (keyFor(row) == wanted or labelKey(row) == fallback) then
      out[#out + 1] = row
    end
  end
  if #out == 0 and fallbackCount == 1 then out[1] = fallbackRow end
  return out
end

local function matchedRows(state, entry, selected)
  if selected then return { selected } end
  return matchedRowsIn(state.ae2Maintain and state.ae2Maintain.targets, entry)
end

function memory.recordManualMaintainer(state, entry, ok, err, report, selected)
  local now = computer.uptime()
  state.ae2MaintainManualPatchAt = now
  local target = targetFor(entry)
  target.request = requestAmount(entry)
  local request = {
    key = report and report.requestKey or keyFor(entry), target = target,
    label = field(entry, "label") or field(entry, "rawLabel") or field(entry, "name") or "target",
    amount = requestAmount(entry), isFluid = field(entry, "isFluid") == true or field(entry, "kind") == "fluid",
    requestState = report and report.requestState or (ok and "accepted" or "failed"),
    requestPhase = report and report.requestPhase,
    requestStatusReason = report and report.requestStatusReason or err,
    trackable = report and report.requestTrackable == true,
    manualConfirmed = report and report.manualConfirmed == true,
    manualLogged = report and report.manualLogged == true,
    recordPending = report and report.recordPending == true,
    observationError = report and report.observationError,
    updatedAt = now, nextPollAt = now, nextLeaseRefreshAt = now + 30
  }
  state.ae2ManualRequest = request
  state.nextAe2CpuRefresh, state.nextAe2Refresh = 0, 0
  if state.ae2 then state.ae2.manualRequest = request end
  memory.queueDaemonHeartbeat(state)
  for _, row in ipairs(matchedRows(state, entry, selected)) do patchRow(row, entry, ok, err, report, now) end
  local cache = state.ae2MaintainCache
  if type(cache) == "table" then
    cache.manualPatchAt = now
    for _, row in ipairs(matchedRowsIn(cache.rows, entry)) do patchRow(row, entry, ok, err, report, now) end
  end
end

function memory.refresh(state, now)
  local record = state and state.ae2ManualRequest
  if type(record) ~= "table" or (record.trackable ~= true and record.recordPending ~= true)
    or (record.requestState ~= "running" and record.recordPending ~= true) then return false end
  now = tonumber(now) or computer.uptime()
  if now < (tonumber(record.nextPollAt) or 0) then return false end
  record.nextPollAt = now + 1
  local loaded, requestTracker = pcall(require, "oc.ae2.request_tracker")
  if record.trackable == true and (not loaded or type(requestTracker) ~= "table") then return false end
  local retained = { state = record.requestState, phase = record.requestPhase, reason = record.requestStatusReason }
  local info = record.trackable == true and requestTracker.status(record.key) or retained
  local hasTrackerRecord = record.trackable == true and info and info.state ~= "none"
  if not hasTrackerRecord and record.recordPending == true then info = retained end
  if not info or info.state == "none" then return false end
  local changed = info.state ~= record.requestState or info.phase ~= record.requestPhase
    or tostring(info.reason or "") ~= tostring(record.requestStatusReason or "")
  local renewLease = now >= (tonumber(record.nextLeaseRefreshAt) or 0)
  if not changed and record.recordPending ~= true and not renewLease then return false end
  record.nextLeaseRefreshAt = now + 30
  record.requestState, record.requestPhase, record.requestStatusReason = info.state, info.phase, info.reason
  record.updatedAt = now
  local report = {
    amount = record.amount, requestKey = record.key, requestState = info.state,
    requestPhase = info.phase, requestStatusReason = info.reason,
    requestTrackable = true, manualConfirmed = record.manualConfirmed,
    manualLogged = record.manualLogged
  }
  local called, result, observeErr = pcall(workflows.observeManual, record.target, report, now)
  local observeFailure = called and observeErr or result
  local recorded = called and result == true
  record.recordPending = not recorded
  if recorded then
    record.manualConfirmed = report.manualConfirmed == true
    record.manualLogged = report.manualLogged == true
  end
  state.ae2WorkflowMessage = receipt(record)
  if not recorded then
    state.ae2WorkflowMessage = state.ae2WorkflowMessage .. " Lifecycle save pending: " .. tostring(observeFailure) .. "."
  end
  state.ae2MaintainManualPatchAt = now
  for _, row in ipairs(matchedRows(state, record.target)) do patchRow(row, record.target, not failedState(record), nil, record, now) end
  local cache = state.ae2MaintainCache
  if type(cache) == "table" then
    cache.manualPatchAt = now
    for _, row in ipairs(matchedRowsIn(cache.rows, record.target)) do
      patchRow(row, record.target, not failedState(record), nil, record, now)
    end
  end
  state.nextAe2CpuRefresh, state.nextAe2Refresh = 0, 0
  if info.state == "done" then state.nextAe2StockRefresh, state.nextAe2MaintainRefresh = 0, 0 end
  if hasTrackerRecord and info.state ~= "running" and recorded then requestTracker.acknowledge(record.key) end
  if state.ae2 then state.ae2.manualRequest = record end
  memory.queueDaemonHeartbeat(state)
  return true
end

return memory
local cache = require("oc.dashboard.cache")
local deckTime = require("oc.dashboard.deck_blocks_time")
local numbers = require("oc.dashboard.number_format")
local operatorStatus = require("oc.dashboard.operator_status")
local pages = require("oc.dashboard.pages")
local style = require("oc.dashboard.style")

local blocks = {}
local colors = style.colors
local logColumnSpec = { { label = "Amount", width = 8 }, { label = "Stock", width = 17 } }
local queueColumnSpec = { { label = "Amount", width = 8 }, { label = "Stock", width = 17 } }

local function euPair(a, b)
  return numbers.quantity(a) .. " / " .. numbers.quantity(b) .. " EU"
end

local function euRatePair(a, b)
  return numbers.quantity(a) .. " in / " .. numbers.quantity(b) .. " out EU/t"
end

local function readyCpus(snapshot)
  local cpus = (snapshot.cpus and snapshot.cpus.cpus) or {}
  local ready = 0
  for _, cpu in ipairs(cpus) do
    if not cpu.busy then ready = ready + 1 end
  end
  return ready, snapshot.cpus and snapshot.cpus.count or 0
end

local function usageText(reading)
  return euRatePair(reading.effectiveAvgIn or reading.avgIn, reading.effectiveAvgOut or reading.avgOut)
end

function blocks.initiativeKey(state)
  if cache.initiativePreviewKey then return cache.initiativePreviewKey(state) end
  if cache.taskPreviewKey then return cache.taskPreviewKey(state) end
  return tostring(state.initiativePage) .. "|" .. table.concat(state.initiatives or {}, "|")
end

function blocks.logsKey(state)
  local log = state.ae2DeckLogs or state.ae2Logs or {}
  local parts = { tostring(log.total), tostring(log.error), tostring(log.path) }
  for i, row in ipairs(log.rows or {}) do
    if i > 24 then break end
    parts[#parts + 1] = tostring(row.stamp or row.uptime) .. ":" .. tostring(row.label) .. ":" .. tostring(row.amount)
  end
  return table.concat(parts, "|")
end

function blocks.queueKey(state)
  local daemon = state.ae2MaintainDaemon or {}
  local now = state.health and state.health.uptime or 0
  local remaining = tonumber(daemon.nextCycleAt) and math.ceil(daemon.nextCycleAt - now) or "n/a"
  local parts = { tostring(daemon.lastTick), tostring(daemon.tickCount), tostring(daemon.queueCount),
    tostring(daemon.inFlightCount), tostring(remaining) }
  local hasLiveRows = (tonumber(daemon.queueCount) or 0) > 0 or (tonumber(daemon.inFlightCount) or 0) > 0
  local rows = hasLiveRows and blocks.dispatchRows(daemon.targetStatus) or {}
  for i, row in ipairs(rows) do
    if i > 24 then break end
    parts[#parts + 1] = tostring(row.label) .. ":" .. tostring(row.amount) .. ":" .. tostring(row.current)
      .. ":" .. tostring(row.min or row.stockBelow) .. ":" .. tostring(row.status) .. ":" .. tostring(row.reason)
      .. ":" .. tostring(row.phase) .. ":" .. tostring(row.statusReason)
  end
  return table.concat(parts, "|")
end

function blocks.drawSystem(panel, snapshot)
  style.box(panel.x, panel.y, panel.w, panel.h, "CORE VITALS")
  local totalMem = snapshot.totalMemory or 1
  local freeMem = snapshot.freeMemory or 0
  local usedPct = 1 - (freeMem / totalMem)
  local pctText = tostring(math.floor((usedPct * 100) + 0.5)) .. "%"
  local color = usedPct > 0.85 and colors.bad or colors.good
  style.text(panel.x + 2, panel.y + 2, "Uptime: " .. deckTime.uptime(snapshot.uptime or 0), colors.text, colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 4, "RAM use", colors.muted, colors.panel, 8)
  style.bar(panel.x + 11, panel.y + 4, math.max(8, panel.w - 20), usedPct, color)
  style.text(panel.x + panel.w - 6, panel.y + 4, pctText, color, colors.panel, 5)
end

function blocks.drawLinks(panel, rows)
  style.box(panel.x, panel.y, panel.w, panel.h, "OC LINKS")
  local counts, types = {}, {}
  for _, row in ipairs(rows) do
    if not counts[row.ctype] then types[#types + 1] = row.ctype end
    counts[row.ctype] = (counts[row.ctype] or 0) + 1
  end
  table.sort(types)
  local maxRows = panel.h - 3
  for i = 1, math.min(maxRows, #types) do
    local ctype = types[i]
    style.text(panel.x + 2, panel.y + 1 + i, ctype .. " x" .. numbers.integer(counts[ctype]), colors.text, colors.panel, panel.w - 4)
  end
  if #types > maxRows then
    style.text(panel.x + 2, panel.y + panel.h - 2, "... " .. numbers.integer(#types - maxRows) .. " more link types", colors.muted, colors.panel, panel.w - 4)
  end
end

function blocks.drawAe2(panel, snapshot)
  style.box(panel.x, panel.y, panel.w, panel.h, "AE2")
  if not snapshot.available then
    style.text(panel.x + 2, panel.y + 2, "Unavailable", colors.warn, colors.panel, panel.w - 4)
    return
  end
  local ready, total = readyCpus(snapshot)
  style.text(panel.x + 2, panel.y + 2, "Network online", colors.good, colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 3, "CPUs: " .. numbers.countRatio(ready, total) .. " Ready", colors.text, colors.panel, panel.w - 4)
end

function blocks.drawPower(panel, snapshot)
  style.box(panel.x, panel.y, panel.w, panel.h, "BATTERY 5000")
  if not snapshot.available then
    style.text(panel.x + 2, panel.y + 2, "Telemetry unavailable", colors.warn, colors.panel, panel.w - 4)
    return
  end
  local first = snapshot.readings[1]
  local percent = first.ratio and string.format("%.1f%%", first.ratio * 100) or "n/a"
  style.text(panel.x + 2, panel.y + 2, usageText(first), style.statusColor(first.status), colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 3, euPair(first.effectiveStored or first.stored, first.effectiveMax or first.max) .. " " .. percent, style.statusColor(first.status), colors.panel, panel.w - 4)
end

function blocks.drawInitiatives(panel, state)
  pages.drawInitiativePreview(panel, state)
end

local function columnsWidth(spec) local width = 0; for i, col in ipairs(spec or {}) do width = width + (col.width or 0) + (i > 1 and 3 or 0) end; return width end

local function splitWidths(width, spec, minLeft)
  width = math.floor(tonumber(width) or 0)
  local right = columnsWidth(spec)
  if width < (minLeft or 24) + right + 1 then return width, 0 end; return width - right - 1, right
end

local function drawColumns(x, y, columns, spec, color)
  local cursor = x
  for i, col in ipairs(spec or {}) do
    if i > 1 then style.text(cursor, y, " | ", color, colors.panel, 3); cursor = cursor + 3 end
    style.text(cursor, y, columns[i] or "", color, colors.panel, col.width or 1)
    cursor = cursor + (col.width or 1)
  end
end

local function columnLabels(spec) local labels = {}; for i, col in ipairs(spec or {}) do labels[i] = col.label or "" end; return labels end

local function drawFixedRow(x, y, width, row, spec, columnsFn, partsFn, color)
  local left, columns = columnsFn(row)
  local leftWidth, rightWidth = splitWidths(width, spec, 24)
  if rightWidth <= 0 then
    local _, compact = partsFn(row); style.textBlock(x, y, left .. " " .. compact, color, colors.panel, width, 1); return
  end
  style.textBlock(x, y, left, color, colors.panel, leftWidth, 1)
  drawColumns(x + leftWidth + 1, y, columns, spec, color)
end

local function drawFixedHeader(x, y, width, spec)
  local leftWidth, rightWidth = splitWidths(width, spec, 24)
  if rightWidth <= 0 then return y end
  style.text(x, y, "Request", colors.muted, colors.panel, leftWidth)
  drawColumns(x + leftWidth + 1, y, columnLabels(spec), spec, colors.muted); return y + 1
end

function blocks.dispatchRows(source)
  local rows = {}
  for _, row in ipairs(source or {}) do
    local status = tostring(row.status or "")
    local amount = tonumber(row.requestedAmount) or tonumber(row.amount) or 0
    if amount > 0 and (status == "queued" or status == "in_flight" or status == "failed"
      or (status == "blocked" and row.phase == "missing_resources")) then
      rows[#rows + 1] = row
    end
  end
  return rows
end

function blocks.drawLogs(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "AE2 MAINTAINER LOGS")
  local log = state.ae2DeckLogs or state.ae2Logs or {}
  local rows = log.rows or {}
  style.text(panel.x + 2, panel.y + 2, "Latest " .. numbers.countRatio(math.min(24, #rows), log.total or 0)
    .. " batches", colors.muted, colors.panel, panel.w - 4)
  if log.error then
    style.textBlock(panel.x + 2, panel.y + 4, "Log read failed: " .. tostring(log.error), colors.warn, colors.panel, panel.w - 4, 2)
    return
  end
  local rowStart = drawFixedHeader(panel.x + 2, panel.y + 3, panel.w - 4, logColumnSpec)
  local limit = math.min(24, #rows, math.max(0, panel.h - (rowStart - panel.y) - 1))
  for i = 1, limit do
    drawFixedRow(panel.x + 2, rowStart + i - 1, panel.w - 4, rows[i], logColumnSpec,
      operatorStatus.logColumns, operatorStatus.logRowParts, colors.text)
  end
  if limit == 0 then style.text(panel.x + 2, panel.y + 4, "No maintainer batches logged yet.", colors.warn, colors.panel, panel.w - 4) end
end

local function queueColor(row)
  if row.status == "queued" then return colors.good end
  if row.status == "in_flight" or row.phase == "missing_resources" then return colors.warn end
  return row.status == "failed" and colors.bad or colors.muted
end

function blocks.drawQueue(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "AE2 QUEUE")
  local daemon = state.ae2MaintainDaemon or {}
  local now = state.health and state.health.uptime or 0
  local remaining = tonumber(daemon.nextCycleAt) and (daemon.nextCycleAt - now) or nil
  local cycle = daemon.lastTick and (daemon.fresh and deckTime.remaining(remaining) or "stale") or "daemon inactive"
  style.text(panel.x + 2, panel.y + 2, "Next request: " .. cycle .. " | Queue: " .. numbers.quantity(daemon.queueCount or 0)
    .. " In-flight: " .. numbers.quantity(daemon.inFlightCount or 0), colors.muted, colors.panel, panel.w - 4)
  local hasLiveRows = (tonumber(daemon.queueCount) or 0) > 0 or (tonumber(daemon.inFlightCount) or 0) > 0
  local rows = hasLiveRows and blocks.dispatchRows(daemon.targetStatus) or {}
  local rowStart = drawFixedHeader(panel.x + 2, panel.y + 3, panel.w - 4, queueColumnSpec)
  local limit = math.min(24, #rows, math.max(0, panel.h - (rowStart - panel.y) - 1))
  for i = 1, limit do
    local row = rows[i] or {}; drawFixedRow(panel.x + 2, rowStart + i - 1, panel.w - 4, row, queueColumnSpec,
      operatorStatus.queueColumns, operatorStatus.queueRowParts, queueColor(row))
  end
  if limit == 0 then style.text(panel.x + 2, panel.y + 4, "No maintainer queue rows in daemon state.", colors.warn, colors.panel, panel.w - 4) end
end

function blocks.drawCompactOverview(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "COMMAND DECK")
  local health = state.health or {}
  local totalMem = health.totalMemory or 1
  local freeMem = health.freeMemory or 0
  local usedPct = 1 - (freeMem / totalMem)
  local pctText = tostring(math.floor((usedPct * 100) + 0.5)) .. "%"
  local ae2Status = state.ae2.available and "online" or "missing"
  local powerStatus = state.power.available and (numbers.integer(state.power.count or 0) .. " node(s)") or "missing"
  local lines = { "Uptime: " .. deckTime.uptime(health.uptime), "RAM use: " .. pctText,
    "Components: " .. numbers.integer(#state.components), "AE2: " .. ae2Status,
    "Battery 5000: " .. powerStatus, "[O] Ops [H] Domain", "[A] AE2 [P] Battery" }
  for i = 1, math.min(#lines, panel.h - 2) do
    local color = i == 2 and (usedPct > 0.85 and colors.bad or colors.good) or (i >= 6 and colors.muted or colors.text)
    style.text(panel.x + 2, panel.y + i, lines[i], color, colors.panel, panel.w - 4)
  end
end

return blocks
local deckTime = {}

function deckTime.uptime(seconds)
  seconds = math.floor(seconds or 0)
  local units = { { 31536000, "y" }, { 86400, "d" }, { 3600, "h" }, { 60, "m" } }
  for i, unit in ipairs(units) do
    if seconds >= unit[1] then
      local major = math.floor(seconds / unit[1])
      local remainder = seconds % unit[1]
      local nextUnit = units[i + 1] or { 1, "s" }
      local minor = math.floor(remainder / nextUnit[1])
      if minor > 0 then return tostring(major) .. unit[2] .. " " .. tostring(minor) .. nextUnit[2] end
      return tostring(major) .. unit[2]
    end
  end
  return tostring(seconds) .. "s"
end

function deckTime.remaining(value)
  value = tonumber(value)
  if not value then return "n/a" end
  if value <= 0 then return "due" end
  if value >= 60 then return tostring(math.floor(value / 60)) .. "m " .. tostring(math.ceil(value % 60)) .. "s" end
  return tostring(math.ceil(value)) .. "s"
end

return deckTime
local actionBar = require("oc.dashboard.action_bar")

local stock = {}

stock.maxQuery = 40

local function text(value)
  return tostring(value or ""):lower()
end

local function sourceEntries(state)
  local cache = state and state.ae2StockCache
  if cache and cache.entries then return cache.entries end
  local snapshot = state and state.ae2 and state.ae2.stock
  return (snapshot and snapshot.entries) or {}
end

local function sourceCache(state)
  return state and state.ae2StockCache or {}
end

function stock.ensure(state)
  state.stockQuery = state.stockQuery or ""
  state.stockPage = state.stockPage or 1
end

local function searchText(cache, index, entry)
  cache.search = cache.search or {}
  if cache.search[index] then return cache.search[index] end
  local value = text((entry and (entry.searchText or entry.label)) or "") .. " "
    .. text((entry and entry.rawLabel) or "") .. " "
    .. text((entry and entry.name) or "") .. " "
    .. text((entry and entry.filter and entry.filter.name) or "") .. " "
    .. text((entry and entry.kind) or "") .. " "
    .. text(entry and entry.isFluid and "fluid" or "") .. " "
    .. text((entry and entry.amount) or "")
  cache.search[index] = value
  return value
end

function stock.matches(entry, query, cache, index)
  query = text(query)
  if query == "" then return true end
  local haystack = searchText(cache or {}, index or 0, entry)
  for token in query:gmatch("%S+") do
    if not haystack:find(token, 1, true) then return false end
  end
  return true
end

function stock.filteredEntries(state)
  stock.ensure(state)
  local rows = {}
  local cache = sourceCache(state)
  for index, entry in ipairs(sourceEntries(state)) do
    if stock.matches(entry, state.stockQuery, cache, index) then rows[#rows + 1] = entry end
  end
  return rows
end

local function countMatches(state)
  local total = 0
  local cache = sourceCache(state)
  for index, entry in ipairs(sourceEntries(state)) do
    if stock.matches(entry, state.stockQuery, cache, index) then total = total + 1 end
  end
  return total
end

local function collectPage(state, first, last)
  local out, matched = {}, 0
  local cache = sourceCache(state)
  for index, entry in ipairs(sourceEntries(state)) do
    if stock.matches(entry, state.stockQuery, cache, index) then
      matched = matched + 1
      if matched >= first and matched <= last then out[#out + 1] = entry end
      if matched > last then break end
    end
  end
  return out
end

function stock.pageCount(state, perPage)
  return math.max(1, math.ceil(countMatches(state) / math.max(1, perPage or 1)))
end

function stock.pageEntries(state, perPage)
  stock.ensure(state)
  perPage = math.max(1, perPage or 16)
  local matched = countMatches(state)
  local pages = math.max(1, math.ceil(matched / perPage))
  state.stockPage = math.max(1, math.min(pages, state.stockPage or 1))
  local first = ((state.stockPage - 1) * perPage) + 1
  return collectPage(state, first, first + perPage - 1), matched, pages
end

function stock.movePage(state, delta)
  local pages = stock.pageCount(state, state.stockPerPage or 16)
  state.stockPage = ((state.stockPage or 1) - 1 + delta) % pages + 1
end

function stock.hitSearch(state, x, y)
  return state.view == "ae2_counts" and actionBar.hit(state, "stock", x, y) == "search"
end

function stock.setSearchActive(state, active)
  stock.ensure(state)
  state.stockSearchActive = active == true
  return true
end

local function setQuery(state, value)
  state.stockQuery = tostring(value or ""):sub(1, stock.maxQuery)
  state.stockPage = 1
  state.nextAe2StockRefresh = 0
end

function stock.handleClipboard(state, value)
  if not state.stockSearchActive then return false end
  setQuery(state, (state.stockQuery or "") .. tostring(value or ""))
  return true
end

function stock.handleTouch(state, x, y)
  if state.view ~= "ae2_counts" then return false end
  local action = actionBar.hit(state, "stock", x, y)
  if action == "prev" then stock.movePage(state, -1)
  elseif action == "next" then stock.movePage(state, 1)
  elseif action == "search" then return stock.setSearchActive(state, true)
  else return false end
  return true
end

function stock.handleKey(state, char, code, keyboard)
  if state.view ~= "ae2_counts" then return false end
  stock.ensure(state)
  local left = keyboard.keys and keyboard.keys.left
  local right = keyboard.keys and keyboard.keys.right
  if left and code == left then
    stock.movePage(state, -1)
    return true
  elseif right and code == right then
    stock.movePage(state, 1)
    return true
  elseif state.stockSearchActive then
    if char == 13 then
      state.stockSearchActive = false
      return true
    elseif char == 24 then
      if state.stockQuery == "" then return false end
      state.stockSearchClipboard = state.stockQuery
      setQuery(state, "")
      return true
    elseif char == 3 then
      if state.stockQuery == "" then return false end
      state.stockSearchClipboard = state.stockQuery
      return false
    elseif char == 22 then
      local value = state.stockSearchClipboard or ""
      if value == "" then return false end
      setQuery(state, value)
      return true
    elseif char == 8 or char == 127 then
      if state.stockQuery == "" then return false end
      setQuery(state, state.stockQuery:sub(1, #state.stockQuery - 1))
      return true
    elseif char and char >= 32 and char <= 126 then
      setQuery(state, state.stockQuery .. string.char(char))
      return true
    end
  end
  return false
end

return stock
local style = require("oc.dashboard.style")
local subtabs = require("oc.dashboard.subtabs")
local numbers = require("oc.dashboard.number_format")

local alerts = {}
local colors = style.colors

local function add(rows, label, policy, color)
  rows[#rows + 1] = { label = label, policy = policy, color = color or colors.warn }
end

local function addCraftAlarm(rows, seen, label, status)
  status = tostring(status or "")
  if status ~= "failed" and status ~= "canceled" then return end
  label = tostring(label or "target")
  local key = status .. ":" .. label
  if seen[key] then return end
  seen[key] = true
  add(rows, "Craft request " .. status .. ": " .. label, "silent dashboard notice only", colors.bad)
end

local function addLowStockAlarm(rows, seen, row)
  row = row or {}
  if row.alertEnabled == false then return end
  local current = tonumber(row.current)
  local below = tonumber(row.alertBelow or row.min)
  if not (current and below and current < below) then return end
  local label = tostring(row.label or "target")
  local key = "low:" .. label
  if seen[key] then return end
  seen[key] = true
  add(rows, "Line low: " .. label .. " " .. numbers.ratio(current, below),
    "silent dashboard notice only", colors.warn)
end

local function firstBattery(state)
  return state.power and state.power.readings and state.power.readings[1] or {}
end

function alerts.evaluate(state)
  local rows = {}
  if not (state.ae2 and state.ae2.available) then
    add(rows, "AE2 disconnected", "silent dashboard notice only", colors.bad)
  end
  local battery = firstBattery(state)
  if type(battery.ratio) == "number" and battery.ratio < 0.25 then
    add(rows, "Battery low", "silent dashboard notice only", colors.bad)
  end
  if type(battery.effectiveAvgIn) == "number" and type(battery.effectiveAvgOut) == "number" then
    if battery.effectiveAvgOut > battery.effectiveAvgIn * 1.25 and (battery.ratio or 0) < 0.80 then
      add(rows, "Power deficit", "silent dashboard notice only", colors.warn)
    end
  end
  local seenCraft, seenLow = {}, {}
  for _, row in ipairs((state.ae2Maintain and state.ae2Maintain.targets) or {}) do
    addLowStockAlarm(rows, seenLow, row)
    addCraftAlarm(rows, seenCraft, row.label, row.requestState)
  end
  local daemon = state.ae2MaintainDaemon or {}
  for _, row in ipairs(daemon.targetStatus or {}) do
    addCraftAlarm(rows, seenCraft, row.label, row.status)
  end
  if daemon.lastSubmitFail and daemon.lastSubmitTarget then
    addCraftAlarm(rows, seenCraft, daemon.lastSubmitTarget, "failed")
  end
  if #rows == 0 then add(rows, "No active alarms", "silent policy idle", colors.good) end
  return rows
end

function alerts.draw(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "BATTERY ALARMS")
  subtabs.draw(style, panel, "power_alarms")
  style.text(panel.x + 2, panel.y + 2, "Alarm policy is visible here; terminal commands stay silent.", colors.muted, colors.panel, panel.w - 4)
  local y = panel.y + 4
  for _, row in ipairs(alerts.evaluate(state)) do
    if y >= panel.y + panel.h - 1 then break end
    y = style.textBlock(panel.x + 2, y, row.label, row.color, colors.panel, panel.w - 4, 2)
    y = style.textBlock(panel.x + 4, y, row.policy, colors.muted, colors.panel, panel.w - 6, 2) + 1
  end
end

return alerts
local actionBar = require("oc.dashboard.action_bar")
local columns = require("oc.dashboard.workflow_page_detail_columns")
local cpuStatus = require("oc.dashboard.cpu_status")
local hint = require("oc.dashboard.workflow_page_detail_hint")
local numbers = require("oc.dashboard.number_format")
local operatorStatus = require("oc.dashboard.operator_status")
local sections = require("oc.dashboard.ae2_page_sections")
local style = require("oc.dashboard.style")
local maintainerUi = require("oc.dashboard.maintainer_ui")
local subtabs = require("oc.dashboard.subtabs")

local page = {}
local colors = style.colors
local targetColumnSpec = {
  { label = "Armed", width = 8 }, { label = "State", width = 9 },
  { label = "Status", width = 36 }, { label = "Stock", width = 17 },
  { label = "Max", width = 9 }, { label = "Craft", width = 5 }
}
local logColumnSpec = { { label = "Amount", width = 8 }, { label = "Stock", width = 14 } }

local function powerLine(power)
  if not power or not power.available then return "Battery: missing" end
  local ratio = type(power.ratio) == "number" and string.format("%.1f%%", power.ratio * 100) or "n/a"
  return "Battery: " .. ratio .. "  " .. numbers.quantity(power.avgIn) .. " in / " .. numbers.quantity(power.avgOut) .. " out EU/t"
end

local function onOff(value)
  return value and "ON" or "OFF"
end

local function queueLine(daemon)
  daemon = daemon or {}
  return "CPUs: detected " .. numbers.integer(daemon.detectedCpuCount, "n/a")
    .. " busy " .. numbers.integer(daemon.busyCpuCount, "n/a")
    .. " Available: " .. numbers.integer(daemon.availableSlots, "n/a")
    .. " | Queue: " .. numbers.quantity(daemon.queueCount or 0)
    .. " In-flight: " .. numbers.quantity(daemon.inFlightCount or 0)
end

local function primaryAlert(report)
  local alert = ((report or {}).alerts and report.alerts[1]) or "Observe only"
  local power = ((report or {}).status or {}).power or {}
  if alert == "Power deficit" and (power.deficit ~= true or (tonumber(power.ratio) or 0) >= 0.80) then
    return "Observe only"
  end
  return alert
end

local function filterLabel(value)
  local query = tostring(value or "")
  if query == "" then return "Filter" end
  if #query > 18 then query = query:sub(1, 15) .. "..." end
  return "Filter: " .. query
end

local function filterCountText(matched, total, query)
  local text = "Targets: " .. numbers.countRatio(matched, total)
  query = tostring(query or "")
  if query ~= "" then text = text .. ' matching "' .. query .. '"' end
  return text
end

local function readinessCounts(rows)
  local armed, ready, blocked = 0, 0, 0
  for _, row in ipairs(rows or {}) do
    if row.armed then armed = armed + 1 end
    if row.ready then ready = ready + 1 else blocked = blocked + 1 end
  end
  return armed, ready, blocked
end

local function daemonState(daemon)
  if daemon and daemon.fresh then return "active" end
  if daemon and daemon.desiredEnabled == true then return daemon.lastTick and "stale" or "starting" end
  return "offline"
end

local function statusStrip(status, daemon, rows, pageNo, pages)
  local armed, ready, blocked = readinessCounts(rows)
  return operatorStatus.summaryStrip({
    "Auto " .. onOff(status.autoEnabled ~= false),
    "Daemon " .. daemonState(daemon),
    "Armed " .. numbers.countRatio(armed, #(rows or {})),
    "Ready " .. numbers.integer(ready),
    "Blocked " .. numbers.integer(blocked),
    "Page " .. numbers.countRatio(pageNo, pages)
  })
end

local function rowSummary(row)
  return operatorStatus.targetRow(row, {
    armedText = "ARMED",
    disarmedText = "DISARMED",
    stockLabel = "Stock ",
    batchLabel = "Max ",
    nextLabel = "next @"
  })
end

local function rowColor(row, selected, daemon)
  return operatorStatus.stateColor(row, selected, { daemonRequired = true, daemon = daemon })
end

local function drawTargetRow(panel, y, row, selected, daemon)
  local color = rowColor(row, selected, daemon)
  local width = panel.w - 4
  local leftWidth, rightWidth = columns.split(width, targetColumnSpec, 4)
  if rightWidth <= 0 then
    style.textBlock(panel.x + 2, y, rowSummary(row), color, colors.panel, width, 1)
    return
  end
  local left, cells = operatorStatus.targetColumns(row, {
    armedText = "ARMED",
    disarmedText = "DISARMED",
    statusColumn = true, splitStatusColumns = true,
    nextLabel = "next @"
  })
  style.textBlock(panel.x + 2, y, left, color, colors.panel, leftWidth, 1)
  columns.drawValues(panel.x + 3 + leftWidth, y, cells, targetColumnSpec, color)
end

local function drawTargetHeader(panel, y)
  return columns.drawHeader(panel, y, targetColumnSpec, 4, "Request")
end

local function drawLogRow(x, y, width, row)
  local left, cells = operatorStatus.logColumns(row)
  local leftWidth, rightWidth = columns.split(width, logColumnSpec, 18)
  if rightWidth <= 0 then
    local _, compact = operatorStatus.logRowParts(row)
    style.textBlock(x, y, left .. " " .. compact, colors.text, colors.panel, width, 1)
    return
  end
  style.textBlock(x, y, left, colors.text, colors.panel, leftWidth, 1)
  columns.drawValues(x + leftWidth + 1, y, cells, logColumnSpec, colors.text)
end

local function drawLogHeader(x, y, width)
  return sections.headerAt(x, y, width, logColumnSpec, 18, "Request")
end

local function drawSearch(panel, state, rows, y, status, daemon, maxRows)
  state.ae2MaintainSearchY = y
  local perPage = math.max(1, math.min(maintainerUi.maxPerPage, maxRows or panel.h - 10))
  state.ae2MaintainPerPage = perPage
  local pageRows, matched, pages, total = maintainerUi.pageEntries(state, rows, perPage)
  style.text(panel.x + 2, y, statusStrip(status, daemon, rows, state.ae2MaintainPage, pages)
    .. " | " .. filterCountText(matched, total, state.ae2MaintainQuery), colors.text, colors.panel, panel.w - 4)
  state.ae2MaintainButtonY = y + 1
  local listY = actionBar.draw(state, "maintainer", panel.x + 2, state.ae2MaintainButtonY, panel.w - 4, {
    { key = "<", label = "Prev", action = "prev" },
    { label = filterLabel(state.ae2MaintainQuery), action = "search", good = state.ae2MaintainSearchActive },
    { key = ">", label = "Next", action = "next" },
    { key = "G", label = "Global Auto", action = "global", good = status.autoEnabled ~= false },
    { label = "Daemon", action = "daemon", good = daemon and (daemon.fresh or daemon.desiredEnabled == true) }
  })
  return pageRows, listY
end

local function hintText(state)
  local row = maintainerUi.selectedRow(state or {}) or {}
  local label = tostring(row.label or "target")
  local message = tostring((state and state.ae2MaintainMessage) or "")
  local text = "SELECTED " .. label .. ": Armed is permission, State is READY/BLOCKED, Status is the reason; Stock is current/Alert Below; Max caps sends and daemon batches; Craft confirms recipes."
  if message ~= "" then return message .. " " .. text end
  return text
end

function page.draw(panel, state)
  state = state or {}
  style.box(panel.x, panel.y, panel.w, panel.h, "AE2 MAINTAINER")
  subtabs.draw(style, panel, "ae2_maintain")
  local report = state.ae2Maintain or {}
  report = report or {}
  local status = report.status or {}
  local daemon = state.ae2MaintainDaemon
  local alert = primaryAlert(report)
  local insideBottom = panel.y + panel.h - 2
  local footerH = panel.h >= 18 and hint.height or 2
  local footerY = math.max(panel.y + 10, insideBottom - footerH + 1)
  local contentBottom = footerY - 1
  style.text(panel.x + 2, panel.y + 2, "Mode: " .. tostring(status.mode or "observe") .. "  " .. alert, colors.muted, colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 3, powerLine(status.power), colors.text, colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 4, cpuStatus.maintainerLine(state, status), colors.text, colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 5, "Crafts: " .. numbers.quantity(status.craftables or 0)
    .. " available; Targets: " .. numbers.integer(status.targetCount or 0), colors.text, colors.panel, panel.w - 4)
  style.text(panel.x + 2, panel.y + 6, queueLine(daemon), colors.muted, colors.panel, panel.w - 4)

  local rows, y = drawSearch(panel, state, report.targets or {}, panel.y + 7, status, daemon,
    math.max(1, contentBottom - panel.y - 10))
  y = drawTargetHeader(panel, y)
  state.ae2MaintainListY = y
  for _, row in ipairs(rows or {}) do
    if y > contentBottom then break end
    local selected = row._maintainerIndex == (state.ae2MaintainSelected or 1)
    drawTargetRow(panel, y, row, selected, daemon)
    y = y + 1
  end
  if #(rows or {}) == 0 and y <= contentBottom then
    style.text(panel.x + 2, y, "No maintainer targets loaded", colors.warn, colors.panel, panel.w - 4)
  end
  hint.drawText(panel, state, footerY, "MAINTAINER HINT", hintText(state), insideBottom - footerY + 1, "ae2Maintain")
end

function page.drawLogs(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "AE2 MAINTAINER LOGS")
  subtabs.draw(style, panel, "ae2_logs")
  local log = (state and state.ae2Logs) or {}
  local rows = log.rows or {}
  local pageNo = log.page or (state and state.ae2LogPage) or 1
  local pages = log.pages or 1
  sections.band(panel, panel.y + 2, "Logbook", "Page " .. numbers.countRatio(pageNo, pages)
    .. " | " .. numbers.integer(log.total or 0) .. " batches | " .. tostring(log.path or "/var/oc/ae2-maintainer.log"),
    colors.muted, colors.panel, panel.w - 4)
  state.ae2LogButtonY = panel.y + 3
  local listStart = actionBar.draw(state, "maintainer_logs", panel.x + 2, state.ae2LogButtonY, panel.w - 4, {
    { key = "<", label = "Prev", action = "prev" },
    { key = ">", label = "Next", action = "next" }
  }) + 1
  if log.error then
    style.textBlock(panel.x + 2, listStart, "Log read failed: " .. tostring(log.error), colors.warn, colors.panel, panel.w - 4, 2)
    return
  end
  local colWidth = math.floor((panel.w - 5) / 2)
  local rowStart = drawLogHeader(panel.x + 2, listStart, colWidth - 1)
  drawLogHeader(panel.x + 2 + colWidth, listStart, colWidth - 1)
  local rowsPerCol = math.max(1, math.min(math.ceil((log.perPage or 25) / 2), panel.y + panel.h - rowStart - 1))
  for i, row in ipairs(rows) do
    local col = math.floor((i - 1) / rowsPerCol)
    local lineRow = (i - 1) % rowsPerCol
    local x = panel.x + 2 + (col * colWidth)
    local y = rowStart + lineRow
    if y < panel.y + panel.h - 1 and x < panel.x + panel.w - 4 then
      drawLogRow(x, y, colWidth - 1, row)
    end
  end
  if #rows == 0 then
    style.text(panel.x + 2, rowStart, "No maintainer batches logged yet.", colors.warn, colors.panel, panel.w - 4)
  end
end

return page
local actionBar = require("oc.dashboard.action_bar")
local columns = require("oc.dashboard.workflow_page_detail_columns")
local cpuStatus = require("oc.dashboard.cpu_status")
local hint = require("oc.dashboard.workflow_page_detail_hint")
local numbers = require("oc.dashboard.number_format")
local operatorStatus = require("oc.dashboard.operator_status")
local style = require("oc.dashboard.style")
local time = require("oc.ae2.time")
local maintainerUi = require("oc.dashboard.maintainer_ui")
local subtabs = require("oc.dashboard.subtabs")

local page = {}
local colors = style.colors
local targetColumnSpec = {
  { label = "Armed", width = 8 }, { label = "State", width = 9 },
  { label = "Status", width = 36 }, { label = "Stock", width = 17 },
  { label = "Max", width = 9 }, { label = "Craft", width = 5 }
}

local function onOff(value)
  return value and "ON" or "OFF"
end

local function uptimeText(value)
  if type(value) ~= "number" then return "never" end
  return time.duration(value)
end

local function stampText(value)
  if type(value) ~= "number" then return "never" end
  return time.short(value)
end

local function nextRequest(daemon)
  daemon = daemon or {}
  if daemon.desiredEnabled == false then return "disabled" end
  if daemon.starting and tonumber(daemon.startupRemaining) and daemon.startupRemaining > 0 then
    return "startup in " .. uptimeText(daemon.startupRemaining)
  end
  if not daemon.lastTick then return "waiting for first heartbeat" end
  if type(daemon.nextIn) == "number" then
    if daemon.nextIn <= 0 then return "due now" end
    return uptimeText(daemon.nextIn)
  end
  return tostring(daemon.nextCycleAt or "unknown")
end

local function cpuSlots(daemon)
  local detected = tonumber(daemon and daemon.detectedCpuCount)
  local available = tonumber(daemon and daemon.availableSlots)
  local busy = tonumber(daemon and daemon.busyCpuCount)
  if not available and detected and busy then available = math.max(0, detected - busy) end
  if detected then return numbers.countRatio(available or 0, detected) end
  return numbers.integer(available, "n/a")
end

local function daemonPower(daemon)
  if daemon and (daemon.desiredEnabled == true or daemon.running == true or daemon.starting == true) then return "ON" end
  return "OFF"
end

local function commandStateStrip(status, daemon, state)
  daemon = daemon or {}
  local cpuText, finals = cpuStatus.daemonParts(state, status, cpuSlots(daemon))
  local parts = {
    "Daemon " .. daemonPower(daemon),
    "Global Auto " .. onOff(status.autoEnabled ~= false),
    "Next request " .. nextRequest(daemon),
    "Queue " .. numbers.quantity(daemon.queueCount or 0),
    "In-flight " .. numbers.quantity(daemon.inFlightCount or 0),
    "CPUs " .. cpuText
  }
  if finals then parts[#parts + 1] = finals:gsub(":", "", 1) end
  return operatorStatus.summaryStrip(parts)
end

local function selectedTargetLine(row)
  return operatorStatus.targetRow(row, {
    selected = true,
    prefix = "Selected: ",
    separator = " | ",
    stockLabel = "stock ",
    batchLabel = "max ",
    lowerLabels = true,
    lowerState = true
  })
end

local function selectedColor(row, daemon)
  return operatorStatus.stateColor(row, false, { daemonRequired = true, daemon = daemon })
end

local function submitReceipt(daemon)
  daemon = daemon or {}
  if daemon.lastSubmitFail then
    return "Last submit failed @" .. stampText(daemon.lastSubmitFail)
  elseif daemon.lastSubmitOk then
    return "Last submit ok @" .. stampText(daemon.lastSubmitOk)
  elseif daemon.lastSubmitAttempt then
    return "Last submit attempted @" .. stampText(daemon.lastSubmitAttempt)
  end
  return nil
end

local function cockpitFooter(state, daemon)
  local message = state and state.ae2MaintainMessage
  if message and message ~= "" then return message, colors.muted end
  if daemon and daemon.lastError then return "Warning: " .. tostring(daemon.lastError), colors.warn end
  return nil, nil
end

local function selectedTarget(state)
  return maintainerUi.selectedRow(state or {}) or {}
end

local function selectedRowHeight(panel)
  return panel.h >= 28 and 3 or 1
end

local function drawSelectedTarget(panel, y, row, daemon)
  local width = panel.w - 4
  local leftWidth, rightWidth = columns.split(width, targetColumnSpec, 4)
  if rightWidth <= 0 then
    style.textBlock(panel.x + 2, y, selectedTargetLine(row), selectedColor(row, daemon), colors.panel, width, 1)
    return y + 1
  end
  y = columns.drawHeader(panel, y, targetColumnSpec, 4, "Target")
  local left, cells = operatorStatus.targetColumns(row, {
    armedText = "ARMED",
    disarmedText = "DISARMED",
    statusColumn = true, splitStatusColumns = true
  })
  local height = selectedRowHeight(panel)
  local color = selectedColor(row, daemon)
  style.textBlock(panel.x + 2, y, left, color, colors.panel, leftWidth, height)
  columns.drawValueBlocks(panel.x + 3 + leftWidth, y, cells, targetColumnSpec, color, colors.panel, height)
  return y + height
end

local function hintText(state, daemon, selected)
  local footer = cockpitFooter(state, daemon)
  local label = tostring(selected and selected.label or "target")
  local text = "SELECTED " .. label .. ": Armed is permission, State is READY/BLOCKED, Status is the active gate; Stock is current/Alert Below; Max caps sends; Danger buttons stay guarded."
  if footer and footer ~= "" then return footer .. " " .. text end
  return text
end

function page.draw(panel, state)
  state = state or {}
  style.box(panel.x, panel.y, panel.w, panel.h, "AE2 DAEMON + ARMING")
  subtabs.draw(style, panel, "ae2_daemon")
  local report = state.ae2Maintain or {}
  local status = report.status or {}
  local daemon = state.ae2MaintainDaemon or {}
  local intervalLocked = daemon.desiredEnabled == true or daemon.running == true
  local intervalText = numbers.seconds(daemon.configInterval)
  local intervalHint = intervalLocked and "locked while running" or "type to edit"
  local insideBottom = panel.y + panel.h - 2
  local footerH = panel.h >= 18 and hint.height or 2
  local footerY = math.max(panel.y + 10, insideBottom - footerH + 1)
  local contentBottom = footerY - 1
  if state.ae2DaemonIntervalEdit then
    intervalText = "[" .. tostring(state.ae2DaemonIntervalValue or "") .. "_]"
    intervalHint = "editing"
  end
  local y = panel.y + 2

  style.text(panel.x + 2, y, commandStateStrip(status, daemon, state), daemon.fresh and colors.good or colors.warn, colors.panel, panel.w - 4); y = y + 1
  state.ae2DaemonIntervalY = y
  style.text(panel.x + 2, y, "Interval " .. intervalText .. " (" .. intervalHint .. ")"
    .. " | Poll " .. numbers.seconds(daemon.configPollInterval), colors.muted, colors.panel, panel.w - 4); y = y + 1
  style.text(panel.x + 2, y, "Controls", colors.accent, colors.panel, panel.w - 4)
  y = y + 1
  state.ae2DaemonPrimaryActionY = y
  y = actionBar.draw(state, "daemon_primary", panel.x + 2, y, panel.w - 4, {
    { label = "Shift+D Daemon", action = "daemon", good = daemon.desiredEnabled == true or daemon.running == true },
    { label = "G Global Auto", action = "global", good = status.autoEnabled ~= false }
  })
  style.text(panel.x + 2, y, "Interval: click/type while stopped; accepts s/m/h/d/w; min 10m, max 1w", colors.muted, colors.panel, panel.w - 4)
  y = y + 1
  local receipt = submitReceipt(daemon)
  if receipt then
    style.text(panel.x + 2, y, "Status: " .. receipt, colors.muted, colors.panel, panel.w - 4)
    y = y + 1
  end

  local selected = selectedTarget(state)
  y = drawSelectedTarget(panel, y, selected, daemon)
  state.ae2DaemonTargetActionY = y
  y = actionBar.draw(state, "daemon_target", panel.x + 2, y, panel.w - 4, {
    { label = "Shift+F Arm Target", action = "arm", good = selected.armed == true },
    { label = "M Send Max", action = "manual" },
    { label = "F Open Flow", action = "flow" },
    { label = "Del Delete", action = "delete", warn = true }
  })

  if y <= contentBottom then
    style.text(panel.x + 2, y, "Danger", colors.warn, colors.panel, panel.w - 4)
    y = y + 1
    actionBar.draw(state, "daemon_danger", panel.x + 2, y, panel.w - 4, {
      { label = "Next Request Now", action = "next_now", danger = true },
      { label = "Arm All", action = "arm_all", warn = true },
      { label = "Start All", action = "start_all", danger = true },
      { label = "Disarm All", action = "disarm", warn = true },
      { label = "X Stop All", action = "stop", danger = true }
    })
  else
    actionBar.draw(state, "daemon_danger", panel.x + 2, y, panel.w - 4, {})
  end
  hint.drawText(panel, state, footerY, "DAEMON HINT", hintText(state, daemon, selected),
    insideBottom - footerY + 1, "ae2Daemon")
end

return page
local computer = require("computer")
local daemonControl = require("oc.ae2.maintainer_daemon_control")
local workflows = require("oc.ae2.workflows")
local numbers = require("oc.dashboard.number_format")
local bulk = require("oc.dashboard.maintainer_ui_bulk")
local manualMemory = require("oc.dashboard.manual_request_memory")
local list = require("oc.dashboard.maintainer_ui_list")
local receipt = require("oc.dashboard.maintainer_ui_receipt")

local actions = {}
local setModeForArmedTargets
local recordManualMaintainer = manualMemory.recordManualMaintainer
local requestAmount = receipt.requestAmount
local requestReceipt = receipt.text

local function refreshSoon(state)
  state.ae2MaintainDirty = true
  state.nextAe2MaintainRefresh = 0
  manualMemory.queueDaemonHeartbeat(state)
end
local function refreshDaemonOnly(state) state.nextAe2DaemonRefresh = 0 end

local function flowEntry(row)
  if not row then return nil end
  local flow = workflows.workflowFor(nil, row) or {
    label = row.label,
    rawLabel = row.rawLabel,
    name = row.name,
    damage = row.damage,
    hasTag = row.hasTag,
    kind = row.kind,
    isFluid = row.isFluid,
    amount = row.amount,
    filter = row.filter,
    craftBinding = row.craftBinding,
    mode = "auto",
    lineIntent = row.lineIntent,
    lineAuthority = row.lineAuthority,
    alertEnabled = row.alertEnabled,
    alertBelow = row.alertBelow or row.min,
    maxRequest = tonumber(row.maxRequest or row.batch or row.request or row.craftTo or 1) or 1,
    maxBasis = row.maxBasis,
    confidence = row.confidence,
    recipeMax = row.recipeMax,
    dangerUnlocked = row.dangerUnlocked,
    locked = row.locked,
    minStock = row.alertBelow or row.min,
    craftTo = row.craftTo,
    batch = tonumber(row.maxRequest or row.batch or row.request or row.craftTo or 1) or 1,
    minBatteryRatio = row.minBatteryRatio,
    maxDeficitRatio = row.maxDeficitRatio,
    requireReadyCpu = row.requireReadyCpu,
    cooldown = row.cooldown,
    armed = row.armed == true
  }
  return {
    label = flow.label or row.label,
    rawLabel = flow.rawLabel or row.rawLabel,
    name = flow.name or row.name,
    damage = flow.damage or row.damage,
    hasTag = flow.hasTag ~= nil and flow.hasTag or row.hasTag,
    kind = flow.kind or row.kind,
    isFluid = flow.isFluid ~= nil and flow.isFluid or row.isFluid,
    amount = flow.amount or row.amount,
    filter = flow.filter or row.filter,
    craftBinding = flow.craftBinding or row.craftBinding,
    source = row.source,
    craftIndex = row.craftIndex,
    rawCraftIndex = row.rawCraftIndex,
    craftable = row.craftable,
    mode = flow.mode,
    workflow = flow
  }
end
local function removeSelectedRow(state, row)
  local rows = list.rows(state)
  local index = row and row._maintainerIndex or state.ae2MaintainSelected or 1
  for i, candidate in ipairs(rows) do
    if candidate == row then index = i; break end
  end
  if rows[index] then table.remove(rows, index) end
  state.ae2MaintainSelected = math.max(1, math.min(index, math.max(1, #rows)))
  if state.ae2Maintain and state.ae2Maintain.status then
    state.ae2Maintain.status.targetCount = #rows
  end
end
function actions.openFlow(state)
  local row = list.selectedRow(state)
  local entry = flowEntry(row)
  if not entry then return false end
  state.ae2Workflow = {
    entries = { entry },
    config = state.ae2Maintain and state.ae2Maintain.config or nil,
    complete = true,
    matched = 1,
    rawCount = 1,
    cache = state.ae2CraftCache or {}
  }
  state.ae2WorkflowSelected = 1
  state.ae2WorkflowPage = 1
  state.ae2WorkflowField = 1
  state.ae2WorkflowQuery = ""
  state.ae2WorkflowMessage = "Opened from Maintainer; conditions loaded from shared workflow config."
  local now = computer.uptime()
  state.nextAe2WorkflowRefresh = now + 60
  state.view = "ae2_workflow"
  return true
end

function actions.requestManual(state)
  local row = list.selectedRow(state)
  local entry = flowEntry(row)
  if not entry then return false end
  local amount = requestAmount(entry)
  local ok, err, report = workflows.requestManual(entry)
  state.ae2MaintainMessage = ok and requestReceipt("Manual request sent: ", entry, amount)
    or requestReceipt("Manual request failed for ", entry, amount)
  recordManualMaintainer(state, entry, ok, err, report, row)
  return true
end

function actions.deleteTarget(state)
  local row = list.selectedRow(state)
  local entry = flowEntry(row)
  if not entry then return false end
  local ok, err, config = workflows.delete(entry)
  if ok then
    removeSelectedRow(state, row)
    setModeForArmedTargets(state, config)
    if state.ae2Maintain then state.ae2Maintain.config = config end
    state.ae2MaintainMessage = "Deleted " .. tostring(entry.label or "target") .. " from maintainer workflows."
  else
    state.ae2MaintainMessage = "Delete failed: " .. tostring(err)
  end
  refreshSoon(state)
  return true
end

function setModeForArmedTargets(state, config)
  return bulk.setModeForArmedTargets(state, config)
end

function actions.toggleTarget(state)
  local row = list.selectedRow(state)
  if not row then return false end
  local nextArmed = not (row.armed == true)
  local ok, err, config = workflows.toggleArmed(row)
  if ok then
    setModeForArmedTargets(state, config)
    row.armed = nextArmed
    state.ae2MaintainMessage = tostring(row.label) .. " is " .. (row.armed and "armed." or "disarmed.")
  else
    state.ae2MaintainMessage = "Target update failed: " .. tostring(err)
  end
  refreshSoon(state)
  return true
end

function actions.disarmAll(state)
  return bulk.disarm(state)
end

function actions.toggleGlobalAuto(state)
  local ok, err, config = workflows.toggleGlobalAuto()
  if ok then
    setModeForArmedTargets(state, config)
    if state.ae2Maintain and state.ae2Maintain.config then state.ae2Maintain.config = config end
    local enabled = workflows.autoEnabled(config)
    state.ae2MaintainMessage = "Global auto is " .. (enabled and "on." or "off.")
  else
    state.ae2MaintainMessage = "Global auto toggle failed: " .. tostring(err)
  end
  refreshSoon(state)
  return true
end

function actions.toggleDaemon(state)
  local ok, err, status = daemonControl.toggle()
  if ok then
    state.ae2MaintainDaemon = status
    state.ae2MaintainMessage = "Daemon desired state is "
      .. ((status and status.desiredEnabled) and "on." or "off.")
  else
    state.ae2MaintainMessage = "Daemon toggle failed: " .. tostring(err)
  end
  refreshSoon(state)
  return true
end

function actions.nextBatchNow(state)
  if not daemonControl.nextBatchNow then
    state.ae2MaintainMessage = "Next Batch Now requires updated AE2 daemon control."; return true
  end
  local ok, err, status = daemonControl.nextBatchNow(); if status then state.ae2MaintainDaemon = status end
  state.ae2MaintainMessage = ok and "Next daemon request cycle requested." or ("Next daemon request cycle failed: " .. tostring(err))
  refreshDaemonOnly(state); return true
end

function actions.setDaemonInterval(state, seconds)
  local ok, err, status = daemonControl.setInterval(seconds)
  if ok then
    state.ae2MaintainDaemon = status
    state.ae2MaintainMessage = "Daemon interval set to "
      .. numbers.seconds(status and status.configInterval) .. "."
  else
    state.ae2MaintainMessage = "Daemon interval edit failed: " .. tostring(err)
  end
  refreshSoon(state)
  return true
end

local function issueText(parts)
  local issues = {}
  for _, part in ipairs(parts or {}) do
    if not part.ok then issues[#issues + 1] = part.name .. " " .. tostring(part.err or "failed") end
  end
  if #issues == 0 then return nil end
  return table.concat(issues, "; ")
end

function actions.armAll(state)
  return bulk.arm(state)
end

function actions.startAllAutomation(state)
  local issue
  if bulk.first(state, "start_all") then
    local daemonOk, daemonErr, daemonStatus = daemonControl.start()
    local autoOk, autoErr = workflows.setGlobalAuto(true)
    if daemonStatus then state.ae2MaintainDaemon = daemonStatus end
    issue = issueText({
      { name = "daemon", ok = daemonOk, err = daemonErr },
      { name = "auto", ok = autoOk, err = autoErr }
    })
  end
  return bulk.setAllArmed(state, "start_all", true, "Start All", issue)
end

function actions.stopAllAutomation(state)
  local issue
  if bulk.first(state, "stop_all") then
    local daemonOk, daemonErr, daemonStatus = daemonControl.stop()
    local autoOk, autoErr = workflows.setGlobalAuto(false)
    if daemonStatus then state.ae2MaintainDaemon = daemonStatus end
    issue = issueText({
      { name = "daemon", ok = daemonOk, err = daemonErr },
      { name = "auto", ok = autoOk, err = autoErr }
    })
  end
  return bulk.setAllArmed(state, "stop_all", false, "Stop All", issue)
end

return actions
local time = require("oc.ae2.time")
local numbers = require("oc.dashboard.number_format")

local receipt = {}

local function fluidLike(entry)
  local name = tostring(entry and entry.name or ""):lower()
  local raw = tostring(entry and entry.rawLabel or ""):lower()
  return entry and (entry.isFluid == true or entry.kind == "fluid"
    or name:find("fluid", 1, true) ~= nil or raw:find("^drops? of") ~= nil)
end

function receipt.requestAmount(entry)
  local flow = entry and entry.workflow or {}
  return tonumber(flow.maxRequest or flow.batch or (entry and (entry.maxRequest or entry.batch or entry.request))) or 1
end

function receipt.text(prefix, entry, amount)
  local label = tostring(entry and (entry.label or entry.rawLabel or entry.name) or "target")
  local shown = numbers.quantity(amount) .. (fluidLike(entry) and " mB " or "x ")
  return tostring(prefix or "") .. shown .. label .. " @" .. time.short() .. "."
end

return receipt
local computer = require("computer")
local maintainer = require("oc.ae2.maintainer")
local workflows = require("oc.ae2.workflows")
local list = require("oc.dashboard.maintainer_ui_list")
local numbers = require("oc.dashboard.number_format")

local bulk = {}
local BULK_LIMIT = 8
local BULK_DELAY = 5

local function refreshSoon(state)
  state.ae2MaintainDirty = true
  state.nextAe2MaintainRefresh = 0
  state.nextAe2DaemonRefresh = 0
end

local function syncRows(state, config)
  if not config then return end
  if state.ae2Maintain then state.ae2Maintain.config = config end
  for _, row in ipairs(list.rows(state)) do
    local flow = workflows.workflowFor(config, row)
    if flow then row.armed = flow.armed == true end
  end
end

local function message(label, progress)
  progress = progress or {}
  local checked = tonumber(progress.checked) or 0
  local changed = tonumber(progress.changed) or 0
  local blocked = tonumber(progress.blocked) or 0
  local total = tonumber(progress.total) or 0
  if progress.complete then
    local suffix = blocked > 0 and ("; " .. numbers.integer(blocked) .. " need exact binding") or ""
    return label .. " complete: " .. numbers.integer(changed) .. " changed; " .. numbers.integer(total) .. " scanned" .. suffix .. "."
  end
  return label .. ": " .. numbers.integer(checked) .. " checked this batch; continuing in 5s."
end

function bulk.setModeForArmedTargets(state, config)
  local mode = workflows.autoEnabled(config) and workflows.armedCount(config) > 0 and "armed" or "observe"
  local ok, err = maintainer.setMode(mode)
  if ok then state.ae2MaintainerMode = mode end
  return ok, err
end

function bulk.first(state, action)
  local current = state.ae2DaemonBulk
  return not current or current.action ~= action or current.complete == true
end

local function startIndex(state, action)
  if bulk.first(state, action) then
    state.ae2DaemonBulk = { action = action, nextIndex = 1 }
  end
  return tonumber(state.ae2DaemonBulk and state.ae2DaemonBulk.nextIndex) or 1
end

local function remember(state, action, progress)
  progress = progress or { complete = true, nextIndex = 1 }
  if progress.complete then
    state.ae2DaemonBulk = nil
  else
    state.ae2DaemonBulk = {
      action = action,
      nextIndex = tonumber(progress.nextIndex) or 1,
      nextAt = computer.uptime() + BULK_DELAY
    }
  end
  return progress
end

local function callSetAllArmed(enabled, options)
  if enabled then return workflows.setAllArmed(true, options) end
  return workflows.setAllArmed(false, options)
end

function bulk.setAllArmed(state, action, enabled, label, issue)
  local options = { startIndex = startIndex(state, action), limit = BULK_LIMIT }
  local ok, err, config, progress = callSetAllArmed(enabled, options)
  progress = remember(state, action, progress)
  if config then
    bulk.setModeForArmedTargets(state, config)
    syncRows(state, config)
  end
  if ok then
    state.ae2MaintainMessage = message(label, progress)
    if issue and issue ~= "" then state.ae2MaintainMessage = issue .. "; " .. state.ae2MaintainMessage end
  else
    state.ae2MaintainMessage = label .. " failed: " .. tostring(err)
  end
  refreshSoon(state)
  return true
end

function bulk.arm(state)
  return bulk.setAllArmed(state, "arm_all", true, "Arm All")
end

function bulk.disarm(state)
  return bulk.setAllArmed(state, "disarm_all", false, "Disarm All")
end

function bulk.continue(state, now)
  local current = state and state.ae2DaemonBulk
  if not (current and current.nextAt) or tonumber(now) < current.nextAt then return false end
  if current.action == "arm_all" then return bulk.setAllArmed(state, "arm_all", true, "Arm All") end
  if current.action == "start_all" then return bulk.setAllArmed(state, "start_all", true, "Start All") end
  if current.action == "disarm_all" then return bulk.setAllArmed(state, "disarm_all", false, "Disarm All") end
  if current.action == "stop_all" then return bulk.setAllArmed(state, "stop_all", false, "Stop All") end
  state.ae2DaemonBulk = nil
  return true
end

return bulk
local actionBar = require("oc.dashboard.action_bar")
local actions = require("oc.dashboard.maintainer_ui_actions")
local list = require("oc.dashboard.maintainer_ui_list")
local daemonUi = {}
local function digit(char) return type(char) == "number" and char >= string.byte("0") and char <= string.byte("9") end
local SUFFIXES = "SsMmHhDdWw"
local function suffix(char) return type(char) == "number" and SUFFIXES:find(string.char(char), 1, true) ~= nil end
local function durationEditChar(char, value)
  value = tostring(value or "")
  if digit(char) and not value:match("[SsMmHhDdWw]$") then return string.char(char) end
  if char == string.byte(".") and value ~= "" and not value:find("%.", 1, false)
    and not value:match("[SsMmHhDdWw]$") then return "." end
  if suffix(char) and value ~= "" and value ~= "." and not value:match("[SsMmHhDdWw]$") then
    return string.char(char)
  end
  return nil
end

local function running(state)
  local daemon = (state and state.ae2MaintainDaemon) or {}
  return daemon.desiredEnabled == true or daemon.running == true or daemon.starting == true
end

local function isCtrlC(char, code, keyboard) return char == 3 or (code == (keyboard and keyboard.keys and keyboard.keys.c or 46)
  and type(keyboard and keyboard.isControlDown) == "function" and keyboard.isControlDown() == true) end

function daemonUi.beginIntervalEdit(state, initial)
  if running(state) then
    state.ae2DaemonIntervalEdit, state.ae2DaemonIntervalValue = nil, nil
    state.ae2MaintainMessage = "Turn daemon off before changing interval."
    return true
  end
  local daemon = state.ae2MaintainDaemon or {}
  local value = initial or tostring(tonumber(daemon.configInterval) or 600)
  state.ae2DaemonIntervalEdit = true
  state.ae2DaemonIntervalValue = tostring(value):sub(1, 10)
  state.ae2MaintainMessage = "Type interval like 15m or 900s; Ctrl+S saves, Ctrl+C cancels."
  return true
end

function daemonUi.handleIntervalEdit(state, char, code, keyboard)
  if not state.ae2DaemonIntervalEdit then return nil end
  if isCtrlC(char, code, keyboard) then
    state.ae2DaemonIntervalEdit, state.ae2DaemonIntervalValue = nil, nil
    state.ae2MaintainMessage = "Interval edit canceled."
    return true
  elseif char == 19 then
    local value = tostring(state.ae2DaemonIntervalValue or "")
    if value == "" then
      state.ae2MaintainMessage = "Type interval duration before saving."
      return true
    end
    state.ae2DaemonIntervalEdit, state.ae2DaemonIntervalValue = nil, nil
    return actions.setDaemonInterval(state, value)
  elseif char == 8 or char == 127 then
    state.ae2DaemonIntervalValue = tostring(state.ae2DaemonIntervalValue or ""):sub(1, -2)
    return true
  else
    local nextChar = durationEditChar(char, state.ae2DaemonIntervalValue)
    if nextChar then
      state.ae2DaemonIntervalValue = (tostring(state.ae2DaemonIntervalValue or "") .. nextChar):sub(1, 10)
      return true
    end
  end
  state.ae2MaintainMessage = "Use digits plus s/m/h/d/w; Ctrl+S saves, Ctrl+C cancels."
  return true
end

function daemonUi.handleTouch(state, x, y)
  if state.view == "ae2_daemon" then
    local primary = actionBar.hit(state, "daemon_primary", x, y)
    if primary == "daemon" then return actions.toggleDaemon(state)
    elseif primary == "global" then return actions.toggleGlobalAuto(state) end
    local danger = actionBar.hit(state, "daemon_danger", x, y)
    if danger == "next_now" then return actions.nextBatchNow(state)
    elseif danger == "arm_all" then return actions.armAll(state)
    elseif danger == "start_all" then return actions.startAllAutomation(state)
    elseif danger == "disarm" then return actions.disarmAll(state)
    elseif danger == "stop" then return actions.stopAllAutomation(state) end
    local target = actionBar.hit(state, "daemon_target", x, y)
    if target == "arm" then return actions.toggleTarget(state)
    elseif target == "manual" then return actions.requestManual(state)
    elseif target == "flow" then return actions.openFlow(state)
    elseif target == "delete" then return actions.deleteTarget(state) end
  end
  if state.view == "ae2_daemon" and y == state.ae2DaemonIntervalY then
    return daemonUi.beginIntervalEdit(state, "")
  end
  return list.handleTouch(state, x, y)
end

function daemonUi.handleKey(state, char, code, keyboard)
  list.ensure(state)
  local editResult = daemonUi.handleIntervalEdit(state, char, code, keyboard)
  if editResult ~= nil then return editResult end
  if digit(char) then return daemonUi.beginIntervalEdit(state, string.char(char)) end
  if char == string.byte("D") then
    return actions.toggleDaemon(state)
  elseif code == keyboard.keys.delete then
    return actions.deleteTarget(state)
  elseif char == string.byte("g") or char == string.byte("G") then
    return actions.toggleGlobalAuto(state)
  elseif char == string.byte("m") or char == string.byte("M") then
    return actions.requestManual(state)
  elseif char == string.byte("f") then
    return actions.openFlow(state)
  elseif char == string.byte("X") then
    return actions.stopAllAutomation(state)
  elseif char == string.byte("F") then
    return actions.toggleTarget(state)
  elseif code == keyboard.keys.up then
    return list.moveSelection(state, -1)
  elseif code == keyboard.keys.down then
    return list.moveSelection(state, 1)
  end
  return false
end

return daemonUi
local list = {}
list.maxPerPage = 32

local function text(value)
  return tostring(value or ""):lower()
end

function list.rows(state)
  return (state.ae2Maintain and state.ae2Maintain.targets) or {}
end

function list.ensure(state)
  state.ae2MaintainQuery = state.ae2MaintainQuery or ""
  state.ae2MaintainPage = state.ae2MaintainPage or 1
  state.ae2MaintainSelected = state.ae2MaintainSelected or 1
end

function list.selectedRow(state)
  list.ensure(state)
  return list.rows(state)[state.ae2MaintainSelected] or list.rows(state)[1]
end

function list.matches(row, query)
  query = text(query)
  if query == "" then return true end
  local stateText = row and row.armed and "armed" or "disarmed"
  local readyText = row and row.ready and "ready" or "blocked"
  local craftableText = row and row.craftable and "craftable craft yes" or "uncraftable craft no"
  local requestState = (row and row.requestState) or (row and row.requestError and "failed") or ""
  local batch = (row and (row.maxRequest or row.batch)) or (row and row.request)
  local stock = row and (tostring(row and row.current or "") .. " " .. tostring(row and row.min or "")) or ""
  local batchLabel, stockLabel = "max maxrequest batch", "stock"
  local haystack = text(row and row.label) .. " " .. text(row and row.reason)
    .. " " .. text(requestState) .. " " .. text(row and row.requestPhase) .. " " .. text(row and row.requestError)
    .. " " .. stateText .. " " .. readyText
    .. " " .. craftableText
    .. " " .. batchLabel .. " " .. text(batch) .. " " .. stockLabel .. " " .. text(stock)
  for token in query:gmatch("%S+") do
    if token == "armed" and not (row and row.armed) then return false end
    if token == "disarmed" and row and row.armed then return false end
    if token == "ready" and not (row and row.ready) then return false end
    if token == "blocked" and row and row.ready then return false end
    if token == "craftable" and not (row and row.craftable) then return false end
    if token == "uncraftable" and row and row.craftable then return false end
    if token == "failed" and not (row and (row.requestState == "failed" or row.requestError)) then return false end
    if not haystack:find(token, 1, true) then return false end
  end
  return true
end

local function countMatches(rows, query)
  local total = 0
  for _, row in ipairs(rows or {}) do
    if list.matches(row, query) then total = total + 1 end
  end
  return total
end

local function collectPage(rows, query, first, last)
  local out, matched = {}, 0
  for index, row in ipairs(rows or {}) do
    if list.matches(row, query) then
      matched = matched + 1
      if matched >= first and matched <= last then
        row._maintainerIndex = index
        out[#out + 1] = row
      end
      if matched > last then break end
    end
  end
  return out
end

function list.pageEntries(state, rows, perPage)
  list.ensure(state)
  perPage = math.max(1, math.min(list.maxPerPage, perPage or 12))
  local matched = countMatches(rows, state.ae2MaintainQuery)
  local pages = math.max(1, math.ceil(matched / perPage))
  state.ae2MaintainPage = ((state.ae2MaintainPage or 1) - 1) % pages + 1
  local first = ((state.ae2MaintainPage - 1) * perPage) + 1
  local page = collectPage(rows, state.ae2MaintainQuery, first, first + perPage - 1)
  if page[1] and not list.matches(list.selectedRow(state), state.ae2MaintainQuery) then
    state.ae2MaintainSelected = page[1]._maintainerIndex
  end
  return page, matched, pages, #(rows or {})
end

function list.movePage(state, delta)
  local perPage = math.max(1, math.min(list.maxPerPage, state.ae2MaintainPerPage or 12))
  local pages = math.max(1, math.ceil(countMatches(list.rows(state), state.ae2MaintainQuery) / math.max(1, perPage)))
  state.ae2MaintainPage = ((state.ae2MaintainPage or 1) - 1 + delta) % pages + 1
  return true
end

function list.moveSelection(state, delta)
  list.ensure(state)
  local visible, pos = {}, 1
  for index, row in ipairs(list.rows(state)) do
    if list.matches(row, state.ae2MaintainQuery) then
      visible[#visible + 1] = index
      if index == state.ae2MaintainSelected then pos = #visible end
    end
  end
  if #visible == 0 then return true end
  pos = math.max(1, math.min(#visible, pos + delta))
  state.ae2MaintainSelected = visible[pos]
  local perPage = math.max(1, math.min(list.maxPerPage, state.ae2MaintainPerPage or 12))
  state.ae2MaintainPage = math.max(1, math.ceil(pos / math.max(1, perPage)))
  return true
end

function list.handleTouch(state, x, y)
  if state.view ~= "ae2_maintain" then return false end
  if y < (state.ae2MaintainListY or 11) then return false end
  local row = y - (state.ae2MaintainListY or 11) + 1
  local page = list.pageEntries(state, list.rows(state), state.ae2MaintainPerPage or 12)
  local item = page[row]
  if not item then return false end
  state.ae2MaintainSelected = item._maintainerIndex or row
  state.view = "ae2_daemon"
  return true
end

return list
local actionBar = require("oc.dashboard.action_bar")
local list = require("oc.dashboard.maintainer_ui_list")

local search = {}
search.maxQuery = 40

local function setQuery(state, value)
  state.ae2MaintainQuery = tostring(value or ""):sub(1, search.maxQuery)
  state.ae2MaintainPage = 1
end

function search.hitSearch(state, x, y)
  return state.view == "ae2_maintain"
    and actionBar.hit(state, "maintainer", x, y) == "search"
end

function search.setSearchActive(state, active)
  list.ensure(state)
  state.ae2MaintainSearchActive = active == true
  return true
end

function search.handleClipboard(state, value)
  if not state.ae2MaintainSearchActive then return false end
  setQuery(state, (state.ae2MaintainQuery or "") .. tostring(value or ""))
  return true
end

function search.handleKey(state, char)
  if not state.ae2MaintainSearchActive then return nil end
  if char == 24 then
    if state.ae2MaintainQuery == "" then return false end
    state.ae2MaintainSearchClipboard = state.ae2MaintainQuery
    setQuery(state, "")
    return true
  elseif char == 3 then
    state.ae2MaintainSearchClipboard = state.ae2MaintainQuery
    return false
  elseif char == 22 then
    setQuery(state, state.ae2MaintainSearchClipboard or "")
    return true
  elseif char == 8 or char == 127 then
    if state.ae2MaintainQuery == "" then return false end
    setQuery(state, state.ae2MaintainQuery:sub(1, #state.ae2MaintainQuery - 1))
    return true
  elseif char == 13 then
    state.ae2MaintainSearchActive = false
    return true
  elseif char and char >= 32 and char <= 126 then
    setQuery(state, state.ae2MaintainQuery .. string.char(char))
    return true
  end
  return nil
end

return search
local actionBar = require("oc.dashboard.action_bar")
local numbers = require("oc.dashboard.number_format")
local actions = require("oc.dashboard.maintainer_ui_actions")
local daemonUi = require("oc.dashboard.maintainer_ui_daemon")
local list = require("oc.dashboard.maintainer_ui_list")
local search = require("oc.dashboard.maintainer_ui_search")

local ui = {}
ui.maxQuery = search.maxQuery
ui.maxPerPage = list.maxPerPage

ui.ensure = list.ensure
ui.selectedRow = list.selectedRow
ui.matches = list.matches
ui.pageEntries = list.pageEntries
ui.movePage = list.movePage
ui.moveSelection = list.moveSelection
ui.hitSearch = search.hitSearch
ui.setSearchActive = search.setSearchActive
ui.handleClipboard = search.handleClipboard
ui.toggleTarget = actions.toggleTarget
ui.openFlow = actions.openFlow
ui.requestManual = actions.requestManual
ui.deleteTarget = actions.deleteTarget
ui.toggleGlobalAuto = actions.toggleGlobalAuto
ui.toggleDaemon = actions.toggleDaemon
ui.nextBatchNow = actions.nextBatchNow
ui.setDaemonInterval = actions.setDaemonInterval
ui.startAllAutomation = actions.startAllAutomation
ui.stopAllAutomation = actions.stopAllAutomation
ui.armAll = actions.armAll
ui.disarmAll = actions.disarmAll
ui.beginDaemonIntervalEdit = daemonUi.beginIntervalEdit
ui.handleDaemonIntervalEdit = daemonUi.handleIntervalEdit

function ui.daemonStatusLine(daemon)
  daemon = daemon or {}
  if daemon.desiredEnabled == false then return "OFF by dashboard config" end
  if daemon.starting then
    local remaining = tonumber(daemon.startupRemaining)
    if remaining and remaining > 0 then
      return "starting; planned first pass in " .. numbers.seconds(remaining)
    end
    return "starting; waiting for first heartbeat"
  end
  if daemon.fresh then
    return "active tick " .. numbers.integer(daemon.tickCount or 0)
      .. " age " .. numbers.seconds(daemon.age)
      .. " status " .. tostring(daemon.lastStatus or "unknown")
  end
  if daemon.lastTick then
    return "stale age " .. numbers.seconds(daemon.age) .. "; toggle Shift+D off/on to restart"
  end
  return "no heartbeat yet; toggle Shift+D to start"
end

local function moveLogPage(state, delta)
  local pages = math.max(1, (state.ae2Logs and state.ae2Logs.pages) or 1)
  state.ae2LogPage = ((state.ae2LogPage or 1) - 1 + delta) % pages + 1
  state.nextAe2LogRefresh = 0
  return true
end

function ui.handleKey(state, char, code, keyboard)
  local left = keyboard.keys and keyboard.keys.left
  local right = keyboard.keys and keyboard.keys.right
  if state.view == "ae2_daemon" then
    return daemonUi.handleKey(state, char, code, keyboard)
  end
  if state.view == "ae2_logs" then
    if left and code == left then
      return moveLogPage(state, -1)
    elseif right and code == right then
      return moveLogPage(state, 1)
    end
    return false
  end
  if state.view ~= "ae2_maintain" then return false end
  list.ensure(state)
  if code == keyboard.keys.up then
    return list.moveSelection(state, -1)
  elseif code == keyboard.keys.down then
    return list.moveSelection(state, 1)
  elseif left and code == left then
    return list.movePage(state, -1)
  elseif right and code == right then
    return list.movePage(state, 1)
  elseif state.ae2MaintainSearchActive then
    local searchResult = search.handleKey(state, char); if searchResult ~= nil then return searchResult end
    return false
  elseif char == string.byte("g") or char == string.byte("G") then
    return actions.toggleGlobalAuto(state)
  end
  return false
end

function ui.handleTouch(state, x, y)
  if state.view == "ae2_daemon" then return daemonUi.handleTouch(state, x, y) end
  if state.view == "ae2_logs" then
    local action = actionBar.hit(state, "maintainer_logs", x, y)
    if action == "prev" then return moveLogPage(state, -1)
    elseif action == "next" then return moveLogPage(state, 1) end
  elseif state.view == "ae2_maintain" then
    local action = actionBar.hit(state, "maintainer", x, y)
    if action == "prev" then return list.movePage(state, -1)
    elseif action == "next" then return list.movePage(state, 1)
    elseif action == "global" then return actions.toggleGlobalAuto(state)
    elseif action == "daemon" then state.view = "ae2_daemon"; return true
    elseif action == "search" then return search.setSearchActive(state, true) end
  end
  return list.handleTouch(state, x, y)
end

return ui
local data = require("oc.dashboard.data")
local actionBar = require("oc.dashboard.action_bar")
local filesystem = require("filesystem")
local newUserReset = require("oc.dashboard.new_user_reset")
local numbers = require("oc.dashboard.number_format")
local performance = require("oc.dashboard.performance")
local style = require("oc.dashboard.style")
local subtabs = require("oc.dashboard.subtabs")

local page = {}
local colors = style.colors
local computerOk, computer = pcall(require, "computer")

local function now()
  if computerOk and computer and computer.uptime then return computer.uptime() end
  return os.clock and os.clock() or 0
end

local function line(panel, y, label, value, color)
  local text = type(value) == "number" and numbers.quantity(value) or tostring(value or "n/a")
  style.textBlock(panel.x + 2, y, label .. ": " .. text, color or colors.text, colors.panel, panel.w - 4, 1)
end

local function pct(used, total)
  if type(used) ~= "number" or type(total) ~= "number" or total <= 0 then return "n/a" end
  return tostring(math.floor((used / total) * 100 + 0.5)) .. "%"
end

local function compact(value)
  if type(value) ~= "number" then return "n/a" end
  return numbers.quantity(value) .. "B"
end

local function compactSeconds(value)
  if type(value) ~= "number" then return "n/a" end
  if value < 1 then return tostring(math.floor(value * 1000 + 0.5) / 1000) .. "s" end
  return numbers.seconds(value)
end

local function yesNo(value)
  if value == true then return "yes" end
  if value == false then return "no" end
  return "n/a"
end

local function storage()
  local okUsed, used = pcall(filesystem.spaceUsed, "/")
  local okTotal, total = pcall(filesystem.spaceTotal, "/")
  if not okUsed or not okTotal then return "n/a" end
  return compact(used) .. " / " .. compact(total)
end

local function drawHealth(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "OPS HEALTH")
  subtabs.draw(style, panel, "ops_health")
  local health = state.health or {}
  local total = health.totalMemory or 1
  local free = health.freeMemory or 0
  line(panel, panel.y + 2, "RAM use", pct(total - free, total))
  line(panel, panel.y + 3, "Storage", storage())
  line(panel, panel.y + 4, "Components", #((state.components) or {}))
  line(panel, panel.y + 5, "Battery lock", state.powerLocked and "Locked" or "Searching")
  line(panel, panel.y + 6, "AE2", state.ae2 and state.ae2.available and "Online" or "Offline")
end

local function drawLinks(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "OPS LINKS")
  subtabs.draw(style, panel, "ops_links")
  local types = {}
  for ctype in pairs(state.componentCounts or {}) do types[#types + 1] = ctype end
  table.sort(types)
  local y = panel.y + 2
  for _, ctype in ipairs(types) do
    if y >= panel.y + panel.h - 1 then break end
    line(panel, y, ctype, "x" .. numbers.integer(state.componentCounts[ctype]))
    y = y + 1
  end
  if y == panel.y + 2 then line(panel, y, "Components", "none", colors.warn) end
end

local function drawPerf(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "OPERATOR PERFORMANCE")
  subtabs.draw(style, panel, "ops_perf")
  local snap = performance.snapshot(state)
  local memory = compact(snap.memoryUsed) .. " / " .. compact(snap.memoryTotal)
  line(panel, panel.y + 2, "Last AE2 calls", snap.lastAe2CallCount)
  line(panel, panel.y + 3, "Warm cursor", snap.warmCursor)
  line(panel, panel.y + 4, "Cache complete", yesNo(snap.cacheComplete))
  line(panel, panel.y + 5, "Memory used", memory)
  line(panel, panel.y + 6, "Next daemon tick", compactSeconds(snap.nextDaemonIn))
  line(panel, panel.y + 7, "Last chunk duration", compactSeconds(snap.lastChunkDuration))
  line(panel, panel.y + 8, "Next chunk size", snap.nextChunkLimit)
  line(panel, panel.y + 9, "Chunk source", snap.lastChunkKind or snap.lastCacheScope, colors.muted)
end

local function drawOps(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "OPERATIONS")
  subtabs.draw(style, panel, "diagnostics")
  line(panel, panel.y + 2, "AE2 links", #(state.ae2.components or {}))
  line(panel, panel.y + 3, "Battery lock", state.powerLocked and "Locked" or "Searching")
  line(panel, panel.y + 4, "Poll", numbers.seconds(data.intervals.power) .. " battery / " .. numbers.seconds(data.intervals.ae2) .. " AE2")
  line(panel, panel.y + 5, "Layout", numbers.integer(state.W) .. "x" .. numbers.integer(state.H))
  line(panel, panel.y + 6, "View", state.view)
  line(panel, panel.y + 7, "Tools", "gt-probe, power-status, ae2-probe", colors.muted)
  line(panel, panel.y + 9, "Danger", "New User deletes local owner state", colors.bad)
  style.textBlock(panel.x + 2, panel.y + 10,
    "Use only when this hard drive is being handed to a new server/user.",
    colors.warn, colors.panel, panel.w - 4, 2)
  local label = newUserReset.confirmActive(state, now()) and "Confirm New User" or "New User"
  actionBar.draw(state, "ops_danger", panel.x + 2, panel.y + 12, panel.w - 4, {
    { label = label, action = "new_user", danger = true }
  })
  if state.opsNewUserMessage then
    style.textBlock(panel.x + 2, panel.y + 14, state.opsNewUserMessage, colors.warn, colors.panel, panel.w - 4, 2)
  end
end

function page.draw(view, panel, state)
  if view == "ops_health" then return drawHealth(panel, state) end
  if view == "ops_links" then return drawLinks(panel, state) end
  if view == "ops_perf" then return drawPerf(panel, state) end
  return drawOps(panel, state)
end

function page.handleTouch(state, x, y)
  if state.view ~= "diagnostics" then return false end
  local action = actionBar.hit(state, "ops_danger", x, y)
  if action ~= "new_user" then return false end
  newUserReset.confirmOrRun(state, now())
  return true
end

return page
local filesystem = require("filesystem")
local readable = require("oc.core.config")

local reset = {}

reset.confirmSeconds = 20
reset.workflowPath = "/etc/oc-ae2-workflows.cfg"
reset.domainPath = "/etc/oc-dashboard-initiatives.cfg"

reset.removePaths = {
  "/etc/oc-ae2-workflows.cfg.bak",
  "/etc/oc-ae2-workflows.cfg.pre-migrate.bak",
  "/etc/oc-ae2-workflows.cfg.new",
  "/etc/oc-ae2-workflows.cfg.previous",
  "/etc/oc-ae2-maintainer.cfg",
  "/etc/oc-ae2-maintainer.cfg.retired",
  "/etc/oc/ae2-maintainer-daemon.cfg",
  "/etc/oc/ae2-maintainer-daemon.cfg.pre-migrate.bak",
  "/etc/oc/ae2-maintainer-daemon.cfg.new",
  "/etc/oc/ae2-maintainer-daemon.cfg.previous",
  "/var/oc/ae2-maintainer.state",
  "/var/oc/ae2-maintainer-manual.state",
  "/var/oc/ae2-maintainer.log",
  "/var/oc/ae2-auto-crafts.log",
  "/var/oc/ae2.log",
  "/etc/oc-dashboard-tasks.cfg",
  "/etc/oc-dashboard-tasks.cfg.retired",
  "/etc/oc-dashboard-initiatives.cfg.pre-migrate.bak",
  "/etc/oc-dashboard-initiatives.cfg.new",
  "/etc/oc-dashboard-initiatives.cfg.previous",
  "/etc/oc/dashboard-title.cfg",
  "/etc/oc/dashboard-title.cfg.pre-migrate.bak",
  "/etc/oc/dashboard-title.cfg.new",
  "/etc/oc/dashboard-title.cfg.previous",
  "/etc/oc/dashboard-power-title.cfg",
  "/etc/oc/dashboard-power-title.cfg.pre-migrate.bak",
  "/etc/oc/dashboard-power-title.cfg.new",
  "/etc/oc/dashboard-power-title.cfg.previous",
  "/etc/oc/dashboard-screen.cfg",
  "/etc/oc/dashboard-screen.cfg.pre-migrate.bak",
  "/etc/oc/dashboard-screen.cfg.new",
  "/etc/oc/dashboard-screen.cfg.previous",
  "/var/oc/screen.log"
}

local function fail(result, label, err)
  result.failed[#result.failed + 1] = tostring(label) .. ": " .. tostring(err or "failed")
end

local function writeSerialized(path, value, result)
  local ok, reason = readable.save(path, value)
  if not ok then fail(result, path, reason); return false end
  result.blanked = result.blanked + 1
  return true
end

local function removePath(path, result)
  local okExists, exists = pcall(filesystem.exists, path)
  if okExists and exists ~= true then result.missing = result.missing + 1; return true end
  local ok, removed, err = pcall(filesystem.remove, path)
  if ok and (removed == true or (removed == nil and err == nil)) then
    result.deleted = result.deleted + 1
    return true
  end
  fail(result, path, err or removed)
  return false
end

local function disableDaemon(result)
  local ok, daemonConfig = pcall(require, "oc.ae2.maintainer_daemon_config")
  if ok and daemonConfig and daemonConfig.setEnabled then
    local saved, err = daemonConfig.setEnabled(false)
    if saved then return true end
    fail(result, "daemon off", err)
  else
    fail(result, "daemon off", daemonConfig or "daemon config unavailable")
  end
  return false
end

local function wakeDaemon()
  local ok, event = pcall(require, "event")
  if ok and event and event.push then pcall(event.push, "oc_ae2_daemon_timer") end
end

local function clearAe2Memory()
  pcall(function() require("oc.ae2.request_cache").clear() end)
  pcall(function() require("oc.ae2.stock_memory").clear() end)
  pcall(function() require("oc.ae2.cache_epoch").reset() end)
  pcall(function() require("oc.ae2.maintainer_queue").reset() end)
end

local function blankInitiatives()
  local out = {}
  for i = 1, 24 do out[i] = "" end
  return out
end

function reset.clearState(state)
  if type(state) ~= "table" then return end
  state.dashboardName = "Click Me To Edit Name"
  state.powerStorageName = "Click Me To Name Storage"
  state.initiatives, state.initiativePage, state.initiativePageReady = blankInitiatives(), 1, false
  state.powerNodes, state.powerLocked, state.power = nil, false, {}
  state.ae2, state.ae2Counts, state.ae2StockCache = { components = {} }, nil, nil
  state.ae2StockMemorySeen, state.ae2StockDaemonReportAt, state.ae2StockAddress = nil, nil, nil
  state.ae2CraftCache, state.ae2Workflow = nil, { entries = {}, count = 0, complete = true }
  state.ae2WorkflowQuery = ""
  -- Remove the retired submitted-query state when resetting an older live
  -- dashboard session; current state construction no longer creates it.
  state.ae2WorkflowSubmittedQuery = nil
  state.ae2WorkflowSelected, state.ae2WorkflowPage = 1, 1
  state.ae2Maintain = { status = { mode = "observe", autoEnabled = false }, targets = {}, alerts = {} }
  state.ae2MaintainCache, state.ae2MaintainDirty, state.ae2ManualRequest = nil, false, nil
  state.ae2MaintainDaemon = { desiredEnabled = false, running = false, fresh = false }
  state.ae2MaintainerMode, state.ae2Logs, state.ae2DeckLogs = "observe", {}, {}
end

function reset.run(state)
  local result = { performed = true, deleted = 0, missing = 0, blanked = 0, failed = {} }
  if not disableDaemon(result) then return false, table.concat(result.failed, "; "), result end
  -- Clear abandoned transaction artifacts before writing the deliberate blank
  -- owner policy, otherwise a prior interrupted write would block the reset.
  for _, path in ipairs(reset.removePaths) do removePath(path, result) end
  writeSerialized(reset.workflowPath, { autoEnabled = false, workflows = {} }, result)
  writeSerialized(reset.domainPath, { __blank = true }, result)
  clearAe2Memory()
  wakeDaemon()
  reset.clearState(state)
  if #result.failed > 0 then return false, table.concat(result.failed, "; "), result end
  return true, nil, result
end

function reset.confirmActive(state, now)
  return type(state) == "table" and tonumber(state.opsNewUserConfirmUntil) ~= nil
    and (tonumber(now) or 0) <= tonumber(state.opsNewUserConfirmUntil)
end

function reset.confirmOrRun(state, now)
  now = tonumber(now) or 0
  if not reset.confirmActive(state, now) then
    state.opsNewUserConfirmUntil = now + reset.confirmSeconds
    state.opsNewUserMessage = "WARNING: deletes all local owner state. Click New User again to confirm."
    return true, nil, { armed = true, performed = false }
  end
  local ok, err, result = reset.run(state)
  state.opsNewUserConfirmUntil = nil
  state.opsNewUserMessage = ok and "New user reset complete. Local owner state is blank."
    or ("New user reset incomplete: " .. tostring(err))
  return ok, err, result
end

return reset
local okComputer, computer = pcall(require, "computer")
if not okComputer then computer = nil end
local chunkAdapt = require("oc.ae2.chunk_adapt")

local performance = {}

local function fallbackNow()
  if os and os.clock then return os.clock() end
  return 0
end

function performance.now()
  if computer and computer.uptime then return computer.uptime() end
  return fallbackNow()
end

local function ensure(state)
  state.performance = state.performance or {}
  return state.performance
end

local function numberOrNil(value)
  local n = tonumber(value)
  if n == nil then return nil end
  return n
end

local function recordCacheFields(target, kind, cache)
  if type(cache) ~= "table" then return end
  target.lastCacheScope = kind or cache.scope or target.lastCacheScope
  if cache.targetCursor ~= nil then target.lastWarmCursor = cache.targetCursor end
  if cache.complete ~= nil then target.lastCacheComplete = cache.complete == true end
  if cache.freeKb ~= nil then target.lastCacheFreeKb = cache.freeKb end
end

function performance.targetLimit(state, scope, baseLimit, reset)
  local p = ensure(state)
  local limit = chunkAdapt.limit(p, scope, { base = baseLimit, reset = reset == true })
  p.lastChunkKind = scope or p.lastChunkKind
  p.nextChunkLimit = limit
  return limit
end

function performance.recordChunk(state, kind, startedAt, endedAt, ae2Calls, cache, options)
  local p = ensure(state)
  options = options or {}
  local finished = numberOrNil(endedAt) or performance.now()
  local started = numberOrNil(startedAt) or finished
  p.lastChunkKind = kind or p.lastChunkKind
  p.lastChunkAt = finished
  p.lastChunkDuration = math.max(0, finished - started)
  if ae2Calls ~= nil then
    p.lastAe2CallCount = math.max(0, math.floor(numberOrNil(ae2Calls) or 0))
  end
  recordCacheFields(p, kind, cache)
  if options.adaptive ~= false then
    local status = chunkAdapt.record(p, options.scope or kind, {
      base = options.baseTargetLimit,
      targetLimit = options.targetLimit,
      duration = p.lastChunkDuration,
      calls = ae2Calls,
      ok = options.ok,
      timeout = options.timeout,
      complete = type(cache) == "table" and cache.complete == true,
      cursorBefore = options.cursorBefore,
      cursorAfter = type(cache) == "table" and cache.targetCursor or options.cursorAfter
    })
    p.lastChunkLimit = status.lastTargetLimit
    p.nextChunkLimit = status.nextLimit
    p.lastChunkDecision = status.lastDecision
  end
  return p
end

function performance.recordCache(state, kind, cache)
  local p = ensure(state)
  recordCacheFields(p, kind, cache)
  return p
end

function performance.memoryUsed(state)
  local health = (state and state.health) or {}
  local total = numberOrNil(health.totalMemory)
  local free = numberOrNil(health.freeMemory)
  if not total and computer and computer.totalMemory then total = numberOrNil(computer.totalMemory()) end
  if not free and computer and computer.freeMemory then free = numberOrNil(computer.freeMemory()) end
  if not total or not free then return nil, total end
  return math.max(0, total - free), total
end

local function daemonSeconds(state, now)
  local daemon = (state and state.ae2MaintainDaemon) or {}
  local nextIn = numberOrNil(daemon.nextIn)
  if nextIn then return math.max(0, nextIn) end
  local nextCycleAt = numberOrNil(daemon.nextCycleAt)
  if nextCycleAt then return math.max(0, nextCycleAt - (numberOrNil(now) or performance.now())) end
  return nil
end

function performance.snapshot(state, now)
  local p = (state and state.performance) or {}
  local stockCache = (state and state.ae2StockCache) or {}
  local maintCache = (state and state.ae2MaintainCache) or {}
  local used, total = performance.memoryUsed(state)
  local cacheComplete = p.lastCacheComplete
  if cacheComplete == nil then
    if maintCache.complete ~= nil then cacheComplete = maintCache.complete == true
    elseif stockCache.complete ~= nil then cacheComplete = stockCache.complete == true end
  end
  return {
    lastAe2CallCount = p.lastAe2CallCount or stockCache.ae2Calls,
    warmCursor = p.lastWarmCursor or maintCache.targetCursor or stockCache.targetCursor,
    cacheComplete = cacheComplete,
    memoryUsed = used,
    memoryTotal = total,
    nextDaemonIn = daemonSeconds(state, now),
    lastChunkDuration = p.lastChunkDuration,
    lastChunkKind = p.lastChunkKind,
    lastCacheScope = p.lastCacheScope,
    lastCacheFreeKb = p.lastCacheFreeKb,
    lastChunkLimit = p.lastChunkLimit,
    nextChunkLimit = p.nextChunkLimit,
    lastChunkDecision = p.lastChunkDecision
  }
end

return performance
local subtabs = {}

subtabs.ae2 = {
  { id = "ae2", label = "AE2" },
  { id = "ae2_counts", label = "Stock" },
  { id = "ae2_cpus", label = "Jobs" },
  { id = "ae2_workflows", label = "Targets" },
  { id = "ae2_workflow", label = "Flow" },
  { id = "ae2_maintain", label = "Maintainer" },
  { id = "ae2_daemon", label = "Daemon" },
  { id = "ae2_logs", label = "Logs" }
}

subtabs.power = {
  { id = "power", label = "Overview" },
  { id = "power_alarms", label = "Alarms" }
}

subtabs.ops = {
  { id = "diagnostics", label = "Ops" },
  { id = "ops_health", label = "Health" },
  { id = "ops_links", label = "Links" },
  { id = "ops_perf", label = "Performance" }
}

local function isAe2(view)
  return view == "ae2" or view == "ae2_counts" or view == "ae2_cpus"
    or view == "ae2_workflows" or view == "ae2_workflow" or view == "ae2_maintain"
    or view == "ae2_daemon" or view == "ae2_logs"
end

local function groupFor(view)
  if isAe2(view) then return subtabs.ae2 end
  if view == "power" or view == "power_alarms" then return subtabs.power end
  if view == "diagnostics" or view == "ops_health" or view == "ops_links" or view == "ops_perf" then return subtabs.ops end
  return nil
end

local function textFor(entry, active)
  if active then return "[" .. entry.label .. "]" end
  return " " .. entry.label .. " "
end

function subtabs.draw(style, panel, view)
  local group = groupFor(view)
  if not group then return end
  local colors = style.colors
  local x = panel.x + 2
  local y = panel.y + 1
  for _, entry in ipairs(group) do
    local active = entry.id == view
    local text = textFor(entry, active)
    if x + #text < panel.x + panel.w - 1 then
      style.text(x, y, text, active and colors.bg or colors.muted, active and colors.accent or colors.panel, #text)
    end
    x = x + #text + 1
  end
end

function subtabs.hit(state, x, y)
  if y ~= 6 then return nil end
  x = tonumber(x)
  local group = groupFor(state.view)
  if not x or not group then return nil end
  local tx = 5
  for _, entry in ipairs(group) do
    local text = textFor(entry, entry.id == state.view)
    if x >= tx and x < tx + #text then return entry.id end
    tx = tx + #text + 1
  end
  return nil
end

return subtabs
local detailPage = require("oc.dashboard.workflow_page_detail")
local listPage = require("oc.dashboard.workflow_page_list")
local setupPage = require("oc.dashboard.workflow_setup_page")

local page = {}

function page.drawList(panel, state)
  if state.ae2WorkflowSetup then return setupPage.draw(panel, state) end
  return listPage.draw(panel, state)
end

function page.drawDetail(panel, state)
  if state.ae2WorkflowSetup then return setupPage.draw(panel, state) end
  return detailPage.draw(panel, state)
end

return page
local actionBar = require("oc.dashboard.action_bar")
local numbers = require("oc.dashboard.number_format")
local operatorStatus = require("oc.dashboard.operator_status")
local sections = require("oc.dashboard.ae2_page_sections")
local style = require("oc.dashboard.style")
local subtabs = require("oc.dashboard.subtabs")
local workflowUi = require("oc.dashboard.workflow_ui")

local page = {}
local colors = style.colors
local craftColumnSpec = { { label = "Mode", width = 8 }, { label = "Kind", width = 12 }, { label = "Max", width = 10 } }

local function kindText(entry)
  return (entry and (entry.isFluid == true or entry.kind == "fluid")) and "fluid" or "item"
end

local function unitText(entry)
  return kindText(entry) == "fluid" and " mB" or ""
end

local function amountText(entry)
  if kindText(entry) == "fluid" then return numbers.quantity(entry and (entry.amount or entry.size), "?") .. " mB" end
  return numbers.quantity(entry and (entry.size or entry.amount) or 1) .. "x"
end

local function selectedEntry(state)
  local entries = state.ae2Workflow and state.ae2Workflow.entries or {}
  return entries[state.ae2WorkflowSelected or 1] or {}
end

local function rowText(entry)
  return operatorStatus.targetRow(entry, { workflow = true })
end

local function rowColor(entry, selected)
  return operatorStatus.stateColor(entry, selected, { workflow = true })
end

local function rowCells(entry)
  local flow = entry and entry.workflow or {}
  local mode = entry and entry.mode == "auto" and "AUTO" or "MANUAL"
  if flow.armed then mode = mode .. "/ARM" end
  return {
    mode,
    kindText(entry) .. " " .. amountText(entry),
    numbers.quantity(flow.maxRequest or flow.batch or entry and entry.amount or 1) .. unitText(entry)
  }
end

local function drawCraftRow(x, y, width, entry, color)
  local leftWidth, rightWidth = sections.split(width, craftColumnSpec, 14)
  if rightWidth <= 0 then
    style.text(x, y, rowText(entry), color, colors.panel, width)
    return
  end
  local label = tostring(entry and entry.label or "craft")
  if entry and entry.craftIndex then label = label .. "  craft #" .. numbers.integer(entry.craftIndex) end
  -- `craftIndex` is a dashboard-session selection ID. `configIndex` is the
  -- durable row number accepted by ae2-workflow --bind/--rebind, so expose
  -- both instead of asking an operator to map a sorted screen row by hand.
  if entry and entry.configIndex then label = label .. "  cfg #" .. numbers.integer(entry.configIndex) end
  style.textBlock(x, y, label, color, colors.panel, leftWidth, 1)
  sections.values(x + leftWidth + 1, y, rowCells(entry), craftColumnSpec, color)
end

local function searchLabel(value)
  local query = tostring(value or "")
  if query == "" then return "Filter Targets" end
  if #query > 18 then query = query:sub(1, 15) .. "..." end
  return "Filter: " .. query
end

local function progressText(report)
  if report.complete then return "  local catalog" end
  return "  loading managed targets"
end

function page.draw(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "AE2 Managed Targets")
  subtabs.draw(style, panel, "ae2_workflows")
  local report = state.ae2Workflow or {}
  local activeEntry = selectedEntry(state)
  local activeFlow = activeEntry.workflow or {}
  state.ae2WorkflowSearchY = panel.y + 2
  state.ae2WorkflowButtonY = panel.y + 3
  local y = actionBar.draw(state, "workflow_list", panel.x + 2, state.ae2WorkflowButtonY, panel.w - 4, {
    { key = "N", label = "Add Recipe / Auto Pause", action = "add", warn = true },
    { key = "<", label = "Prev", action = "prev" },
    { label = searchLabel(state.ae2WorkflowQuery), action = "search", good = state.ae2WorkflowSearchActive },
    { key = ">", label = "Next", action = "next" },
    { key = "M", label = "Max Request: " .. numbers.quantity(activeFlow.maxRequest or activeFlow.batch or 1) .. unitText(activeEntry), action = "manual" },
    { key = "Shift+A", label = "Auto: " .. tostring(activeEntry.mode == "auto" and "on" or "manual"), action = "auto", good = activeEntry.mode == "auto" }
  })
  local rowStart = y + 1
  local rows = math.max(1, math.min(math.floor(workflowUi.maxPerPage / 2), panel.y + panel.h - rowStart - 1))
  local perPage = rows * 2
  state.ae2WorkflowRows = rows
  state.ae2WorkflowPerPage = perPage
  local entries, matched, maxPage, total = workflowUi.pageEntries(state, perPage)
  local progress = progressText(report)
  local query = tostring(state.ae2WorkflowQuery or "")
  local subject = query ~= "" and (' for "' .. query .. '"') or ""
  sections.band(panel, panel.y + 2, "Target Filter", numbers.countRatio(matched, total)
    .. " configured" .. subject .. "  page " .. numbers.countRatio(state.ae2WorkflowPage or 1, maxPage)
    .. progress)
  local colWidth = math.floor((panel.w - 5) / 2)
  sections.headerAt(panel.x + 2, y, colWidth - 1, craftColumnSpec, 14, "Craft")
  sections.headerAt(panel.x + 2 + colWidth, y, colWidth - 1, craftColumnSpec, 14, "Craft")
  state.ae2WorkflowListY = y + 1
  for offset, item in ipairs(entries) do
    local col = math.floor((offset - 1) / rows)
    local row = (offset - 1) % rows
    local x = panel.x + 2 + col * colWidth
    local y = state.ae2WorkflowListY + row
    local selected = item.index == (state.ae2WorkflowSelected or 1)
    drawCraftRow(x, y, colWidth - 1, item.entry, rowColor(item.entry, selected))
  end
  if #entries == 0 then
    style.text(panel.x + 2, state.ae2WorkflowListY, report.error or "No matching crafts", colors.warn, colors.panel, panel.w - 4)
  end
end

return page
local actionBar = require("oc.dashboard.action_bar")
local binding = require("oc.ae2.request_binding")
local columns = require("oc.dashboard.workflow_page_detail_columns")
local hint = require("oc.dashboard.workflow_page_detail_hint")
local lineContract = require("oc.ae2.line_contract")
local numbers = require("oc.dashboard.number_format")
local operatorStatus = require("oc.dashboard.operator_status")
local style = require("oc.dashboard.style")
local subtabs = require("oc.dashboard.subtabs")
local workflowUi = require("oc.dashboard.workflow_ui")

local page = {}
local colors = style.colors
local conditionColumnSpec = { { label = "Setting", width = 42 }, { label = "Condition Setting's Effect", width = 64 } }
local conditionRowHeight = 2

local function selected(state)
  local entries = state.ae2Workflow and state.ae2Workflow.entries or {}
  return entries[state.ae2WorkflowSelected or 1] or {}
end

local function kindText(entry)
  return (entry and (entry.isFluid == true or entry.kind == "fluid")) and "fluid" or "item"
end

local function unitText(entry)
  return kindText(entry) == "fluid" and " mB" or ""
end

local function armedText(entry)
  local flow = entry.workflow or {}
  return flow.armed and "armed" or "disarmed"
end

local function autoText(entry)
  return entry.mode == "auto" and "on" or "manual"
end

local function switchText(enabled)
  return enabled and "[ON]" or "[OFF]"
end

local function registerChoiceHit(hits, field, value, x, x2, y, index, height)
  for offset = 0, math.max(1, tonumber(height) or 1) - 1 do
    hits[#hits + 1] = { field = field, value = value, x = x, x2 = x2, y = y + offset, index = index }
  end
end

local function choiceLine(current, values, hits, field, x, y, index, height)
  local out = {}
  for _, value in ipairs(values) do
    local id, label = value[1], value[2]
    local text = id == current and ("[" .. label .. "]") or (" " .. label .. " ")
    registerChoiceHit(hits, field, id, x, x + #text - 1, y, index, height)
    out[#out + 1] = text
    x = x + #text + 1
  end
  return table.concat(out, " ")
end

local function commandText(flow, lineState, lineReason, maxRequest, units)
  local state = tostring(lineState or "configured")
  if state == "ready" then
    return "Command: WILL SUBMIT " .. numbers.quantity(flow.request or maxRequest) .. units
  elseif state == "recipe_unknown" then
    return "Command: BLOCKED - recipe ceiling unknown"
  elseif state == "danger_locked" then
    return "Command: BLOCKED - request cap above safety boundary"
  elseif state == "satisfied" then
    return "Command: HOLD - stock satisfies Alert Below"
  elseif state == "manual_only" then
    return "Command: MANUAL ONLY - use Send Max"
  elseif state == "observe" or state == "alert" or state == "suggest" then
    return "Command: SAFE - " .. lineContract.authorityLabel(flow.lineAuthority)
  end
  return "Command: " .. state .. " - " .. tostring(lineReason or "waiting")
end

local function batteryText(flow)
  if tonumber(flow.minBatteryRatio) == 0 then return "disabled" end
  return tostring(flow.minBatteryRatio or 0.25) .. "+"
end

local function powerText(flow)
  if tonumber(flow.maxDeficitRatio) == 0 then return "disabled" end
  return "out <= in x " .. tostring(flow.maxDeficitRatio or 1.25)
end

local function automationText(entry)
  local flow = entry.workflow or {}
  local mode = entry.mode == "auto" and "AUTO" or "MANUAL"
  return operatorStatus.summaryStrip({ "Automation: " .. mode .. " / " .. (flow.armed and "ARMED" or "safe") })
end

local function automationColor(entry)
  local flow = entry.workflow or {}
  return operatorStatus.stateColor({ armed = flow.armed == true, ready = entry.mode == "auto" and flow.armed == true }, false)
end

local function bindingText(entry)
  local index = entry and entry.configIndex and (" cfg #" .. tostring(entry.configIndex)) or ""
  local bindErr = binding.error(entry or {})
  if bindErr then return "Binding: REQUIRED" .. index .. " (ae2-workflow --show-bind)" end
  return "Binding: exact" .. index .. " (verified on submit)"
end

local function bindingColor(entry)
  return binding.error(entry or {}) and colors.warn or colors.good
end

local function commandColor(lineState)
  local state = tostring(lineState or "")
  if state == "ready" then return colors.good end
  if state == "danger_locked" or state == "recipe_unknown" then return colors.warn end
  return colors.muted
end

local function effectForSwitch(onText, offText, enabled)
  return enabled and onText or offText
end

local function conditionColor(field, active, flow)
  if active then return colors.accent end
  if field == "lineAuthority" then
    return flow.lineAuthority == "auto" and colors.good or colors.muted
  elseif field == "lineIntent" then
    return flow.lineIntent == "manual_only" and colors.muted or colors.text
  elseif field == "alertEnabled" then
    return flow.alertEnabled ~= false and colors.text or colors.muted
  elseif field == "requireReadyCpu" then
    return flow.requireReadyCpu ~= false and colors.text or colors.muted
  elseif field == "minBatteryRatio" then
    return tonumber(flow.minBatteryRatio) == 0 and colors.muted or colors.text
  elseif field == "maxDeficitRatio" then
    return tonumber(flow.maxDeficitRatio) == 0 and colors.muted or colors.text
  elseif field == "locked" then
    return flow.locked == true and colors.warn or colors.text
  end
  return colors.text
end

local function currentChoice(flow, field)
  if field == "lineIntent" then return flow[field] or "maintain_buffer" end
  if field == "lineAuthority" then return flow[field] or "observe" end
  return flow[field]
end

local function drawConditionRow(panel, y, item, index, active, flow, state)
  local field = item[1]
  local width = panel.w - 4
  local leftWidth, rightWidth = columns.split(width, conditionColumnSpec, 24)
  local color = conditionColor(field, index == active, flow)
  local prefix = index == active and "> " or "  "
  local label = prefix .. tostring(item.label or field)
  local setting = item.setting or item.text or ""
  local effect = item.effect or ""
  local height = tonumber(item.height) or conditionRowHeight
  state.ae2WorkflowFieldRows[index] = { field = field, y = y, h = height }
  state.ae2WorkflowFieldRows[field] = y
  if state.ae2WorkflowEditField == field then
    setting = "[" .. tostring(state.ae2WorkflowEditValue or "") .. "_]"
  elseif item.choices then
    local x = rightWidth > 0 and panel.x + 3 + leftWidth or panel.x + 2 + #label + 1
    setting = choiceLine(currentChoice(flow, field), item.choices, state.ae2WorkflowChoiceHits, field, x, y, index, height)
  end
  if rightWidth <= 0 then
    local compact = label .. "  " .. tostring(setting)
    if effect ~= "" then compact = compact .. " - " .. tostring(effect) end
    style.textBlock(panel.x + 2, y, compact, color, colors.panel, width, height)
    return
  end
  style.textBlock(panel.x + 2, y, label, color, colors.panel, leftWidth, height)
  columns.drawSettingEffect(panel.x + 3 + leftWidth, y, setting, effect, conditionColumnSpec, color, height)
end

function page.draw(panel, state)
  style.box(panel.x, panel.y, panel.w, panel.h, "AE2 Flow + Arming")
  subtabs.draw(style, panel, "ae2_workflow")
  local entry = selected(state)
  local flow = entry.workflow or {}
  local active = state.ae2WorkflowField or 1
  local cooldownMin = tonumber(workflowUi.minimumCooldown) or 600
  local cooldownMax = tonumber(workflowUi.maxCooldown) or 604800
  local units = unitText(entry)
  local alertBelow = flow.alertBelow or flow.minStock
  local maxRequest = flow.maxRequest or flow.batch or 1
  local alertText = numbers.quantity(alertBelow, "unset") .. units
  local maxRequestText = numbers.quantity(maxRequest) .. units
  local lineState = flow.lineState or entry.lineState or "configured"
  local lineReason = flow.lineReason or entry.lineReason or "waiting for maintainer state"
  local rowHeight = panel.h >= 32 and conditionRowHeight or 1
  local fields = {
    { "lineIntent", label = "Intent Mode Selector", effect = lineContract.intentHint(flow.lineIntent), choices = {
      { "maintain_buffer", "Maintain" }, { "push_max", "Push Max" },
      { "recipe_governed", "Recipe" }, { "manual_only", "Manual" }
    } },
    { "lineAuthority", label = "Authority Mode Selector", effect = lineContract.authorityHint(flow.lineAuthority), choices = {
      { "observe", "Observe" }, { "alert", "Alert" },
      { "suggest", "Suggest" }, { "auto", "Auto" }
    } },
    { "alertBelow", label = "Alert Below", setting = alertText,
      effect = "Alert Below is " .. alertText .. "; maintain requests start only under this stock." },
    { "maxRequest", label = "Max Request", setting = maxRequestText,
      effect = "Max Request is " .. maxRequestText .. "; M sends this and auto batches cap here." },
    { "alertEnabled", label = "Low Alert Switch", setting = switchText(flow.alertEnabled ~= false),
      effect = effectForSwitch("Dashboard low-stock alarm enabled", "Low-stock alarm muted", flow.alertEnabled ~= false) },
    { "requireReadyCpu", label = "CPU Gate", setting = switchText(flow.requireReadyCpu ~= false) .. " ready CPU",
      effect = effectForSwitch("Daemon waits for a ready CPU", "CPU readiness gate bypassed", flow.requireReadyCpu ~= false) },
    { "minBatteryRatio", label = "Battery", setting = batteryText(flow),
      effect = "0 disables; otherwise block auto below this stored-power ratio" },
    { "maxDeficitRatio", label = "Power", setting = powerText(flow),
      effect = "0 disables; otherwise block auto when output outruns input" },
    { "cooldown", label = "Cooldown", setting = numbers.seconds(flow.cooldown or 600)
      .. " (min " .. numbers.seconds(cooldownMin) .. ", max " .. numbers.seconds(cooldownMax) .. ")",
      effect = "Minimum wait after a sent or failed batch" },
    { "locked", label = "Contract Lock", setting = switchText(flow.locked == true),
      effect = effectForSwitch("Protect this line from edits", "Edits are allowed", flow.locked == true) }
  }
  for _, item in ipairs(fields) do item.height = rowHeight end
  state.ae2WorkflowFieldRows = {}
  state.ae2WorkflowChoiceHits = {}
  local y, insideBottom = panel.y + 2, panel.y + panel.h - 2
  style.text(panel.x + 2, y, "Selected craft: " .. tostring(entry.label or "Select a craft"), colors.accent, colors.panel, panel.w - 4); y = y + 1
  style.text(panel.x + 2, y, "Kind: " .. kindText(entry) .. "  " .. automationText(entry)
    .. "  " .. bindingText(entry), bindingColor(entry), colors.panel, panel.w - 4); y = y + 1
  style.text(panel.x + 2, y, commandText(flow, lineState, lineReason, maxRequest, units),
    commandColor(lineState), colors.panel, panel.w - 4); y = y + 1
  state.ae2FlowButtonY = y
  local flowButtons = {}
  if binding.error(entry) ~= nil then
    flowButtons[#flowButtons + 1] = { key = "B", label = "Bind Recipe / Auto Pause", action = "bind", warn = true }
  end
  flowButtons[#flowButtons + 1] =
    { key = "M", label = "Send Max: " .. numbers.quantity(maxRequest) .. units, action = "manual" }
  flowButtons[#flowButtons + 1] =
    { key = "Shift+A", label = "Auto: " .. autoText(entry), action = "auto", good = entry.mode == "auto" }
  flowButtons[#flowButtons + 1] =
    { key = "Shift+F", label = "Arm: " .. armedText(entry), action = "arm", good = flow.armed == true }
  y = actionBar.draw(state, "workflow_flow", panel.x + 2, y, panel.w - 4, flowButtons)
  y = columns.drawHeader(panel, y, conditionColumnSpec, 24)
  local footerH = panel.h >= 18 and hint.height or 2
  local footerY = math.max(y, insideBottom - footerH + 1)
  local contentBottom = footerY - 1
  for i, item in ipairs(fields) do
    if y + rowHeight - 1 > contentBottom then break end
    drawConditionRow(panel, y, item, i, active, flow, state)
    y = y + rowHeight
  end
  hint.draw(panel, state, fields[active], footerY, insideBottom - footerY + 1)
end

return page
local actionBar = require("oc.dashboard.action_bar")
local binding = require("oc.ae2.request_binding")
local sections = require("oc.dashboard.ae2_page_sections")
local style = require("oc.dashboard.style")
local subtabs = require("oc.dashboard.subtabs")
local workflowSetup = require("oc.dashboard.workflow_setup")

local page = {}
local colors = style.colors

local function titleFor(value)
  return value.mode == "bind" and "AE2 RECIPE BINDING" or "AE2 ADD MANAGED RECIPE"
end

local function stageLabel(stage)
  if stage == "stopping" then return "0 AUTOMATION INTERLOCK"
  elseif stage == "input" then return "1 INPUT"
  elseif stage == "confirm" then return "2 SAFETY REVIEW"
  elseif stage == "scanning" then return "3 DISCOVERING"
  elseif stage == "results" then return "4 EXACT RECIPE REVIEW"
  elseif stage == "committing" then return "5 VERIFYING + SAVING"
  elseif stage == "restoring" then return "6 RESTORING AUTOMATION"
  elseif stage == "stop_failed" then return "STOP INTERLOCK FAILED"
  elseif stage == "restore_failed" then return "AUTOMATION RESTORE FAILED" end
  return tostring(stage or "SETUP"):upper()
end

local function identity(candidate)
  local kind = candidate and (candidate.kind or (candidate.isFluid and "fluid" or "item")) or "item"
  local damage = candidate and candidate.damage
  local tag = candidate and candidate.hasTag == true and "TAGGED" or "untagged"
  return tostring(kind) .. "  " .. tostring(candidate and candidate.name or "registry unavailable")
    .. (damage ~= nil and ("  damage " .. tostring(damage)) or "") .. "  " .. tag
end

local function drawHeader(panel, state, value)
  style.box(panel.x, panel.y, panel.w, panel.h, titleFor(value))
  subtabs.draw(style, panel, state.view)
  local y = sections.band(panel, panel.y + 2, "Setup State", stageLabel(value.stage)
    .. "  |  " .. (value.mode == "bind" and ("repair cfg #" .. tostring(value.targetConfigIndex or "?")) or "new target"))
  local status = value.lifecycle or {}
  local ownership
  if value.stage == "stopping" then
    ownership = "STOP requested; waiting for worker generation " .. tostring(status.ownerGeneration or "?") .. " exit proof"
  elseif value.stage == "restoring" then
    ownership = "Prior daemon ownership was ON; restart is automatic and first planning is deferred"
  elseif value.stage == "stop_failed" then
    ownership = "INTERLOCK BLOCKED | no discovery authorized | inspect or retry"
  elseif value.stage == "restore_failed" then
    ownership = "Maintainer remains OFF | saved recipe will not be repeated | retry restart or leave off"
  elseif value.restoreRequired == false then
    ownership = "Maintainer was already OFF; setup will leave it OFF"
  else
    ownership = "Maintainer PAUSED | " .. tostring(status.proof or "generation-scoped exit proved") .. " | resumes after save/cancel"
  end
  return sections.band(panel, y, "Automation Interlock", ownership)
end

local function drawError(panel, y, value, reason)
  reason = reason or value.error
  if not reason or reason == "" then return y end
  local _, used = style.textBlock(panel.x + 2, y, "BLOCKED: " .. tostring(reason), colors.bad, colors.panel, panel.w - 4, 2)
  return y + math.max(1, used)
end

local function drawInput(panel, state, value, y)
  style.text(panel.x + 2, y, "Search for the recipe output you can already craft in this AE2 network.", colors.text, colors.panel, panel.w - 4)
  y = y + 2
  style.text(panel.x + 2, y, "> " .. tostring(value.query or "") .. "_", colors.bg, colors.accent, panel.w - 4)
  y = y + 2
  style.textBlock(panel.x + 2, y,
    "Use a recognizable output label or registry fragment. This becomes an explicit, bounded metadata scan only after review.",
    colors.muted, colors.panel, panel.w - 4, 2)
  y = y + 3
  drawError(panel, y, value)
  actionBar.draw(state, "workflow_setup", panel.x + 2, panel.y + panel.h - 3, panel.w - 4, {
    { key = "Ctrl+C", label = "Cancel", action = "cancel" },
    { key = "Enter", label = "Review Scan", action = "review", good = true }
  })
end

local function drawConfirm(panel, state, value, y)
  style.text(panel.x + 2, y, "Candidate query: " .. tostring(value.query), colors.accent, colors.panel, panel.w - 4)
  y = y + 2
  style.textBlock(panel.x + 2, y,
    "Setup automatically pauses Maintainer and waits for real worker-exit proof before opening AE2 recipe metadata. Discovery is bounded and never requests a craft.",
    colors.warn, colors.panel, panel.w - 4, 2)
  y = y + 3
  style.textBlock(panel.x + 2, y,
    "Verification reads one exact live Craftable handle. When scalar getCraftable is unavailable, one bounded, filtered getCraftables compatibility lookup is used. AE2FC capacity cells also verify their K label. The result saves DISARMED.",
    colors.text, colors.panel, panel.w - 4, 2)
  y = y + 3
  drawError(panel, y, value)
  actionBar.draw(state, "workflow_setup", panel.x + 2, panel.y + panel.h - 3, panel.w - 4, {
    { key = "Ctrl+C", label = "Cancel", action = "cancel" },
    { key = "Enter", label = "Edit Query", action = "edit" },
    { key = "Ctrl+S", label = "Authorize Scan", action = "start", warn = true }
  })
end

local function drawScanning(panel, state, value, y)
  local report = value.report or {}
  local progress = report.progress
  local progressText = type(progress) == "table"
    and (tostring(progress.state or "scanning") .. "; " .. tostring(progress.candidates or 0)
      .. "/" .. tostring(progress.limit or "?") .. " candidates")
    or tostring(progress or "bounded chunk scheduled")
  style.text(panel.x + 2, y, "Searching for: " .. tostring(value.query), colors.accent, colors.panel, panel.w - 4)
  y = y + 2
  style.text(panel.x + 2, y, "Metadata rows scanned: " .. tostring(value.scanned or report.scanned or 0), colors.text, colors.panel, panel.w - 4)
  y = y + 1
  style.text(panel.x + 2, y, "Exact candidates retained: " .. tostring(#workflowSetup.candidates(state)), colors.text, colors.panel, panel.w - 4)
  y = y + 1
  style.text(panel.x + 2, y, "Progress: " .. progressText, colors.muted, colors.panel, panel.w - 4)
  y = y + 1
  style.text(panel.x + 2, y, "Chunk budget: " .. tostring(value.scanLimit or workflowSetup.defaultScanLimit)
    .. " metadata rows/pass; " .. tostring(value.chunkDelay or workflowSetup.defaultChunkDelay)
    .. "s yielded continuation", colors.muted, colors.panel, panel.w - 4)
  y = y + 2
  style.textBlock(panel.x + 2, y,
    "Yielding between chunks protects the shared server. You can cancel safely; native iterators are disposed immediately.",
    colors.muted, colors.panel, panel.w - 4, 2)
  actionBar.draw(state, "workflow_setup", panel.x + 2, panel.y + panel.h - 3, panel.w - 4, {
    { key = "Ctrl+C", label = "Cancel Scan", action = "cancel", warn = true }
  })
end

local function drawCandidate(panel, value, candidate, index, x, y, width)
  local selected = index == value.selected
  local blocked = binding.onboardingError(candidate) ~= nil
  local fg = selected and colors.bg or blocked and colors.bad or colors.text
  local bg = selected and (blocked and colors.bad or colors.accent) or colors.panel
  local prefix = selected and "> " or "  "
  local suffix = blocked and "  [BLOCKED]" or ""
  style.text(x, y, prefix .. tostring(candidate.label or candidate.rawLabel or candidate.name or "candidate") .. suffix, fg, bg, width)
  style.text(x, y + 1, "  " .. identity(candidate), selected and colors.bg or colors.muted, bg, width)
  value.candidateHits[#value.candidateHits + 1] = { x = x, y = y, w = width, index = index }
  value.candidateHits[#value.candidateHits + 1] = { x = x, y = y + 1, w = width, index = index }
end

local function drawResults(panel, state, value, y)
  local rows = workflowSetup.candidates(state)
  local selectedReason = workflowSetup.selectedCandidateError(state)
  local bindable = 0
  for _, candidate in ipairs(rows) do if binding.onboardingError(candidate) == nil then bindable = bindable + 1 end end
  style.text(panel.x + 2, y, "Review discovered outputs for: " .. tostring(value.query), colors.accent, colors.panel, panel.w - 4)
  y = y + 1
  style.text(panel.x + 2, y, tostring(#rows) .. " candidate(s), " .. tostring(bindable) .. " bindable, after "
    .. tostring(value.scanned or 0) .. " metadata rows.", colors.muted, colors.panel, panel.w - 4)
  y = y + 2
  value.candidateHits = {}
  local available = math.max(1, panel.y + panel.h - y - 5)
  local perPage = math.max(1, math.floor(available / 2))
  local pageIndex = math.floor(((value.selected or 1) - 1) / perPage)
  local first = pageIndex * perPage + 1
  for index = first, math.min(#rows, first + perPage - 1) do
    drawCandidate(panel, value, rows[index], index, panel.x + 2, y, panel.w - 4)
    y = y + 2
  end
  if #rows == 0 then
    style.text(panel.x + 2, y, "No recipe candidate matched. Edit the query and scan again.", colors.warn, colors.panel, panel.w - 4)
  end
  local consequenceY = math.min(panel.y + panel.h - 6, y + 1)
  local consequence = selectedReason
    and "SELECTED OUTPUT BLOCKED -> CHOOSE A BINDABLE RESULT OR EDIT / RESCAN"
    or "VERIFY EXACT OUTPUT -> SAVE DISARMED -> REFRESH TARGETS -> RESTORE MAINTAINER"
  style.text(panel.x + 2, consequenceY, consequence,
    selectedReason and colors.bad or colors.muted, colors.panel, panel.w - 4)
  drawError(panel, math.min(panel.y + panel.h - 5, consequenceY + 1), value, selectedReason or value.error)
  actionBar.draw(state, "workflow_setup", panel.x + 2, panel.y + panel.h - 3, panel.w - 4, {
    { key = "Ctrl+C", label = "Cancel", action = "cancel" },
    { key = "Shift+R", label = "Edit / Rescan", action = "rescan" },
    { key = "Up/Down", label = "Select", action = "next" },
    { key = "Ctrl+S", label = value.mode == "bind" and "Verify + Bind" or "Verify + Add", action = "commit",
      good = selectedReason == nil, disabled = selectedReason ~= nil }
  })
end

local function drawStopping(panel, state, value, y)
  local status = value.lifecycle or {}
  style.text(panel.x + 2, y, "AUTOMATIC SAFE STOP IN PROGRESS", colors.warn, colors.panel, panel.w - 4)
  y = y + 2
  style.textBlock(panel.x + 2, y,
    "Add/Bind has revoked this computer's Maintainer generation and woken its worker. Recipe input stays locked until the old planning tick has fully returned.",
    colors.text, colors.panel, panel.w - 4, 3)
  y = y + 4
  style.text(panel.x + 2, y, "Owner generation: " .. tostring(status.ownerGeneration or "unknown"), colors.muted, colors.panel, panel.w - 4)
  style.text(panel.x + 2, y + 1, "Maintenance generation: " .. tostring(status.maintenanceGeneration or "pending"), colors.muted, colors.panel, panel.w - 4)
  if value.cancelPending then
    style.text(panel.x + 2, y + 3, "Cancel queued; prior ownership restores only after exit proof.", colors.warn, colors.panel, panel.w - 4)
  end
  actionBar.draw(state, "workflow_setup", panel.x + 2, panel.y + panel.h - 3, panel.w - 4, {
    { key = "Ctrl+C", label = value.cancelPending and "Cancel Queued" or "Cancel Safely", action = "cancel", warn = true }
  })
end

local function drawCommitting(panel, state, value, y)
  style.text(panel.x + 2, y, "VERIFYING + SAVING", colors.accent, colors.panel, panel.w - 4)
  y = y + 2
  style.textBlock(panel.x + 2, y,
    "Resolving and reading one exact live Craftable handle. When scalar getCraftable is unavailable, one bounded, filtered getCraftables compatibility lookup is used. Tagged AE2FC capacity cells must also match their canonical K label. Policy saves manual / observe / DISARMED.",
    colors.text, colors.panel, panel.w - 4, 3)
  y = y + 4
  style.text(panel.x + 2, y, "No craft request is sent by this sequence.", colors.good, colors.panel, panel.w - 4)
end

local function drawRestoring(panel, state, value, y)
  style.text(panel.x + 2, y, "RESTORING AUTOMATION", colors.accent, colors.panel, panel.w - 4)
  y = y + 2
  style.textBlock(panel.x + 2, y,
    value.saved and "Recipe is durably saved DISARMED. Restoring only the daemon ownership inherited when setup opened; its first planning pass is deferred."
      or "Discovery is closed. Restoring only the daemon ownership inherited when setup opened; no recipe policy was changed.",
    colors.text, colors.panel, panel.w - 4, 3)
  style.text(panel.x + 2, y + 4, "Inputs remain locked until the restart receipt returns.", colors.muted, colors.panel, panel.w - 4)
end

local function drawLifecycleFailure(panel, state, value, y)
  local stopping = value.stage == "stop_failed"
  style.text(panel.x + 2, y, stopping and "STOP INTERLOCK FAILED" or "AUTOMATION RESTORE FAILED", colors.bad, colors.panel, panel.w - 4)
  y = drawError(panel, y + 2, value) + 1
  style.textBlock(panel.x + 2, y,
    stopping and "Discovery remains locked. Retry the automatic interlock or close and inspect AE2 > Daemon."
      or "The recipe transaction will not repeat. Retry only the restart, or deliberately leave Maintainer OFF.",
    colors.warn, colors.panel, panel.w - 4, 2)
  actionBar.draw(state, "workflow_setup", panel.x + 2, panel.y + panel.h - 3, panel.w - 4, {
    { key = "Ctrl+S", label = stopping and "Retry Safe Stop" or "Retry Restart", action = "retry_lifecycle", good = true },
    { key = "Ctrl+C", label = stopping and "Close + Inspect" or "Leave OFF + Close", action = "leave_off", warn = true }
  })
end

function page.draw(panel, state)
  local value = state.ae2WorkflowSetup
  if not value then return false end
  local y = drawHeader(panel, state, value) + 1
  if value.stage == "stopping" then drawStopping(panel, state, value, y)
  elseif value.stage == "input" then drawInput(panel, state, value, y)
  elseif value.stage == "confirm" then drawConfirm(panel, state, value, y)
  elseif value.stage == "scanning" then drawScanning(panel, state, value, y)
  elseif value.stage == "results" then drawResults(panel, state, value, y)
  elseif value.stage == "committing" then drawCommitting(panel, state, value, y)
  elseif value.stage == "restoring" then drawRestoring(panel, state, value, y)
  elseif value.stage == "stop_failed" or value.stage == "restore_failed" then drawLifecycleFailure(panel, state, value, y)
  else
    value.error = "Unknown recipe setup state: " .. tostring(value.stage)
    value.stage = "input"
    drawInput(panel, state, value, y)
  end
  return true
end

return page
local style = require("oc.dashboard.style")

local columns = {}
local colors = style.colors

local function columnsWidth(spec)
  local width = 0
  for i, col in ipairs(spec or {}) do
    width = width + (col.width or 0) + (i > 1 and 3 or 0)
  end
  return width
end

function columns.split(width, spec, minLeft)
  width = math.floor(tonumber(width) or 0)
  local right = columnsWidth(spec)
  if width < (minLeft or 24) + right + 1 then return width, 0 end
  return width - right - 1, right
end

local function drawColumns(x, y, values, spec, color, bg)
  bg = bg or colors.panel
  local cursor = x
  for i, col in ipairs(spec or {}) do
    if i > 1 then
      style.text(cursor, y, " | ", color, bg, 3)
      cursor = cursor + 3
    end
    style.text(cursor, y, values[i] or "", color, bg, col.width or 1)
    cursor = cursor + (col.width or 1)
  end
end

function columns.drawValues(x, y, values, spec, color, bg)
  drawColumns(x, y, values, spec, color or colors.text, bg)
end

function columns.drawValueBlocks(x, y, values, spec, color, bg, height)
  bg = bg or colors.panel
  height = math.max(1, tonumber(height) or 1)
  local cursor = x
  for i, col in ipairs(spec or {}) do
    if i > 1 then
      style.text(cursor, y, " | ", color, bg, 3)
      cursor = cursor + 3
    end
    style.textBlock(cursor, y, values[i] or "", color, bg, col.width or 1, height)
    cursor = cursor + (col.width or 1)
  end
end

local function labels(spec)
  local out = {}
  for i, col in ipairs(spec or {}) do out[i] = col.label or "" end
  return out
end

function columns.labels(spec)
  return labels(spec)
end

local function drawHeaderTitle(x, y, label, width)
  local title = " " .. tostring(label or "") .. " "
  if #title > width then title = tostring(label or ""):sub(1, width) end
  if #title > 0 then style.text(x, y, title, colors.bg, colors.accent, math.min(width, #title)) end
end

function columns.drawHeader(panel, y, spec, minLeft, leftLabel)
  local leftWidth, rightWidth = columns.split(panel.w - 4, spec, minLeft)
  leftLabel = leftLabel or "Condition"
  style.fill(panel.x + 1, y, panel.w - 2, 1, colors.border)
  if rightWidth <= 0 then
    local compactLabel = leftLabel == "Condition" and "Conditions" or leftLabel
    drawHeaderTitle(panel.x + 2, y, compactLabel, panel.w - 4)
    return y + 1
  end
  drawHeaderTitle(panel.x + 2, y, leftLabel, leftWidth)
  drawColumns(panel.x + 3 + leftWidth, y, labels(spec), spec, colors.text, colors.border)
  return y + 1
end

function columns.drawSettingEffect(x, y, setting, effect, spec, color, height)
  local settingWidth = spec[1] and spec[1].width or 1
  local effectWidth = spec[2] and spec[2].width or 1
  style.textBlock(x, y, setting or "", color, colors.panel, settingWidth, height)
  style.text(x + settingWidth, y, " | ", color, colors.panel, 3)
  style.textBlock(x + settingWidth + 3, y, effect or "", color, colors.panel, effectWidth, height)
end

return columns
local style = require("oc.dashboard.style")

local hint = {}
local colors = style.colors

hint.height = 3

local function editLabel(field)
  if field == "lineIntent" then return "Intent" end
  if field == "lineAuthority" then return "Authority" end
  if field == "alertBelow" then return "Alert Below" end
  if field == "maxRequest" then return "Max Request" end
  if field == "alertEnabled" then return "Low Alert" end
  if field == "requireReadyCpu" then return "CPU Gate" end
  if field == "minBatteryRatio" then return "Battery" end
  if field == "maxDeficitRatio" then return "Power" end
  if field == "cooldown" then return "Cooldown" end
  if field == "locked" then return "Contract Lock" end
  return tostring(field)
end

local function fieldHint(field)
  if field == "alertBelow" then
    return "Type K, M, B, T, or P here. Maintain requests start only below Alert Below."
  elseif field == "maxRequest" then
    return "Type K, M, B, T, or P here. M sends Max Request; auto batches cap here."
  elseif field == "minBatteryRatio" then
    return "Set Battery to 0 to disable this stored-power gate. Batteryless auto needs Battery=0 and Power=0 together."
  elseif field == "maxDeficitRatio" then
    return "Set Power to 0 to disable this input/output gate. Batteryless auto needs Battery=0 and Power=0 together."
  elseif field == "cooldown" then
    return "Type S, M, H, D, or W for cooldowns; bare numbers are seconds."
  elseif field == "lineIntent" then
    return "Intent decides when this line wants a request: maintain buffer, push max, recipe governed, or manual only."
  elseif field == "lineAuthority" then
    return "Authority decides who may act: observe, alert, suggest, or daemon auto submit."
  elseif field == "alertEnabled" then
    return "OFF mutes only the low-stock dashboard alarm; Alert Below still gates automation."
  elseif field == "requireReadyCpu" then
    return "ON waits for a ready CPU before daemon submit; OFF lets AE2 decide at request time."
  elseif field == "locked" then
    return "ON protects this line contract from accidental condition edits."
  end
  return "Select a condition to see the exact control rule before changing it."
end

local function footerText(state, item)
  local field = state.ae2WorkflowEditField or (item and item[1])
  local prefix = state.ae2WorkflowEditField and ("EDITING " .. editLabel(field) .. ": Ctrl+S saves, Ctrl+C cancels.")
    or ("SELECTED " .. editLabel(field) .. ":")
  local message = tostring(state.ae2WorkflowMessage or "")
  local text = prefix .. " " .. fieldHint(field)
  if message ~= "" then return message .. " " .. text end
  return text
end

local function drawBand(panel, y, title, text, height)
  height = math.max(1, tonumber(height) or hint.height)
  style.fill(panel.x + 1, y, panel.w - 2, height, colors.border)
  if panel.w >= 44 then
    title = " " .. tostring(title or "HINT") .. " "
    style.text(panel.x + 2, y, title, colors.bg, colors.accent, #title)
    style.textBlock(panel.x + 3 + #title, y, tostring(text or ""), colors.text, colors.border,
      panel.w - #title - 5, height)
  else
    style.textBlock(panel.x + 2, y, tostring(text or ""), colors.text, colors.border, panel.w - 4, height)
  end
end

function hint.drawText(panel, state, y, title, text, height, statePrefix)
  statePrefix = statePrefix or "dashboard"
  height = math.max(1, tonumber(height) or hint.height)
  if state then
    state[statePrefix .. "HintY"] = y
    state[statePrefix .. "HintHeight"] = height
  end
  drawBand(panel, y, title, text, height)
end

function hint.draw(panel, state, item, y, height)
  hint.drawText(panel, state, y, "FLOW HINT", footerText(state, item), height, "ae2Workflow")
end

return hint
local computer = require("computer")
local lineContract = require("oc.ae2.line_contract")
local time = require("oc.ae2.time")
local workflows = require("oc.ae2.workflows")
local numbers = require("oc.dashboard.number_format")
local manualMemory = require("oc.dashboard.manual_request_memory")
local sync = require("oc.dashboard.workflow_ui_sync")
local list = require("oc.dashboard.workflow_ui_list")

local actions = {}
actions.adjustInterval = 0.18
actions.minimumCooldown = workflows.minimumCooldown
actions.maxCooldown = workflows.maxCooldown
local recordManualMaintainer = manualMemory.recordManualMaintainer

local function fields()
  return workflows.conditionFields or { "lineIntent", "lineAuthority", "alertBelow", "maxRequest" }
end

local function typedField(field)
  return field == "alertBelow" or field == "maxRequest" or field == "minStock" or field == "batch" or field == "minBatteryRatio"
    or field == "maxDeficitRatio" or field == "cooldown"
end

local function requestReceipt(prefix, entry, amount)
  local label = tostring(entry and (entry.label or entry.rawLabel or entry.name) or "target")
  local shown = numbers.quantity(amount) .. (sync.fluidLike(entry) and " mB " or "x ")
  return tostring(prefix or "") .. shown .. label .. " @" .. time.short() .. "."
end

function actions.moveField(state, delta)
  local count = #fields()
  state.ae2WorkflowField = math.max(1, math.min(count, (state.ae2WorkflowField or 1) + delta))
  return true
end

function actions.requestManual(state)
  local entry = list.selectedEntry(state)
  if not entry then return false end
  local amount = sync.requestAmount(entry)
  local ok, err, report = workflows.requestManual(entry)
  local prefix = manualMemory.receiptPrefix(ok, report)
  state.ae2WorkflowMessage = requestReceipt(prefix, entry, amount) .. " " .. manualMemory.statusText(report, err) .. "."
  recordManualMaintainer(state, entry, ok, err, report)
  return true
end

function actions.toggleAuto(state)
  local entry = list.selectedEntry(state)
  if not entry then return false end
  local ok, err, config = workflows.toggleAuto(entry)
  if ok then sync.applyWorkflowPatch(state, entry, config); sync.syncMaintainerTargets(state, entry) end
  state.ae2WorkflowMessage = ok and ("Auto mode now " .. tostring(entry.mode or "manual") .. ".")
    or ("Auto toggle failed: " .. tostring(err))
  return true
end

function actions.toggleArmed(state)
  local entry = list.selectedEntry(state)
  if not entry then return false end
  local ok, err, config = workflows.toggleArmed(entry)
  if ok then sync.applyWorkflowPatch(state, entry, config); sync.syncMaintainerTargets(state, entry) end
  local armed = entry.workflow and entry.workflow.armed and "armed" or "disarmed"
  state.ae2WorkflowMessage = ok and ("Auto armed state now " .. armed .. ".")
    or ("Auto arm failed: " .. tostring(err))
  return true
end

function actions.adjustCondition(state, delta)
  local now = computer.uptime()
  if state.ae2WorkflowLastAdjustAt and now - state.ae2WorkflowLastAdjustAt < actions.adjustInterval then
    return false
  end
  state.ae2WorkflowLastAdjustAt = now
  local entry = list.selectedEntry(state)
  if not entry then return false end
  local field = fields()[state.ae2WorkflowField or 1]
  local ok, err, config = workflows.adjustPending(entry, field, delta)
  if ok then
    sync.applyWorkflowPatch(state, entry, config)
    sync.syncMaintainerTargets(state, entry)
    state.ae2WorkflowSavePending = true
    state.nextAe2WorkflowSave = nil
  end
  state.ae2WorkflowMessage = ok and ("Updated " .. tostring(field) .. ".") or ("Update failed: " .. tostring(err))
  return true
end

function actions.setCondition(state, field, value)
  local entry = list.selectedEntry(state)
  if not entry then return false end
  if not typedField(field) then
    state.ae2WorkflowMessage = "Typed edit supports Alert Below, Max Request, Battery, Power, and Cooldown."
    return true
  end
  local ok, err, config = workflows.setValue(entry, field, value)
  local applied = value
  if ok then
    sync.applyWorkflowPatch(state, entry, config)
    sync.syncMaintainerTargets(state, entry)
    if entry.workflow and entry.workflow[field] ~= nil then applied = entry.workflow[field] end
    state.ae2WorkflowSavePending = false
    state.nextAe2WorkflowSave = nil
  end
  local shown = field == "cooldown" and numbers.seconds(applied)
    or (field == "alertBelow" or field == "maxRequest" or field == "minStock" or field == "batch") and numbers.quantity(applied)
    or tostring(applied)
  state.ae2WorkflowMessage = ok and ("Saved " .. tostring(field) .. " as " .. shown .. ".")
    or ("Set failed: " .. tostring(err))
  return true
end

function actions.setChoice(state, field, value)
  local entry = list.selectedEntry(state)
  if not entry then return false end
  if type(workflows.setChoice) ~= "function" then
    state.ae2WorkflowMessage = "Direct selector unavailable; redeploy AE2 workflow editor."
    return true
  end
  local ok, err, config = workflows.setChoice(entry, field, value)
  if ok then
    sync.applyWorkflowPatch(state, entry, config)
    sync.syncMaintainerTargets(state, entry)
    state.ae2WorkflowSavePending = false
    state.nextAe2WorkflowSave = nil
  end
  local label = field == "lineIntent" and lineContract.intentLabel(value)
    or field == "lineAuthority" and lineContract.authorityLabel(value) or tostring(value)
  local noun = field == "lineAuthority" and "Authority" or "Intent"
  state.ae2WorkflowMessage = ok and (noun .. " set to " .. label .. ".")
    or ("Selector failed: " .. tostring(err))
  return true
end

return actions
local cacheEpoch = require("oc.ae2.cache_epoch")
local lineContract = require("oc.ae2.line_contract")
local manualMemory = require("oc.dashboard.manual_request_memory")

local sync = {}

local function labelKey(value)
  return tostring(value and (value.label or value.rawLabel or value.name) or ""):lower()
end

local function targetFor(value)
  value = value or {}
  return {
    label = value.label,
    rawLabel = value.rawLabel,
    name = value.name,
    damage = value.damage,
    hasTag = value.hasTag,
    kind = value.kind,
    isFluid = value.isFluid,
    amount = value.amount,
    filter = value.filter,
    craftBinding = value.craftBinding
  }
end

local function keyFor(value)
  return cacheEpoch.targetKey(targetFor(value))
end

function sync.fluidLike(entry)
  local name = tostring(entry and entry.name or ""):lower()
  local raw = tostring(entry and entry.rawLabel or ""):lower()
  return entry and (entry.isFluid == true or entry.kind == "fluid"
    or name:find("fluid", 1, true) ~= nil or raw:find("^drops? of") ~= nil)
end

function sync.requestAmount(entry)
  local flow = entry and entry.workflow or {}
  return tonumber(flow.maxRequest or flow.batch or (entry and (entry.maxRequest or entry.batch or entry.request))) or 1
end

local function stockDerivedReason(reason)
  local text = tostring(reason or "")
  return text == "stock ready"
    or text == "stock refreshed; target already satisfied"
    or text:find("^stock%s+") ~= nil
end

local function refreshTargetStockMath(row)
  if not row then return end
  lineContract.annotate(row)
  local current, min = tonumber(row.current), tonumber(row.alertBelow or row.min)
  if not (current and min and stockDerivedReason(row.reason)) then return end
  row.ready = false
  row.reason = current >= min and "stock ready" or "waiting for daemon refresh"
end

function sync.applyWorkflowPatch(state, entry, config)
  if not (entry and config and config.workflows) then return end
  local wanted, fallback = keyFor(entry), labelKey(entry)
  local uniqueFallback, fallbackCount = nil, 0
  for _, row in ipairs(config.workflows or {}) do
    local rowKey, matched = keyFor(row), false
    if entry.name then
      matched = row.name and rowKey == wanted
      if not row.name and rowKey == fallback then uniqueFallback, fallbackCount = row, fallbackCount + 1 end
    elseif row.name then
      matched = false
    else
      matched = rowKey == wanted or rowKey == fallback
    end
    if matched then
      entry.workflow = row
      entry.mode = row.mode or entry.mode
      if state.ae2Workflow and state.ae2Workflow.config then state.ae2Workflow.config = config end
      return row
    end
  end
  if entry.name and fallbackCount == 1 then
    entry.workflow = uniqueFallback
    entry.mode = uniqueFallback.mode or entry.mode
    if state.ae2Workflow and state.ae2Workflow.config then state.ae2Workflow.config = config end
    return uniqueFallback
  end
end

local function copyFlowToTarget(row, flow)
  if not (row and flow) then return end
  row.label = flow.label or row.label
  row.rawLabel = flow.rawLabel
  row.name, row.damage, row.hasTag = flow.name, flow.damage, flow.hasTag
  row.kind, row.isFluid, row.amount, row.filter = flow.kind, flow.isFluid, flow.amount, flow.filter
  row.craftBinding = flow.craftBinding
  row.min, row.alertBelow, row.craftTo = flow.minStock, flow.alertBelow or flow.minStock, flow.craftTo
  row.batch, row.maxRequest = flow.batch, flow.maxRequest or flow.batch
  row.lineIntent, row.lineAuthority = flow.lineIntent, flow.lineAuthority
  row.alertEnabled, row.maxBasis, row.confidence = flow.alertEnabled, flow.maxBasis, flow.confidence
  row.recipeMax, row.dangerUnlocked, row.locked = flow.recipeMax, flow.dangerUnlocked, flow.locked
  row.minBatteryRatio, row.maxDeficitRatio = flow.minBatteryRatio, flow.maxDeficitRatio
  row.requireReadyCpu, row.cooldown, row.armed = flow.requireReadyCpu, flow.cooldown, flow.armed == true
  refreshTargetStockMath(row)
end

local function dirtyMaintainer(state)
  state.ae2MaintainDirty = true
  state.nextAe2MaintainRefresh = 0
  manualMemory.queueDaemonHeartbeat(state)
end

function sync.syncMaintainerTargets(state, entry)
  local flow = entry and entry.workflow
  local targets = state.ae2Maintain and state.ae2Maintain.targets
  if not flow then return end
  if not targets then dirtyMaintainer(state); return end
  local wanted, fallback = keyFor(flow), labelKey(flow)
  local uniqueFallback, fallbackCount = nil, 0
  for _, row in ipairs(targets) do
    if flow.name and row.name and keyFor(row) == wanted then
      copyFlowToTarget(row, flow); dirtyMaintainer(state); return
    elseif flow.name and not row.name and labelKey(row) == fallback then
      uniqueFallback, fallbackCount = row, fallbackCount + 1
    elseif not flow.name and not row.name and labelKey(row) == fallback then
      copyFlowToTarget(row, flow); dirtyMaintainer(state); return
    end
  end
  if fallbackCount == 1 then copyFlowToTarget(uniqueFallback, flow) end
  dirtyMaintainer(state)
end

return sync
local list = {}
list.maxPerPage = 32

local function text(value)
  return tostring(value or ""):lower()
end

local function pageSize(perPage)
  return math.max(1, math.min(list.maxPerPage, perPage or 16))
end

function list.entries(state)
  return (state.ae2Workflow and state.ae2Workflow.entries) or {}
end

function list.ensure(state)
  state.ae2WorkflowQuery = state.ae2WorkflowQuery or ""
  state.ae2WorkflowPage = state.ae2WorkflowPage or 1
  state.ae2WorkflowSelected = state.ae2WorkflowSelected or 1
end

function list.selectedEntry(state)
  return list.entries(state)[state.ae2WorkflowSelected or 1]
end

function list.matches(entry, query)
  query = text(query)
  if query == "" then return true end
  local haystack = text((entry and entry.label) or "") .. " "
    .. text((entry and entry.rawLabel) or "") .. " "
    .. text((entry and entry.name) or "") .. " "
    .. text((entry and entry.mode) or "") .. " "
    .. text((entry and entry.kind) or "") .. " "
    .. text(entry and entry.isFluid and "fluid" or "")
  for token in query:gmatch("%S+") do
    if not haystack:find(token, 1, true) then return false end
  end
  return true
end

local function countMatches(state)
  local total = 0
  for _, entry in ipairs(list.entries(state)) do
    if list.matches(entry, state.ae2WorkflowQuery) then total = total + 1 end
  end
  return total
end

function list.collectPage(state, first, last)
  local out, matched = {}, 0
  for index, entry in ipairs(list.entries(state)) do
    if list.matches(entry, state.ae2WorkflowQuery) then
      matched = matched + 1
      if matched >= first and matched <= last then out[#out + 1] = { entry = entry, index = index } end
      if matched > last then break end
    end
  end
  return out
end

function list.pageCount(state, perPage)
  return math.max(1, math.ceil(countMatches(state) / pageSize(perPage)))
end

function list.pageEntries(state, perPage)
  list.ensure(state)
  perPage = pageSize(perPage)
  local matched = countMatches(state)
  local pages = math.max(1, math.ceil(matched / perPage))
  state.ae2WorkflowPage = ((state.ae2WorkflowPage or 1) - 1) % pages + 1
  local first = ((state.ae2WorkflowPage - 1) * perPage) + 1
  local page = list.collectPage(state, first, first + perPage - 1)
  if page[1] and not list.matches(list.selectedEntry(state), state.ae2WorkflowQuery) then
    state.ae2WorkflowSelected = page[1].index
  end
  return page, matched, pages, #list.entries(state)
end

function list.movePage(state, delta)
  local perPage = pageSize(state.ae2WorkflowPerPage)
  local pages = list.pageCount(state, perPage)
  state.ae2WorkflowPage = ((state.ae2WorkflowPage or 1) - 1 + delta) % pages + 1
  local first = ((state.ae2WorkflowPage - 1) * perPage) + 1
  local page = list.collectPage(state, first, first)
  if page[1] then state.ae2WorkflowSelected = page[1].index end
  return true
end

function list.moveSelection(state, delta)
  list.ensure(state)
  local visible, pos = {}, 1
  for index, entry in ipairs(list.entries(state)) do
    if list.matches(entry, state.ae2WorkflowQuery) then
      visible[#visible + 1] = index
      if index == state.ae2WorkflowSelected then pos = #visible end
    end
  end
  if #visible == 0 then return true end
  pos = math.max(1, math.min(#visible, pos + delta))
  state.ae2WorkflowSelected = visible[pos]
  state.ae2WorkflowPage = math.max(1, math.ceil(pos / pageSize(state.ae2WorkflowPerPage)))
  return true
end

function list.openDetail(state)
  if list.selectedEntry(state) then state.view = "ae2_workflow" end
  return true
end

function list.handleTouch(state, x, y)
  if state.view ~= "ae2_workflows" then return false end
  if y < (state.ae2WorkflowListY or 10) then return false end
  local row = y - (state.ae2WorkflowListY or 10)
  local rows = math.max(1, state.ae2WorkflowRows or 16)
  local perPage = pageSize(state.ae2WorkflowPerPage or (rows * 2))
  if row < 0 or row >= rows then return false end
  local col = tonumber(x) and x > math.floor((state.W or 80) / 2) and 1 or 0
  local first = ((state.ae2WorkflowPage or 1) - 1) * perPage + (col * rows) + row + 1
  local page = list.collectPage(state, first, first)
  if not page[1] then return false end
  state.ae2WorkflowSelected = page[1].index
  return list.openDetail(state)
end

return list
local actionBar = require("oc.dashboard.action_bar")
local list = require("oc.dashboard.workflow_ui_list")

local search = {}
search.maxQuery = 40

local function setQuery(state, value)
  state.ae2WorkflowQuery = tostring(value or ""):sub(1, search.maxQuery)
  state.ae2WorkflowPage = 1
  local page = list.collectPage(state, 1, 1)
  if page[1] then state.ae2WorkflowSelected = page[1].index end
end

function search.hitSearch(state, x, y)
  return state.view == "ae2_workflows" and actionBar.hit(state, "workflow_list", x, y) == "search"
end

function search.setSearchActive(state, active)
  list.ensure(state)
  state.ae2WorkflowSearchActive = active == true
  return true
end

function search.handleClipboard(state, value)
  if state.view ~= "ae2_workflows" or not state.ae2WorkflowSearchActive then return false end
  setQuery(state, (state.ae2WorkflowQuery or "") .. tostring(value or ""))
  return true
end

function search.submit(state)
  local query = tostring(state.ae2WorkflowQuery or ""):gsub("^%s+", ""):gsub("%s+$", "")
  setQuery(state, query)
  -- The filter is local to configured workflow targets. Do not convert Enter
  -- into an AE2 request: grid-wide catalog APIs allocate before Lua can cap
  -- their work and have previously destabilized the shared server.
  state.ae2WorkflowMessage = query == "" and "Showing all managed targets."
    or "Filtering managed targets locally; live AE2 browsing is disabled."
  state.ae2WorkflowSearchActive = false
  return true
end

function search.handleKey(state, char)
  if state.view ~= "ae2_workflows" or not state.ae2WorkflowSearchActive then return nil end
  if char == 24 then
    if state.ae2WorkflowQuery == "" then return false end
    state.ae2WorkflowSearchClipboard = state.ae2WorkflowQuery
    setQuery(state, "")
    return true
  elseif char == 3 then
    if state.ae2WorkflowQuery == "" then return false end
    state.ae2WorkflowSearchClipboard = state.ae2WorkflowQuery
    return false
  elseif char == 22 then
    local value = state.ae2WorkflowSearchClipboard or ""
    if value == "" then return false end
    setQuery(state, value)
    return true
  elseif char == 8 or char == 127 then
    if state.ae2WorkflowQuery == "" then return false end
    setQuery(state, state.ae2WorkflowQuery:sub(1, #state.ae2WorkflowQuery - 1))
    return true
  elseif char == 13 then
    return search.submit(state)
  elseif char and char >= 32 and char <= 126 then
    setQuery(state, state.ae2WorkflowQuery .. string.char(char))
    return true
  end
  return nil
end

return search
local actionBar = require("oc.dashboard.action_bar")
local binding = require("oc.ae2.request_binding")
local actions = require("oc.dashboard.workflow_ui_actions")
local list = require("oc.dashboard.workflow_ui_list")
local search = require("oc.dashboard.workflow_ui_search")
local setup = require("oc.dashboard.workflow_setup")
local ui = {}
ui.maxQuery = search.maxQuery; ui.maxPerPage = list.maxPerPage
ui.ensure = list.ensure; ui.matches = list.matches
ui.pageCount = list.pageCount; ui.pageEntries = list.pageEntries
ui.movePage = list.movePage; ui.moveSelection = list.moveSelection
ui.moveField = actions.moveField
ui.requestManual = actions.requestManual; ui.toggleAuto = actions.toggleAuto; ui.toggleArmed = actions.toggleArmed
ui.adjustCondition = actions.adjustCondition; ui.setCondition = actions.setCondition; ui.setChoice = actions.setChoice
ui.minimumCooldown = actions.minimumCooldown; ui.maxCooldown = actions.maxCooldown
ui.hitSearch = search.hitSearch; ui.setSearchActive = search.setSearchActive
ui.setupActive = setup.active; ui.cancelSetup = setup.cancel
function ui.handleClipboard(state, value)
  if setup.active(state) then return setup.handleClipboard(state, value) end
  return search.handleClipboard(state, value)
end
local defaults = { alertBelow = 0, maxRequest = 1, minBatteryRatio = 0.25, maxDeficitRatio = 1.25, cooldown = 600 }
local function fields()
  return { "lineIntent", "lineAuthority", "alertBelow", "maxRequest", "alertEnabled", "requireReadyCpu", "minBatteryRatio", "maxDeficitRatio", "cooldown", "locked" }
end
local function selectedField(state) return fields()[state.ae2WorkflowField or 1] end
local function editableField(field) return defaults[field] ~= nil end
local function decimalField(field) return field == "minBatteryRatio" or field == "maxDeficitRatio" end
local function compactField(field) return field == "alertBelow" or field == "maxRequest" end
local function durationField(field) return field == "cooldown" end
local function digit(char) return char and char >= string.byte("0") and char <= string.byte("9") end
local function decimalPoint(char) return char == string.byte(".") end
local function decimalAllowed(field) return decimalField(field) or compactField(field) or durationField(field) end
local function maxEditLength(field) return compactField(field) and 16 or durationField(field) and 10 or 9 end
local function suffixSet(field) return durationField(field) and "SMHDW" or "KMBTP" end
local function suffixChar(char, field) local v = char and string.char(char):upper() or nil; return v and v:find("^[" .. suffixSet(field) .. "]$") and v or nil end
local function hasSuffix(value, field) return tostring(value or ""):upper():find("[" .. suffixSet(field) .. "]$") ~= nil end
local function appendEdit(state, text) state.ae2WorkflowEditValue = (tostring(state.ae2WorkflowEditValue or "") .. tostring(text or "")):sub(1, maxEditLength(state.ae2WorkflowEditField)) end
local function isCtrlC(char, code, keyboard) return char == 3 or (code == (keyboard and keyboard.keys and keyboard.keys.c or 46)
  and type(keyboard and keyboard.isControlDown) == "function" and keyboard.isControlDown() == true) end
function ui.beginNumberEdit(state, field, initial)
  if not editableField(field) then return false end
  local entry = list.selectedEntry(state); local flow = entry and entry.workflow or {}
  local fallback = defaults[field] or 0
  local value = initial or tostring(tonumber(flow[field]) or fallback)
  if not decimalAllowed(field) then value = tostring(math.floor(tonumber(value) or fallback)) end
  if value == "." then value = "0." end
  state.ae2WorkflowEditField = field; state.ae2WorkflowEditValue = tostring(value):sub(1, maxEditLength(field))
  return true
end
function ui.handleNumberEdit(state, char, code, keyboard)
  local field = state.ae2WorkflowEditField
  if not field then return nil end
  if isCtrlC(char, code, keyboard) then
    state.ae2WorkflowEditField = nil; state.ae2WorkflowEditValue = nil; state.ae2WorkflowMessage = "Edit canceled."
    return true
  elseif char == 19 then
    local value = state.ae2WorkflowEditValue
    state.ae2WorkflowEditField = nil; state.ae2WorkflowEditValue = nil
    return actions.setCondition(state, field, value)
  elseif char == 8 or char == 127 then
    state.ae2WorkflowEditValue = tostring(state.ae2WorkflowEditValue or ""):sub(1, -2)
    return true
  elseif digit(char) then
    if (compactField(field) or durationField(field)) and hasSuffix(state.ae2WorkflowEditValue, field) then return true end
    appendEdit(state, string.char(char)); return true
  elseif decimalAllowed(field) and decimalPoint(char) then
    local value = tostring(state.ae2WorkflowEditValue or "")
    if (compactField(field) or durationField(field)) and hasSuffix(value, field) then return true end
    if value:find(".", 1, true) then return true end
    state.ae2WorkflowEditValue = ((value == "" and "0" or value) .. "."):sub(1, maxEditLength(field))
    return true
  elseif (compactField(field) or durationField(field)) and suffixChar(char, field) then
    local value = tostring(state.ae2WorkflowEditValue or "")
    if value == "" or hasSuffix(value, field) then return true end
    appendEdit(state, suffixChar(char, field)); return true
  end
  state.ae2WorkflowMessage = "Press Ctrl+S to save or Ctrl+C to cancel."
  return true
end
function ui.handleTouch(state, x, y)
  if setup.active(state) then return setup.handleTouch(state, x, y) end
  if state.view == "ae2_workflows" then
    local action = actionBar.hit(state, "workflow_list", x, y)
    if action == "add" then return setup.open(state) end
    if action == "prev" then return list.movePage(state, -1)
    elseif action == "next" then return list.movePage(state, 1)
    elseif action == "manual" then return actions.requestManual(state)
    elseif action == "auto" then return actions.toggleAuto(state)
    elseif action == "search" then return search.setSearchActive(state, true) end
  elseif state.view == "ae2_workflow" then
    local action = actionBar.hit(state, "workflow_flow", x, y)
    if action == "bind" then return setup.openSelected(state) end
    if action == "manual" then return actions.requestManual(state)
    elseif action == "auto" then return actions.toggleAuto(state)
    elseif action == "arm" then return actions.toggleArmed(state) end
  end
  if state.view == "ae2_workflow" and state.ae2WorkflowChoiceHits then
    for _, hit in ipairs(state.ae2WorkflowChoiceHits) do
      if y == hit.y and x >= hit.x and x <= hit.x2 then
        if hit.index then state.ae2WorkflowField = hit.index end
        return actions.setChoice(state, hit.field, hit.value)
      end
    end
  end
  if state.view == "ae2_workflow" and state.ae2WorkflowFieldRows then
    for index, row in ipairs(state.ae2WorkflowFieldRows) do
      local h = math.max(1, tonumber(row.h) or 1)
      if y >= row.y and y < row.y + h then
        state.ae2WorkflowField = index
        if editableField(row.field) then return ui.beginNumberEdit(state, row.field, "") or true end
        return actions.adjustCondition(state, 1)
      end
    end
  end
  return list.handleTouch(state, x, y)
end
function ui.handleKey(state, char, code, keyboard)
  if state.view ~= "ae2_workflows" and state.view ~= "ae2_workflow" then return false end
  keyboard = keyboard or require("keyboard"); local keys = keyboard.keys or {}; local left, right = keys.left, keys.right
  if setup.active(state) then return setup.handleKey(state, char, code, keyboard) end
  local detail = state.view == "ae2_workflow"; list.ensure(state)
  if detail then
    local editResult = ui.handleNumberEdit(state, char, code, keyboard); if editResult ~= nil then return editResult end
    if digit(char) then return ui.beginNumberEdit(state, selectedField(state), string.char(char)) end
    if decimalAllowed(selectedField(state)) and decimalPoint(char) then return ui.beginNumberEdit(state, selectedField(state), ".") end
    if char == 13 then
      local field = selectedField(state)
      if editableField(field) then return ui.beginNumberEdit(state, field) or true end
      return actions.adjustCondition(state, 1)
    end
  end
  if not detail and (char == string.byte("n") or char == string.byte("N")) then
    return setup.open(state)
  elseif detail and (char == string.byte("b") or char == string.byte("B")) then
    local entry = list.selectedEntry(state)
    if entry and binding.error(entry) ~= nil then return setup.openSelected(state) end
    state.ae2WorkflowMessage = "Recipe is already identity-bound; use explicit ae2-workflow --rebind only for deliberate correction."
    return true
  elseif not detail and left and code == left then
    return list.movePage(state, -1)
  elseif not detail and right and code == right then
    return list.movePage(state, 1)
  elseif not detail and code == keys.up then return list.moveSelection(state, -1)
  elseif not detail and code == keys.down then return list.moveSelection(state, 1)
  elseif not detail and state.ae2WorkflowSearchActive then
    local searchResult = search.handleKey(state, char); if searchResult ~= nil then return searchResult end
  end
  if detail and code == keys.up then return actions.moveField(state, -1) end
  if detail and code == keys.down then return actions.moveField(state, 1) end
  if detail and (char == string.byte("q") or char == string.byte("Q") or code == left or char == string.byte("-")) then
    return actions.adjustCondition(state, -1)
  elseif detail and (char == string.byte("e") or char == string.byte("E") or code == right or char == string.byte("=") or char == string.byte("+")) then
    return actions.adjustCondition(state, 1)
  elseif not detail and (char == string.byte("m") or char == string.byte("M")) then
    return actions.requestManual(state)
  elseif not detail and char == string.byte("A") then
    return actions.toggleAuto(state)
  end
  if detail and (char == string.byte("m") or char == string.byte("M")) then return actions.requestManual(state) end
  if detail and char == string.byte("A") then return actions.toggleAuto(state) end
  if detail and char == string.byte("F") then return actions.toggleArmed(state) end
  return false end
return ui
local tabs = {}

tabs.order = {
  { id = "overview", label = "Deck", key = "V" },
  { id = "initiatives", label = "Domain", key = "H" },
  { id = "ae2", label = "AE2", key = "A" },
  { id = "power", label = "Battery", key = "P" },
  { id = "diagnostics", label = "Ops", key = "O" }
}

tabs.aliases = {
  core = "initiatives",
  health = "initiatives",
  tasks = "initiatives",
  next = "initiatives",
  ops = "diagnostics",
  perf = "ops_perf",
  performance = "ops_perf",
  links = "ops_links",
  components = "ops_links",
  stock = "ae2_counts",
  jobs = "ae2_cpus",
  crafts = "ae2_workflows",
  flow = "ae2_workflow",
  keep = "ae2_maintain",
  arming = "ae2_daemon",
  daemon = "ae2_daemon",
  requests = "ae2_daemon",
  ae2_requests = "ae2_daemon",
  logs = "ae2_logs",
  alarms = "power_alarms",
  ops_health = "ops_health",
  ops_perf = "ops_perf",
  ops_components = "ops_links",
  ops_diagnostics = "diagnostics"
}

tabs.parents = {
  ae2_counts = "ae2",
  ae2_cpus = "ae2",
  ae2_workflows = "ae2",
  ae2_workflow = "ae2",
  ae2_maintain = "ae2",
  ae2_daemon = "ae2",
  ae2_logs = "ae2",
  power_alarms = "power",
  ops_health = "diagnostics",
  ops_links = "diagnostics",
  ops_perf = "diagnostics"
}

local function indexOf(view)
  view = tabs.mainFor(view)
  for i, entry in ipairs(tabs.order) do
    if entry.id == view then return i end
  end
  return 1
end

local function isMain(view)
  for _, entry in ipairs(tabs.order) do
    if entry.id == view then return true end
  end
  return false
end

local function tabText(entry, active)
  local label = entry.key .. ":" .. entry.label
  if active then return "[" .. label .. "]" end
  return " " .. label .. " "
end

function tabs.normalize(view)
  view = tabs.aliases[view] or view
  if isMain(view) or tabs.parents[view] then return view end
  return tabs.order[1].id
end

function tabs.mainFor(view)
  view = tabs.aliases[view] or view
  return tabs.parents[view] or view
end

function tabs.move(view, delta)
  local nextIndex = indexOf(view) + delta
  while nextIndex < 1 do nextIndex = nextIndex + #tabs.order end
  while nextIndex > #tabs.order do nextIndex = nextIndex - #tabs.order end
  return tabs.order[nextIndex].id
end

function tabs.draw(style, state, y)
  local colors = style.colors
  local x = 3
  local mainView = tabs.mainFor(state.view)
  for _, entry in ipairs(tabs.order) do
    local active = entry.id == mainView
    local text = tabText(entry, active)
    local fg = active and colors.bg or colors.muted
    local bg = active and colors.accent or colors.bg
    if x + #text < state.W then
      style.text(x, y, text, fg, bg, #text)
    end
    x = x + #text + 1
  end
end

function tabs.hit(state, x, y)
  if y ~= 3 then return nil end
  x = tonumber(x)
  if not x then return nil end
  local tx = 3
  local mainView = tabs.mainFor(state.view)
  for _, entry in ipairs(tabs.order) do
    local text = tabText(entry, entry.id == mainView)
    if tx + #text < state.W and x >= tx and x < tx + #text then
      return entry.id
    end
    tx = tx + #text + 1
  end
  return nil
end

return tabs
local keyboard = require("keyboard")
local initiatives = require("oc.dashboard.initiatives")

local initiativeEditor = {}

initiativeEditor.lineY = 9

local function selected(editor)
  if editor.selected == nil then return nil end
  editor.selected = math.max(1, math.min(initiatives.maxInitiatives, editor.selected or 1))
  return editor.selected
end

local function appendText(editor, value)
  local index = selected(editor)
  if not index then return false end
  local current = tostring(editor.draft[index] or "")
  value = tostring(value or ""):gsub("[%c]", "")
  local room = (editor.maxLength or initiatives.maxLength) - #current
  if room <= 0 then return false end
  editor.draft[index] = current .. value:sub(1, room)
  return true
end

local function repaintOverlay(state)
  state._initiativeEditorOverlayOnly = true
  return true
end

function initiativeEditor.open(state)
  state.initiativeEditor = {
    selected = 1,
    draft = initiatives.copy(state.initiatives),
    maxLength = initiativeEditor.maxLength(state),
    clipboard = state.initiativeClipboard or ""
  }
end

function initiativeEditor.maxLength(state)
  local width = tonumber(state and state.W) or 80
  return math.max(20, math.min(initiatives.maxLength, width - 20))
end

function initiativeEditor.pick(y)
  local index = tonumber(y) and (y - initiativeEditor.lineY + 1) or nil
  if index and index >= 1 and index <= initiatives.maxInitiatives then
    return index
  end
  return nil
end

function initiativeEditor.moveSelection(editor, delta)
  local index = selected(editor) or (delta > 0 and 0 or initiatives.maxInitiatives + 1)
  editor.selected = ((index - 1 + delta) % initiatives.maxInitiatives) + 1
end

function initiativeEditor.handle(state, ev)
  local editor = state.initiativeEditor
  if not editor then return false end

  if ev[1] == "touch" then
    local index = initiativeEditor.pick(ev[4])
    if index then
      editor.selected = index
      return repaintOverlay(state)
    end
    if editor.selected ~= nil then
      editor.selected = nil
      return repaintOverlay(state)
    end
  elseif ev[1] == "clipboard" then
    if appendText(editor, ev[3]) then return repaintOverlay(state) end
    return false
  elseif ev[1] == "key_down" then
    local char = ev[3]
    local code = ev[4]
    if char == 19 then
      local ok, err, normalized = initiatives.save(editor.draft)
      state.initiatives = normalized or initiatives.normalize(editor.draft)
      state.initiativeEditor = nil
      state.initiativePage = 1
      state.initiativeMessage = ok and "Initiatives saved" or err
      return true
    elseif char == 13 then
      local index = selected(editor) or 0
      editor.selected = (index % initiatives.maxInitiatives) + 1
      return repaintOverlay(state)
    elseif keyboard.keys and code == keyboard.keys.up then
      initiativeEditor.moveSelection(editor, -1)
      return repaintOverlay(state)
    elseif keyboard.keys and code == keyboard.keys.down then
      initiativeEditor.moveSelection(editor, 1)
      return repaintOverlay(state)
    elseif char == 24 then
      local index = selected(editor)
      local value = index and tostring(editor.draft[index] or "") or ""
      if not index or value == "" then return false end
      editor.clipboard = value
      state.initiativeClipboard = value
      editor.draft[index] = ""
      return repaintOverlay(state)
    elseif char == 3 then
      local index = selected(editor)
      local value = index and tostring(editor.draft[index] or "") or ""
      if not index or value == "" then return false end
      editor.clipboard = value
      state.initiativeClipboard = value
      return false
    elseif char == 22 then
      local index = selected(editor)
      if not index then return false end
      local value = tostring(editor.clipboard or state.initiativeClipboard or "")
      if value == "" then return false end
      editor.draft[index] = value:sub(1, editor.maxLength or initiatives.maxLength)
      return repaintOverlay(state)
    elseif char == 8 or char == 127 then
      local index = selected(editor)
      if not index then return false end
      local value = tostring(editor.draft[index] or "")
      if value == "" then return false end
      editor.draft[index] = value:sub(1, math.max(0, #value - 1))
      return repaintOverlay(state)
    elseif char and char >= 32 and char <= 126 then
      if appendText(editor, string.char(char)) then return repaintOverlay(state) end
      return false
    end
  end

  return false
end

return initiativeEditor
local serialization = require("serialization")
local readable = require("oc.core.config")

local initiatives = {}

initiatives.path = "/etc/oc-dashboard-initiatives.cfg"
initiatives.legacyPath = "/etc/oc-dashboard-tasks.cfg"
initiatives.maxInitiatives = 24
initiatives.previewCount = 8
initiatives.maxLength = 60

local defaults = {
  "Multi-Electrolyzer",
  "HSS-G Quad EBF",
  "HSS-E Ingots"
}

local function trim(value)
  value = tostring(value or "")
  value = value:gsub("^%s+", ""):gsub("%s+$", "")
  return value:gsub("[%c]", "")
end

function initiatives.defaults()
  local out = {}
  for i = 1, initiatives.maxInitiatives do
    out[i] = defaults[i] or ""
  end
  return out
end

function initiatives.blank()
  local out = {}
  for i = 1, initiatives.maxInitiatives do out[i] = "" end
  return out
end

function initiatives.copy(list)
  local out = {}
  for i = 1, initiatives.maxInitiatives do
    out[i] = tostring((list and list[i]) or "")
  end
  return out
end

function initiatives.normalize(list)
  local out = {}
  local hasAny = false
  for i = 1, initiatives.maxInitiatives do
    local value = trim(list and list[i])
    if #value > initiatives.maxLength then
      value = value:sub(1, initiatives.maxLength)
    end
    out[i] = value
    if value ~= "" then hasAny = true end
  end
  if not hasAny then return initiatives.defaults() end
  return out
end

local function readConfig(path)
  local ok, handle = pcall(io.open, path, "r")
  if not ok or not handle then return nil end

  local text = handle:read("*a") or ""
  handle:close()
  return text
end

function initiatives.load()
  local text = readConfig(initiatives.path) or readConfig(initiatives.legacyPath)
  if not text then return initiatives.defaults() end
  local decodedOk, value = pcall(serialization.unserialize, text)
  if decodedOk and type(value) == "table" and value.__blank == true then
    return initiatives.blank()
  end
  if decodedOk and type(value) == "table" then
    return initiatives.normalize(value)
  end
  return initiatives.defaults()
end

function initiatives.save(list)
  local normalized = initiatives.normalize(list)
  local saved, saveReason = readable.save(initiatives.path, normalized)
  if not saved then return false, saveReason end
  return true, nil, normalized
end

function initiatives.pageCount(list)
  local last = 0
  for i = 1, initiatives.maxInitiatives do
    if list and list[i] and list[i] ~= "" then last = i end
  end
  return math.max(1, math.ceil(last / initiatives.previewCount))
end

function initiatives.count(list)
  local total = 0
  for i = 1, initiatives.maxInitiatives do
    if list and list[i] and list[i] ~= "" then total = total + 1 end
  end
  return total
end

return initiatives
local style = require("oc.dashboard.style")
local tabs = require("oc.dashboard.tabs")
local deck = require("oc.dashboard.deck_blocks")
local pages = require("oc.dashboard.pages")
local title = require("oc.dashboard.title")

local views = {}
local colors = style.colors

function views.getLayout(width, height)
  local layout = { width = width, height = height }
  if width >= 110 and height >= 22 then
    local middleW = math.max(30, math.floor((width - 9) * 0.40))
    local rightX = 42 + middleW + 3
    local rightW = math.max(24, width - rightX - 2)
    local lowerW = math.floor((width - 8) / 2)
    layout.mode = "wide"
    layout.page = { x = 3, y = 5, w = width - 5, h = height - 6 }
    layout.system = { x = 3, y = 5, w = 36, h = 7 }
    layout.links = { x = 42, y = 5, w = middleW, h = 7 }
    layout.ae2 = { x = 3, y = 13, w = 36, h = 5 }
    layout.power = { x = 42, y = 13, w = middleW, h = 5 }
    layout.initiatives = { x = rightX, y = 5, w = rightW, h = 13 }
    layout.logs = { x = 3, y = 19, w = lowerW, h = height - 20 }
    layout.queue = { x = 5 + lowerW, y = 19, w = width - lowerW - 7, h = height - 20 }
  else
    layout.mode = "compact"
    layout.main = { x = 2, y = 5, w = width - 2, h = math.max(6, height - 6) }
  end
  return layout
end

local function drawHeader(state)
  local fallbackName = title.defaultName or "Click Me To Edit Name"
  local editor = state.dashboardTitleEditor
  local name = tostring((editor and editor.value) or state.dashboardName or fallbackName)
  local shownName = editor and ("[" .. name .. "_]") or name
  local rightX = math.max(3, state.W - 34)
  state.dashboardTitleX = 3
  state.dashboardTitleY = 2
  state.dashboardTitleW = #shownName
  style.text(3, 2, shownName .. " Command Deck", colors.accent, colors.bg, math.max(10, rightX - 4))
  local rightText = editor and "[Ctrl+S/Enter] Save" or "[Ctrl+Q] Exit [Ctrl+R] Refresh"
  style.text(rightX, 2, rightText, colors.muted, colors.bg, 32)
  tabs.draw(style, state, 3)
end

local function activeSearch(state)
  if state.view == "ae2_counts" and state.stockSearchActive then return "STOCK FILTER", state.stockQuery end
  if state.view == "ae2_workflows" and state.ae2WorkflowSearchActive then return "TARGET FILTER", state.ae2WorkflowQuery end
  if state.view == "ae2_maintain" and state.ae2MaintainSearchActive then return "MAINTAINER FILTER", state.ae2MaintainQuery end
  return nil
end

function views.searchPopupOpen(state)
  return activeSearch(state) ~= nil
end

function views.searchPopupHit(state, x, y)
  local b = state and state.searchPopupBounds
  return b and x >= b.x and x < b.x + b.w and y >= b.y and y < b.y + b.h
end

function views.closeSearchPopup(state)
  local hadSearch = state.stockSearchActive or state.ae2WorkflowSearchActive or state.ae2MaintainSearchActive
  if not hadSearch then return false end
  state.stockSearchActive = false
  state.ae2WorkflowSearchActive = false
  state.ae2MaintainSearchActive = false
  return true
end

local function drawSearchPopup(state)
  local title, query = activeSearch(state)
  if not title then state.searchPopupBounds = nil; return end
  local w = math.min(64, math.max(28, state.W - 8))
  local h = 5
  local x = math.max(3, math.floor((state.W - w) / 2))
  local y = math.max(5, math.floor((state.H - h) / 2))
  state.searchPopupBounds = { x = x, y = y, w = w, h = h }
  style.box(x, y, w, h, title)
  style.text(x + 2, y + 2, "> " .. tostring(query or ""), colors.bg, colors.accent, w - 4)
  style.text(x + 2, y + 3, "Type to filter; Ctrl+X/C/V edit; Enter closes", colors.muted, colors.panel, w - 4)
end

function views.drawCompact(state, layout)
  local panel = layout.main
  if state.view == "initiatives" then
    pages.drawInitiatives(panel, state)
  elseif pages.canDraw(state.view) then
    pages.draw(state.view, panel, state)
  else
    deck.drawCompactOverview(panel, state)
  end
end

function views.drawPage(panel, state, layoutMode)
  if state.view == "initiatives" then
    pages.drawInitiatives(panel, state)
  elseif pages.canDraw(state.view) then
    pages.draw(state.view, panel, state)
  end
end

function views.needsClear(state, layout)
  local changed = state._lastView ~= state.view
    or state._lastLayoutMode ~= layout.mode
    or state._lastW ~= state.W
    or state._lastH ~= state.H
  state._lastView = state.view
  state._lastLayoutMode = layout.mode
  state._lastW = state.W
  state._lastH = state.H
  return changed
end

function views.draw(state)
  local layout = views.getLayout(state.W, state.H)
  local scene = tostring(state.view) .. ":" .. tostring(layout.mode) .. ":" .. tostring(state.W) .. "x" .. tostring(state.H)
  style.beginFrame(scene)
  state._forcePaint = views.needsClear(state, layout)
  -- Keep a root layer in every retained scene. It is a no-op on a steady
  -- frame, but lets the canvas safely replay a popup/list contraction without
  -- leaving stale pixels or clearing the terminal during normal polling.
  style.fill(1, 1, state.W, state.H, colors.bg)
  drawHeader(state)
  if layout.mode == "compact" then
    views.drawCompact(state, layout)
  elseif state.view ~= "overview" then
    views.drawPage(layout.page, state, layout.mode)
  else
    deck.drawSystem(layout.system, state.health)
    deck.drawLinks(layout.links, state.components)
    deck.drawAe2(layout.ae2, state.ae2)
    deck.drawPower(layout.power, state.power)
    deck.drawInitiatives(layout.initiatives, state)
    deck.drawLogs(layout.logs, state)
    deck.drawQueue(layout.queue, state)
  end
  drawSearchPopup(state)
  if state.initiativeEditor then pages.drawInitiativeEditor(state) end
  state._forcePaint = false
  state._initiativeEditorOverlayOnly = false
  style.endFrame()
end

return views
#!/bin/lua
local dashboard = require("oc.dashboard.app")
local args = {...}

dashboard.run(args[1])
