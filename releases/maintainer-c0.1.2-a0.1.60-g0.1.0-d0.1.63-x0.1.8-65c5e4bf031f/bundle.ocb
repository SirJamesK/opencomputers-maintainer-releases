local function failExit()
  if os and type(os.exit) == "function" then os.exit(1) end
end

local function usage()
  io.write("usage: oc-config-migrate <verify-install|status|recover CONFIRM|apply CONFIRM>\n")
  io.write("verify-install checks every declared file on this Maintainer computer; Waterline is excluded.\n")
  io.write("status is read-only. Close oc-dashboard and stop the maintainer daemon before recovery or conversion.\n")
  io.write("Conversion formats only human-owned /etc config and archives raw inputs; it never formats /var journals.\n")
end

local function releaseSummary()
  local releases = {}
  for _, group in ipairs(installGroups) do releases[#releases + 1] = group.name .. " " .. group.version end
  return table.concat(releases, " | ")
end

local function declaredTargetCount()
  local total = 0
  for _, group in ipairs(installGroups) do total = total + #group.targets end
  return total
end

local function verifyInstall(quiet)
  local loaded, filesystem = pcall(require, "filesystem")
  if not loaded or type(filesystem) ~= "table" or type(filesystem.exists) ~= "function" then
    io.write("error: Maintainer installation is incomplete; no config was changed.\n")
    io.write("OpenOS filesystem inspection is unavailable. Deploy the full matched stack, then retry.\n")
    return false
  end
  local missing, rows, total = {}, {}, 0
  for _, group in ipairs(installGroups) do
    local presentCount = 0
    for _, path in ipairs(group.targets) do
      total = total + 1
      local checked, present = pcall(filesystem.exists, path)
      if not checked or present ~= true then
        missing[#missing + 1] = { group = group, path = path }
      else
        presentCount = presentCount + 1
      end
    end
    rows[#rows + 1] = { group = group, present = presentCount, total = #group.targets }
  end
  if not quiet or #missing > 0 then
    io.write("MAINTAINER INSTALL PRESENCE VERIFICATION\n")
    io.write("command: oc-config-migrate verify-install\n")
    io.write("scope: local Maintainer computer only; no remote computer is contacted.\n")
    io.write("waterline excluded: run waterline-grade5 verify-install on the Waterline computer.\n")
    io.write("declared targets: " .. tostring(declaredTargetCount()) .. "\n")
    io.write("state       system       expected   targets\n")
    for _, row in ipairs(rows) do
      local state = row.present == row.total and "present" or "incomplete"
      io.write(string.format("%-11s %-12s %-10s %3d/%-3d\n", state, row.group.name,
        row.group.version, row.present, row.total))
    end
    io.write("missing targets: " .. tostring(#missing) .. "/" .. tostring(total) .. "\n")
  end
  if #missing == 0 then
    if not quiet then
      io.write("MIGRATION GATE: READY FOR status\n")
      io.write("ok: Maintainer install verified; " .. tostring(total) .. " matched manifest targets are present.\n")
      io.write("expected release: " .. releaseSummary() .. "\n")
      io.write("note: path presence does not prove byte-for-byte release identity; deploy each root from one matched build.\n")
    end
    return true
  end
  io.write("error: Maintainer installation is incomplete; no config was changed.\n")
  for _, row in ipairs(missing) do
    io.write("missing [" .. row.group.name .. " " .. row.group.version .. "]: " .. row.path .. "\n")
  end
  io.write("MIGRATION GATE: BLOCKED\n")
  io.write("Deploy every file in the matched Core, AE2, GT Power, Dashboard, and Commands roots, then retry.\n")
  io.write("expected release: " .. releaseSummary() .. "\n")
  return false
end

local command = args[1]
local verifyCommand = command == "verify-install" or command == "--verify-install" or command == "--verify_install"

if verifyCommand then
  if args[2] then usage(); failExit(); return end
  if not verifyInstall(false) then failExit() end
  return
end

local mode
if (command == "status" or command == "--status") and not args[2] then mode = "status"
elseif (command == "recover" or command == "--recover") and args[2] == "CONFIRM" and not args[3] then mode = "recover"
elseif (command == "apply" or command == "--apply") and args[2] == "CONFIRM" and not args[3] then mode = "apply"
else usage(); failExit(); return end

-- Recovery and conversion are mutations. Presence-proof the complete matched
-- runtime before loading migration modules or touching durable policy.
if mode ~= "status" and not verifyInstall(true) then failExit(); return end

local loaded, migration = pcall(require, "oc.dashboard.config_migration")
if not loaded or type(migration) ~= "table" then
  io.write("error: oc-config-migrate runtime is incomplete or mixed; no config was changed.\n")
  io.write("Run oc-config-migrate verify-install, deploy every missing matched-stack target, then retry.\n")
  io.write("detail: " .. tostring(migration) .. "\n")
  failExit()
  return
end

local function printReport(report, reportMode)
  local titles = {
    status = "CONFIG FORMAT MIGRATION STATUS (POLICY FILES ONLY)",
    recover = "CONFIG FORMAT MIGRATION RECOVERY (POLICY FILES ONLY)",
    apply = "CONFIG FORMAT MIGRATION APPLY (POLICY FILES ONLY)",
  }
  io.write((titles[reportMode] or "CONFIG FORMAT MIGRATION (POLICY FILES ONLY)") .. "\n")
  io.write("This report does not verify installed program files; run oc-config-migrate verify-install.\n")
  io.write("missing/unowned_missing are config states, not missing program files.\n")
  io.write("state       config                 detail\n")
  for _, row in ipairs((report and report.entries) or {}) do
    io.write(string.format("%-11s %-22s %s\n", tostring(row.state or "?"), tostring(row.label or "?"),
      tostring(row.detail or "")))
  end
end

if mode == "status" then
  printReport(migration.plan(), mode)
elseif mode == "recover" then
  local ok, reason, report = migration.recover()
  printReport(report, mode)
  if ok then
    io.write("ok: deterministic staged-config recovery complete. Re-run status before apply.\n")
  else
    io.write("error: " .. tostring(reason) .. "\n")
    failExit()
  end
elseif mode == "apply" then
  local ok, reason, report = migration.apply()
  printReport(report, mode)
  if ok then
    io.write("ok: readable config conversion complete; .pre-migrate.bak/.retired files preserve source data.\n")
  else
    io.write("error: " .. tostring(reason) .. "\n")
    failExit()
  end
end
#!/bin/lua
local screen = require("oc.dashboard.screen")
local args = {...}

local ok, err, info = screen.apply()
if args[1] == "--status" then
  if ok and info then
    io.write("gpu: " .. tostring(info.gpu) .. "\n")
    io.write("screen: " .. tostring(info.screen) .. "\n")
    io.write("resolution: " .. tostring(info.width) .. "x" .. tostring(info.height) .. "\n")
    io.write("depth: " .. tostring(info.depth) .. "\n")
    io.write("source: " .. tostring(info.source or "unknown") .. "\n")
    if info.configError then io.write("config warning: " .. tostring(info.configError) .. "\n") end
  else
    io.write("screen apply failed: " .. tostring(err) .. "\n")
  end
  io.write("config: " .. tostring(screen.configPath) .. "\n")
end
local logger = require("oc.core.logger")
local screen = require("oc.dashboard.screen")

local log = logger.new("/var/oc/screen.log", "info", 4096)

local function describe(info)
  info = info or {}
  return "gpu=" .. tostring(info.gpu)
    .. " screen=" .. tostring(info.screen)
    .. " size=" .. tostring(info.width) .. "x" .. tostring(info.height)
    .. " depth=" .. tostring(info.depth)
    .. " source=" .. tostring(info.source)
end

local function apply(reason)
  local ok, err, info = screen.apply()
  if ok then
    log:write("info", tostring(reason or "screen") .. " " .. describe(info))
    if info and info.configError then
      log:write("warn", "config warning: " .. tostring(info.configError))
    end
    return true, nil, info
  end
  log:write("warn", tostring(reason or "screen") .. " failed: " .. tostring(err))
  return false, err
end

function start()
  apply("start")
end

function stop()
  log:write("info", "stop")
end

function status()
  local ok, err, info = apply("status")
  if ok then
    io.write(describe(info) .. "\n")
  else
    io.stderr:write("screen failed: " .. tostring(err) .. "\n")
  end
end
local dashboard = require("oc.dashboard.app")
local args = {...}

dashboard.run(args[1])
/usr/bin/oc-screen-full
