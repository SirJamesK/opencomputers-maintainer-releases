DATA
local store = require("oc.core.config_store")

local config = {}

local luaKeywords = {
  ["and"] = true, ["break"] = true, ["do"] = true, ["else"] = true,
  ["elseif"] = true, ["end"] = true, ["false"] = true, ["for"] = true,
  ["function"] = true, ["goto"] = true, ["if"] = true, ["in"] = true,
  ["local"] = true, ["nil"] = true, ["not"] = true, ["or"] = true,
  ["repeat"] = true, ["return"] = true, ["then"] = true, ["true"] = true,
  ["until"] = true, ["while"] = true
}

local keyTypeOrder = { number = 1, string = 2, boolean = 3 }

local function numberText(value)
  if value ~= value or value == math.huge or value == -math.huge then
    return nil, "config cannot serialize a non-finite number"
  end
  local text = string.format("%.17g", value)
  return text == "-0" and "0" or text
end

local function quoteString(value)
  local output = { "\"" }
  for index = 1, #value do
    local byte = string.byte(value, index)
    if byte == 34 then
      output[#output + 1] = "\\\""
    elseif byte == 92 then
      output[#output + 1] = "\\\\"
    elseif byte >= 32 and byte <= 126 then
      output[#output + 1] = string.char(byte)
    else
      output[#output + 1] = string.format("\\%03d", byte)
    end
  end
  output[#output + 1] = "\""
  return table.concat(output)
end

local function keyText(key)
  local kind = type(key)
  if kind == "string" then
    if key:match("^[%a_][%w_]*$") and not luaKeywords[key] then return key end
    return "[" .. quoteString(key) .. "]"
  elseif kind == "number" then
    local text, reason = numberText(key)
    return text and "[" .. text .. "]" or nil, reason
  elseif kind == "boolean" then
    return key and "[true]" or "[false]"
  end
  return nil, "config cannot serialize a " .. kind .. " table key"
end

local function lessKey(left, right)
  local leftKind, rightKind = type(left), type(right)
  if leftKind ~= rightKind then return keyTypeOrder[leftKind] < keyTypeOrder[rightKind] end
  if leftKind == "number" or leftKind == "string" then return left < right end
  return left == false and right == true
end

local renderValue

local function renderTable(value, depth, active)
  if active[value] then return nil, "config cannot serialize a recursive table" end
  active[value] = true

  local arrayLength = 0
  while rawget(value, arrayLength + 1) ~= nil do arrayLength = arrayLength + 1 end
  local mapKeys = {}
  for key in next, value do
    local isArray = type(key) == "number" and key >= 1 and key % 1 == 0 and key <= arrayLength
    if not isArray then
      local renderedKey, keyReason = keyText(key)
      if not renderedKey then
        active[value] = nil
        return nil, keyReason
      end
      mapKeys[#mapKeys + 1] = { key = key, text = renderedKey }
    end
  end
  table.sort(mapKeys, function(left, right) return lessKey(left.key, right.key) end)

  local lines = {}
  for index = 1, arrayLength do
    local rendered, reason = renderValue(value[index], depth + 1, active)
    if not rendered then
      active[value] = nil
      return nil, reason
    end
    lines[#lines + 1] = string.rep("  ", depth + 1) .. rendered .. ","
  end
  for _, entry in ipairs(mapKeys) do
    local rendered, reason = renderValue(value[entry.key], depth + 1, active)
    if not rendered then
      active[value] = nil
      return nil, reason
    end
    lines[#lines + 1] = string.rep("  ", depth + 1) .. entry.text .. " = " .. rendered .. ","
  end
  active[value] = nil
  if #lines == 0 then return "{}" end
  return "{\n" .. table.concat(lines, "\n") .. "\n" .. string.rep("  ", depth) .. "}"
end

renderValue = function(value, depth, active)
  local kind = type(value)
  if kind == "nil" then return "nil" end
  if kind == "boolean" then return value and "true" or "false" end
  if kind == "number" then return numberText(value) end
  if kind == "string" then return quoteString(value) end
  if kind == "table" then return renderTable(value, depth, active) end
  return nil, "config cannot serialize a " .. kind .. " value"
end

function config.render(values)
  return renderValue(values, 0, {})
end

function config.load(path, defaults)
  return store.load(path, defaults)
end

function config.save(path, values)
  return store.save(path, values, config.render)
end

return config
-- Filesystem side of durable config persistence. Kept separate from the
-- renderer so both modules stay within the in-game hand-paste budget.
local filesystem = require("filesystem")
local serialization = require("serialization")

local store = {}

local function shallowCopy(source)
  local copy = {}
  if type(source) == "table" then
    for key, value in pairs(source) do copy[key] = value end
  end
  return copy
end

local function exists(path)
  local ok, present, reason = pcall(filesystem.exists, path)
  if not ok then return nil, tostring(present) end
  if type(present) ~= "boolean" then return nil, tostring(reason or "could not inspect " .. tostring(path)) end
  return present
end

local function rename(from, to)
  local ok, result, reason = pcall(filesystem.rename, from, to)
  if not ok or result ~= true then return false, tostring(reason or result or "rename failed") end
  return true
end

local function remove(path)
  local present, presentReason = exists(path)
  if present == nil then return false, presentReason end
  if not present then return true end
  local ok, result, reason = pcall(filesystem.remove, path)
  if not ok or result ~= true then return false, tostring(reason or result or "remove failed") end
  return true
end

local function ensureParent(path)
  local ok, parent = pcall(filesystem.path, path)
  if not ok then return false, tostring(parent) end
  if not parent or parent == "" then return true end
  local present, presentReason = exists(parent)
  if present == nil then return false, presentReason end
  if present then return true end
  local made, result, reason = pcall(filesystem.makeDirectory, parent)
  if not made or result == false then return false, tostring(reason or result or "could not create " .. parent) end
  local verified, verifyReason = exists(parent)
  if verified ~= true then return false, verifyReason or ("could not create " .. parent) end
  return true
end

local function readFile(path)
  local present, presentReason = exists(path)
  if present == nil then return nil, presentReason, nil end
  if not present then return nil, nil, false end
  local opened, handle, openReason = pcall(io.open, path, "r")
  if not opened then return nil, tostring(handle), true end
  if not handle then return nil, tostring(openReason or "could not open " .. tostring(path)), true end
  local readOk, body, readReason = pcall(function() return handle:read("*a") end)
  local closeOk, closed, closeReason = pcall(function() return handle:close() end)
  if not readOk then return nil, tostring(readReason or body), true end
  if not closeOk or closed == false then return nil, tostring(closeReason or closed or "could not close " .. tostring(path)), true end
  return body or "", nil, true
end

local function writeFile(path, body)
  local opened, handle, openReason = pcall(io.open, path, "w")
  if not opened then return false, tostring(handle) end
  if not handle then return false, tostring(openReason or "could not write " .. tostring(path)) end
  local writeOk, wrote, writeReason = pcall(function() return handle:write(body) end)
  local closeOk, closed, closeReason = pcall(function() return handle:close() end)
  if not writeOk or wrote == nil or wrote == false then return false, tostring(writeReason or wrote or "write failed") end
  if not closeOk or closed == false then return false, tostring(closeReason or closed or "close failed") end
  return true
end

local function decodeTable(body)
  if body == "" then return nil, "config file is empty" end
  local decoded, loaded, reason = pcall(serialization.unserialize, body)
  if not decoded then return nil, tostring(loaded) end
  if type(loaded) ~= "table" then return nil, reason or "config file did not contain a table" end
  return loaded
end

function store.load(path, defaults)
  local result = shallowCopy(defaults)
  if not path then return result end
  local body, readReason, present = readFile(path)
  if present == nil then return nil, readReason end
  if not present then
    -- Use the verified prior policy after an interrupted promotion, but do not
    -- promote/delete it implicitly; the operator recovery path owns that.
    body, readReason, present = readFile(path .. ".previous")
    if present == nil then return nil, readReason end
    if not present then return result end
  end
  local loaded, reason = decodeTable(body)
  if not loaded then return nil, reason end
  for key, value in pairs(loaded) do result[key] = value end
  return result
end

function store.save(path, values, render)
  local rendered, renderReason = render(values or {})
  if not rendered then return false, renderReason end
  local parentOk, parentReason = ensureParent(path)
  if not parentOk then return false, parentReason end
  local staged, previous = path .. ".new", path .. ".previous"
  local stagedPresent, stagedReason = exists(staged)
  if stagedPresent == nil then return false, stagedReason end
  local previousPresent, previousReason = exists(previous)
  if previousPresent == nil then return false, previousReason end
  if stagedPresent or previousPresent then return false, "configuration requires recovery before saving: " .. tostring(path) end

  local current, currentReason, currentPresent = readFile(path)
  if currentPresent == nil then return false, currentReason end
  if currentPresent then
    local decoded, decodeReason = decodeTable(current)
    if not decoded then return false, "refusing to overwrite unreadable existing config: " .. tostring(decodeReason) end
  end
  local wrote, writeReason = writeFile(staged, rendered .. "\n")
  if not wrote then remove(staged); return false, writeReason end
  local stagedBody, stagedReadReason, stagedExists = readFile(staged)
  if stagedExists ~= true then
    remove(staged)
    return false, "staged config verification failed: " .. tostring(stagedReadReason)
  end
  local decoded, decodeReason = decodeTable(stagedBody)
  if not decoded then
    remove(staged)
    return false, "staged config verification failed: " .. tostring(decodeReason)
  end

  local moved = false
  if currentPresent then
    local moveOk, moveReason = rename(path, previous)
    if not moveOk then remove(staged); return false, "could not preserve prior config: " .. tostring(moveReason) end
    moved = true
  end
  local promoted, promoteReason = rename(staged, path)
  if not promoted then
    if moved then rename(previous, path) end
    remove(staged)
    return false, "could not promote staged config: " .. tostring(promoteReason)
  end
  if moved then
    local cleaned, cleanupReason = remove(previous)
    if not cleaned then return false, "config promoted but prior cleanup requires recovery: " .. tostring(cleanupReason) end
  end
  return true
end

return store
local computer = require("computer")
local filesystem = require("filesystem")

local logger = {}
local levels = { debug = 10, info = 20, warn = 30, error = 40 }

local function ensureParent(path)
  local parent = filesystem.path(path)
  if parent and parent ~= "" and not filesystem.exists(parent) then
    filesystem.makeDirectory(parent)
  end
end

function logger.new(path, minimumLevel, maxBytes)
  local instance = {
    path = path or "/var/oc/core.log",
    minimum = levels[minimumLevel or "info"] or levels.info,
    maxBytes = maxBytes or 8192
  }

  function instance:write(level, message)
    local numericLevel = levels[level or "info"] or levels.info
    if numericLevel < self.minimum then
      return true
    end

    ensureParent(self.path)
    if filesystem.exists(self.path) and filesystem.size(self.path) > self.maxBytes then
      filesystem.remove(self.path .. ".1")
      filesystem.rename(self.path, self.path .. ".1")
    end

    local handle, reason = io.open(self.path, "a")
    if not handle then
      return false, reason
    end

    handle:write(string.format("%.2f [%s] %s\n", computer.uptime(), level or "info", tostring(message)))
    handle:close()
    return true
  end

  return instance
end

return loggerlocal event = require("event")
local computer = require("computer")

local scheduler = {}

function scheduler.new()
  return { tasks = {} }
end

function scheduler.every(state, name, interval, callback)
  state.tasks[#state.tasks + 1] = {
    name = name,
    interval = math.max(1, interval or 1),
    callback = callback,
    nextRun = 0
  }
end

function scheduler.runOnce(state)
  local now = computer.uptime()
  for _, task in ipairs(state.tasks) do
    if now >= task.nextRun then
      task.nextRun = now + task.interval
      task.callback(now, task.name)
    end
  end
end

function scheduler.run(state, stopSignal, idleSeconds)
  while true do
    scheduler.runOnce(state)
    local signal = table.pack(event.pull(idleSeconds or 1))
    if signal.n > 0 and signal[1] == stopSignal then
      return true
    end
  end
end

return schedulerlocal component = require("component")

local registry = {}

function registry.list(componentType)
  local found = {}
  for address, kind in component.list(componentType) do
    found[#found + 1] = { address = address, type = kind }
  end
  return found
end

function registry.first(componentType)
  for address, kind in component.list(componentType) do
    return address, kind
  end
  return nil
end

function registry.proxy(address)
  if not address then
    return nil, "missing component address"
  end
  return component.proxy(address)
end

function registry.methods(address)
  local proxy, reason = registry.proxy(address)
  if not proxy then
    return nil, reason
  end

  local names = {}
  for methodName in pairs(proxy) do
    names[#names + 1] = methodName
  end
  table.sort(names)
  return names
end

return registrylocal component = require("component")
local computer = require("computer")

local health = {}

function health.snapshot(options)
  options = options or {}
  -- A health panel usually needs process facts, not a second component
  -- enumeration. Callers that already own a component cache can opt out and
  -- retain that cache without making an unrelated screen wake the whole bus.
  local componentCounts = options.componentCounts or {}
  if options.includeComponents ~= false then
    componentCounts = {}
    for _, kind in component.list() do
      componentCounts[kind] = (componentCounts[kind] or 0) + 1
    end
  end

  return {
    uptime = computer.uptime(),
    freeMemory = computer.freeMemory(),
    totalMemory = computer.totalMemory(),
    energy = computer.energy(),
    maxEnergy = computer.maxEnergy(),
    components = componentCounts
  }
end

function health.print(snapshot)
  snapshot = snapshot or health.snapshot()
  io.write(string.format("uptime: %.2fs\n", snapshot.uptime))
  io.write(string.format("memory: %d / %d free\n", snapshot.freeMemory, snapshot.totalMemory))
  io.write(string.format("computer energy: %.0f / %.0f\n", snapshot.energy, snapshot.maxEnergy))
  io.write("components:\n")
  for kind, count in pairs(snapshot.components) do
    io.write(string.format("  %s: %d\n", kind, count))
  end
end

return health
local component = require("component")

local inspect = {}

local function methodNames(address)
  local ok, methods = pcall(component.methods, address)
  if not ok or type(methods) ~= "table" then
    return {}
  end

  local names = {}
  for name in pairs(methods) do
    names[#names + 1] = name
  end
  table.sort(names)
  return names
end

local function hasMethod(row, methodName)
  for _, name in ipairs(row.methods) do
    if name == methodName then
      return true
    end
  end
  return false
end

function inspect.list(filterType)
  local rows = {}
  for address, ctype in component.list(filterType) do
    rows[#rows + 1] = {
      address = address,
      ctype = ctype,
      methods = methodNames(address)
    }
  end
  table.sort(rows, function(a, b)
    if a.ctype == b.ctype then return a.address < b.address end
    return a.ctype < b.ctype
  end)
  return rows
end

function inspect.print(filterType)
  local rows = inspect.list(filterType)
  if #rows == 0 then
    io.write("no components")
    if filterType then io.write(" matching " .. tostring(filterType)) end
    io.write("\n")
    return
  end

  for _, row in ipairs(rows) do
    io.write(string.format("%s %s\n", row.ctype, row.address))
    if #row.methods == 0 then
      io.write("  methods: none visible\n")
    else
      io.write("  methods: " .. table.concat(row.methods, ", ") .. "\n")
    end
  end
end

function inspect.findByMethod(methodName)
  local matches = {}
  for _, row in ipairs(inspect.list()) do
    if hasMethod(row, methodName) then
      matches[#matches + 1] = row
    end
  end
  return matches
end

function inspect.printMethod(methodName)
  if not methodName or methodName == "" then
    io.write("usage: oc-components --method <methodName>\n")
    return
  end

  local rows = inspect.findByMethod(methodName)
  if #rows == 0 then
    io.write("no components expose method " .. tostring(methodName) .. "\n")
    return
  end

  for _, row in ipairs(rows) do
    io.write(string.format("%s %s exposes %s\n", row.ctype, row.address, methodName))
  end
end

return inspectlocal computer = require("computer")
local filesystem = require("filesystem")

local watchdog = {}

local function ensureParent(path)
  local parent = filesystem.path(path)
  if parent and parent ~= "" and not filesystem.exists(parent) then
    filesystem.makeDirectory(parent)
  end
end

function watchdog.heartbeat(path, label)
  path = path or "/var/oc/watchdog.state"
  ensureParent(path)

  local handle, reason = io.open(path, "w")
  if not handle then
    return false, reason
  end

  handle:write(string.format("%s %.2f\n", label or "core", computer.uptime()))
  handle:close()
  return true
end

return watchdog#!/bin/lua
local health = require("oc.core.health")
health.print()
#!/bin/lua
local inspect = require("oc.core.inspect")
local args = {...}

if args[1] == "--method" or args[1] == "-m" then
  inspect.printMethod(args[2])
else
  inspect.print(args[1])
end
local watchdog = require("oc.core.watchdog")

local args = {...}
local command = args[1] or "start"

if command == "start" then
  watchdog.heartbeat("/var/oc/watchdog.state", "oc-core-start")
  return true
elseif command == "stop" then
  watchdog.heartbeat("/var/oc/watchdog.state", "oc-core-stop")
  return true
end

io.stderr:write("usage: oc-core.lua start|stop\n")
return falselocal component = require("component")
local adapterStock = require("oc.ae2.adapter_stock")
local cpu = require("oc.ae2.adapter_cpu")

local adapter = {}

adapter.types = {
  "me_controller",
  "me_interface",
  "me_importbus",
  "me_exportbus"
}

local function methods(address)
  local ok, result = pcall(component.methods, address)
  if ok and type(result) == "table" then
    return result
  end
  return {}
end

local function hasMethod(address, methodName)
  return methods(address)[methodName] ~= nil
end

local function isAeNetwork(address)
  local available = methods(address)
  return available.getItemsInNetwork ~= nil and available.getCraftables ~= nil
end

local function safeCall(address, methodName, ...)
  if not hasMethod(address, methodName) then
    return nil, "missing method: " .. methodName
  end

  local values = table.pack(pcall(component.invoke, address, methodName, ...))
  if not values[1] then
    return nil, tostring(values[2])
  end
  return table.unpack(values, 2, values.n)
end

function adapter.components(options)
  options = options or {}
  local found = {}
  local seen = {}
  for _, kind in ipairs(adapter.types) do
    for address in component.list(kind) do
      seen[address] = true
      found[#found + 1] = { address = address, type = kind }
    end
  end
  -- `component.methods` for every component is useful only when explicitly
  -- diagnosing an unusual integration. Normal dashboard refreshes already
  -- know the AE2 component types and must not turn one AE2 status read into a
  -- server-wide component-method probe.
  if options.includeUnknown == true then
    for address, kind in component.list() do
      if not seen[address] and isAeNetwork(address) then
        seen[address] = true
        found[#found + 1] = { address = address, type = kind }
      end
    end
  end
  return found
end

function adapter.primary()
  local preferred = { "me_controller", "me_interface", "me_exportbus", "me_importbus" }
  for _, kind in ipairs(preferred) do
    for address in component.list(kind) do
      return { address = address, type = kind }
    end
  end
  return nil, "no AE2 components found"
end

function adapter.networkPower(node)
  local stored, storedError = safeCall(node.address, "getStoredPower")
  local max, maxError = safeCall(node.address, "getMaxStoredPower")
  local usage, usageError = safeCall(node.address, "getAvgPowerUsage")
  local injection, injectionError = safeCall(node.address, "getAvgPowerInjection")
  local idle, idleError = safeCall(node.address, "getIdlePowerUsage")
  return {
    stored = stored,
    max = max,
    usage = usage,
    injection = injection,
    idle = idle,
    storedError = storedError,
    maxError = maxError,
    usageError = usageError,
    injectionError = injectionError,
    idleError = idleError
  }
end

function adapter.cpuSummary(node)
  return cpu.summary(node, safeCall)
end

local function tableCount(address, methodName)
  local values, err = safeCall(address, methodName)
  if type(values) == "table" then
    return math.max(tonumber(values.n) or 0, #values)
  end
  return nil, err
end

function adapter.networkCounts(node, options)
  options = options or {}
  local items, itemsError
  if options.countItems == true then
    items, itemsError = tableCount(node.address, "getItemsInNetwork")
  end
  local fluids, fluidsError
  if options.countFluids == true then
    fluids, fluidsError = tableCount(node.address, "getFluidsInNetwork")
  end
  local craftables, craftablesError
  if options.countCraftables == true then
    craftables, craftablesError = tableCount(node.address, "getCraftables")
  end
  return {
    items = items,
    fluids = fluids,
    craftables = craftables,
    itemsError = itemsError,
    fluidsError = fluidsError,
    craftablesError = craftablesError,
    itemsSkipped = options.countItems ~= true,
    fluidsSkipped = options.countFluids ~= true,
    craftablesSkipped = options.countCraftables ~= true
  }
end

function adapter.itemCount(node, filter)
  local items = safeCall(node.address, "getItemsInNetwork", filter)
  if type(items) ~= "table" then
    return nil, "item query unavailable"
  end
  return #items
end

adapterStock.bind(adapter, safeCall)

function adapter.methods(node)
  local names = {}
  for name in pairs(methods(node.address)) do
    names[#names + 1] = name
  end
  table.sort(names)
  return names
end

return adapter
local component = require("component")
local requestInvoker = require("oc.ae2.request_invoker")

-- CPU proxy tables can carry nested Crafting CPU handles that are lost when
-- passed through component.invoke. Keep the proxy-specific witness work in a
-- focused module so the public adapter remains small enough to audit and
-- paste safely.
local cpu = {}

local function cpuHandles(row)
  local out, seen = {}, {}
  local function add(value)
    if value ~= nil and not seen[value] then
      out[#out + 1] = value
      seen[value] = true
    end
  end
  if type(row) == "table" then
    add(row.cpu)
    add(row.handle)
    add(row.cluster)
    add(row)
  end
  return out
end

local function cpuBusy(row)
  if type(row) ~= "table" then return false end
  local value = row.busy
  if value == true then return true end
  if value == false or value == nil then return false end
  if type(value) == "number" then return value ~= 0 end
  local text = tostring(value):lower()
  return text == "true" or text == "1" or text == "yes" or text == "busy" or text == "working"
end

local function cpuField(value, key)
  if value == nil then return nil end
  local ok, result = pcall(function() return value[key] end)
  if ok then return result end
  return nil
end

local function cpuCallResult(values, methodName)
  if values[1] then
    if values[2] ~= nil then return values[2], nil end
    return nil, tostring(values[3] or ("nil result: " .. methodName))
  end
  return nil, tostring(values[2])
end

local function callCpuMethod(handle, methodName)
  local okMethod, method = pcall(function() return handle and handle[methodName] end)
  if okMethod and method ~= nil then
    local direct = table.pack(pcall(function() return method() end))
    if direct[1] then return cpuCallResult(direct, methodName) end
    local selfStyle = table.pack(pcall(function() return method(handle) end))
    if selfStyle[1] then return cpuCallResult(selfStyle, methodName) end
    return nil, tostring(direct[2] or selfStyle[2])
  end
  if not okMethod then return nil, tostring(method) end
  if type(handle) == "string" then
    local raw = table.pack(pcall(component.invoke, handle, methodName))
    if raw[1] and raw[2] ~= nil then return table.unpack(raw, 2, raw.n) end
    return nil, raw[1] and ("nil result: " .. methodName) or tostring(raw[2])
  end
  if handle ~= nil then return nil, "missing method: " .. tostring(methodName) end
  return nil, nil
end

local function optionalWitnessUnavailable(err)
  local text = tostring(err or "")
  local lower = text:lower()
  return text == ""
    or text:find("missing method:", 1, true) ~= nil
    or text:find("missing methods:", 1, true) ~= nil
    or text:find("nil result:", 1, true) ~= nil
    or lower:find("no crafting monitor", 1, true) ~= nil
    or lower:find("nothing is crafted", 1, true) ~= nil
end

local function rememberLabel(row, stack)
  local label = cpuField(stack, "label") or cpuField(stack, "name") or stack
  if label == nil then return end
  row.finalOutputLabels = row.finalOutputLabels or {}
  row.finalOutputLabels[#row.finalOutputLabels + 1] = tostring(label)
end

local function rememberLabels(row, stacks)
  if type(stacks) ~= "table" then
    rememberLabel(row, stacks)
    return
  end
  if cpuField(stacks, "label") ~= nil or cpuField(stacks, "name") ~= nil then
    rememberLabel(row, stacks)
    return
  end
  local seen = {}
  local reported = math.max(tonumber(stacks.n) or 0, #stacks)
  for index = 1, reported do
    if stacks[index] ~= nil then
      seen[index] = true
      rememberLabel(row, stacks[index])
    end
  end
  for key, stack in pairs(stacks) do
    if key ~= "n" and not seen[key] then rememberLabel(row, stack) end
  end
end

local function eachCpu(cpus, fn)
  local seen = {}
  local reported = math.max(tonumber(cpus and cpus.n) or 0, #(cpus or {}))
  for index = 1, reported do
    if cpus[index] ~= nil then
      seen[index] = true
      fn(cpus[index], index)
    end
  end
  for key, row in pairs(cpus or {}) do
    if key ~= "n" and not seen[key] then fn(row, key) end
  end
end

local function snapshotFinalOutputs(cpus)
  eachCpu(cpus, function(row)
    if type(row) == "table" then
      row.finalOutputChecked = true
      row.finalOutputLabels = nil
      row.finalOutputStack = nil
      row.finalOutputError = nil
      local firstErr = nil
      for _, handle in ipairs(cpuHandles(row)) do
        local stack, err = callCpuMethod(handle, "finalOutput")
        if stack ~= nil then
          row.finalOutputStack = stack
          rememberLabels(row, stack)
          row.finalOutputError = nil
          return
        elseif err and not optionalWitnessUnavailable(err) and not firstErr then
          firstErr = err
        end
      end
      row.finalOutputError = cpuBusy(row) and firstErr and tostring(firstErr) or nil
    end
  end)
end

local function finalOutputStats(cpus)
  local outputs, missingBusy = 0, 0
  eachCpu(cpus, function(row)
    if type(row) == "table" then
      local labels = row.finalOutputLabels
      local hasOutput = row.finalOutputStack ~= nil
        or (type(labels) == "table" and labels[1] ~= nil)
      if hasOutput then
        outputs = outputs + 1
      elseif cpuBusy(row) and row.finalOutputError == nil then
        missingBusy = missingBusy + 1
      end
    end
  end)
  return outputs, missingBusy
end

local function candidate(cpus, source)
  snapshotFinalOutputs(cpus)
  local outputs, missingBusy = finalOutputStats(cpus)
  return { cpus = cpus, source = source, outputs = outputs, missingBusy = missingBusy }
end

local function better(candidateRow, current)
  if not current then return true end
  if candidateRow.outputs ~= current.outputs then return candidateRow.outputs > current.outputs end
  return candidateRow.missingBusy < current.missingBusy
end

local function proxyGetCpus(address)
  local ok, proxy = pcall(component.proxy, address)
  if not ok then return nil, tostring(proxy) end
  local method = proxy and proxy.getCpus
  if not requestInvoker.isCallable(method) then return nil, "missing method: getCpus" end

  local best
  local values = table.pack(pcall(method))
  if values[1] and type(values[2]) == "table" then best = candidate(values[2], "proxy") end
  if not best or best.missingBusy > 0 then
    local selfStyle = table.pack(pcall(method, proxy))
    if selfStyle[1] and type(selfStyle[2]) == "table" then
      local recovered = candidate(selfStyle[2], "proxy-self")
      if better(recovered, best) then best = recovered end
    elseif not best and selfStyle[1] then
      return table.unpack(selfStyle, 2, selfStyle.n)
    end
  end
  if best then return best.cpus, nil, best.source, true end
  if values[1] then return table.unpack(values, 2, values.n) end
  return nil, tostring(values[2])
end

function cpu.summary(node, safeCall)
  local cpus, err, source, snapshotted = proxyGetCpus(node.address)
  source = source or "proxy"
  if type(cpus) ~= "table" then
    cpus, err = safeCall(node.address, "getCpus")
    source = "invoke"
  end
  if type(cpus) ~= "table" then return { count = 0, cpus = {}, error = err } end
  if not snapshotted then snapshotFinalOutputs(cpus) end
  return { count = math.max(tonumber(cpus.n) or 0, #cpus), cpus = cpus, source = source }
end

return cpu
local computer = require("computer")
local stockRows = require("oc.ae2.adapter_stock_rows")
local stockBulk = require("oc.ae2.adapter_stock_bulk")
local stockTarget = require("oc.ae2.adapter_stock_target")

local stock = {}

stock.schema = 3
stock.softFreeKb = 512
stock.hardFreeKb = 384
stock.preferredFreeKb = 768

local function now()
  local ok, value = pcall(computer.uptime)
  return ok and tonumber(value) or 0
end

local function freeKb()
  local ok, value = pcall(computer.freeMemory)
  if not ok or type(value) ~= "number" then return nil end
  return math.floor(value / 1024)
end

local function collectFull()
  if type(collectgarbage) == "function" then collectgarbage("collect") end
end

local function resetCache(cache)
  for key in pairs(cache) do cache[key] = nil end
  cache.schema = stock.schema
end

function stock.memoryMode(cache)
  local free = freeKb()
  if free and free < stock.hardFreeKb then return "emergency", free end
  if free and free < stock.softFreeKb then return "compact", free end
  if free and free < stock.preferredFreeKb then return "indexed", free end
  return "full", free
end

local function pressure(cache, mode, free)
  cache.mode, cache.freeKb = mode, free
  if mode ~= "full" then cache.search = {} end
  if mode == "compact" or mode == "emergency" then cache.byLabel = nil end
  if mode == "emergency" then collectFull() end
end

stock.runtime = {
  now = now,
  resetCache = resetCache,
  pressure = pressure
}

function stock.searchText(cache, index, entry)
  return stockRows.searchText(cache, index, entry)
end

function stock.bulkRefresh(node, cache, options, safeCall)
  return stockBulk.bulkRefresh(stock, stockRows, node, cache, options, safeCall)
end

function stock.targetRefresh(node, cache, options, safeCall)
  return stockTarget.targetRefresh(stock, stockRows, node, cache, options, safeCall)
end

function stock.bind(adapter, safeCall)
  function adapter.stockDiscover(node, options)
    local cache = stock.bulkRefresh(node, {}, { force = true }, safeCall)
    return { total = cache.total or 0, entries = cache.entries or {}, error = cache.error, cache = cache }
  end

  function adapter.stockEntryCount(node, entry, cache)
    local kind = entry and (entry.kind or entry[stockRows.KIND] or (entry.isFluid and "fluid" or "item"))
    local fp = entry and (entry[stockRows.FP] or stockRows.fingerprint(kind, entry))
    local index = fp and cache and cache.byFp and cache.byFp[fp]
    local row = index and cache.entries and cache.entries[index]
    if row and stockRows.sameStockLabel(row, entry) then return row[stockRows.SIZE], nil end
    return tonumber(entry and (entry.size or entry[stockRows.SIZE])) or 0, nil
  end

  function adapter.stockRefresh(node, cache, options)
    if options and type(options.targets) == "table" then
      return stock.targetRefresh(node, cache, options, safeCall)
    end
    return stock.bulkRefresh(node, cache, options, safeCall)
  end
end

return stock
local match = require("oc.ae2.craft_match")

local rows = {}

local KIND, FP, LABEL, SIZE, DAMAGE, TAG, NAME, RAW, FILTER = 1, 2, 3, 4, 5, 6, 7, 8, 9
rows.KIND, rows.FP, rows.LABEL, rows.SIZE = KIND, FP, LABEL, SIZE
rows.DAMAGE, rows.TAG, rows.NAME, rows.RAW, rows.FILTER = DAMAGE, TAG, NAME, RAW, FILTER

local function fluidLabelKey(row)
  return row and row.isFluid and ("fluid-label:" .. tostring(row[LABEL] or row.label or ""):lower()) or nil
end

local function itemSize(item)
  return tonumber(item and (item.size or item.amount or item.count)) or 0
end

local function itemLabel(item)
  return tostring((item and (item.label or item.name)) or "unknown")
end

function rows.cleanStockLabel(value)
  return match.tidyLabel(value)
end

function rows.targetLabel(target)
  return tostring(target and (target.label or target.rawLabel or target.name) or "target")
end

function rows.itemLooksFluid(item)
  if match.nestedFluid(item) then return true end
  local label = match.stripFormattingCodes(itemLabel(item))
  if label:find("^[Dd]rops? of%s+") then return true end
  if item and (item.kind == "fluid" or item.type == "fluid" or item.isFluid == true) then return true end
  return item and item.amount ~= nil and item.damage == nil and item.maxDamage == nil
end

function rows.targetKind(target)
  if not target then return "item" end
  if target.isFluid == true or target.kind == "fluid" then return "fluid" end
  if match.stripFormattingCodes(target.rawLabel or target.label or ""):find("^[Dd]rops? of%s+") then return "fluid" end
  return "item"
end

function rows.sameStockLabel(row, entry)
  local raw = itemLabel(entry)
  return raw == row.rawLabel or rows.cleanStockLabel(raw) == row.label
end

local function itemFilter(item)
  local filter = {}
  if item.name then filter.name = item.name end
  if item.damage ~= nil then filter.damage = item.damage end
  if not filter.name and item.label then filter.label = item.label end
  return filter
end

local function fluidFilter(fluid)
  local filter = {}
  if fluid.name then filter.name = fluid.name end
  if not filter.name and fluid.label then filter.label = fluid.label end
  return filter
end

function rows.fingerprint(kind, stack)
  if kind == "fluid" then
    return "fluid:" .. tostring(stack and (stack.name or stack.label) or "")
  end
  return "item:" .. tostring(stack and stack.name or "") .. ":" .. tostring(stack and stack.damage or 0)
    .. ":" .. (stack and stack.hasTag and "1" or "0")
end

function rows.normalizeItem(item)
  local rawLabel = itemLabel(item)
  local filter = itemFilter(item)
  local label, fp = rows.cleanStockLabel(rawLabel), rows.fingerprint("item", item)
  local row = { "item", fp, label, itemSize(item), filter.damage or 0, item and item.hasTag and 1 or 0,
    filter.name or "?", rawLabel, filter }
  row.rawLabel, row.label, row.size, row.filter = rawLabel, label, row[SIZE], filter
  row.kind = row[KIND]
  row.isFluid = false
  row.name, row.damage, row.hasTag = filter.name, filter.damage, row[TAG] == 1
  return row
end

function rows.normalizeFluid(fluid)
  local rawLabel = itemLabel(fluid)
  local filter = fluidFilter(fluid)
  local label, fp = rows.cleanStockLabel(rawLabel), rows.fingerprint("fluid", fluid)
  local row = { "fluid", fp, label, itemSize(fluid), 0, 0, filter.name or "?", rawLabel, filter }
  row.rawLabel, row.label, row.size, row.amount, row.filter = rawLabel, label, row[SIZE], row[SIZE], filter
  row.kind = row[KIND]
  row.isFluid = row[KIND] == "fluid"
  row.stockSource = "fluid"
  row.name, row.damage, row.hasTag = filter.name, nil, false
  return row
end

function rows.normalizeFluidProxy(item)
  local identity = match.normalizeStack(item, nil)
  local quantity = itemSize(item)
  local row = rows.normalizeFluid({
    label = identity.label, name = identity.name, amount = quantity, size = quantity
  })
  row[FP] = "fluid-proxy:" .. tostring(row.label or ""):lower()
  row[RAW], row.rawLabel = identity.rawLabel, identity.rawLabel
  row.stockSource = "item_proxy"
  return row
end

function rows.zeroTargetRow(target)
  target = target or {}
  local filter = target.filter or {}
  local kind = rows.targetKind(target)
  local stack = {
    label = target.label or target.rawLabel or filter.label or filter.name or target.name,
    name = target.name or filter.name,
    damage = target.damage or filter.damage,
    hasTag = target.hasTag == true,
    size = 0,
    amount = 0,
    kind = kind,
    isFluid = kind == "fluid"
  }
  local row = stack.isFluid and rows.normalizeFluid(stack) or rows.normalizeItem(stack)
  row[FP] = "zero-target:" .. rows.targetKey(target)
  row.label = rows.targetLabel(target)
  row.rawLabel = target.rawLabel or row.rawLabel
  row.filter = target.filter or row.filter
  row.stockTarget = true
  return row
end

function rows.addRow(out, byFp, entry)
  local index = byFp[entry[FP]] or byFp[fluidLabelKey(entry)]
  if index and out[index] then
    local row = out[index]
    local rowSize, entrySize = tonumber(row[SIZE]) or 0, tonumber(entry[SIZE]) or 0
    local mixedFluidProxy = (entry.stockSource == "fluid" and row.stockSource == "item_proxy")
      or (entry.stockSource == "item_proxy" and row.stockSource == "fluid")
    if mixedFluidProxy then
      if entry.stockSource == "fluid" and entrySize >= rowSize then
        row[FP], row[NAME], row[RAW], row[FILTER] = entry[FP], entry[NAME], entry[RAW], entry[FILTER]
        row.name, row.rawLabel, row.filter, row.stockSource = entry.name, entry.rawLabel, entry.filter, entry.stockSource
      end
      row[SIZE] = math.max(rowSize, entrySize)
      byFp[entry[FP]] = index
      byFp[fluidLabelKey(entry)] = index
    elseif entry.stockSource == "item_proxy" and row.stockSource == "item_proxy" then
      row[SIZE] = math.max(rowSize, entrySize)
    else
      row[SIZE] = row[SIZE] + entry[SIZE]
    end
    row.size = row[SIZE]
    if row.isFluid then row.amount = row[SIZE] end
    return
  end
  byFp[entry[FP]] = #out + 1
  if fluidLabelKey(entry) then byFp[fluidLabelKey(entry)] = #out + 1 end
  out[#out + 1] = entry
end

function rows.addMatchingRows(out, byFp, values, target, fluidRows)
  if type(values) ~= "table" then return end
  for _, value in ipairs(values) do
    local row = fluidRows and rows.normalizeFluid(value)
      or rows.itemLooksFluid(value) and rows.normalizeFluidProxy(value)
      or rows.normalizeItem(value)
    if match.sameTarget(row, target) then rows.addRow(out, byFp, row) end
  end
end

function rows.hasTargetRow(out, target)
  for _, row in ipairs(out or {}) do
    if match.sameTarget(row, target) then return true end
  end
  return false
end

function rows.sortRows(out)
  table.sort(out, function(a, b)
    if a[SIZE] ~= b[SIZE] then return a[SIZE] > b[SIZE] end
    return tostring(a[LABEL]) < tostring(b[LABEL])
  end)
end

function rows.rebuildIndexes(cache, out, mode)
  local byFp, byLabel = {}, {}
  for index, row in ipairs(out or {}) do
    byFp[row[FP]] = index
    if mode == "full" then byLabel[tostring(row[LABEL]):lower()] = index end
  end
  cache.byFp = byFp
  cache.byLabel = mode == "full" and byLabel or nil
  cache.search = {}
end

function rows.clearRows(cache)
  cache.rows, cache.entries, cache.total = {}, {}, 0
  cache.byFp, cache.byLabel, cache.search = {}, nil, {}
end

function rows.searchText(cache, index, entry)
  cache = cache or {}
  cache.search = cache.search or {}
  if cache.search[index] then return cache.search[index] end
  entry = entry or (cache.entries and cache.entries[index])
  if not entry then return "" end
  local value = tostring(entry[KIND] or "") .. " " .. tostring(entry[FP] or "") .. " "
    .. tostring(entry[LABEL] or "") .. " " .. tostring(entry[RAW] or "") .. " "
    .. tostring(entry[NAME] or "") .. " " .. tostring(entry.isFluid and "fluid" or entry.kind or "")
    .. " " .. tostring(entry.amount or "")
  value = value:lower()
  cache.search[index] = value
  return value
end

function rows.targetSignature(targets)
  local parts = {}
  for index, target in ipairs(targets or {}) do
    parts[index] = rows.targetKey(target)
  end
  return table.concat(parts, "|")
end

function rows.targetKey(target)
  local marker = type(target and target.craftBinding) == "table" and target.craftBinding or {}
  return rows.targetKind(target) .. ":" .. rows.targetLabel(target) .. ":"
    .. tostring(target and target.name or "") .. ":" .. tostring(target and target.damage or "")
    .. ":" .. tostring(target and target.hasTag == true) .. ":" .. tostring(marker.label or "")
end

return rows
local bulk = {}

function bulk.bulkRefresh(stock, rows, node, cache, options, safeCall)
  cache, options = cache or {}, options or {}
  if cache.schema ~= stock.schema then stock.runtime.resetCache(cache) end
  cache.entries = cache.entries or cache.rows or {}
  cache.rows = cache.entries
  local stamp = stock.runtime.now()
  local mode, free = stock.memoryMode(cache)
  stock.runtime.pressure(cache, mode, free)
  local minRefresh = tonumber(options.minRefreshSeconds) or 60
  local age = stamp - (tonumber(cache.lastRefresh) or 0)
  cache.age = math.max(0, math.floor(age))
  if mode == "emergency" then
    cache.error = "stock refresh skipped: low memory"
    return cache
  end
  if not options.force and #cache.entries > 0 and age < minRefresh then return cache end
  local items, err = safeCall(node.address, "getItemsInNetwork")
  local fluids, fluidErr = safeCall(node.address, "getFluidsInNetwork")
  cache.ae2Calls = (tonumber(cache.ae2Calls) or 0) + 2
  cache.itemError = type(items) == "table" and nil or err
  cache.fluidError = type(fluids) == "table" and nil or fluidErr
  if type(items) ~= "table" and type(fluids) ~= "table" then
    cache.error = err or fluidErr or "stock snapshot unavailable"
    return cache
  end
  local out, byFp = {}, {}
  if type(items) == "table" then
    for i, item in ipairs(items) do
      rows.addRow(out, byFp, rows.itemLooksFluid(item) and rows.normalizeFluidProxy(item) or rows.normalizeItem(item))
      if i % 64 == 0 and os.sleep then os.sleep(0) end
    end
  end
  if type(fluids) == "table" then
    for i, fluid in ipairs(fluids) do
      rows.addRow(out, byFp, rows.normalizeFluid(fluid))
      if i % 64 == 0 and os.sleep then os.sleep(0) end
    end
  end
  rows.sortRows(out)
  cache.rows, cache.entries, cache.total = out, out, #out
  cache.itemTotal = type(items) == "table" and #items or nil
  cache.fluidTotal = type(fluids) == "table" and #fluids or nil
  cache.schema = stock.schema
  cache.lastRefresh, cache.age, cache.error = stamp, 0, nil
  cache.scope, cache.targetCount, cache.targetSignature = "bulk", nil, nil
  rows.rebuildIndexes(cache, out, mode)
  items, fluids = nil, nil
  if type(collectgarbage) == "function" then collectgarbage("step", 200) end
  return cache
end

return bulk
local cacheEpoch = require("oc.ae2.cache_epoch")
local match = require("oc.ae2.craft_match")
local stockMemory = require("oc.ae2.stock_memory")

local target = {}

local function stampEpoch(cache, signature)
  cache.epoch = cacheEpoch.snapshot()
  if cache.epoch then cache.epoch.targetSignature = signature end
end

local function pruneRows(cache, rows, targets)
  local valid, out, byFp = {}, {}, {}
  for _, stockTarget in ipairs(targets or {}) do valid[rows.targetKey(stockTarget)] = true end
  for _, row in ipairs(cache.entries or cache.rows or {}) do
    if row.targetKey and valid[row.targetKey] then rows.addRow(out, byFp, row) end
  end
  cache.rows, cache.entries, cache.total = out, out, #out
  cache.byFp, cache.byLabel, cache.search = byFp, nil, {}
end

local function callStock(safeCall, node, methodName, filter)
  if filter and next(filter) then return safeCall(node.address, methodName, filter) end
  return safeCall(node.address, methodName)
end

local function proxyFilters(rows, stockTarget, base)
  local filters, seen = {}, {}
  local function add(filter)
    if type(filter) ~= "table" or not next(filter) then return end
    local key = tostring(filter.name or "") .. "|" .. tostring(filter.damage or "") .. "|" .. tostring(filter.label or "")
    if not seen[key] then
      seen[key] = true
      filters[#filters + 1] = filter
    end
  end
  add(base)
  local label = rows.targetLabel(stockTarget)
  if label ~= "" and label ~= "target" then
    add({ label = label })
    if not label:find("^[Dd]rops? of%s+") then
      add({ label = "Drops of " .. label })
      add({ label = "drop of " .. label })
    end
  end
  return filters
end

function target.targetRefresh(stock, rows, node, cache, options, safeCall)
  cache, options = cache or {}, options or {}
  local targets = type(options.targets) == "table" and options.targets or {}
  if cache.schema ~= stock.schema then stock.runtime.resetCache(cache) end
  cache.entries = cache.entries or cache.rows or {}
  cache.rows = cache.entries
  local previousScope = cache.scope
  local previousSignature = cache.targetSignature
  local signature = rows.targetSignature(targets)
  local epochSignature = cacheEpoch.targetSignature(targets)
  cacheEpoch.recordNodes({ ae2Primary = node })
  local invalid = cacheEpoch.invalidationFor(cache.epoch)
  local restart = options.restart == true or previousScope ~= "workflow-targets"
    or previousSignature ~= signature or invalid.stock == true
  local resetRows = previousScope ~= "workflow-targets" or invalid.ae2Primary == true
  local stamp = stock.runtime.now()
  local mode, free = stock.memoryMode(cache)
  stock.runtime.pressure(cache, mode, free)
  if restart then
    if resetRows then rows.clearRows(cache) else pruneRows(cache, rows, targets) end
    cache.targetCursor = 1
  end
  cache.scope = "workflow-targets"
  cache.targetCount = #targets
  cache.targetSignature = signature
  local minRefresh = tonumber(options.minRefreshSeconds) or 60
  local age = stamp - (tonumber(cache.lastRefresh) or 0)
  cache.age = math.max(0, math.floor(age))
  if mode == "emergency" then
    if restart and resetRows then rows.clearRows(cache)
    elseif restart then pruneRows(cache, rows, targets) end
    cache.error = "stock refresh skipped: low memory"
    cache.complete = true
    stampEpoch(cache, epochSignature)
    return cache
  end
  if #targets == 0 then
    rows.clearRows(cache)
    cache.schema = stock.schema
    cache.lastRefresh, cache.age = stamp, 0
    cache.complete, cache.targetCursor = true, 1
    cache.error = "no configured workflow stock targets"
    stampEpoch(cache, epochSignature)
    return cache
  end
  if not options.force and previousScope == "workflow-targets" and previousSignature == signature
    and #cache.entries > 0 and cache.complete ~= false and age < minRefresh then return cache end
  local slice, sliceByFp, refreshed = {}, {}, {}
  local itemError, fluidError = nil, nil
  local calls = 0
  local limit = math.max(1, math.floor(tonumber(options.targetLimit) or #targets))
  local first = math.max(1, math.floor(tonumber(cache.targetCursor) or 1))
  if first > #targets then first = 1 end
  local last = math.min(#targets, first + limit - 1)
  for index = first, last do
    local stockTarget = targets[index]
    local targetKey = rows.targetKey(stockTarget)
    local memoryKey = cacheEpoch.targetKey(stockTarget)
    local before = #slice
    refreshed[targetKey] = true
    local filter = match.targetFilter(stockTarget)
    if rows.targetKind(stockTarget) == "fluid" then
      local fluids, err = callStock(safeCall, node, "getFluidsInNetwork", filter)
      calls = calls + 1
      if type(fluids) ~= "table" and filter and next(filter) then
        fluids, err = safeCall(node.address, "getFluidsInNetwork")
        calls = calls + 1
      end
      if type(fluids) == "table" then rows.addMatchingRows(slice, sliceByFp, fluids, stockTarget, true) else fluidError = fluidError or err end
      for _, itemFilterValue in ipairs(proxyFilters(rows, stockTarget, filter)) do
        local items, itemErr = callStock(safeCall, node, "getItemsInNetwork", itemFilterValue)
        calls = calls + 1
        if type(items) == "table" then rows.addMatchingRows(slice, sliceByFp, items, stockTarget, false) else itemError = itemError or itemErr end
      end
    else
      local items, err = callStock(safeCall, node, "getItemsInNetwork", filter)
      calls = calls + 1
      if type(items) == "table" then rows.addMatchingRows(slice, sliceByFp, items, stockTarget, false) else itemError = itemError or err end
    end
    if not rows.hasTargetRow(slice, stockTarget) then rows.addRow(slice, sliceByFp, rows.zeroTargetRow(stockTarget)) end
    for rowIndex = before + 1, #slice do
      slice[rowIndex].targetKey = targetKey
      slice[rowIndex].stockMemoryKey = memoryKey
    end
    if index % 8 == 0 and os.sleep then os.sleep(0) end
  end
  local memoryUpdated = stockMemory.rememberRows(slice, {
    address = node and node.address,
    source = "stock",
    at = stamp
  })
  local out, byFp = {}, {}
  for _, row in ipairs(cache.entries or {}) do
    if not (row.targetKey and refreshed[row.targetKey]) then rows.addRow(out, byFp, row) end
  end
  for _, row in ipairs(slice) do rows.addRow(out, byFp, row) end
  rows.sortRows(out)
  local complete = last >= #targets
  cache.rows, cache.entries, cache.total = out, out, #out
  cache.itemTotal, cache.fluidTotal = nil, nil
  cache.itemError, cache.fluidError = itemError, fluidError
  cache.schema = stock.schema
  cache.lastRefresh, cache.age = stamp, 0
  cache.complete = complete
  cache.targetCursor = complete and 1 or last + 1
  cache.truncated = not complete
  cache.error = not complete and ("warming stock target cache " .. tostring(last) .. "/" .. tostring(#targets))
    or nil
  cache.ae2Calls = (tonumber(cache.ae2Calls) or 0) + calls
  if memoryUpdated > 0 then
    cache.stockMemoryUpdated = stamp
    cache.stockMemoryUpdatedRows = memoryUpdated
  end
  stampEpoch(cache, epochSignature)
  rows.rebuildIndexes(cache, out, mode)
  if type(collectgarbage) == "function" then collectgarbage("step", 200) end
  return cache
end

return target
local adapter = require("oc.ae2.adapter")

local monitor = {}

function monitor.snapshot(options)
  options = options or {}
  local components = adapter.components()
  local primary, reason = adapter.primary()
  if not primary then
    return {
      available = false,
      reason = reason,
      components = components
    }
  end

  local snapshot = {
    available = true,
    primary = {
      address = primary.address,
      type = primary.type
    },
    components = components,
    power = adapter.networkPower(primary),
    cpus = adapter.cpuSummary(primary)
  }
  if options.detail then
    snapshot.counts = adapter.networkCounts(primary, {
      countItems = options.countItems == true,
      countFluids = options.countFluids == true,
      countCraftables = options.countCraftables == true
    })
  end
  return snapshot
end

function monitor.cpuSnapshot(snapshot)
  if not snapshot or not snapshot.available or not snapshot.primary then
    return monitor.snapshot()
  end
  snapshot.cpus = adapter.cpuSummary({ address = snapshot.primary.address, type = snapshot.primary.type })
  return snapshot
end

local function pageEntries(entries, limit)
  local result = {}
  for i = 1, math.min(limit or 16, #(entries or {})) do
    result[#result + 1] = entries[i]
  end
  return result
end

function monitor.cacheEntries(cache)
  cache = cache or {}
  if type(cache.entries) ~= "table" and type(cache.rows) == "table" then cache.entries = cache.rows end
  if type(cache.entries) ~= "table" then cache.entries = {} end
  if type(cache.cursor) ~= "number" or cache.cursor < 1 then cache.cursor = 1 end
  if cache.cursor > #cache.entries then cache.cursor = 1 end
  return cache.entries
end

function monitor.sortEntries(entries)
  table.sort(entries, function(a, b)
    local aSize = tonumber(a and a.size) or 0
    local bSize = tonumber(b and b.size) or 0
    if aSize ~= bSize then return aSize > bSize end
    return tostring(a and a.label or "") < tostring(b and b.label or "")
  end)
end

function monitor.stockSnapshot(snapshot, cache, options)
  options = options or {}
  cache = cache or {}
  if not snapshot or not snapshot.available or not snapshot.primary then
    snapshot = monitor.snapshot()
  end
  if not snapshot.available then return snapshot, cache end

  local node = { address = snapshot.primary.address, type = snapshot.primary.type }
  cache = adapter.stockRefresh(node, cache, {
    force = options.force or options.discover,
    minRefreshSeconds = options.minRefreshSeconds,
    targets = options.targets,
    targetLimit = options.targetLimit,
    restart = options.restart
  }) or cache
  local entries = monitor.cacheEntries(cache)
  monitor.sortEntries(entries)
  snapshot.stock = {
    total = cache.total or #entries,
    cached = #entries,
    cursor = cache.cursor,
    entries = pageEntries(entries, options.displayLimit or 16),
    error = cache.error,
    age = cache.age,
    mode = cache.mode,
    scope = cache.scope,
    targetCount = cache.targetCount,
    targetCursor = cache.targetCursor,
    complete = cache.complete,
    truncated = cache.truncated,
    freeKb = cache.freeKb,
    ae2Calls = cache.ae2Calls,
    itemError = cache.itemError,
    fluidError = cache.fluidError,
    itemTotal = cache.itemTotal,
    fluidTotal = cache.fluidTotal,
    search = cache.search and "lazy" or "off"
  }
  return snapshot, cache
end

function monitor.print(snapshot, options)
  options = options or {}
  snapshot = snapshot or monitor.snapshot()
  if not snapshot.available then
    io.write("AE2 unavailable: " .. tostring(snapshot.reason) .. "\n")
    return
  end

  io.write(string.format("AE2 primary: %s %s\n", snapshot.primary.type, snapshot.primary.address))
  io.write(string.format("AE2 components: %d\n", #snapshot.components))
  io.write(string.format("AE2 CPUs: %d\n", snapshot.cpus.count or 0))

  local power = snapshot.power or {}
  if power.stored and power.max then
    io.write(string.format("AE2 power: %.0f / %.0f\n", power.stored, power.max))
  else
    io.write("AE2 power: unavailable\n")
  end

  local counts = snapshot.counts
  if options.offlineGrid == true and not counts then
    counts = adapter.networkCounts({ address = snapshot.primary.address }, {
      countItems = true,
      countFluids = true,
      countCraftables = true
    })
  end
  if not counts then
    io.write("AE2 grid counts: disabled in normal operation (run ae2-scan --offline for planned diagnostics)\n")
    return
  end
  io.write(string.format("AE2 items: %s fluids: %s craftables: %s\n",
    tostring(counts.items or "n/a"),
    tostring(counts.fluids or "n/a"),
    tostring(counts.craftables or "n/a")))
end

return monitor
local catalog = require("oc.ae2.craft_catalog")
local discovery = require("oc.ae2.craft_discovery")
local probe = require("oc.ae2.craft_probe")
local requests = require("oc.ae2.craft_requests")

local craft = {}

function craft.catalog(node, filter, options)
  return catalog.catalog(node, filter, options)
end

function craft.discover(node, filter, options)
  return discovery.discover(node, filter, options)
end

function craft.discoverAll(filter, options)
  return discovery.discoverAll(filter, options)
end

function craft.findIn(entries, target)
  return discovery.findIn(entries, target)
end

function craft.find(target)
  return discovery.find(target)
end

function craft.stockIndex(node, targets)
  return catalog.stockIndex(node, targets)
end

function craft.stockCount(node, target, stockIndex)
  return catalog.stockCount(node, target, stockIndex)
end

function craft.request(entry, amount, options)
  return requests.request(entry, amount, options)
end

function craft.requestTarget(target, amount, options)
  return requests.requestTarget(target, amount, options)
end

function craft.requestStatus(status)
  return requests.requestStatus(status)
end

function craft.print(filterText, options)
  return probe.print(filterText, options)
end

return craft
local component = require("component")

local bridge = {}

local function isCallable(value)
  if type(value) == "function" then return true end
  if type(value) ~= "table" and type(value) ~= "userdata" then return false end
  local ok, metatable = pcall(getmetatable, value)
  return ok and type(metatable) == "table" and type(metatable.__call) == "function"
end

function bridge.safeInvokeRaw(address, methodName, ...)
  local values = table.pack(pcall(component.invoke, address, methodName, ...))
  if not values[1] then return nil, tostring(values[2]) end
  return table.unpack(values, 2, values.n)
end

function bridge.safeInvoke(address, methodName, ...)
  local ok, proxy = pcall(component.proxy, address)
  local method = ok and proxy and proxy[methodName]
  if isCallable(method) then
    local values = table.pack(pcall(method, ...))
    if values[1] then return table.unpack(values, 2, values.n) end
  end
  return bridge.safeInvokeRaw(address, methodName, ...)
end

function bridge.safeInvokeOptional(address, methodName, value)
  if value == nil or (type(value) == "table" and next(value) == nil) then
    return bridge.safeInvoke(address, methodName)
  end
  return bridge.safeInvoke(address, methodName, value)
end

function bridge.readCraftableStack(craftable)
  if not craftable then return nil, "nil craftable" end
  -- GTNH exposes Craftable.getStack(); older AE2 examples may expose getItemStack().
  local gtnhOk, gtnhStackOrErr = pcall(function()
    return craftable.getStack()
  end)
  if gtnhOk and type(gtnhStackOrErr) == "table" then return gtnhStackOrErr, nil end

  local ok, stackOrErr = pcall(function()
    return craftable.getItemStack()
  end)
  if ok and type(stackOrErr) == "table" then return stackOrErr, nil end

  return nil, "getStack failed: " .. tostring(gtnhStackOrErr)
    .. "; getItemStack failed: " .. tostring(stackOrErr)
end

function bridge.callObject(object, methodName, ...)
  local okMethod, method = pcall(function() return object and object[methodName] end)
  local methodErr = nil
  if not okMethod then method, methodErr = nil, tostring(method) end
  if not isCallable(method) then return nil, methodErr or ("missing method: " .. methodName) end
  local values = table.pack(pcall(method, ...))
  if values[1] and values[2] ~= nil then return table.unpack(values, 2, values.n) end
  local firstError = values[1] and nil or tostring(values[2])
  local retry = table.pack(pcall(method, object, ...))
  if retry[1] then return table.unpack(retry, 2, retry.n) end
  return nil, firstError or tostring(retry[2])
end

function bridge.craftableCount(craftables)
  craftables = craftables or {}
  return math.max(tonumber(craftables.n) or 0, #craftables)
end

function bridge.eachCraftable(craftables, fn)
  craftables = craftables or {}
  local seen = {}
  local count = 0
  local stop = false
  local function visit(key, value)
    if stop then return end
    if value ~= nil and not seen[key] then
      seen[key] = true
      count = count + 1
      if fn(value, key) == false then stop = true end
    end
  end
  local reported = bridge.craftableCount(craftables)
  for i = 1, reported do visit(i, craftables[i]) end
  for key, value in pairs(craftables) do
    if key ~= "n" and type(value) ~= "function" then visit(key, value) end
  end
  return count
end

return bridge
local adapter = require("oc.ae2.adapter")
local bridge = require("oc.ae2.craft_bridge")
local match = require("oc.ae2.craft_match")

local catalog = {}

local function fluidTarget(target)
  return target and (target.isFluid or target.kind == "fluid")
end

local function readFluidsFor(filter)
  if not filter then return true end
  if fluidTarget(filter) then return true end
  -- A legacy label-only target is normalized as kind=item, but it can still
  -- resolve through an AE2FC "Drops of …" fluid proxy. Only an exact named
  -- item can safely skip the shared fluid snapshot.
  if tostring(filter.kind or ""):lower() == "item" and filter.name then return false end
  return not filter.name
end

local function needsFluidStock(targets)
  for _, target in ipairs(targets or {}) do
    if readFluidsFor(target) then return true end
  end
  return false
end

local function stockRows(items)
  local rows = {}
  for _, item in ipairs(items or {}) do
    local entry = match.normalizeStack(item, nil)
    entry.stockSize = match.stackSize(item)
    entry.isCraftable = item.isCraftable == true or item.craftable == true
    rows[#rows + 1] = entry
  end
  return rows
end

local function fluidStockRows(node, targets)
  if not needsFluidStock(targets) then return nil, nil end
  local fluids, err = bridge.safeInvoke(node.address, "getFluidsInNetwork")
  if type(fluids) ~= "table" then return nil, err or "fluid stock query unavailable" end
  return stockRows(fluids), nil
end

local function stockTotal(rows, target)
  local total = 0
  for _, entry in ipairs(rows or {}) do
    if match.sameTarget(entry, target) then total = total + (tonumber(entry.stockSize) or 0) end
  end
  return total
end

local function addCraftable(entries, node, stack, target)
  if not (stack and stack.isCraftable) then return end
  local entry = match.normalizeStack(stack, nil)
  if target and not match.sameTarget(entry, target) then return end
  entry.source = { address = node.address, type = node.type }
  entry.hasTag = stack.hasTag == true
  entry.filter = match.targetFilter(entry)
  entries[#entries + 1] = entry
end

function catalog.catalog(node, filter, options)
  options = options or {}
  node = node or adapter.primary()
  if not node then return { available = false, entries = {}, error = "no AE2 component" } end
  local entries = {}
  if not fluidTarget(filter) then
    local items, err = bridge.safeInvokeOptional(node.address, "getItemsInNetwork", match.targetFilter(filter))
    if type(items) ~= "table" then
      return { available = false, entries = {}, error = err or "getItemsInNetwork unavailable" }
    end
    for _, item in ipairs(items) do
      addCraftable(entries, node, item, nil)
    end
  end
  if readFluidsFor(filter) then
    local fluids = options.fluidRows
    if type(fluids) ~= "table" then fluids = bridge.safeInvoke(node.address, "getFluidsInNetwork") end
    if type(fluids) == "table" then
      for _, fluid in ipairs(fluids) do
        addCraftable(entries, node, fluid, filter)
      end
    end
  end
  table.sort(entries, function(a, b) return a.label < b.label end)
  return {
    available = true,
    entries = entries,
    count = #entries,
    componentCount = 1,
    source = "items+fluids",
    error = #entries == 0 and "no craftable item/fluid metadata visible" or nil
  }
end

function catalog.stockIndex(node, targets)
  node = node or adapter.primary()
  if not node then return { available = false, error = "no AE2 component" } end
  local fluidRows, fluidError = fluidStockRows(node, targets)
  return {
    available = true,
    address = node.address,
    fluidRows = fluidRows,
    fluidError = fluidError
  }
end

function catalog.stockCount(node, target, stockIndex)
  node = node or adapter.primary()
  if not node then return nil, "no AE2 component" end
  local method = target and (target.isFluid or target.kind == "fluid") and "getFluidsInNetwork" or "getItemsInNetwork"
  if method == "getFluidsInNetwork" and stockIndex and stockIndex.address == node.address then
    if stockIndex.fluidRows then return stockTotal(stockIndex.fluidRows, target), nil end
    if stockIndex.fluidError then return nil, stockIndex.fluidError end
  end
  local items, err
  if method == "getFluidsInNetwork" then
    items, err = bridge.safeInvoke(node.address, method)
  else
    items, err = bridge.safeInvoke(node.address, method, match.targetFilter(target))
  end
  if type(items) ~= "table" then return nil, err or "stock query unavailable" end
  local total = 0
  for _, item in ipairs(items) do
    local entry = match.normalizeStack(item, nil)
    if match.sameTarget(entry, target) then total = total + match.stackSize(item) end
  end
  return total, nil
end

return catalog
-- Public craft-discovery facade. The implementation is split by metadata vs
-- live Craftable-handle work so normal callers can audit the expensive path.
local adapter = require("oc.ae2.adapter")
local match = require("oc.ae2.craft_match")
local metadata = require("oc.ae2.craft_discovery_metadata")
local live = require("oc.ae2.craft_discovery_live")

local discovery = {}

function discovery.discoverMetadata(node, filter, options)
  return metadata.discover(node, filter, options)
end

function discovery.discoverAllMetadata(filter, options)
  return metadata.discoverAll(filter, options)
end

function discovery.discover(node, filter, options)
  return live.discover(node, filter, options)
end

function discovery.discoverAll(filter, options)
  options = options or {}
  if options.metadata == true then return metadata.discoverAll(filter, options) end
  return live.discoverAll(filter, options)
end

function discovery.findIn(entries, target)
  for _, entry in ipairs(entries or {}) do
    if match.sameTarget(entry, target) then return entry end
  end
  return nil
end

function discovery.find(target)
  local primary, reason = adapter.primary()
  if not primary then return nil, reason end
  local filter = match.targetFilter(target)
  local report = discovery.discoverAll(filter)
  local entry = discovery.findIn(report.entries, target)
  if entry then return entry, nil, report end
  if target and target.label and (filter.label or filter.name) then
    report = discovery.discoverAll(nil)
    entry = discovery.findIn(report.entries, target)
    if entry then return entry, nil, report end
  end
  return nil, report.error or "craftable not found", report
end

return discovery
-- Shared bounded-craft-discovery helpers. Keeping these pure-ish helpers out
-- of the public facade keeps diagnostic paths paste-safe without changing
-- their iterator/cursor contract.
local bridge = require("oc.ae2.craft_bridge")
local match = require("oc.ae2.craft_match")

local shared = {}

function shared.queryMatches(entry, query)
  query = tostring(query or ""):lower()
  if query == "" then return true end
  local haystack = tostring(entry.label or ""):lower() .. " "
    .. tostring(entry.rawLabel or ""):lower() .. " "
    .. tostring(entry.name or ""):lower() .. " "
    .. tostring(entry.kind or ""):lower() .. " "
    .. tostring(entry.isFluid and "fluid" or ""):lower() .. " "
    .. tostring(entry.amount or ""):lower()
  for token in query:gmatch("%S+") do
    if not haystack:find(token, 1, true) then return false end
  end
  return true
end

function shared.startIndex(options, total)
  if total <= 0 then return 1 end
  local index = math.floor(tonumber(options.startIndex) or 1)
  if index < 1 or index > total then return 1 end
  return index
end

function shared.normalizeCraftable(craftable, stack, node, key, options)
  local entry = match.normalizeStack(stack, options.lite and nil or craftable)
  entry.source = { address = node.address, type = node.type }
  entry.craftIndex = key
  return entry
end

function shared.entryLess(a, b)
  local leftLabel = tostring(a and a.label or "")
  local rightLabel = tostring(b and b.label or "")
  if leftLabel ~= rightLabel then return leftLabel < rightLabel end
  return tostring(match.entryKey(a)) < tostring(match.entryKey(b))
end

function shared.copyOptions(options)
  local out = {}
  for key, value in pairs(options or {}) do out[key] = value end
  return out
end

local function callable(value)
  local kind = type(value)
  return kind == "function" or kind == "userdata" or kind == "table"
end

function shared.openItemIterator(node, options)
  local iterators = type(options.iterators) == "table" and options.iterators or {}
  local iterator = iterators[node.address]
  if iterator ~= nil then return iterator, nil end
  local err
  iterator, err = bridge.safeInvokeOptional(node.address, "allItems")
  if not callable(iterator) then return nil, err or "allItems iterator unavailable" end
  return iterator, nil
end

function shared.nextItem(iterator)
  local ok, itemOrErr = pcall(iterator)
  if not ok then return nil, tostring(itemOrErr), false end
  return itemOrErr, nil, itemOrErr == nil
end

function shared.normalizeMetadataItem(item, node, key)
  if not (item and (item.isCraftable == true or item.craftable == true)) then return nil end
  local entry = match.normalizeStack(item, nil)
  entry.source = { address = node.address, type = node.type, mode = "allItems" }
  entry.craftIndex = key
  return entry
end

return shared
-- Explicit metadata-only discovery. This remains diagnostic-only: callers
-- must choose it instead of normal foreground workflow/catalog refreshes.
local adapter = require("oc.ae2.adapter")
local match = require("oc.ae2.craft_match")
local shared = require("oc.ae2.craft_discovery_shared")

local metadata = {}

function metadata.discover(node, filter, options)
  options = options or {}
  node = node or adapter.primary()
  if not node then return { available = false, entries = {}, error = "no AE2 component" } end
  local maxEntries = tonumber(options.maxEntries)
  if maxEntries and maxEntries <= 0 and options.stopAfterMaxEntries == true then
    return { available = true, entries = {}, count = 0, matched = 0, capped = true,
      componentCount = 1, scanned = 0, nextCursor = options.startIndex or 1, complete = true }
  end
  local iterator, err = shared.openItemIterator(node, options)
  if not iterator then return { available = false, entries = {}, error = err or "allItems iterator unavailable" } end
  local entries, matched, scanned = {}, 0, 0
  local scanLimit = tonumber(options.scanLimit)
  local stopAfterMaxEntries = options.stopAfterMaxEntries == true
  local stoppedByMaxEntries = false
  local start = math.max(1, math.floor(tonumber(options.startIndex) or 1))
  local nextCursor, complete = start, false
  while not (scanLimit and scanned >= scanLimit) do
    local item, itemErr, done = shared.nextItem(iterator)
    if itemErr then
      return { available = false, entries = entries, error = itemErr, componentCount = 1,
        scanned = scanned, nextCursor = nextCursor, complete = true }
    end
    if done then complete = true; break end
    scanned = scanned + 1
    local entry = type(item) == "table" and shared.normalizeMetadataItem(item, node, nextCursor) or nil
    nextCursor = nextCursor + 1
    if entry and shared.queryMatches(entry, options.query) then
      matched = matched + 1
      if not maxEntries or #entries < maxEntries then entries[#entries + 1] = entry end
      if stopAfterMaxEntries and maxEntries and #entries >= maxEntries then
        stoppedByMaxEntries, complete = true, true
        break
      end
    end
  end
  table.sort(entries, shared.entryLess)
  return {
    available = true, entries = entries, count = #entries, matched = matched,
    capped = stoppedByMaxEntries or (maxEntries and matched > #entries) or false,
    componentCount = 1, scanned = scanned, nextCursor = nextCursor,
    iterator = complete and nil or iterator, complete = complete
  }
end

function metadata.discoverAll(filter, options)
  options = options or {}
  local primary, reason = adapter.primary()
  local entries, seen, errors = {}, {}, {}
  local scannedNodes, componentCount = {}, 0
  local matched, maxEntries = 0, tonumber(options.maxEntries)
  local stopAfterMaxEntries = options.stopAfterMaxEntries == true
  local stoppedByMaxEntries, available, nextCursor, complete, scanned = false, false, nil, true, 0
  local remaining = tonumber(options.scanLimit)
  local cursors, iterators, doneNodes, rawCounts = {}, {}, {}, {}
  local hasCursorMap = type(options.cursors) == "table"
  local cursorMap = hasCursorMap and options.cursors or {}
  local iteratorMap = type(options.iterators) == "table" and options.iterators or {}
  local doneMap = type(options.doneNodes) == "table" and options.doneNodes or {}
  local stoppedEarly = false
  local function scan(node)
    if not node or scannedNodes[node.address] then return end
    scannedNodes[node.address], componentCount = true, componentCount + 1
    if doneMap[node.address] then
      available, doneNodes[node.address], rawCounts[node.address] = true, true, 0
      return
    end
    if remaining and remaining <= 0 then stoppedEarly = true; return false end
    local nodeOptions = shared.copyOptions(options)
    nodeOptions.startIndex = cursorMap[node.address] or (hasCursorMap and 1 or options.startIndex)
    nodeOptions.iterators = iteratorMap
    if remaining then nodeOptions.scanLimit = remaining end
    if maxEntries then nodeOptions.maxEntries = math.max(0, maxEntries - #entries) end
    local report = metadata.discover(node, filter, nodeOptions)
    if report.available then available = true end
    local nodeScanned = tonumber(report.scanned) or 0
    scanned = scanned + nodeScanned
    if remaining then remaining = remaining - nodeScanned end
    matched = matched + (tonumber(report.matched) or #(report.entries or {}))
    if report.capped and stopAfterMaxEntries then stoppedByMaxEntries = true end
    if report.complete == true then doneNodes[node.address] = true else
      complete, cursors[node.address] = false, report.nextCursor
      if report.iterator then iterators[node.address] = report.iterator end
    end
    if not nextCursor and report.complete ~= true then nextCursor = report.nextCursor end
    if report.error then errors[#errors + 1] = tostring(node.type) .. " " .. tostring(node.address):sub(1, 8) .. ": " .. report.error end
    for _, entry in ipairs(report.entries or {}) do
      local key = match.entryKey(entry)
      if not seen[key] and (not maxEntries or #entries < maxEntries) then seen[key], entries[#entries + 1] = true, entry end
    end
    if stoppedByMaxEntries then complete = true; return false end
    if remaining and remaining <= 0 and report.complete ~= true then return false end
  end
  scan(primary)
  if options.scanAll or #entries == 0 then
    for _, node in ipairs(adapter.components()) do if scan(node) == false then break end end
  end
  if stoppedEarly then complete = false end
  table.sort(entries, shared.entryLess)
  return {
    available = available, entries = entries, count = #entries, rawCount = nil, matched = matched,
    capped = stoppedByMaxEntries or (maxEntries and matched > #entries) or false,
    componentCount = componentCount, scanned = scanned, nextCursor = nextCursor,
    cursors = cursors, iterators = iterators, doneNodes = doneNodes, rawCounts = rawCounts,
    complete = stoppedByMaxEntries or complete, errors = errors,
    error = complete and #entries == 0 and (#errors > 0 and table.concat(errors, "; ") or reason or "no matching craft metadata visible") or nil
  }
end

return metadata
-- Explicit live Craftable-handle discovery. It is intentionally separate
-- from metadata iteration so normal foreground workflow views cannot reach it
-- by accident.
local adapter = require("oc.ae2.adapter")
local bridge = require("oc.ae2.craft_bridge")
local catalog = require("oc.ae2.craft_catalog")
local match = require("oc.ae2.craft_match")
local shared = require("oc.ae2.craft_discovery_shared")

local live = {}

function live.discover(node, filter, options)
  options = options or {}
  node = node or adapter.primary()
  if not node then return { available = false, entries = {}, error = "no AE2 component" } end
  local craftableFilter = options.unfiltered and nil or filter
  local craftables, err = bridge.safeInvokeOptional(node.address, "getCraftables", craftableFilter)
  if type(craftables) ~= "table" then
    return { available = false, entries = {}, error = err or "getCraftables unavailable" }
  end
  local entries, stackErrors, matched, scanned = {}, 0, 0, 0
  local maxEntries, scanLimit = tonumber(options.maxEntries), tonumber(options.scanLimit)
  local stopAfterMaxEntries = options.stopAfterMaxEntries == true
  local stoppedByMaxEntries = false
  local rawCount = bridge.craftableCount(craftables)
  local start = shared.startIndex(options, rawCount)
  local nextCursor, complete = start, rawCount == 0
  bridge.eachCraftable(craftables, function(craftable, key)
    local numericKey = tonumber(key)
    if numericKey and numericKey < start then return end
    if scanLimit and scanned >= scanLimit then return false end
    scanned = scanned + 1
    if numericKey then
      nextCursor = numericKey + 1
      if nextCursor > rawCount then nextCursor, complete = 1, true end
    else
      nextCursor = start + scanned
    end
    local stack, stackError = bridge.readCraftableStack(craftable)
    if type(stack) == "table" then
      local entry = shared.normalizeCraftable(craftable, stack, node, key, options)
      if shared.queryMatches(entry, options.query) then
        matched = matched + 1
        if not maxEntries or #entries < maxEntries then entries[#entries + 1] = entry end
        if stopAfterMaxEntries and maxEntries and #entries >= maxEntries then
          stoppedByMaxEntries, complete = true, true
          return false
        end
      end
    elseif stack == nil or stackError then
      stackErrors = stackErrors + 1
    end
  end)
  if scanned == 0 and rawCount > 0 then nextCursor, complete = 1, true end
  craftables = nil
  if type(collectgarbage) == "function" then collectgarbage("collect") end
  table.sort(entries, shared.entryLess)
  local errorText = nil
  if #entries == 0 and scanned > 0 and stackErrors >= scanned then
    errorText = "getCraftables returned " .. tostring(rawCount) .. " rows but getStack/getItemStack failed"
  end
  return {
    available = true, entries = entries, count = #entries, rawCount = rawCount, matched = matched,
    capped = stoppedByMaxEntries or (maxEntries and matched > #entries) or false,
    componentCount = 1, scanned = scanned, nextCursor = nextCursor, complete = complete,
    error = errorText, stackErrors = stackErrors
  }
end

function live.discoverAll(filter, options)
  options = options or {}
  local primary, reason = adapter.primary()
  if options.catalog then return catalog.catalog(primary, filter, options) end
  local entries, seen, errors = {}, {}, {}
  local scannedNodes, componentCount = {}, 0
  local rawCount, matched, maxEntries = 0, 0, tonumber(options.maxEntries)
  local stopAfterMaxEntries = options.stopAfterMaxEntries == true
  local stoppedByMaxEntries, available, nextCursor, complete, scanned = false, false, nil, true, 0
  local remaining = tonumber(options.scanLimit)
  local cursors = {}
  local hasCursorMap = type(options.cursors) == "table"
  local cursorMap = hasCursorMap and options.cursors or {}
  local doneMap = type(options.doneNodes) == "table" and options.doneNodes or {}
  local doneNodes = {}
  local rawCountMap = type(options.rawCounts) == "table" and options.rawCounts or {}
  local rawCounts = {}
  local stoppedEarly = false
  local function scan(node)
    if not node or scannedNodes[node.address] then return end
    scannedNodes[node.address], componentCount = true, componentCount + 1
    if doneMap[node.address] then
      local knownRaw = tonumber(rawCountMap[node.address]) or 0
      available, doneNodes[node.address], rawCounts[node.address] = true, true, knownRaw
      rawCount = rawCount + knownRaw
      return
    end
    if remaining and remaining <= 0 then stoppedEarly = true; return false end
    local nodeOptions = shared.copyOptions(options)
    nodeOptions.startIndex = cursorMap[node.address] or (hasCursorMap and 1 or options.startIndex)
    if remaining then nodeOptions.scanLimit = remaining end
    if maxEntries then nodeOptions.maxEntries = math.max(0, maxEntries - #entries) end
    local report = live.discover(node, filter, nodeOptions)
    if report.available then available = true end
    local nodeScanned = tonumber(report.scanned) or 0
    scanned = scanned + nodeScanned
    if remaining then remaining = remaining - nodeScanned end
    local nodeRawCount = tonumber(report.rawCount) or 0
    rawCounts[node.address], rawCount = nodeRawCount, rawCount + nodeRawCount
    matched = matched + (tonumber(report.matched) or #(report.entries or {}))
    if report.capped and stopAfterMaxEntries then stoppedByMaxEntries = true end
    if report.complete == true then doneNodes[node.address] = true else
      complete, cursors[node.address] = false, report.nextCursor
    end
    if not nextCursor and report.complete ~= true then nextCursor = report.nextCursor end
    if report.error then errors[#errors + 1] = tostring(node.type) .. " " .. tostring(node.address):sub(1, 8) .. ": " .. report.error end
    for _, entry in ipairs(report.entries or {}) do
      local key = match.entryKey(entry)
      if not seen[key] and (not maxEntries or #entries < maxEntries) then seen[key], entries[#entries + 1] = true, entry end
    end
    if stoppedByMaxEntries then complete = true; return false end
    if remaining and remaining <= 0 and report.complete ~= true then return false end
  end
  scan(primary)
  if options.scanAll or (#entries == 0 and rawCount == 0) then
    for _, node in ipairs(adapter.components()) do if scan(node) == false then break end end
  end
  if stoppedEarly then complete = false end
  table.sort(entries, shared.entryLess)
  return {
    available = available, entries = entries, count = #entries, rawCount = rawCount, matched = matched,
    capped = stoppedByMaxEntries or (maxEntries and matched > #entries) or false,
    componentCount = componentCount, scanned = scanned, nextCursor = nextCursor,
    cursors = cursors, doneNodes = doneNodes, rawCounts = rawCounts,
    complete = stoppedByMaxEntries or complete, errors = errors,
    error = #entries == 0 and (#errors > 0 and table.concat(errors, "; ") or reason or "no craftables visible") or nil
  }
end

return live
local match = {}

local formatCode = "[0-9A-FK-ORa-fk-or]"

-- Component callbacks and serialized config may represent booleans as strings
-- or numbers. Keep unfamiliar truthy values tagged so normalization cannot
-- accidentally turn an NBT-bearing identity into an ordinary safe target.
local function tagged(value)
  return not (value == nil or value == false or value == "false" or value == 0 or value == "0")
end

function match.stripFormattingCodes(value)
  local text = tostring(value or "unknown")
  local section = string.char(194, 167)
  local legacySection = string.char(167)
  return text
    :gsub(section .. formatCode, "")
    :gsub(legacySection .. formatCode, "")
    :gsub("[$&]" .. formatCode, "")
end

local function cleanLabel(value)
  return (match.stripFormattingCodes(value)
    :gsub("^%s*[%d,%.]+[KkMmBbTtPp]?%s*[xX]%s+[Dd]rops?%s+of%s+", "")
    :gsub("^%s*[%d,%.]+[KkMmBbTtPp]?%s+[Dd]rops?%s+of%s+", "")
    :gsub("^[Dd]rops?%s+of%s+", ""))
end

local function fluidProxyLabel(label)
  label = match.stripFormattingCodes(label)
  return label:find("^[Dd]rops?%s+of%s+") ~= nil
    or label:find("^%s*[%d,%.]+[KkMmBbTtPp]?%s+[Dd]rops?%s+of%s+") ~= nil
    or label:find("^%s*[%d,%.]+[KkMmBbTtPp]?%s*[xX]%s+[Dd]rops?%s+of%s+") ~= nil
end

local function itemLooksFluid(item)
  if match.nestedFluid(item) then return true end
  local label = tostring(item and (item.rawLabel or item.label or item.name) or "")
  if fluidProxyLabel(label) then return true end
  if item and (item.kind == "fluid" or item.type == "fluid" or item.isFluid == true) then return true end
  return item and item.amount ~= nil and item.damage == nil and item.maxDamage == nil
end

function match.nestedFluid(stack)
  if type(stack) ~= "table" then return nil end
  local value = stack.fluidDrop
  if type(value) == "table" then return value, "fluidDrop" end
  value = stack.fluidPacket
  if type(value) == "table" then return value, "fluidPacket" end
  return nil
end

function match.stackLabel(stack)
  return match.tidyLabel(stack and (stack.label or stack.name))
end

function match.tidyLabel(value)
  return cleanLabel(value):gsub("^%s+", ""):gsub("%s+$", "")
end

function match.stackSize(stack)
  return tonumber(stack and (stack.size or stack.amount or stack.count)) or 0
end

function match.stackKind(stack)
  return itemLooksFluid(stack) and "fluid" or "item"
end

function match.itemDamage(value)
  local number = tonumber(value)
  if number then return math.floor(number) end
  return value
end

function match.normalizeStack(stack, craftable)
  local fluid = match.nestedFluid(stack)
  local identity = fluid or stack
  local kind = fluid and "fluid" or match.stackKind(stack)
  local size = match.stackSize(stack)
  if size == 0 and fluid then size = match.stackSize(fluid) end
  local out = {
    craftable = craftable,
    label = match.stackLabel(identity),
    rawLabel = tostring(stack and (stack.label or stack.name) or "unknown"),
    name = identity and identity.name,
    damage = kind == "fluid" and nil or (identity and match.itemDamage(identity.damage)),
    hasTag = identity and tagged(identity.hasTag) or false,
    size = size,
    amount = fluid and fluid.amount or (stack and stack.amount),
    kind = kind,
    isFluid = kind == "fluid"
  }
  out.filter = match.targetFilter(out)
  return out
end

function match.targetFilter(target)
  target = target or {}
  local source = target.filter or {}
  local filter = {}
  for key, value in pairs(source) do
    if key ~= "kind" and key ~= "isFluid" and key ~= "amount" and not (source.name and key == "label") then
      filter[key] = key == "damage" and match.itemDamage(value) or value
    end
  end
  if next(filter) then return filter end
  if target.name then filter.name = target.name end
  if target.damage ~= nil then filter.damage = match.itemDamage(target.damage) end
  if target.name then return filter end
  if target.label then filter.label = target.label end
  return filter
end

function match.labelMatches(entry, target)
  return match.tidyLabel(entry and (entry.label or entry.rawLabel)):lower()
    == match.tidyLabel(target and (target.label or target.rawLabel)):lower()
end

function match.sameTarget(entry, target)
  target = target or {}
  local targetKind = itemLooksFluid(target) and "fluid" or target.kind
  local targetIsFluid = targetKind == "fluid" or target.isFluid == true
  if targetKind and entry.kind and targetKind ~= entry.kind then return false end
  if (target.isFluid ~= nil or targetKind == "fluid") and (entry.isFluid == true) ~= targetIsFluid then return false end
  if target.name then
    if entry.name ~= target.name then return false end
    if target.damage ~= nil and entry.damage ~= match.itemDamage(target.damage) then return false end
    if target.hasTag ~= nil and tagged(entry.hasTag) ~= tagged(target.hasTag) then return false end
    local proxyVariant = fluidProxyLabel(tostring(target.rawLabel or target.label or ""))
      or fluidProxyLabel(tostring(entry.rawLabel or entry.label or ""))
    if (target.craftBinding or proxyVariant) and target.label
        and not match.labelMatches(entry, target) then return false end
    return true
  end
  if target.label then return match.labelMatches(entry, target) end
  return true
end

local function variantLabel(entry)
  return match.tidyLabel(entry and (entry.label or entry.rawLabel)):lower()
end

function match.entryKey(entry)
  if entry.name and entry.name ~= "" then
    return tostring(entry.kind or "item") .. "|" .. tostring(entry.name) .. "|" .. tostring(entry.damage or "")
      .. "|" .. tostring(tagged(entry.hasTag)) .. "|" .. variantLabel(entry)
  end
  return tostring(entry.kind or (entry.isFluid and "fluid" or "item")) .. "|label|" .. match.tidyLabel(entry.label):lower()
end

return match
local adapter = require("oc.ae2.adapter")
local bridge = require("oc.ae2.craft_bridge")
local discovery = require("oc.ae2.craft_discovery")
local match = require("oc.ae2.craft_match")
local requester = require("oc.ae2.requester")

local probe = {}

local function countKind(entries, wanted)
  local total = 0
  for _, row in ipairs(entries or {}) do
    local kind = row.isFluid and "fluid" or tostring(row.kind or "item")
    if kind == wanted then total = total + 1 end
  end
  return total
end

local function keysOf(stack)
  local keys = {}
  if type(stack) ~= "table" then return "" end
  for key in pairs(stack) do keys[#keys + 1] = tostring(key) end
  table.sort(keys)
  return table.concat(keys, ",")
end

local function fluidHint(stack)
  local text = (tostring(stack and stack.label or "") .. " " .. tostring(stack and stack.name or "")):lower()
  return text:find("^[Dd]rops? of%s+") or text:find("fluid", 1, true) or text:find("molten", 1, true)
    or text:find("steam", 1, true) or text:find("water", 1, true)
end

local function printRawCraftSignals(node, limit)
  local craftables, err = bridge.safeInvokeOptional(node.address, "getCraftables", nil)
  if type(craftables) ~= "table" then
    io.write("raw craft stack signals: unavailable " .. tostring(err or "getCraftables failed") .. "\n")
    return
  end
  local total, amount, kindFluid, typeFluid, flagFluid, hints, shown, hintShown = 0, 0, 0, 0, 0, 0, 0, 0
  bridge.eachCraftable(craftables, function(craftable, key)
    local stack = bridge.readCraftableStack(craftable)
    if type(stack) == "table" then
      total = total + 1
      local kind = match.stackKind(stack)
      if stack.amount ~= nil then amount = amount + 1 end
      if kind == "fluid" then kindFluid = kindFluid + 1 end
      if stack.type == "fluid" or stack.kind == "fluid" then typeFluid = typeFluid + 1 end
      if stack.isFluid == true then flagFluid = flagFluid + 1 end
      local hint = fluidHint(stack)
      if hint then
        hints = hints + 1
        if hintShown < (limit or 8) then
          hintShown = hintShown + 1
          io.write(string.format("raw fluid-hint %s label=%s name=%s size=%s hasTag=%s damage=%s\n",
            tostring(key), tostring(stack.label or "n/a"), tostring(stack.name or "n/a"),
            tostring(stack.size or "n/a"), tostring(stack.hasTag), tostring(stack.damage or "n/a")))
        end
      end
      if shown < (limit or 8) then
        shown = shown + 1
        io.write(string.format("raw craft %s kind=%s label=%s name=%s size=%s amount=%s keys=%s\n",
          tostring(key), tostring(kind), tostring(stack.label or "n/a"), tostring(stack.name or "n/a"),
          tostring(stack.size or "n/a"), tostring(stack.amount or "n/a"), keysOf(stack)))
      end
    end
  end)
  io.write(string.format("raw craft stack signals: total=%s amount=%s kindFluid=%s typeFluid=%s isFluid=%s labelHints=%s\n",
    tostring(total), tostring(amount), tostring(kindFluid), tostring(typeFluid), tostring(flagFluid), tostring(hints)))
end

local function printStockFluidRequestHints(node, stockCache, limit)
  if not node then return end
  local checked = 0
  for _, row in ipairs(stockCache.entries or {}) do
    local kind = row and (row.isFluid and "fluid" or tostring(row.kind or "item"))
    if kind == "fluid" and row.label then
      checked = checked + 1
      local entry, err, report = requester.findCraftable({ label = row.label }, { labelScanLimit = 0 })
      report = report or {}
      if entry then
        local entryKind = entry.isFluid and "fluid" or tostring(entry.kind or "item")
        io.write(string.format("fluid request probe %s: yes -> %s %s kind=%s scans=%s handles=%s\n",
          tostring(row.label), tostring(entry.label or "unknown"), tostring(entry.name or ""),
          tostring(entryKind), tostring(report.scans or 0), tostring(report.handles or 0)))
      else
        io.write(string.format("fluid request probe %s: no %s handles=%s expanded=%s first=%s\n",
          tostring(row.label), tostring(err or "unknown"), tostring(report.handles or 0),
          tostring(report.expanded or 0), tostring(report.firstLabel or "n/a")))
      end
      if checked >= (limit or 3) then break end
    end
  end
  if checked == 0 then io.write("fluid request probe: no Stock fluid rows to test\n") end
end

local function printRequestProbe(target)
  local entry, err, report = requester.findCraftable(target, { maxScans = 3, labelScanLimit = 0 })
  report = report or {}
  if entry then
    io.write(string.format("requestable: yes %s %s\n", tostring(entry.label or "unknown"), tostring(entry.name or "")))
  else
    io.write("requestable: no " .. tostring(err or "unknown") .. "\n")
  end
  io.write(string.format("live scans=%s handles=%s expanded=%s unrequestable=%s first=%s\n",
    tostring(report.scans or 0), tostring(report.handles or 0), tostring(report.expanded or 0),
    tostring(report.unrequestable or 0), tostring(report.firstLabel or "n/a")))
  if report.error then io.write("request detail: " .. tostring(report.error) .. "\n") end
  for i, value in ipairs(report.errors or {}) do
    if i > 3 then break end
    io.write("request error: " .. tostring(value) .. "\n")
  end
end

function probe.print(filterText, options)
  options = options or {}
  if options.offline ~= true then
    io.write("Craftable grid probe refused: use ae2-craft-probe --offline during planned diagnostics.\n")
    return nil, "offline diagnostic confirmation required"
  end
  local target = filterText and filterText ~= "" and { label = filterText } or nil
  if target then
    local entry, err = discovery.find(target)
    if not entry then
      io.write("craftable not found: " .. tostring(err) .. "\n")
      printRequestProbe(target)
      return
    end
    io.write(string.format("craftable: %s %s\n", entry.label, tostring(entry.name or "")))
    printRequestProbe(entry)
    return
  end
  local primary, reason = adapter.primary()
  if not primary then io.write("AE2 unavailable: " .. tostring(reason) .. "\n") return end
  local report = discovery.discoverAll(nil, { lite = true, unfiltered = true, scanAll = true })
  local counts = adapter.networkCounts(primary, { countCraftables = true })
  local stockCache = adapter.stockRefresh(primary, {}, { force = true, minRefreshSeconds = 0 })
  local fluidCrafts = countKind(report.entries, "fluid")
  local itemCrafts = countKind(report.entries, "item")
  local stockFluidRows = countKind(stockCache.entries, "fluid")
  io.write(string.format("stock fluids: %s visible, %s cached rows, error %s\n",
    tostring(stockCache.fluidTotal or "n/a"), tostring(stockFluidRows),
    tostring(stockCache.fluidError or "ok")))
  io.write(string.format("craft rows: %s item / %s fluid\n", tostring(itemCrafts), tostring(fluidCrafts)))
  io.write(string.format("live craftables: %d listed / %s reported across %d visible AE2 component(s), expanded %s\n",
    #(report.entries or {}), tostring(counts.craftables or "n/a"),
    tonumber(report.componentCount) or 0, tostring(report.matched or 0)))
  if (tonumber(stockCache.fluidTotal) or 0) > 0 and fluidCrafts == 0 then
    io.write("Stock fluids are visible, but live getCraftables() returned no fluid outputs; check AE2FC/ExtraCells craftable exposure or adapter topology.\n")
    printRawCraftSignals(primary, 8)
    printStockFluidRequestHints(primary, stockCache, 3)
  end
  if #(report.entries or {}) == 0 then
    if report.error then io.write("Detail: " .. tostring(report.error) .. "\n") end
    io.write("No craftables reported by AE2. Patterns must be on the same AE2 grid as this controller.\n")
  end
  for i = 1, math.min(12, #(report.entries or {})) do
    local row = report.entries[i]
    local kind = row.isFluid and "fluid" or tostring(row.kind or "item")
    local amount = row.isFluid and (tostring(row.amount or row.size or 0) .. " mB") or (tostring(row.size or 1) .. "x")
    io.write(string.format("%02d %s %s %s %s\n", i, kind, amount, row.label, tostring(row.name or "")))
  end
end

return probe
local bridge = require("oc.ae2.craft_bridge")
local requester = require("oc.ae2.requester")
local requestTracker = require("oc.ae2.request_tracker")

local requests = {}

local function requestCraft(craftable, amount, options)
  options = options or {}
  amount = tonumber(amount) or 1
  if amount <= 0 then return nil, "request amount must be positive" end
  local prioritize = options.prioritizePower ~= false
  local status, err
  if options.cpuName ~= nil then
    status, err = bridge.callObject(craftable, "request", amount, prioritize, options.cpuName)
    if status then return status, nil end
  end
  status, err = bridge.callObject(craftable, "request", amount, prioritize)
  if status then return status, nil end
  local fallback, fallbackErr = bridge.callObject(craftable, "request", amount)
  return fallback, fallback and nil or (fallbackErr or err)
end

function requests.request(entry, amount, options)
  options = options or {}
  if not entry or not entry.craftable then return nil, "missing craftable" end
  if (tonumber(amount) or 0) <= 0 then return nil, "request amount must be positive" end
  local status, err = requestCraft(entry.craftable, amount, options)
  if not status then return nil, err end
  return status, nil
end

function requests.requestTarget(target, amount, options)
  return requester.requestTarget(target, amount, options)
end

function requests.requestStatus(status)
  if not status then return { done = false, canceled = false, error = "no request" } end
  local info = requestTracker.inspect(status)
  if info.state == "failed" or info.state == "blocked" then
    return { done = false, canceled = false, error = info.reason, state = info.state, phase = info.phase }
  end
  return {
    done = info.state == "done",
    canceled = info.state == "canceled",
    computing = info.phase == "computing",
    state = info.state,
    phase = info.phase,
    error = info.state == "canceled" and info.reason or nil
  }
end

return requests
local invoker = require("oc.ae2.request_invoker")
local binding = require("oc.ae2.request_binding")
local cacheKeys = require("oc.ae2.request_cache_keys")
local fingerprint = require("oc.ae2.request_fingerprint")

local cache = {
  byName = {},
  entries = {},
  entryKeys = {},
  maxEntries = 96
}

function cache.clear()
  cache.byName, cache.entries, cache.entryKeys = {}, {}, {}
end

local function rebuild(entries)
  cache.byName, cache.entries, cache.entryKeys = {}, {}, {}
  for _, entry in ipairs(entries or {}) do cache.remember(entry) end
end

function cache.trim()
  local max = tonumber(cache.maxEntries) or 96
  if max < 1 then max = 1 end
  if #cache.entries <= max then return end
  local old = cache.entries
  local kept = {}
  for i = math.max(1, #old - max + 1), #old do kept[#kept + 1] = old[i] end
  rebuild(kept)
end

function cache.remember(entry)
  local bindErr = binding.error(entry)
  if bindErr then return nil, bindErr end
  if not (entry and entry.craftable and invoker.hasMethod(entry.craftable, "request")) then return nil end
  entry.methods = nil
  local named = cacheKeys.nameKey(entry)
  if named then cache.byName[named] = entry end
  local entryKey = cacheKeys.entryKey(entry)
  if entryKey and cache.entryKeys[entryKey] then
    local index = cache.entryKeys[entryKey]
    if type(index) == "number" and cache.entries[index] then
      cache.entries[index] = entry
    else
      cache.entryKeys[entryKey] = #cache.entries + 1
      cache.entries[#cache.entries + 1] = entry
    end
  elseif entryKey then
    cache.entryKeys[entryKey] = #cache.entries + 1
    cache.entries[#cache.entries + 1] = entry
  elseif not entryKey then
    cache.entries[#cache.entries + 1] = entry
  end
  cache.trim()
  return entry
end

function cache.lookup(target)
  local bindErr = binding.error(target)
  if bindErr then return nil, bindErr end
  if target and target.craftable and invoker.hasMethod(target.craftable, "request") then return target end
  local named = cacheKeys.nameKey(target)
  local entry = named and cache.byName[named] or nil
  if entry and fingerprint.same(entry, target) then return entry end
  return nil, "exact live Craftable handle is not cached"
end

function cache.forget(target)
  local kept, removed = {}, 0
  local targetKey = cacheKeys.entryKey(target)
  for _, entry in ipairs(cache.entries or {}) do
    local entryKey = cacheKeys.entryKey(entry)
    if (targetKey and entryKey == targetKey) or fingerprint.same(entry, target) then removed = removed + 1
    else kept[#kept + 1] = entry end
  end
  if removed > 0 then rebuild(kept) end
  return removed > 0, removed
end

function cache.pruneCursors(nodes)
  local live = {}
  for _, node in ipairs(nodes or {}) do
    if node and node.address then live[tostring(node.address)] = true end
  end
  local kept, changed = {}, false
  for _, entry in ipairs(cache.entries or {}) do
    local address = entry and entry.source and entry.source.address
    if address and not live[tostring(address)] then
      changed = true
    else
      kept[#kept + 1] = entry
    end
  end
  if changed then rebuild(kept) end
end

function cache.bindingError(target) return binding.error(target) end

function cache.isExactTarget(target)
  return binding.isExact(target)
end

-- Compatibility entry points intentionally fail closed. The OC AE2 bridge
-- materializes its grid before Lua sees a result, so a local result limit
-- cannot make a live Craftable scan safe for a foreground or daemon path.
local function scanDisabled()
  return nil, "live AE2 Craftable grid scans are disabled; use the bounded direct exact resolver for configured identities", {
    disabled = true, scans = 0, handles = 0, expanded = 0, errors = {}
  }
end

function cache.hasSnapshot() return false end
function cache.craftablesFor() return scanDisabled() end
function cache.scanNode() return scanDisabled() end
function cache.resolve() return scanDisabled() end
function cache.warm() return { disabled = true, scans = 0, handles = 0, expanded = 0, errors = {} } end

return cache
local match = require("oc.ae2.request_match")

local keys = {}

local function kindFor(value)
  return tostring(value and (value.kind or (value.isFluid and "fluid" or "item")) or "item")
end

function keys.nameKey(value)
  if not (value and value.name) then return nil end
  local marker = type(value.craftBinding) == "table" and value.craftBinding or nil
  local boundMode = marker and tostring(marker.mode or "") or ""
  local boundLabel = marker and match.tidyLabel(marker.label):lower() or ""
  return kindFor(value) .. "|" .. tostring(value.name) .. "|" .. tostring(value.damage or "")
    .. "|" .. tostring(value.hasTag == true) .. "|" .. boundMode .. "|" .. boundLabel
end

local function labelKey(value, label)
  value = value or {}
  return "l:" .. tostring(value.kind or (value.isFluid and "fluid" or "item")) .. "|" .. label
end

function keys.labelKeys(value)
  local out = {}
  local raw = match.tidyLabel(value and (value.rawLabel or value.label)):lower()
  local plain = match.plainLabel(raw):lower()
  if raw ~= "" then out[#out + 1] = labelKey(value, raw) end
  if plain ~= "" and plain ~= raw then out[#out + 1] = labelKey(value, plain) end
  return out
end

function keys.entryKey(entry)
  local named = keys.nameKey(entry)
  if named then return "n:" .. named end
  local labels = keys.labelKeys(entry)
  return labels[1]
end

return keys
-- Pure exact-identity contract shared by UI, workflow editing, stock, and
-- request code. Keeping it free of OpenComputers component imports is
-- deliberate: showing a binding state must never wake an AE2 integration.
local binding = {}
binding.capacityMode = "ae2fc_capacity_label_v1"
binding.itemCapacityMode = "ae2_item_capacity_label_v1"
local nativeTiers = {
  basic = { ["1"] = true, ["4"] = true, ["16"] = true, ["64"] = true },
  advanced = { ["256"] = true, ["1024"] = true, ["4096"] = true, ["16384"] = true }
}
local formatCode = "[0-9A-FK-ORa-fk-or]"

local function validName(value)
  return type(value) == "string" and value:find("%S") ~= nil
end

local function validItemDamage(value)
  return type(value) == "number" and value == value and value >= 0
    and value < math.huge and value == math.floor(value)
end

local function cleanLabel(value)
  local text = tostring(value or "")
  local section = string.char(194, 167)
  local legacySection = string.char(167)
  return text
    :gsub(section .. formatCode, "")
    :gsub(legacySection .. formatCode, "")
    :gsub("[$&]" .. formatCode, "")
    :gsub("^%s+", "")
    :gsub("%s+$", "")
    :gsub("%s+", " ")
end

local function kindFor(value)
  return value and (value.kind or (value.isFluid and "fluid" or "item")) or "item"
end

local function canonicalLabel(value)
  return cleanLabel(value and (value.label or value.rawLabel or value.name))
end

local function shapeError(value)
  if type(value) ~= "table" or value.name == nil then
    return "BIND EXACT TARGET REQUIRED: label-only targets cannot submit"
  end
  if not validName(value.name) then
    return "BIND EXACT TARGET REQUIRED: registry name must be a non-empty string"
  end
  local kind = kindFor(value)
  if kind ~= "item" and kind ~= "fluid" then
    return "BIND EXACT TARGET REQUIRED: target kind must be item or fluid"
  end
  if kind == "item" and not validItemDamage(value.damage) then
    return "BIND EXACT TARGET REQUIRED: item damage must be a finite non-negative whole number"
  end
  return nil
end

-- Serialized OpenOS values and addon callbacks do not always preserve a Lua
-- boolean. Treat only explicit false-like values as untagged; unfamiliar
-- values stay blocked rather than being guessed safe.
function binding.tagged(value)
  if type(value) == "table" then value = value.hasTag end
  return not (value == nil or value == false or value == "false" or value == 0 or value == "0")
end

-- These storage-cell families encode the recipe tier in both their registry
-- identity and operator-visible label. That lets guarded onboarding verify a
-- narrow tagged result without pretending arbitrary NBT is exact.
local function capacityContract(value)
  if type(value) ~= "table" or kindFor(value) ~= "item" or not binding.tagged(value)
      or not validName(value.name) or not validItemDamage(value.damage) then return nil end
  local registry = tostring(value.name):lower()
  local tier = registry:match("^ae2fc:fluid_storage(%d+)$")
  local family, mode = "fluid", binding.capacityMode
  if not tier then
    tier = registry:match("^ae2fc:multi_fluid_storage(%d+)$")
    family = "multi-fluid"
  end
  if not tier then
    local basic = registry:match("^appliedenergistics2:item%.itembasicstoragecell%.(%d+)k$")
    local advanced = registry:match("^appliedenergistics2:item%.itemadvancedstoragecell%.(%d+)k$")
    tier = basic and nativeTiers.basic[basic] and basic
      or advanced and nativeTiers.advanced[advanced] and advanced
    family, mode = "", binding.itemCapacityMode
  end
  if not tier then return nil end
  local infix = family ~= "" and (family .. " ") or ""
  return { mode = mode, label = tostring(tier) .. "k me " .. infix .. "storage cell" }
end

function binding.capacityCell(value)
  local contract = capacityContract(value)
  return contract ~= nil and canonicalLabel(value):lower() == contract.label
end

local function capacityRegistry(value)
  return capacityContract(value) ~= nil
end

function binding.makeCapacityBinding(value)
  if not binding.capacityCell(value) then return nil end
  local contract = capacityContract(value)
  return {
    mode = contract.mode,
    name = tostring(value.name),
    damage = math.floor(tonumber(value.damage)),
    label = contract.label
  }
end

function binding.validCapacityBinding(value)
  if not binding.capacityCell(value) then return false end
  local contract = capacityContract(value)
  local marker = value.craftBinding
  if type(marker) ~= "table" or marker.mode ~= contract.mode then return false end
  if not validName(marker.name) or not validItemDamage(marker.damage)
      or canonicalLabel(marker) == "" then return false end
  return tostring(marker.name) == tostring(value.name)
    and tonumber(marker.damage) == tonumber(value.damage)
    and canonicalLabel(marker):lower() == canonicalLabel(value):lower()
end

function binding.copyCapacityBinding(value)
  if not binding.validCapacityBinding(value) then return nil end
  return binding.makeCapacityBinding(value)
end

function binding.onboardingError(value)
  local err = shapeError(value)
  if err then return err end
  if binding.tagged(value) and not binding.capacityCell(value) then
    if capacityRegistry(value) then
      return "BIND EXACT TARGET REQUIRED: capacity label does not match its registry tier and family"
    end
    return "BIND EXACT TARGET REQUIRED: tagged variants are ambiguous without a server direct binding"
  end
  return nil
end

function binding.error(value)
  local err = shapeError(value)
  if err then return err end
  if binding.tagged(value) then
    if binding.validCapacityBinding(value) then return nil end
    if capacityRegistry(value) then
      return "BIND EXACT TARGET REQUIRED: tagged capacity cell has no matching server-verified binding"
    end
    return "BIND EXACT TARGET REQUIRED: tagged variants are ambiguous without a server direct binding"
  end
  return nil
end

function binding.isExact(value)
  local err = binding.error(value)
  return err == nil, err
end

return binding
local adapter = require("oc.ae2.adapter")
local cpuWitness = require("oc.ae2.maintainer_cpu_witness")

local cpu = {}

local function cpuStorage(row)
  return tonumber(row and (row.storage or row.availableStorage or row.bytes or row.size))
end

function cpu.pick(node, options)
  options = options or {}
  if options.cpuName ~= nil then return options.cpuName end
  node = node or adapter.primary()
  if not node then return nil end
  local summary = adapter.cpuSummary(node)
  local minStorage = tonumber(options.minCpuStorage or options.bytes or options.amount) or 0
  local best = nil
  for _, row in ipairs((summary and summary.cpus) or {}) do
    local storage = cpuStorage(row)
    if not cpuWitness.cpuBusy(row) and row.name and (not storage or storage >= minStorage) then
      if not best or (cpuStorage(best) or 0) < (storage or 0) then best = row end
    end
  end
  return best and best.name or nil, best, summary
end

return cpu
local descriptor = {}

-- A descriptor lookup used to obtain a Craftable by scanning the live grid.
-- Keep the module only to turn stale callers into an explicit, safe failure.
function descriptor.findOne()
  return nil, "BIND EXACT TARGET REQUIRED: descriptor scans are disabled for normal AE2 requests", {
    disabled = true, handles = 0, expanded = 0, errors = {}
  }
end

return descriptor
local component = require("component")

local bridge = require("oc.ae2.craft_bridge")
local binding = require("oc.ae2.request_binding")
local cache = require("oc.ae2.request_cache")
local fingerprint = require("oc.ae2.request_fingerprint")
local invoker = require("oc.ae2.request_invoker")
local match = require("oc.ae2.request_match")
local nodes = require("oc.ae2.request_nodes")

-- Newer GTNH bridges expose scalar getCraftable(detail, type). Older server
-- builds expose only getCraftables(filter), so an explicit bind or cold submit
-- may use one nonempty server-filtered compatibility call. Passive status and
-- page refreshes never load this action-only resolver.
local direct = {}

local function kindFor(target)
  return target and (target.isFluid == true or target.kind == "fluid") and "fluid" or "item"
end

local function detailFor(target)
  local detail = { name = target.name, size = 1 }
  if kindFor(target) == "fluid" then detail.amount = 1
  else detail.damage = match.itemDamage(target.damage) end
  return detail
end

local function invoke(node, target)
  local values = table.pack(pcall(component.invoke, node.address, "getCraftable", detailFor(target), kindFor(target)))
  if not values[1] then
    local err = tostring(values[2])
    local lower = err:lower()
    local unavailable = lower:find("no such method", 1, true) ~= nil
      or lower:find("unknown method", 1, true) ~= nil
      or lower:find("missing method", 1, true) ~= nil
      or lower:find("method not found", 1, true) ~= nil
    return nil, err, unavailable
  end
  if values[2] == nil then return nil, "exact recipe is not available on " .. tostring(node.type or "AE2") end
  return values[2], nil, false
end

local function entryFor(handle, node, target, marker)
  if not invoker.hasMethod(handle, "request") then return nil, "direct result has no request method" end
  local stack, err = bridge.readCraftableStack(handle)
  if type(stack) ~= "table" then return nil, err or "direct result has no readable stack" end
  local entry = match.normalizeStack(stack, handle, node)
  if marker then
    entry.craftBinding = marker
    if not binding.validCapacityBinding(entry) then
      return nil, "direct result identity did not match configured target"
    end
  end
  if not fingerprint.same(entry, target) then
    return nil, "direct result identity did not match configured target"
  end
  return entry
end

local function copyTarget(target, marker)
  if not marker then return target end
  local out = {}
  for key, value in pairs(target or {}) do out[key] = value end
  out.craftBinding = marker
  return out
end

local function remember(entry, options)
  if options.remember == false then return entry end
  local retained, retainErr = cache.remember(entry)
  if retained then return retained end
  return nil, retainErr or "could not retain exact Craftable handle"
end

local function capacityMarker(target, options)
  local marker = binding.copyCapacityBinding(target)
  if marker then return marker end
  if options.onboardingCapacity == true and binding.onboardingError(target) == nil
      and binding.capacityCell(target) then
    return binding.makeCapacityBinding(target)
  end
  return nil
end

local function compatibilityFilter(target, marker)
  local kind = kindFor(target)
  if kind == "fluid" then
    local label = target and (target.rawLabel or target.label)
    if type(label) == "string" and label ~= "" then return { label = label }, "fluid-label" end
    if target and type(target.name) == "string" and target.name ~= "" then
      return { name = target.name }, "fluid-name"
    end
    return nil
  end
  if marker then
    local label = target and (target.rawLabel or target.label)
    if type(label) ~= "string" or label == "" then return nil end
    return {
      name = target.name,
      damage = match.itemDamage(target.damage),
      label = label
    }, "capacity-name-damage-label"
  end
  if target and type(target.name) == "string" and target.name ~= "" and target.damage ~= nil then
    return { name = target.name, damage = match.itemDamage(target.damage) }, "item-name-damage"
  end
  return nil
end

local function collectReleasedCraftables()
  if type(collectgarbage) == "function" then collectgarbage("collect") end
end

local function filteredResolve(expected, marker, options, scalarReport)
  local filter, filterMode = compatibilityFilter(expected, marker)
  local report = {
    direct = true,
    directCalls = scalarReport.directCalls,
    scalarUnavailable = scalarReport.methodUnavailable == true,
    scalarErrors = scalarReport.errors,
    compatibility = true,
    compatibilityCalls = 0,
    compatibilityNodes = 0,
    compatibilityFilter = filterMode,
    scans = 0,
    handles = 0,
    expanded = 0,
    errors = {},
    fullScanSkipped = false,
    capacityBinding = marker ~= nil
  }
  if not filter or next(filter) == nil then
    report.lastError = "exact compatibility filter is unavailable"
    return nil, report.lastError, report
  end

  local nodeLimit = math.max(1, math.min(1, math.floor(tonumber(options.compatibilityNodeLimit) or 1)))
  local callLimit = math.max(1, math.min(1, math.floor(tonumber(options.compatibilityCallLimit) or 1)))
  local handleLimit = math.max(1, math.min(32, math.floor(tonumber(options.compatibilityHandleLimit) or 16)))
  local lastError
  for _, node in ipairs(nodes.candidates(expected)) do
    if report.compatibilityNodes >= nodeLimit or report.compatibilityCalls >= callLimit then break end
    report.compatibilityNodes = report.compatibilityNodes + 1
    report.compatibilityCalls = report.compatibilityCalls + 1
    report.scans = report.scans + 1
    -- Use one component invocation directly. The generic proxy helper may
    -- retry through component.invoke after a proxy-side error, which would
    -- violate this compatibility boundary's one-call contract.
    local values = table.pack(pcall(component.invoke, node.address, "getCraftables", filter))
    local craftables = values[1] and values[2] or nil
    local invokeErr = values[1] and nil or tostring(values[2])
    if type(craftables) == "table" then
      local found, checked, truncated = nil, 0, false
      invoker.eachCraftable(craftables, function(handle)
        if checked >= handleLimit then truncated = true; return false end
        checked = checked + 1
        report.handles = report.handles + 1
        local entry, entryErr = entryFor(handle, node, expected, marker)
        if entry then
          report.expanded = report.expanded + 1
          found = entry
          return false
        end
        lastError = entryErr or lastError
        if #report.errors < 4 and entryErr then report.errors[#report.errors + 1] = tostring(entryErr) end
        return true
      end)
      craftables = nil
      collectReleasedCraftables()
      if found then
        local retained, retainErr = remember(found, options)
        if retained then
          report.matched, report.mode, report.source = true, "compat-filtered-exact", found.source
          return retained, nil, report
        end
        lastError = retainErr or "could not retain compatibility Craftable handle"
      elseif truncated then
        lastError = "exact filtered Craftable result exceeded the " .. tostring(handleLimit) .. "-handle safety cap"
        report.truncated = true
      elseif checked == 0 then
        lastError = "exact filtered Craftable lookup returned no handles"
      end
    else
      lastError = invokeErr or "getCraftables compatibility method is unavailable"
      report.errors[#report.errors + 1] = tostring(lastError)
    end
  end
  report.lastError = lastError or "exact filtered Craftable lookup found no matching output"
  return nil, report.lastError, report
end

function direct.resolve(target, options)
  options = options or {}
  local marker = capacityMarker(target, options)
  local expected = copyTarget(target, marker)
  local bindErr = cache.bindingError(target)
  local report = {
    direct = true, directCalls = 0, nodes = 0, unavailableNodes = 0,
    errors = {}, scans = 0, handles = 0, expanded = 0, fullScanSkipped = true
  }
  if bindErr and not marker then
    report.bindingRequired, report.lastError = true, bindErr
    return nil, bindErr, report
  end
  if marker then report.capacityBinding = true end

  local limit = math.max(1, math.floor(tonumber(options.directNodeLimit) or 3))
  local lastError
  for _, node in ipairs(nodes.candidates(target)) do
    if report.nodes >= limit then break end
    report.nodes = report.nodes + 1
    local handle, invokeErr, unavailable = invoke(node, expected)
    report.directCalls = report.directCalls + 1
    if unavailable then report.unavailableNodes = report.unavailableNodes + 1 end
    if handle then
      local entry, entryErr = entryFor(handle, node, expected, marker)
      if entry then
        local remembered, rememberErr = remember(entry, options)
        if remembered then
          report.matched, report.mode, report.source = true,
            marker and "direct-capacity" or "direct-exact", entry.source
          return remembered, nil, report
        end
        entryErr = rememberErr or "could not retain direct exact handle"
      end
      lastError = entryErr
      report.errors[#report.errors + 1] = tostring(node.type) .. ": " .. tostring(entryErr)
    else
      lastError = invokeErr or lastError
      report.errors[#report.errors + 1] = tostring(node.type) .. ": " .. tostring(invokeErr or "no exact recipe")
    end
  end
  report.methodUnavailable = report.nodes > 0 and report.unavailableNodes == report.nodes
  if report.methodUnavailable or options.compatibilityFallback == true then
    return filteredResolve(expected, marker, options, report)
  end
  report.lastError = lastError or "no AE2 component exposed getCraftable"
  return nil, report.lastError, report
end

return direct
local component = require("component")

local invoker = {}

-- OpenOS wraps Java Value callbacks (Craftable.request/getStack and
-- CraftingStatus methods) as tables with a visible __call metamethod. Test
-- doubles and some bridges use ordinary Lua functions, so both forms are the
-- supported callable contract.
function invoker.isCallable(value)
  if type(value) == "function" then return true end
  if type(value) ~= "table" and type(value) ~= "userdata" then return false end
  local ok, metatable = pcall(getmetatable, value)
  return ok and type(metatable) == "table" and type(metatable.__call) == "function"
end

function invoker.safeInvoke(address, methodName, ...)
  local values = table.pack(pcall(component.invoke, address, methodName, ...))
  if not values[1] then return nil, tostring(values[2]) end
  return table.unpack(values, 2, values.n)
end

local function proxyInvoke(address, methodName, ...)
  local ok, proxy = pcall(component.proxy, address)
  local method = ok and proxy and proxy[methodName]
  if not invoker.isCallable(method) then return nil, "missing proxy method: " .. methodName end
  local values = table.pack(pcall(method, ...))
  if values[1] then return table.unpack(values, 2, values.n) end
  return nil, tostring(values[2])
end

function invoker.invokeNode(node, methodName, filter)
  local result, err
  if filter == nil or (type(filter) == "table" and next(filter) == nil) then
    result, err = proxyInvoke(node.address, methodName)
    if result ~= nil then return result end
    return invoker.safeInvoke(node.address, methodName)
  end
  result, err = proxyInvoke(node.address, methodName, filter)
  if result ~= nil then return result end
  return invoker.safeInvoke(node.address, methodName, filter)
end

function invoker.isHandle(value)
  local valueType = type(value)
  return valueType == "table" or valueType == "userdata"
end

function invoker.hasMethod(object, methodName)
  local ok, method = pcall(function() return object and object[methodName] end)
  return ok and invoker.isCallable(method)
end

function invoker.callObject(object, methodName, ...)
  local okMethod, method = pcall(function() return object and object[methodName] end)
  local methodErr = nil
  if not okMethod then method = nil end
  if invoker.isCallable(method) then
    local direct = table.pack(pcall(method, ...))
    if direct[1] and direct[2] ~= nil then return table.unpack(direct, 2, direct.n) end
    if not direct[1] then methodErr = tostring(direct[2]) end
    local selfStyle = table.pack(pcall(method, object, ...))
    if selfStyle[1] and selfStyle[2] ~= nil then return table.unpack(selfStyle, 2, selfStyle.n) end
    if not selfStyle[1] then methodErr = methodErr or tostring(selfStyle[2]) end
  end
  if type(object) == "string" then
    local raw = table.pack(pcall(function(...) return component.invoke(object, methodName, ...) end, ...))
    if raw[1] and raw[2] ~= nil then return table.unpack(raw, 2, raw.n) end
    return nil, raw[1] and "nil result: " .. methodName or tostring(raw[2] or methodErr or ("missing method: " .. methodName))
  end
  return nil, methodErr or ("missing method: " .. methodName)
end

function invoker.methodList(object)
  local ok, methods = pcall(function() return component.methods(object) end)
  if not ok or type(methods) ~= "table" then return "unavailable" end
  local names = {}
  for name in pairs(methods) do names[#names + 1] = tostring(name) end
  table.sort(names)
  return table.concat(names, ",")
end

function invoker.eachCraftable(craftables, fn)
  craftables = craftables or {}
  local seen = {}
  local count = 0
  local stop = false
  local function visit(key, value)
    if stop then return end
    if value ~= nil and not seen[key] and invoker.isHandle(value) then
      seen[key] = true
      count = count + 1
      if fn(value, key) == false then stop = true end
    end
  end
  local reported = math.max(tonumber(craftables.n) or 0, #craftables)
  for i = 1, reported do visit(i, craftables[i]) end
  for key, value in pairs(craftables) do
    if key ~= "n" and type(value) ~= "function" then visit(key, value) end
  end
  return count
end

return invoker
local match = require("oc.ae2.request_match")

local fingerprint = {}

function fingerprint.boolValue(value)
  if value == true or value == "true" or value == 1 then return true end
  if value == false or value == "false" or value == 0 or value == nil then return false end
  return not not value
end

function fingerprint.numValue(value)
  return match.itemDamage(tonumber(value or 0) or 0)
end

function fingerprint.from(value)
  if type(value) ~= "table" then return nil end
  local marker = type(value.craftBinding) == "table" and value.craftBinding or nil
  return {
    label = value.label or value.rawLabel or value.name,
    rawLabel = value.rawLabel,
    name = value.name,
    kind = value.kind or (value.isFluid and "fluid" or "item"),
    damage = fingerprint.numValue(value.damage),
    hasTag = fingerprint.boolValue(value.hasTag),
    maxSize = value.maxSize,
    bindingMode = marker and marker.mode or nil,
    bindingLabel = marker and match.tidyLabel(marker.label):lower() or nil
  }
end

function fingerprint.same(entry, target)
  local left = fingerprint.from(entry)
  local right = fingerprint.from(target)
  if not (left and right and left.name and right.name) then return false end
  if left.kind and right.kind and left.kind ~= right.kind then return false end
  if tostring(left.name) ~= tostring(right.name) then return false end
  if right.damage ~= nil and match.itemDamage(left.damage) ~= match.itemDamage(right.damage) then return false end
  if (left.hasTag == true) ~= (right.hasTag == true) then return false end
  if left.bindingMode ~= nil or right.bindingMode ~= nil then
    if left.bindingMode ~= right.bindingMode or left.bindingLabel ~= right.bindingLabel then return false end
  end
  return true
end

function fingerprint.describe(value)
  local fp = fingerprint.from(value)
  if not fp then return "nil target" end
  return tostring(fp.label or "unknown")
    .. " | kind=" .. tostring(fp.kind or "item")
    .. " | " .. tostring(fp.name or "no-name")
    .. " | dmg=" .. tostring(fp.damage)
    .. " | tag=" .. tostring(fp.hasTag == true)
    .. " | tagType=" .. type(value.hasTag)
    .. " | dmgType=" .. type(value.damage)
end

return fingerprint
local labelScan = {}

-- Kept as a deployed compatibility module so older callers fail safely rather
-- than attempting a whole-grid lookup by display label.
function labelScan.find()
  return nil, "BIND EXACT TARGET REQUIRED: label scans are disabled for normal AE2 requests", {
    disabled = true, scans = 0, handles = 0, expanded = 0, errors = {}
  }
end

return labelScan
local match = {}

local formatCode = "[0-9A-FK-ORa-fk-or]"

local function stripFormattingCodes(value)
  local text = tostring(value or "unknown")
  local section = string.char(194, 167)
  local legacySection = string.char(167)
  return text
    :gsub(section .. formatCode, "")
    :gsub(legacySection .. formatCode, "")
    :gsub("[$&]" .. formatCode, "")
end

local function cleanLabel(value)
  return (stripFormattingCodes(value)
    :gsub("^%s*[%d,%.]+[KkMmBbTtPpEe]?%s*[xX]%s+[Dd]rops?%s+of%s+", "")
    :gsub("^%s*[%d,%.]+[KkMmBbTtPpEe]?%s+[Dd]rops?%s+of%s+", "")
    :gsub("^[Dd]rops?%s+of%s+", ""))
end

local countPrefix = "^%s*[%d,%.]+[KkMmBbTtPpEe]?%s*[xX]%s+"

-- Component callbacks and serialized config may represent booleans as strings
-- or numbers. Keep unfamiliar truthy values tagged so normalization cannot
-- accidentally turn an NBT-bearing identity into an ordinary safe target.
local function tagged(value)
  return not (value == nil or value == false or value == "false" or value == 0 or value == "0")
end

function match.fluidProxy(item)
  local label = tostring(item and (item.rawLabel or item.label or item.name) or "")
  return label:find("^[Dd]rops?%s+of%s+") ~= nil
    or label:find("^%s*[%d,%.]+[KkMmBbTtPp]?%s+[Dd]rops?%s+of%s+") ~= nil
    or label:find("^%s*[%d,%.]+[KkMmBbTtPp]?%s*[xX]%s+[Dd]rops?%s+of%s+") ~= nil
end

function match.realFluid(item)
  if not item or match.fluidProxy(item) then return false end
  return (item.kind == "fluid" or item.type == "fluid" or item.isFluid == true) and item.amount ~= nil
end

local function itemLooksFluid(item)
  if match.nestedFluid(item) then return true end
  if match.fluidProxy(item) then return true end
  if match.realFluid(item) then return true end
  if item and (item.kind == "fluid" or item.type == "fluid" or item.isFluid == true) then return true end
  return item and item.amount ~= nil and item.damage == nil and item.maxDamage == nil
end

function match.nestedFluid(stack)
  if type(stack) ~= "table" then return nil end
  local value = stack.fluidDrop
  if type(value) == "table" then return value, "fluidDrop" end
  value = stack.fluidPacket
  if type(value) == "table" then return value, "fluidPacket" end
  return nil
end

function match.tidyLabel(value)
  return cleanLabel(value):gsub("^%s+", ""):gsub("%s+$", "")
end

function match.countPrefixed(value)
  return match.tidyLabel(value):find(countPrefix) ~= nil
end

function match.plainLabel(value)
  return match.tidyLabel(value):gsub(countPrefix, "")
end

local function stackLabel(stack)
  return match.plainLabel(stack and (stack.label or stack.name))
end

local function stackSize(stack)
  return tonumber(stack and (stack.size or stack.amount or stack.count)) or 0
end

function match.stackKind(stack)
  return itemLooksFluid(stack) and "fluid" or "item"
end

function match.itemDamage(value)
  local number = tonumber(value)
  if number then return math.floor(number) end
  return value
end

function match.normalizeStack(stack, craftable, node)
  local fluid = match.nestedFluid(stack)
  local identity = fluid or stack
  local kind = fluid and "fluid" or match.stackKind(stack)
  local size = stackSize(stack)
  if size == 0 and fluid then size = stackSize(fluid) end
  local out = {
    craftable = craftable,
    label = stackLabel(identity),
    rawLabel = tostring(stack and (stack.label or stack.name) or "unknown"),
    name = identity and identity.name,
    damage = kind == "fluid" and nil or (identity and match.itemDamage(identity.damage)),
    hasTag = identity and tagged(identity.hasTag) or false,
    size = size,
    amount = fluid and fluid.amount or (stack and stack.amount),
    kind = kind,
    isFluid = kind == "fluid",
    source = node and { address = node.address, type = node.type } or nil
  }
  out.filter = match.targetFilter(out)
  return out
end

function match.targetStack(target)
  local kind = target and (itemLooksFluid(target) and "fluid" or (target.kind or (target.isFluid and "fluid" or "item")))
  return {
    label = target and (target.label or target.rawLabel or target.name) or "target",
    rawLabel = target and target.rawLabel,
    name = target and target.name,
    damage = target and match.itemDamage(target.damage),
    hasTag = target and tagged(target.hasTag) or false,
    size = target and (target.size or target.amount or target.count),
    amount = target and target.amount,
    kind = kind,
    isFluid = kind == "fluid",
    craftBinding = target and target.craftBinding
