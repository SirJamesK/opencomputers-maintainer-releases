function match.targetFilter(target)
  target = target or {}
  local source = target.filter or {}
  local filter = {}
  for key, value in pairs(source) do
    if key ~= "kind" and key ~= "isFluid" and key ~= "amount" and not (source.name and key == "label") then
      filter[key] = key == "damage" and match.itemDamage(value) or value
    end
  end
  if next(filter) then return filter end
  if target.name then filter.name = target.name end
  if target.damage ~= nil then filter.damage = match.itemDamage(target.damage) end
  if target.name then return filter end
  if target.label then filter.label = target.label end
  return filter
end

function match.sameTarget(entry, target)
  target = target or {}
  local targetKind = itemLooksFluid(target) and "fluid" or target.kind
  local targetIsFluid = targetKind == "fluid" or target.isFluid == true
  if targetKind and entry.kind and targetKind ~= entry.kind then return false end
  if (target.isFluid ~= nil or targetKind == "fluid") and (entry.isFluid == true) ~= targetIsFluid then return false end
  local wantedRaw = match.tidyLabel(target.label or target.rawLabel):lower()
  if target.name then
    if entry.name ~= target.name then return false end
    if target.damage ~= nil and entry.damage ~= match.itemDamage(target.damage) then return false end
    if target.hasTag ~= nil and tagged(entry.hasTag) ~= tagged(target.hasTag) then return false end
    if (target.craftBinding or match.fluidProxy(target) or match.fluidProxy(entry)) and wantedRaw ~= "" then
      local label = match.tidyLabel(entry.label or entry.rawLabel):lower()
      local raw = match.tidyLabel(entry.rawLabel or entry.label):lower()
      local wantedPlain = match.plainLabel(wantedRaw):lower()
      if label ~= wantedRaw and raw ~= wantedRaw
          and match.plainLabel(label):lower() ~= wantedPlain
          and match.plainLabel(raw):lower() ~= wantedPlain then return false end
    end
    return true
  end
  if wantedRaw ~= "" then
    if match.tidyLabel(entry.label):lower() == wantedRaw then return true end
    if match.tidyLabel(entry.rawLabel):lower() == wantedRaw then return true end
    if not match.countPrefixed(wantedRaw) then
      local wantedPlain = match.plainLabel(wantedRaw):lower()
      if match.plainLabel(entry.label):lower() == wantedPlain then return true end
      if match.plainLabel(entry.rawLabel):lower() == wantedPlain then return true end
    end
  end
  if wantedRaw ~= "" then return false end
  return true
end

return match
local adapter = require("oc.ae2.adapter")
local match = require("oc.ae2.request_match")

local nodes = {}

local function add(out, seen, node)
  if node and node.address and not seen[node.address] then
    seen[node.address] = true
    out[#out + 1] = node
  end
end

local function addRequestNode(out, seen, node)
  if node and (node.type == "me_controller" or node.type == "me_interface") then add(out, seen, node) end
end

local function copyFilter(filter)
  local out = {}
  for key, value in pairs(filter or {}) do out[key] = value end
  return out
end

local function filterKey(filter)
  local parts = {}
  for key, value in pairs(filter or {}) do parts[#parts + 1] = tostring(key) .. "=" .. tostring(value) end
  table.sort(parts)
  return table.concat(parts, "&")
end

local function addMode(out, seen, name, filter)
  filter = copyFilter(filter)
  if not next(filter) then return end
  local key = filterKey(filter)
  if seen[key] then return end
  seen[key] = true
  out[#out + 1] = { name = name, filter = filter }
end

local function fluidLike(target)
  local label = tostring(target and (target.rawLabel or target.label or target.name) or "")
  return target and (target.isFluid == true or target.kind == "fluid" or label:find("^[Dd]rops? of%s+") ~= nil)
end

function nodes.candidates(target)
  local out, seen = {}, {}
  addRequestNode(out, seen, adapter.primary())
  for _, node in ipairs(adapter.components()) do addRequestNode(out, seen, node) end
  return out
end

function nodes.preciseModes(target)
  target = target or {}
  local out, seen = {}, {}
  local filter = match.targetFilter(target)
  if filter.name and filter.damage ~= nil then
    addMode(out, seen, "name-damage-filter", { name = filter.name, damage = filter.damage })
  end
  if target.filter then addMode(out, seen, "catalog-filter", filter) end
  if filter.name and filter.damage == nil then addMode(out, seen, "name-filter", { name = filter.name }) end
  if fluidLike(target) and target.label then addMode(out, seen, "fluid-label-filter", { label = target.label }) end
  if not target.name and target.label then addMode(out, seen, "label-filter", { label = target.label }) end
  if fluidLike(target) and target.rawLabel and target.rawLabel ~= target.label then
    addMode(out, seen, "fluid-raw-label-filter", { label = target.rawLabel })
  end
  if not target.name and target.rawLabel and target.rawLabel ~= target.label then
    addMode(out, seen, "raw-label-filter", { label = target.rawLabel })
  end
  addMode(out, seen, "filtered", filter)
  return out
end

function nodes.warmCandidates()
  return nodes.candidates(nil)
end

return nodes
local fingerprint = require("oc.ae2.request_fingerprint")
local invoker = require("oc.ae2.request_invoker")
local requestCache = require("oc.ae2.request_cache")
local direct = require("oc.ae2.request_direct")

local resolver = {}

local function reportFor(target)
  return {
    scans = 0,
    handles = 0,
    expanded = 0,
    matched = false,
    fullScanSkipped = true,
    exactTarget = target and target.name ~= nil or false,
    errors = {}
  }
end

local function cachedExact(target, report)
  local entry, cacheErr = requestCache.lookup(target)
  if not entry then return nil, cacheErr end
  if not (entry.craftable and invoker.hasMethod(entry.craftable, "request")) then
    requestCache.forget(target)
    return nil, "cached exact Craftable handle is no longer requestable"
  end
  if not fingerprint.same(entry, target) then
    requestCache.forget(target)
    report.cachedRejected = true
    return nil, "cached exact Craftable identity changed"
  end
  entry.mode = "cached-exact"
  report.cached, report.matched, report.mode = true, true, "cached-exact"
  return entry, nil
end

-- A cache hit is preferred. A cold exact identity uses the bridge's scalar
-- getCraftable callback where available; pre-scalar bridges may make one
-- nonempty exact-filtered compatibility call inside request_direct.
function resolver.find(target, options)
  options = options or {}
  local report = reportFor(target)
  local bindErr = requestCache.bindingError(target)
  if bindErr then
    report.bindingRequired = true
    report.lastError = bindErr
    return nil, bindErr, report
  end
  local entry, err = cachedExact(target, report)
  if entry then return entry, nil, report end
  if options.requireCached ~= true and options.allowDirect ~= false then
    local directEntry, directErr, directReport = direct.resolve(target, options)
    for key, value in pairs(directReport or {}) do report[key] = value end
    if directEntry then return directEntry, nil, report end
    err = directErr or err
  end
  report.cacheRequired, report.coldRequest = true, true
  report.mode = "exact-binding-required"
  report.lastError = err or "BIND EXACT TARGET REQUIRED: direct exact Craftable lookup is unavailable"
  return nil, report.lastError, report
end

function resolver.warm()
  return { disabled = true, scans = 0, handles = 0, expanded = 0,
    reason = "bulk Craftable warming is disabled; exact direct binding happens only at a request boundary" }
end

return resolver
local invoker = require("oc.ae2.request_invoker")
local requestCache = require("oc.ae2.request_cache")
local requestCpu = require("oc.ae2.request_cpu")
local requestFingerprint = require("oc.ae2.request_fingerprint")
local requestResolver = require("oc.ae2.request_resolver")
local requestTracker = require("oc.ae2.request_tracker")

local submit = {}

local lastReport = {}

local function targetLabel(target)
  return tostring(target and (target.label or target.rawLabel or target.name) or "request")
end

local function failedState(state)
  return state == "failed" or state == "canceled" or state == "blocked"
end

local function confirmedState(state, phase)
  return state == "running" and phase == "submitted"
end

local function daemonAuthorized(options)
  local expected = tonumber(options and options.daemonGeneration)
  if expected == nil then return true end
  local loaded, daemonConfig = pcall(require, "oc.ae2.maintainer_daemon_config")
  if not loaded or not daemonConfig or type(daemonConfig.load) ~= "function" then
    return false, "daemon generation revoked: control config unavailable"
  end
  local ok, cfg = pcall(daemonConfig.load)
  if not ok or type(cfg) ~= "table" or cfg.enabled ~= true
      or tonumber(cfg.generation) ~= expected then
    return false, "daemon generation revoked before craft submit"
  end
  return true
end

local function requestCraftable(craftable, amount, options, source)
  amount = tonumber(amount) or 1
  if amount <= 0 then return nil, "request amount must be positive" end
  local prioritize = options.prioritizePower ~= false
  options._cpuName = nil
  options._cpuMode = "ae2-auto"
  options._requestError = nil
  local authorized, authorityError = daemonAuthorized(options)
  if not authorized then return nil, authorityError end
  local simple = table.pack(pcall(function()
    return craftable.request(amount)
  end))
  if simple[1] and simple[2] ~= nil then return table.unpack(simple, 2, simple.n) end
  local simpleErr = simple[1] and "nil result: request" or tostring(simple[2])
  local pickedCpuName = options.cpuName
  local cpuMode = pickedCpuName ~= nil and "caller-hint" or "ae2-auto"
  if pickedCpuName == nil then
    pickedCpuName = requestCpu.pick(source, options)
    cpuMode = pickedCpuName and "submit-time-hint" or "no-ready-cpu-hint"
  end
  options._cpuName = pickedCpuName
  options._cpuMode = cpuMode
  if pickedCpuName ~= nil then
    authorized, authorityError = daemonAuthorized(options)
    if not authorized then return nil, authorityError end
    local status, err = invoker.callObject(craftable, "request", amount, prioritize, pickedCpuName)
    if status then return status, nil end
    if err then options._requestError = err end
  end
  authorized, authorityError = daemonAuthorized(options)
  if not authorized then return nil, authorityError end
  local status, err = invoker.callObject(craftable, "request", amount, prioritize)
  if status then return status, nil end
  return nil, err or options._requestError or simpleErr
end

function submit.requestTarget(target, amount, options)
  options = options or {}
  local amountValue = tonumber(amount) or 0
  if amountValue <= 0 then
    lastReport = { guarded = true, error = "request amount must be positive", amount = amountValue }
    return nil, lastReport.error, lastReport
  end
  local label = targetLabel(target)
  local trackKey = options.track and options.track.id or label
  local canStart, guardErr = requestTracker.canStart(trackKey, options)
  if not canStart then
    local pendingResult = tostring(guardErr or ""):find("awaiting acknowledgement", 1, true) ~= nil
    lastReport = { guarded = true, error = guardErr,
      requestState = pendingResult and "blocked" or nil,
      requestPhase = pendingResult and "request_result" or nil,
      requestStatusReason = pendingResult and guardErr or nil,
      pendingResult = pendingResult }
    return nil, guardErr, lastReport
  end
  local entry, findErr, report = requestResolver.find(target, options)
  lastReport = report or {}
  lastReport.amount = amountValue
  if not entry then
    lastReport.fingerprint = requestFingerprint.describe(target)
    lastReport.error = tostring(findErr or "no requestable craftable") .. ": " .. lastReport.fingerprint
    return nil, lastReport.error, lastReport
  end
  local ok, status, err = pcall(requestCraftable, entry.craftable, amountValue, options, entry.source)
  if not ok then status, err = nil, tostring(status) end
  local authorityRevoked = not status and tostring(err or ""):find("daemon generation revoked", 1, true) ~= nil
  local pickedCpuName = options._cpuName
  lastReport.cpuName = pickedCpuName
  lastReport.cpuMode = options._cpuMode or "ae2-auto"
  lastReport.requestKey = tostring(trackKey)
  local statusInfo = status and requestTracker.inspect(status) or nil
  lastReport.requestState = statusInfo and statusInfo.state or authorityRevoked and "blocked" or "failed"
  lastReport.requestPhase = statusInfo and statusInfo.phase or authorityRevoked and "daemon_authority" or nil
  lastReport.requestStatusReason = statusInfo and statusInfo.reason or err
  lastReport.requestTrackable = statusInfo and statusInfo.trackable ~= false and status ~= true
  lastReport.requestConfirmed = confirmedState(lastReport.requestState, lastReport.requestPhase)
  lastReport.requestPending = lastReport.requestState == "running" and lastReport.requestPhase == "computing"
  lastReport.requestUnverified = lastReport.requestState == "accepted"
  lastReport.requested = status ~= nil and not failedState(lastReport.requestState)
  if authorityRevoked then lastReport.guarded = true end
  lastReport.error = err or (lastReport.requested and nil or lastReport.requestStatusReason)
  if not status and (lastReport.cached
      or tostring(err or ""):find("request method", 1, true)) then
    requestCache.forget(target)
  end
  if not status then return nil, err or "request failed", lastReport end
  if failedState(lastReport.requestState) then
    return nil, lastReport.requestStatusReason or lastReport.requestState, lastReport
  end
  local track = options.track or {}
  track.phase, track.reason = lastReport.requestPhase, lastReport.requestStatusReason
  track.label = track.label or label
  track.target = track.target or target
  options.track = track
  if lastReport.requestTrackable and lastReport.requestState == "running" then
    requestTracker.remember(trackKey, status, options.track)
  end
  return status, nil, lastReport
end

function submit.lastReport()
  return lastReport
end

return submit
local invoker = require("oc.ae2.request_invoker")

local tracker = { active = {} }

local function requestHandle(record)
  if type(record) == "table" and record.request then return record.request end
  return record
end

local function firstReason(...)
  for i = 1, select("#", ...) do
    local value = select(i, ...)
    if value then return tostring(value) end
  end
  return nil
end

local function resourceBlocker(reason)
  local text = tostring(reason or "")
  local lower = text:lower()
  if lower:find("missing resources", 1, true)
    or lower:find("missing resource", 1, true)
    or lower:find("missing ingredients", 1, true)
    or lower:find("missing ingredient", 1, true) then
    return { state = "blocked", phase = "missing_resources", reason = "missing resources", rawReason = text }
  end
  return nil
end

local statusMethods = { "hasFailed", "isComputing", "isCanceled", "isDone" }

local function statusContract(request)
  local any, missing = false, nil
  for _, name in ipairs(statusMethods) do
    local present = invoker.hasMethod(request, name)
    any = any or present
    if not present then missing = missing or name end
  end
  if not any then return false, "no status methods" end
  if missing then return false, "missing method: " .. missing end
  return true
end

local function inspectRequest(request)
  request = requestHandle(request)
  if not request then return { state = "none", phase = "missing", reason = "no request" } end
  local complete, contractErr = statusContract(request)
  if not complete then
    if contractErr == "no status methods" then return { state = "accepted", trackable = false } end
    return { state = "failed", phase = "status_error", reason = contractErr }
  end
  local computing, computingErr = invoker.callObject(request, "isComputing")
  if computing == nil then return { state = "failed", phase = "status_error", reason = computingErr } end
  if computing == true then return { state = "running", phase = "computing", reason = computingErr } end
  local failed, failedErr = invoker.callObject(request, "hasFailed")
  local canceled, canceledErr = invoker.callObject(request, "isCanceled")
  local done, doneErr = invoker.callObject(request, "isDone")
  if failed == nil or canceled == nil or done == nil then
    return { state = "failed", phase = "status_error",
      reason = firstReason(failedErr, canceledErr, doneErr) or "incomplete AE2 status contract" }
  end
  if failed == true then
    local reason = tostring(failedErr or "AE2 request failed")
    return resourceBlocker(reason) or { state = "failed", phase = "failed", reason = reason }
  end
  if canceled == true then return { state = "canceled", phase = "canceled", reason = canceledErr } end
  if done == true then return { state = "done", phase = "done", reason = doneErr } end
  return { state = "running", phase = "submitted" }
end

function tracker.inspect(request)
  return inspectRequest(request)
end

function tracker.prune()
  -- Poll every retained handle, but do not erase a terminal result here.
  -- GTNH completes recipe planning asynchronously; deleting the handle as
  -- soon as it reports missing resources made that failure disappear before
  -- Dashboard or the daemon could publish it. Terminal records are released
  -- only through acknowledge(), or overwritten by a deliberate new request.
  local states = {}
  for label, record in pairs(tracker.active) do states[label] = tracker.inspect(record) end
  return states
end

function tracker.count()
  local states = tracker.prune()
  local count = 0
  for _, state in pairs(states) do if state.state == "running" then count = count + 1 end end
  return count
end

function tracker.running()
  local states = tracker.prune()
  for label, record in pairs(tracker.active) do
    if states[label].state == "running" then return label, requestHandle(record) end
  end
  return nil
end

function tracker.canStart(label, options)
  options = options or {}
  local states = tracker.prune()
  local key = tostring(label or "request")
  local current = tracker.active[key]
  if current then
    local state = states[key].state
    if state == "running" then return false, "request already running: " .. key end
    return false, "request result awaiting acknowledgement: " .. key
  end
  local maxInFlight = tonumber(options.maxInFlight) or 1
  if maxInFlight < 1 then maxInFlight = 1 end
  local count = 0
  for _, state in pairs(states) do if state.state == "running" then count = count + 1 end end
  if count >= maxInFlight then return false, "request slots full: " .. tostring(maxInFlight) end
  return true
end

function tracker.remember(label, status, details)
  if status then
    details = details or {}
    tracker.active[tostring(label or "request")] = {
      request = status,
      label = tostring(details.label or label or "request"),
      id = details.id,
      amount = details.amount,
      submittedAt = details.submittedAt,
      target = details.target,
      source = details.source,
      phase = details.phase,
      reason = details.reason
    }
  end
  return status
end

function tracker.status(label)
  local key = tostring(label or "request")
  local record = tracker.active[key]
  if not record then return { state = "none" } end
  return tracker.inspect(record)
end

function tracker.summaries()
  local states = tracker.prune()
  local rows = {}
  for label, record in pairs(tracker.active) do
    local state = states[label]
    if type(record) == "table" then
      rows[#rows + 1] = {
        label = record.label or label,
        id = record.id,
        amount = record.amount,
        submittedAt = record.submittedAt,
        target = record.target,
        source = record.source,
        state = state.state,
        phase = state.phase or record.phase,
        reason = state.reason or record.reason
      }
    else
      rows[#rows + 1] = { label = label, state = state.state, phase = state.phase, reason = state.reason }
    end
  end
  return rows
end

function tracker.acknowledge(label)
  local key = tostring(label or "request")
  if tracker.active[key] == nil then return false end
  tracker.active[key] = nil
  return true
end

function tracker.clear()
  tracker.active = {}
end

return tracker
local requestResolver = require("oc.ae2.request_resolver")
local requestSubmit = require("oc.ae2.request_submit")
local cpuWitness = require("oc.ae2.maintainer_cpu_witness")

local requester = {}

function requester.readyCpu(cpus)
  for _, cpu in ipairs(cpus or {}) do
    if not cpuWitness.cpuBusy(cpu) then return cpu.name or cpu.label end
  end
  return nil
end

function requester.findCraftable(target, options)
  return requestResolver.find(target, options)
end

function requester.requestTarget(target, amount, options)
  return requestSubmit.requestTarget(target, amount, options)
end

function requester.warm(options)
  return requestResolver.warm(options)
end

function requester.lastReport()
  return requestSubmit.lastReport()
end

return requester
local computer = require("computer")

local time = {}

local function seconds(value)
  local number = tonumber(value)
  if not number then number = computer.uptime() end
  if number < 0 then number = 0 end
  return math.floor(number + 0.5)
end

function time.now()
  return computer.uptime()
end

function time.short(value)
  local total = seconds(value)
  local days = math.floor(total / 86400)
  total = total % 86400
  local hours = math.floor(total / 3600)
  total = total % 3600
  local minutes = math.floor(total / 60)
  local secs = total % 60
  if days > 0 then return string.format("%dd%02d:%02d", days, hours, minutes) end
  if hours > 0 then return string.format("%d:%02d:%02d", hours, minutes, secs) end
  return string.format("%02d:%02d", minutes, secs)
end

function time.duration(value)
  local total = seconds(value)
  if total >= 3600 then return string.format("%dh%02dm", math.floor(total / 3600), math.floor((total % 3600) / 60)) end
  if total >= 60 then return string.format("%dm%02ds", math.floor(total / 60), total % 60) end
  return tostring(total) .. "s"
end

function time.receipt(prefix, label, amount, isFluid)
  label = tostring(label or "target")
  amount = math.floor(tonumber(amount) or 1)
  if isFluid then
    return tostring(prefix or "") .. tostring(amount) .. " mB " .. label .. " @" .. time.short() .. "."
  end
  return tostring(prefix or "") .. tostring(amount) .. "x " .. label .. " @" .. time.short() .. "."
end

return time
local computer = require("computer")

local budget = {}

local defaults = {
  capacity = 8,
  refillPerSecond = 4
}

local profiles = {
  manual_action = { priority = 1, cost = 8, borrow = true },
  daemon_dispatch = { priority = 2, cost = 8, borrow = true },
  warm_continuation = { priority = 3, cost = 8 },
  visible_refresh = { priority = 4, cost = 4 },
  passive_cache = { priority = 5, cost = 2 }
}

local state = {
  capacity = defaults.capacity,
  refillPerSecond = defaults.refillPerSecond,
  tokens = defaults.capacity,
  updatedAt = nil,
  lastKind = nil
}

local function nowValue(options)
  return tonumber(options and options.now) or computer.uptime()
end

local function profileFor(kind)
  return profiles[kind] or profiles.visible_refresh
end

local function refill(now)
  now = tonumber(now) or computer.uptime()
  if not state.updatedAt then
    state.updatedAt = now
    state.tokens = math.min(state.capacity, tonumber(state.tokens) or state.capacity)
    return
  end
  local elapsed = now - state.updatedAt
  if elapsed > 0 then
    state.tokens = math.min(state.capacity, (tonumber(state.tokens) or 0) + (elapsed * state.refillPerSecond))
    state.updatedAt = now
  end
end

local function snapshot(kind, wait, borrowed)
  local waiting = (tonumber(wait) or 0) > 0
  return {
    kind = kind,
    tokens = state.tokens,
    capacity = state.capacity,
    refillPerSecond = state.refillPerSecond,
    wait = wait or 0,
    borrowed = borrowed == true,
    reason = waiting and "AE2 budget cooling down" or nil
  }
end

function budget.reset(options)
  options = options or {}
  state.capacity = math.max(1, tonumber(options.capacity) or defaults.capacity)
  state.refillPerSecond = math.max(0.1, tonumber(options.refillPerSecond) or defaults.refillPerSecond)
  state.tokens = tonumber(options.tokens) or state.capacity
  state.updatedAt = nowValue(options)
  state.lastKind = nil
end

function budget.status(options)
  refill(nowValue(options))
  return snapshot(state.lastKind)
end

function budget.priorities()
  local out = {}
  for kind, profile in pairs(profiles) do out[kind] = profile.priority end
  return out
end

function budget.waitFor(kind, options)
  options = options or {}
  local profile = profileFor(kind)
  local cost = math.max(0, tonumber(options.cost) or profile.cost or 1)
  refill(nowValue(options))
  if state.tokens >= cost then return 0 end
  return math.ceil(((cost - state.tokens) / state.refillPerSecond) * 10) / 10
end

function budget.trySpend(kind, options)
  options = options or {}
  local profile = profileFor(kind)
  local cost = math.max(0, tonumber(options.cost) or profile.cost or 1)
  local borrow = options.borrow == true or profile.borrow == true
  refill(nowValue(options))
  state.lastKind = kind
  if cost <= 0 then return true, snapshot(kind) end
  if state.tokens >= cost then
    state.tokens = state.tokens - cost
    return true, snapshot(kind)
  end
  if borrow then
    state.tokens = state.tokens - cost
    return true, snapshot(kind, 0, true)
  end
  return false, snapshot(kind, budget.waitFor(kind, { cost = cost, now = nowValue(options) }))
end

return budget
local computerOk, computer = pcall(require, "computer")
if not computerOk then computer = { uptime = function() return os.clock and os.clock() or 0 end } end

local epoch = {}

local state = {
  workflowVersion = 0,
  workflowSignature = nil,
  targetSignature = nil,
  ae2Primary = nil,
  batteryNode = nil,
  lastCompleteWarm = nil,
  lastReason = nil,
  lastManualBatch = nil,
  lastAutoBatch = nil,
  lastBatch = nil
}

local function boolText(value)
  return tostring(value == true)
end

local function kindFor(target)
  if not target then return "item" end
  if target.isFluid == true or target.kind == "fluid" then return "fluid" end
  local label = tostring(target.rawLabel or target.label or "")
  if label:find("^[Dd]rops? of%s+") then return "fluid" end
  return target.kind or "item"
end

local function targetsFor(config)
  if type(config) ~= "table" then return {} end
  if type(config.targets) == "table" then return config.targets end
  local targets = {}
  for _, row in ipairs(config.workflows or {}) do
    if row.mode == "auto" then targets[#targets + 1] = row end
  end
  return targets
end

function epoch.targetKey(target)
  target = target or {}
  if target.name then
    return tostring(kindFor(target)) .. ":" .. tostring(target.name) .. ":"
      .. tostring(target.damage or "") .. ":" .. boolText(target.hasTag) .. ":"
      .. tostring(target.rawLabel or target.label or target.name or ""):lower()
  end
  return tostring(target.label or target.rawLabel or "target"):lower()
end

function epoch.targetSignature(targets)
  local parts = {}
  for index, target in ipairs(targets or {}) do parts[index] = epoch.targetKey(target) end
  return table.concat(parts, "|")
end

local function policyValue(target, key, fallback)
  local value = target and target[key]
  if value == nil and fallback then value = target and target[fallback] end
  return tostring(value or "")
end

function epoch.configSignature(config)
  config = config or {}
  local parts = {}
  local targets = targetsFor(config)
  for index, target in ipairs(targets) do
    parts[index] = table.concat({
      epoch.targetKey(target),
      policyValue(target, "min", "minStock"),
      policyValue(target, "craftTo", "minStock"),
      policyValue(target, "batch"),
      policyValue(target, "minBatteryRatio"),
      policyValue(target, "maxDeficitRatio"),
      tostring(target and target.requireReadyCpu),
      policyValue(target, "cooldown"),
      boolText(target and target.armed)
    }, ":")
  end
  return tostring(config.autoEnabled ~= false) .. "|" .. table.concat(parts, "|")
end

function epoch.nodeId(node)
  if type(node) ~= "table" or not node.address then return nil end
  return tostring(node.type or node.kind or "node") .. ":" .. tostring(node.address)
end

local function copy()
  return {
    workflowVersion = state.workflowVersion,
    workflowSignature = state.workflowSignature,
    targetSignature = state.targetSignature,
    ae2Primary = state.ae2Primary,
    batteryNode = state.batteryNode,
    lastCompleteWarm = state.lastCompleteWarm,
    lastReason = state.lastReason,
    lastManualBatch = state.lastManualBatch,
    lastAutoBatch = state.lastAutoBatch,
    lastBatch = state.lastBatch
  }
end

function epoch.reset()
  state.workflowVersion, state.workflowSignature, state.targetSignature = 0, nil, nil
  state.ae2Primary, state.batteryNode = nil, nil
  state.lastCompleteWarm, state.lastReason = nil, nil
  state.lastManualBatch, state.lastAutoBatch, state.lastBatch = nil, nil, nil
end

function epoch.snapshot()
  return copy()
end

function epoch.recordWorkflow(config, reason)
  local targets = targetsFor(config)
  local targetSig = epoch.targetSignature(targets)
  local signature = epoch.configSignature(config)
  local targetsChanged = state.targetSignature ~= targetSig
  local changed = targetsChanged or state.workflowSignature ~= signature
  if changed then
    state.workflowVersion = state.workflowVersion + 1
    state.workflowSignature = signature
    state.targetSignature = targetSig
    state.lastReason = reason or (targetsChanged and "target_signature" or "workflow_policy")
  end
  local out = copy()
  out.changed = changed
  out.targetsChanged = targetsChanged
  out.policyChanged = changed and not targetsChanged
  return out
end

function epoch.recordNodes(nodes)
  nodes = nodes or {}
  local ae2 = epoch.nodeId(nodes.ae2Primary or nodes.primary or nodes.ae2)
  local battery = epoch.nodeId(nodes.batteryNode or nodes.battery or nodes.power)
  local ae2Changed = ae2 ~= nil and state.ae2Primary ~= ae2
  local batteryChanged = battery ~= nil and state.batteryNode ~= battery
  if ae2Changed then state.ae2Primary, state.lastReason = ae2, "ae2_primary" end
  if batteryChanged then state.batteryNode, state.lastReason = battery, "battery_node" end
  local out = copy()
  out.ae2Changed, out.batteryChanged = ae2Changed, batteryChanged
  return out
end

local function recordBatch(entry, now, reason)
  local batch = {
    at = tonumber(now) or computer.uptime(),
    target = epoch.targetKey(entry)
  }
  if reason == "auto_batch" then state.lastAutoBatch = batch else state.lastManualBatch = batch end
  state.lastBatch = { at = batch.at, target = batch.target, reason = reason }
  state.lastReason = reason
  return copy()
end

function epoch.recordManualBatch(entry, now)
  return recordBatch(entry, now, "manual_batch")
end

function epoch.recordAutoBatch(entry, now)
  return recordBatch(entry, now, "auto_batch")
end

function epoch.markCompleteWarm(report, now)
  if type(report) == "table" and report.status and report.status.complete == true then
    state.lastCompleteWarm = tonumber(now) or computer.uptime()
    state.lastReason = "complete_warm"
  end
  return copy()
end

function epoch.invalidationFor(cacheEpoch)
  cacheEpoch = cacheEpoch or {}
  local ae2Changed = state.ae2Primary and cacheEpoch.ae2Primary
    and state.ae2Primary ~= cacheEpoch.ae2Primary
  local batteryChanged = state.batteryNode and cacheEpoch.batteryNode
    and state.batteryNode ~= cacheEpoch.batteryNode
  local targetsChanged = state.targetSignature and cacheEpoch.targetSignature
    and state.targetSignature ~= cacheEpoch.targetSignature
  local workflowChanged = cacheEpoch.workflowVersion
    and cacheEpoch.workflowVersion ~= state.workflowVersion
  return {
    workflow = workflowChanged == true,
    policy = workflowChanged == true and not targetsChanged and not ae2Changed,
    context = ae2Changed == true or batteryChanged == true,
    targetRows = ae2Changed == true or targetsChanged == true,
    stock = ae2Changed == true or targetsChanged == true,
    ae2Primary = ae2Changed == true,
    batteryNode = batteryChanged == true
  }
end

function epoch.stamp(cache, config, context, complete, now)
  if type(cache) ~= "table" then return nil end
  epoch.recordWorkflow(config, complete and "complete_warm" or "warm_slice")
  if context then
    epoch.recordNodes({ ae2Primary = context.primary, batteryNode = context.batteryNode or (context.current or {}).power })
  end
  cache.epoch = complete and epoch.markCompleteWarm({ status = { complete = true } }, now) or copy()
  return cache.epoch
end

return epoch
local cacheEpoch = require("oc.ae2.cache_epoch")

local computerOk, computer = pcall(require, "computer")
if not computerOk then computer = { uptime = function() return os.clock and os.clock() or 0 end } end

local memory = {}

memory.maxEntries = 256
memory.maxAge = 900
memory.maxFutureSkew = 5
local entries = {}

local function now()
  local ok, value = pcall(computer.uptime)
  return ok and tonumber(value) or 0
end

local function keyFor(target, options)
  options = options or {}
  if options.key then return tostring(options.key) end
  if target and target.stockMemoryKey then return tostring(target.stockMemoryKey) end
  return cacheEpoch.targetKey(target)
end

local function currentFor(row)
  local value = row and (row.current or row.size or row.amount or row[4])
  return tonumber(value)
end

local function compact(target, row, key, address, source, at)
  target, row = target or {}, row or {}
  local current = currentFor(row)
  if current == nil then return nil end
  return {
    key = key,
    address = address,
    source = source or "unknown",
    at = at,
    current = current,
    label = row.label or target.label or target.rawLabel or target.name,
    rawLabel = row.rawLabel or target.rawLabel,
    name = row.name or target.name,
    damage = row.damage ~= nil and row.damage or target.damage,
    hasTag = row.hasTag ~= nil and row.hasTag or target.hasTag,
    kind = row.kind or target.kind,
    isFluid = row.isFluid ~= nil and row.isFluid or target.isFluid,
    amount = row.amount or target.amount,
    filter = row.filter or target.filter,
    craftBinding = target.craftBinding or row.craftBinding
  }
end

local function prune()
  local count = 0
  for _ in pairs(entries) do count = count + 1 end
  while count > memory.maxEntries do
    local oldestKey, oldestAt = nil, nil
    for key, entry in pairs(entries) do
      if oldestAt == nil or (tonumber(entry.at) or 0) < oldestAt then
        oldestKey, oldestAt = key, tonumber(entry.at) or 0
      end
    end
    if not oldestKey then return end
    entries[oldestKey] = nil
    count = count - 1
  end
end

function memory.clear()
  entries = {}
end

function memory.remember(target, row, options)
  options = options or {}
  local key = keyFor(target, options)
  local at = tonumber(options.at) or now()
  local previous = entries[key]
  if previous and (tonumber(previous.at) or 0) > at then return false, previous end
  local entry = compact(target, row, key, options.address, options.source, at)
  if not entry then return false, previous end
  entries[key] = entry
  prune()
  return true, entry
end

function memory.rememberRows(rows, options)
  options = options or {}
  local aggregated = {}
  for _, row in ipairs(rows or {}) do
    local key = row and row.stockMemoryKey
    local current = key and currentFor(row)
    if key and current then
      local aggregate = aggregated[key]
      if aggregate then
        aggregate.size = (tonumber(aggregate.size) or 0) + current
        aggregate.current = aggregate.size
      else
        aggregate = {}
        for field, value in pairs(row) do aggregate[field] = value end
        aggregate.size, aggregate.current = current, current
        aggregated[key] = aggregate
      end
    end
  end
  local changed = 0
  for key, row in pairs(aggregated) do
    local ok = memory.remember(row, row, {
      key = key,
      address = options.address,
      source = options.source or "stock",
      at = options.at
    })
    if ok then changed = changed + 1 end
  end
  return changed
end

function memory.lookup(target, options)
  options = options or {}
  local entry = entries[keyFor(target, options)]
  if not entry then return nil end
  if options.address and entry.address ~= options.address then return nil end
  return entry
end

function memory.age(entry, at)
  if type(entry) ~= "table" or type(entry.at) ~= "number" then return nil end
  return (tonumber(at) or now()) - entry.at
end

function memory.isFresh(entry, options)
  options = options or {}
  local age = memory.age(entry, options.at)
  if age == nil then return false, "stock snapshot unavailable", nil end
  if age < -memory.maxFutureSkew then return false, "stock snapshot timestamp is in the future", age end
  age = math.max(0, age)
  local maxAge = tonumber(options.maxAge)
  if maxAge == nil then maxAge = memory.maxAge end
  if maxAge >= 0 and age > maxAge then
    return false, "stock snapshot stale", age
  end
  return true, nil, age
end

function memory.fresh(target, options)
  options = options or {}
  local entry = memory.lookup(target, options)
  if not entry then return nil, "stock snapshot unavailable", nil end
  local fresh, reason, age = memory.isFresh(entry, options)
  if not fresh then return nil, reason, age end
  return entry, nil, age
end

function memory.apply(row, target, options)
  row = row or {}
  local entry = memory.lookup(target or row, options)
  if not entry then return row, false end
  local fresh, reason, age = memory.isFresh(entry, options)
  row.current = entry.current
  local min = tonumber(row.min or (target and target.min)) or 0
  local craftTo = tonumber(row.craftTo or (target and (target.craftTo or target.min))) or min
  local batch = tonumber(row.batch or (target and target.batch)) or craftTo
  row.min, row.craftTo, row.batch = min, craftTo, batch
  row.request = row.current >= min and 0 or batch
  if row.request < 0 then row.request = 0 end
  row.error = nil
  row.stockMemoryAt = entry.at
  row.stockMemorySource = entry.source
  row.stockMemoryFresh = fresh
  row.stockMemoryAge = age
  if not fresh then row.stockMemoryReason = reason end
  return row, true
end

function memory.snapshot()
  local copy = {}
  for key, entry in pairs(entries) do
    local row = {}
    for field, value in pairs(entry) do row[field] = value end
    copy[key] = row
  end
  return copy
end

return memory
local component = require("component")

local cache = require("oc.ae2.request_cache")
local stockMemory = require("oc.ae2.stock_memory")

-- These NetworkControl methods perform one exact monitor lookup. They are the
-- only normal-path stock readers: no getItemsInNetwork/getFluidsInNetwork call
-- is permitted from a maintainer or foreground refresh.
local direct = {}

local function kindFor(target)
  return target and (target.isFluid == true or target.kind == "fluid") and "fluid" or "item"
end

local function valueFor(stack, kind)
  if type(stack) ~= "table" then return nil end
  if kind == "fluid" then return tonumber(stack.amount or stack.size or stack.count) end
  return tonumber(stack.size or stack.count or stack.amount)
end

function direct.refresh(target, node, options)
  options = options or {}
  local bindErr = cache.bindingError(target)
  if bindErr then return nil, bindErr, { calls = 0, bindingRequired = true } end
  if not (node and node.address) then return nil, "exact stock reader has no AE2 node", { calls = 0 } end
  local kind = kindFor(target)
  local method = kind == "fluid" and "getFluidInNetwork" or "getItemInNetwork"
  -- The scalar overload is supported by both the original GTNH implementation
  -- and current releases. Some deployed versions advertise the newer table
  -- overload but reject it at runtime with "string expected, got table".
  -- Exact untagged bindings need only registry name plus item damage, so the
  -- scalar call preserves identity without a compatibility retry or grid scan.
  local values
  if kind == "fluid" then
    values = table.pack(pcall(component.invoke, node.address, method, target.name))
  else
    values = table.pack(pcall(component.invoke, node.address, method, target.name, target.damage))
  end
  local report = { calls = 1, method = method, source = { address = node.address, type = node.type } }
  if not values[1] then return nil, tostring(values[2]), report end

  -- A successful nil response is an exact zero, not an invitation to scan the
  -- grid by label. That distinction is what keeps an empty target safe.
  local current = values[2] == nil and 0 or valueFor(values[2], kind)
  if current == nil then return nil, "exact stock reader returned no usable count", report end
  local changed, entry = stockMemory.remember(target, {
    current = current,
    label = target.label,
    rawLabel = target.rawLabel,
    name = target.name,
    damage = target.damage,
    hasTag = target.hasTag,
    kind = kind,
    isFluid = kind == "fluid",
    amount = target.amount,
    filter = target.filter,
    craftBinding = target.craftBinding
  }, {
    address = node.address,
    source = "direct-exact",
    at = options.at
  })
  if not entry then return nil, "could not retain exact stock reading", report end
  report.current, report.changed, report.entry = entry.current, changed == true, entry
  return entry, nil, report
end

return direct
local adapt = {}

local DEFAULT_BASE = 8
local FAST_SECONDS = 0.5
local SLOW_SECONDS = 2

local function number(value)
  local n = tonumber(value)
  if n == nil then return nil end
  return n
end

local function whole(value, fallback)
  return math.max(1, math.floor(number(value) or fallback or DEFAULT_BASE))
end

local function bounds(base)
  return math.max(1, math.floor(base / 2)), math.max(base, base * 2)
end

local function clamp(value, base)
  local min, max = bounds(base)
  value = whole(value, base)
  if value < min then return min end
  if value > max then return max end
  return value
end

local function scopes(container)
  container.adaptiveChunks = container.adaptiveChunks or {}
  return container.adaptiveChunks
end

local function slot(container, scope, base)
  local all = scopes(container)
  local key = tostring(scope or "default")
  local current = all[key]
  if type(current) ~= "table" or current.base ~= base then
    current = { base = base, nextLimit = base }
    all[key] = current
  end
  return current
end

local function complete(options)
  return options and options.complete == true
end

local function stalled(current, options, duration)
  if options and (options.ok == false or options.timeout == true) then return true end
  if duration and duration >= (number(options and options.slowSeconds) or SLOW_SECONDS) then return true end
  if complete(options) then return false end
  local calls = options and number(options.calls)
  if calls ~= nil and calls <= 0 then return true end
  local before = options and number(options.cursorBefore)
  local after = options and number(options.cursorAfter)
  return before ~= nil and after ~= nil and before == after
end

function adapt.limit(container, scope, options)
  options = options or {}
  local base = whole(options.base, DEFAULT_BASE)
  local current = slot(container, scope, base)
  if options.reset == true then current.nextLimit = base end
  current.lastIssued = clamp(current.nextLimit or base, base)
  return current.lastIssued
end

function adapt.record(container, scope, options)
  options = options or {}
  local base = whole(options.base, DEFAULT_BASE)
  local current = slot(container, scope, base)
  local duration = math.max(0, number(options.duration) or 0)
  local min, max = bounds(base)
  current.lastTargetLimit = clamp(options.targetLimit or current.lastIssued or base, base)
  current.lastDuration = duration
  current.lastCalls = options.calls
  current.lastCursor = options.cursorAfter
  if stalled(current, options, duration) then
    current.nextLimit = min
    current.lastDecision = "down"
  elseif complete(options) then
    current.nextLimit = base
    current.lastDecision = "reset"
  elseif duration <= (number(options.fastSeconds) or FAST_SECONDS) then
    current.nextLimit = max
    current.lastDecision = "up"
  else
    current.nextLimit = base
    current.lastDecision = "base"
  end
  return current
end

function adapt.status(container, scope, options)
  options = options or {}
  local base = whole(options.base, DEFAULT_BASE)
  local current = slot(container, scope, base)
  return {
    base = base,
    lastTargetLimit = current.lastTargetLimit,
    nextLimit = current.nextLimit,
    lastDecision = current.lastDecision,
    lastDuration = current.lastDuration,
    lastCalls = current.lastCalls
  }
end

return adapt
local filesystem = require("filesystem")
local serialization = require("serialization")
local time = require("oc.ae2.time")

local log = {}

log.path = "/var/oc/ae2-maintainer.log"
log.maxEntries = 100

local function ensureParent(path)
  local parent = filesystem.path(path)
  if parent and parent ~= "" and not filesystem.exists(parent) then
    filesystem.makeDirectory(parent)
  end
end

local function numberOrNil(value)
  local number = tonumber(value)
  if not number then return nil end
  return number
end

local function record(row, now)
  row = row or {}
  now = tonumber(now) or time.now()
  return {
    stamp = time.short(now),
    uptime = now,
    label = tostring(row.label or "target"),
    amount = numberOrNil(row.request or row.amount or row.batch) or 0,
    current = numberOrNil(row.current),
    min = numberOrNil(row.min),
    craftTo = numberOrNil(row.craftTo),
    batch = numberOrNil(row.batch),
    state = tostring(row.requestState or "running"),
    phase = row.requestPhase and tostring(row.requestPhase) or nil,
    reason = row.requestStatusReason and tostring(row.requestStatusReason) or nil,
    name = row.name and tostring(row.name) or nil,
    damage = row.damage,
    hasTag = row.hasTag == true
  }
end

local function boundedLimit(value)
  local limit = math.floor(tonumber(value) or log.maxEntries)
  if limit < 0 then return 0 end
  return limit
end

local function readLines(limit, detectOverflow)
  limit = boundedLimit(limit)
  local lines, overflow = {}, false
  local input = io.open(log.path, "r")
  if not input then return lines, overflow end
  while #lines < limit do
    local line = input:read("*l")
    if not line then break end
    if line ~= "" then lines[#lines + 1] = line end
  end
  if detectOverflow then
    while true do
      local line = input:read("*l")
      if not line then break end
      if line ~= "" then
        overflow = true
        break
      end
    end
  end
  input:close()
  return lines, overflow
end

local function writeLines(lines)
  lines = lines or {}
  ensureParent(log.path)
  local output, err = io.open(log.path, "w")
  if not output then return false, err or ("could not write " .. log.path) end
  for _, line in ipairs(lines) do output:write(line .. "\n") end
  output:close()
  return true, nil, #lines
end

local function readSlice(pageNumber, perPage)
  local rows, total = {}, 0
  local handle = io.open(log.path, "r")
  if not handle then return rows, total end
  local first = ((pageNumber - 1) * perPage) + 1
  local last = first + perPage - 1
  while true do
    local line = handle:read("*l")
    if not line then break end
    if line ~= "" then
      total = total + 1
      if total >= first and total <= last then
        local ok, row = pcall(serialization.unserialize, line)
        rows[#rows + 1] = ok and type(row) == "table" and row or { stamp = "bad record", label = line, amount = 0 }
      end
    end
  end
  handle:close()
  return rows, total
end

function log.append(source, now)
  local row = record(source, now)
  local lines = readLines(log.maxEntries - 1)
  ensureParent(log.path)
  local output, err = io.open(log.path, "w")
  if not output then return false, err or ("could not write " .. log.path) end
  output:write(serialization.serialize(row) .. "\n")
  for _, line in ipairs(lines) do output:write(line .. "\n") end
  output:close()
  return true, nil, row
end

function log.prune(maxEntries)
  local lines, overflow = readLines(maxEntries or log.maxEntries, true)
  if not overflow then return true, nil, #lines end
  return writeLines(lines)
end

function log.page(pageNumber, perPage)
  pageNumber = math.max(1, math.floor(tonumber(pageNumber) or 1))
  perPage = math.max(1, math.floor(tonumber(perPage) or 25))
  local pruned, pruneErr = log.prune(log.maxEntries)
  local rows, total = readSlice(pageNumber, perPage)
  local pages = math.max(1, math.ceil(total / perPage))
  if pageNumber > pages then
    pageNumber = pages
    rows, total = readSlice(pageNumber, perPage)
  end
  local result = { rows = rows, page = pageNumber, pages = pages, total = total, perPage = perPage, path = log.path }
  if not pruned and pruneErr then result.error = tostring(pruneErr) end
  return result
end

return log
local match = require("oc.ae2.request_match")
local witness = {}
local invokerModule = nil
local function invoker()
  if invokerModule == false then return nil end
  if invokerModule then return invokerModule end
  local ok, module = pcall(require, "oc.ae2.request_invoker")
  if ok and type(module) == "table" then
    invokerModule = module
    return invokerModule
  end
  invokerModule = false
  return nil
end

local function cpuHandles(row)
  local out, seen = {}, {}
  local function add(value)
    if value ~= nil and not seen[value] then
      out[#out + 1] = value
      seen[value] = true
    end
  end
  if type(row) == "table" then
    add(row.cpu)
    add(row.handle)
    add(row.cluster)
    add(row)
  end
  return out
end

local function cpuName(row, index) return tostring(row and (row.name or row.label or row.id) or ("cpu " .. tostring(index))) end

local function cpuBusy(row)
  if type(row) ~= "table" then return false end
  local value = row.busy
  if value == true then return true end
  if value == false or value == nil then return false end
  if type(value) == "number" then return value ~= 0 end
  local text = tostring(value):lower()
  return text == "true" or text == "1" or text == "yes" or text == "busy" or text == "working"
end

local function cpuField(value, key)
  if value == nil then return nil end
  local ok, result = pcall(function() return value[key] end)
  return ok and result or nil
end

local function stackView(stack)
  if type(stack) == "table" then return stack end
  return {
    label = cpuField(stack, "label") or tostring(stack or "unknown"),
    name = cpuField(stack, "name"),
    damage = cpuField(stack, "damage"),
    hasTag = cpuField(stack, "hasTag"),
    size = cpuField(stack, "size"),
    amount = cpuField(stack, "amount"),
    kind = cpuField(stack, "kind"), isFluid = cpuField(stack, "isFluid"),
    fluidDrop = cpuField(stack, "fluidDrop"), fluidPacket = cpuField(stack, "fluidPacket")
  }
end

local function cpuCallResult(values)
  if values[1] then
    if values[2] ~= nil then return values[2], nil end
    return nil, tostring(values[3] or "nil result: finalOutput")
  end
  return nil, tostring(values[2])
end

local function callFinalOutput(cpu)
  local okMethod, method = pcall(function() return cpu and cpu.finalOutput end)
  if okMethod and method ~= nil then
    local direct = table.pack(pcall(function() return method() end))
    if direct[1] then return cpuCallResult(direct) end
    local selfStyle = table.pack(pcall(function() return method(cpu) end))
    if selfStyle[1] then return cpuCallResult(selfStyle) end
    return nil, tostring(direct[2] or selfStyle[2])
  end
  if not okMethod then return nil, tostring(method) end
  if type(cpu) == "string" then
    local api = invoker()
    if api and api.callObject then
      local stack, err = api.callObject(cpu, "finalOutput")
      if stack ~= nil then return stack, nil end
      if tostring(err or ""):find("nil result", 1, true) then return nil, nil end
      return nil, err
    end
  end
  return nil, "missing method: finalOutput"
end

local function optionalWitnessUnavailable(err)
  local text = tostring(err or "")
  local lower = text:lower()
  return text == ""
    or text:find("missing method:", 1, true) ~= nil
    or text:find("missing methods:", 1, true) ~= nil
    or text:find("nil result:", 1, true) ~= nil
    or lower:find("no crafting monitor", 1, true) ~= nil
    or lower:find("nothing is crafted", 1, true) ~= nil
end

local function cachedFinalOutput(row)
  if type(row) ~= "table" or row.finalOutputChecked ~= true then return nil, nil, false end
  if row.finalOutputStack ~= nil then return row.finalOutputStack, nil, true end
  return nil, row.finalOutputError, true
end

local function labelKey(value)
  local key = match.tidyLabel(match.plainLabel(value)):lower()
  if key == "" or key == "unknown" then return nil end
  return key
end

local function addWanted(wanted, value)
  local key = labelKey(value)
  if key then wanted[key] = true end
end

local function wantedLabel(wanted, value)
  local key = labelKey(value)
  return key and wanted[key] == true
end

local function fluidLabelMatches(active, target)
  if not (target and (target.isFluid == true or target.kind == "fluid")) then return false end
  local wanted = {}
  addWanted(wanted, target.label)
  addWanted(wanted, target.rawLabel)
  return wantedLabel(wanted, active and active.label) or wantedLabel(wanted, active and active.rawLabel)
end

local function itemLabelMatches(active, target)
  if not target or target.isFluid == true or target.kind == "fluid" then return false end
  if active and active.kind and active.kind ~= "item" then return false end
  local wanted = {}
  addWanted(wanted, target.label)
  addWanted(wanted, target.rawLabel)
  return wantedLabel(wanted, active and active.label) or wantedLabel(wanted, active and active.rawLabel)
end

local function fluidLike(value)
  return value and (value.isFluid == true or value.kind == "fluid" or match.fluidProxy(value) == true)
end

local function legacyFluidProxy(value)
  local name = tostring(value and value.name or ""):lower()
  return name == "ae2fc:fluid_drop" or name == "ae2fc:fluid_packet" or match.fluidProxy(value) == true
end

local function targetHasStableIdentity(target)
  if type(target) ~= "table" then return false end
  if target.name ~= nil and tostring(target.name) ~= "" then return true end
  return labelKey(target.label) ~= nil or labelKey(target.rawLabel) ~= nil
end

local function eachCpu(cpus, fn)
  local seen = {}
  local reported = math.max(tonumber(cpus and cpus.n) or 0, #(cpus or {}))
  for index = 1, reported do
    if cpus[index] ~= nil then
      seen[index] = true
      fn(cpus[index], index)
    end
  end
  for key, row in pairs(cpus or {}) do
    if key ~= "n" and not seen[key] then fn(row, key) end
  end
end

function witness.cpuBusy(row) return cpuBusy(row) end

function witness.activeOutputs(cpuSummary)
  local cpus = cpuSummary and cpuSummary.cpus or cpuSummary or {}
  local rows = {}
  local diagnostics = { scannedCpus = 0, busyCpus = 0, finalOutputs = 0, errors = 0 }
  local function addOutput(stack, row, index, busy)
    diagnostics.finalOutputs = diagnostics.finalOutputs + 1
    local out = match.normalizeStack(stackView(stack))
    out.cpuName = cpuName(row, index)
    out.cpuIndex = index
    out.cpuBusy = busy
    out.phase = "cpu_final_output"
    rows[#rows + 1] = out
  end
  eachCpu(cpus, function(row, index)
    diagnostics.scannedCpus = diagnostics.scannedCpus + 1
    local busy = cpuBusy(row)
    if busy then diagnostics.busyCpus = diagnostics.busyCpus + 1 end
    local stack, err
    local checked
    stack, err, checked = cachedFinalOutput(row)
    if not checked then
      local firstErr = nil
      for _, handle in ipairs(cpuHandles(row)) do
        local candidate, candidateErr = callFinalOutput(handle)
        if candidate ~= nil then
          stack, err = candidate, nil
          break
        elseif candidateErr and not optionalWitnessUnavailable(candidateErr) and not firstErr then
          firstErr = candidateErr
        end
      end
      if stack == nil then err = firstErr end
    end
    if type(stack) == "table" and (type(stack[1]) == "table" or type(stack.n) == "number") then
      local seen = {}
      local reported = math.max(tonumber(stack.n) or 0, #stack)
      for stackIndex = 1, reported do
        if type(stack[stackIndex]) == "table" then
          seen[stackIndex] = true
          addOutput(stack[stackIndex], row, index, busy)
        end
      end
      for key, value in pairs(stack) do
        if key ~= "n" and not seen[key] and type(value) == "table" then addOutput(value, row, index, busy) end
      end
    elseif type(stack) == "table" then
      addOutput(stack, row, index, busy)
    elseif stack ~= nil then
      addOutput(stack, row, index, busy)
    elseif err and not optionalWitnessUnavailable(err) then
      diagnostics.errors = diagnostics.errors + 1
      diagnostics.firstError = diagnostics.firstError or tostring(err)
      diagnostics.firstErrorCpu = diagnostics.firstErrorCpu or cpuName(row, index)
    end
  end)
  rows.diagnostics = diagnostics
  return rows
end

function witness.matches(active, target)
  if not (active and target) then return false end
  if active.name and target.name then
    if match.sameTarget(active, target) then return true end
    return (legacyFluidProxy(active) or legacyFluidProxy(target)) and (fluidLike(active) or fluidLike(target))
      and fluidLabelMatches(active, target)
  end
  if fluidLike(active) or fluidLike(target) then return fluidLabelMatches(active, target) end
  if fluidLabelMatches(active, target) then return true end
  if itemLabelMatches(active, target) then return true end
  if not active.name or not targetHasStableIdentity(target) then return false end
  return match.sameTarget(active, target)
end

function witness.find(activeCrafts, target)
  for _, active in ipairs(activeCrafts or {}) do
    if witness.matches(active, target) then return active end
  end
  return nil
end

return witness
local computer = require("computer")
local serialization = require("serialization")
local dispatchBuilder = require("oc.ae2.maintainer_queue_dispatch")

local queue = {
  state = {}, seeded = false, statePath = "/var/oc/ae2-maintainer.state",
  manualStatePath = "/var/oc/ae2-maintainer-manual.state", manualGeneration = 0
}
local MAX_MANUAL_STATE_BYTES = 131072

function queue.id(row)
  return dispatchBuilder.id(row)
end

function queue.backoff(attempts)
  return dispatchBuilder.backoff(attempts)
end

local function readSerialized(path, maxBytes)
  local handle = io.open(path, "r")
  if not handle then return {} end
  local text = handle:read(maxBytes and (maxBytes + 1) or "*a") or ""
  handle:close()
  if maxBytes and #text > maxBytes then return {} end
  local ok, value = pcall(serialization.unserialize, text)
  return ok and type(value) == "table" and value or {}
end

local function seedFromState()
  if queue.seeded then return end
  queue.seeded = true
  local value = readSerialized(queue.statePath)
  local now = computer.uptime()
  for _, row in ipairs(value.targetStatus or {}) do
    local retryableBlock = row.status == "blocked" and row.phase == "missing_resources"
    if row.id and (row.status == "in_flight" or row.status == "queued"
        or row.status == "failed" or retryableBlock) then
      queue.state[row.id] = {
        status = "unknown",
        attempts = 1,
        nextEligibleAt = now + 600,
        lastError = "unknown after reboot"
      }
    end
  end
end

local function manualReservations()
  local now = computer.uptime()
  local durable = readSerialized(queue.manualStatePath, MAX_MANUAL_STATE_BYTES)
  local generation = tonumber(durable.generation) or 0
  local updatedAt = tonumber(durable.updatedAt)
  if generation < (tonumber(queue.manualGeneration) or 0) then return {} end
  local rebooted = updatedAt and updatedAt > now
  queue.manualGeneration = generation
  local active = {}
  for id, row in pairs(type(durable.reservations) == "table" and durable.reservations or {}) do
    local rowGeneration = tonumber(row and row.generation) or 0
    local rowUpdated = tonumber(row and row.updatedAt)
    local valid = type(row) == "table" and tostring(row.id or "") == tostring(id)
      and rowGeneration > 0 and rowGeneration <= generation and rowUpdated and (rebooted or rowUpdated <= now)
    if valid then
      local cooldownUntil = tonumber(row.cooldownUntil) or 0
      local retryUntil = tonumber(row.retryUntil) or 0
      local boundary = math.max(cooldownUntil, retryUntil)
      local memory = queue.state[id] or {}
      if rebooted and rowGeneration > (tonumber(memory.manualGeneration) or 0) then
        memory.status, memory.attempts = "unknown", math.max(1, tonumber(memory.attempts) or 0)
        memory.phase, memory.statusReason = "reboot_recovery", "manual request ownership unknown after reboot"
        memory.lastError, memory.manualGeneration = memory.statusReason, rowGeneration
        memory.nextEligibleAt = math.max(tonumber(memory.nextEligibleAt) or 0, now + 600)
        queue.state[id] = memory
      elseif not rebooted and boundary > now and rowGeneration > (tonumber(memory.manualGeneration) or 0) then
        memory.manualGeneration = rowGeneration
        local repaired = (row.state == "running" and row.phase == "submitted") or row.state == "done"
        if repaired then
          memory.status, memory.attempts = "manual", 0
          memory.lastFailAt, memory.lastError = nil, nil
          memory.nextEligibleAt = cooldownUntil
        else
          memory.status = row.state == "blocked" and "resource_blocked" or "failed"
          memory.nextEligibleAt = math.max(tonumber(memory.nextEligibleAt) or 0, boundary)
        end
        memory.phase, memory.statusReason = row.phase, row.reason
        queue.state[id] = memory
      end
      if not rebooted and row.state == "running" and (tonumber(row.leaseUntil) or 0) > now then active[id] = row end
    end
  end
  return active
end

function queue.reset()
  queue.state = {}
  queue.seeded = true
  queue.manualGeneration = 0
end

function queue.prune(validIds)
  seedFromState()
  validIds = validIds or {}
  for id in pairs(queue.state) do
    if not validIds[id] then queue.state[id] = nil end
  end
end

function queue.build(report, options)
  seedFromState()
  options = options or {}
  options.manualReservations = manualReservations()
  return dispatchBuilder.build(queue, report, options)
end

function queue.markSubmitted(entry, now)
  if not entry then return end
  now = tonumber(now) or computer.uptime()
  local memory = queue.state[entry.id] or {}
  local changed = memory.status ~= "in_flight"
  memory.status, memory.lastSubmitAt, memory.attempts = "in_flight", now, 0
  memory.phase = entry.row and entry.row.requestPhase
  memory.statusReason = entry.row and entry.row.requestStatusReason
  memory.nextEligibleAt = now + (tonumber(entry.row and entry.row.cooldown) or 600)
  queue.state[entry.id] = memory
  entry.status, entry.lastSubmitAt, entry.nextEligibleAt = "in_flight", now, memory.nextEligibleAt
  entry.phase, entry.statusReason = memory.phase, memory.statusReason
  return memory, changed
end

function queue.markPlanning(entry, now)
  if not entry then return end
  now = tonumber(now) or computer.uptime()
  local memory = queue.state[entry.id] or {}
  memory.status, memory.lastAttemptAt = "planning", now
  memory.phase, memory.statusReason = "computing", "AE2 recipe calculation in progress"
  queue.state[entry.id] = memory
  entry.status, entry.phase, entry.statusReason = "in_flight", memory.phase, memory.statusReason
  entry.reason = "AE2 planning request; no CPU assigned yet"
  return memory
end

function queue.markUnverified(entry, now)
  if not entry then return end
  now = tonumber(now) or computer.uptime()
  local memory = queue.state[entry.id] or {}
  memory.status, memory.lastAttemptAt = "unknown", now
  memory.phase, memory.statusReason = "confirmation_unavailable", "request confirmation unavailable"
  memory.nextEligibleAt = now + dispatchBuilder.cooldownFor(entry.row or entry)
  queue.state[entry.id] = memory
  entry.status, entry.phase, entry.statusReason = "blocked", memory.phase, memory.statusReason
  entry.nextEligibleAt, entry.reason = memory.nextEligibleAt, memory.statusReason
  return memory
end

function queue.markDone(entry, now, token)
  if not entry then return end
  now = tonumber(now) or computer.uptime()
  local memory = queue.state[entry.id] or {}
  local changed = token == nil or memory.terminalToken ~= token
  if changed then
    memory.status, memory.lastDoneAt, memory.attempts = "done", now, 0
    memory.phase, memory.statusReason, memory.lastError = "done", nil, nil
    memory.nextEligibleAt = now + dispatchBuilder.cooldownFor(entry.row or entry)
    memory.terminalToken = token
  end
  queue.state[entry.id] = memory
  entry.status, entry.phase = "done", "done"
  entry.lastDoneAt, entry.nextEligibleAt = memory.lastDoneAt, memory.nextEligibleAt
  entry.reason = "AE2 request completed"
  return memory, changed
end

function queue.markFailed(entry, err, now, token)
  if not entry then return end
  now = tonumber(now) or computer.uptime()
  local memory = queue.state[entry.id] or {}
  local changed = token == nil or memory.terminalToken ~= token
  if changed then
    memory.attempts = (tonumber(memory.attempts) or 0) + 1
    memory.status, memory.lastFailAt, memory.lastError = "failed", now, tostring(err or "request failed")
    memory.phase, memory.statusReason = "failed", memory.lastError
    memory.nextEligibleAt, memory.terminalToken = now + queue.backoff(memory.attempts), token
  end
  queue.state[entry.id] = memory
  entry.status, entry.lastFailAt, entry.lastError = "failed", memory.lastFailAt, memory.lastError
  entry.phase, entry.statusReason = memory.phase, memory.statusReason
  entry.attempts, entry.nextEligibleAt, entry.reason = memory.attempts, memory.nextEligibleAt, memory.lastError
  return memory, changed
end

function queue.markBlocked(entry, err, now, phase, token)
  if not entry then return end
  now = tonumber(now) or computer.uptime()
  local memory = queue.state[entry.id] or {}
  local changed = token == nil or memory.terminalToken ~= token
  if changed then
    memory.attempts = (tonumber(memory.attempts) or 0) + 1
    memory.status, memory.lastFailAt, memory.lastError = "resource_blocked", now, tostring(err or "missing resources")
    memory.phase, memory.statusReason = phase or "missing_resources", memory.lastError
    memory.nextEligibleAt, memory.terminalToken = now + queue.backoff(memory.attempts), token
  end
  queue.state[entry.id] = memory
  entry.status, entry.lastFailAt, entry.lastError = "blocked", memory.lastFailAt, memory.lastError
  entry.phase, entry.statusReason = memory.phase, memory.statusReason
  entry.attempts, entry.nextEligibleAt, entry.reason = memory.attempts, memory.nextEligibleAt, memory.lastError
  return memory, changed
end

function queue.markManual(row, now)
  if not row then return end
  now = tonumber(now) or computer.uptime()
  local id = queue.id(row)
  local memory = queue.state[id] or {}
  memory.status, memory.lastSubmitAt, memory.lastDoneAt = "manual", now, now
  memory.lastFailAt, memory.lastError, memory.phase, memory.statusReason = nil, nil, nil, nil
  memory.attempts, memory.nextEligibleAt = 0, now + dispatchBuilder.cooldownFor(row)
  queue.state[id] = memory
  return memory
end

return queue
-- Queue construction is deliberately separate from durable queue memory.  The
-- daemon calls this once per completed status pass; keeping it compact makes
-- the public queue facade easy to paste and keeps dispatch policy testable.
local computer = require("computer")
local lineContract = require("oc.ae2.line_contract")
local cpuWitness = require("oc.ae2.maintainer_cpu_witness")
local requestTracker = require("oc.ae2.request_tracker")

local dispatch = {}
local MAX_AUTO_SUBMITS_PER_CYCLE = 1

local function variantLabel(row) row = row or {}; return tostring(row.rawLabel or row.label or row.name or "target"):lower() end

local function kindFor(row)
  local label = tostring(row and (row.rawLabel or row.label) or "")
  return row and (row.isFluid == true or row.kind == "fluid") and "fluid"
    or (label:find("^[Dd]rops? of%s+") and "fluid" or (row and row.kind or "item"))
end

function dispatch.id(row)
  row = row or {}
  if row.name then
    return table.concat({
      tostring(kindFor(row)), tostring(row.name), tostring(math.floor(tonumber(row.damage) or 0)),
      tostring(row.hasTag == true), variantLabel(row)
    }, ":")
  end
  return tostring(row.label or row.rawLabel or "target"):lower()
end

function dispatch.backoff(attempts)
  attempts = math.max(1, tonumber(attempts) or 1)
  if attempts <= 1 then return 600 end
  if attempts == 2 then return 1200 end
  return 2400
end

function dispatch.cooldownFor(row)
  row = row or {}
  local workflow = type(row.workflow) == "table" and row.workflow or {}
  return tonumber(row.cooldown or workflow.cooldown) or 600
end

local function resourceBlocked(memory)
  return memory and (memory.status == "resource_blocked" or memory.phase == "missing_resources")
end

local function activeMaps(manualReservations)
  local byId, byLabel, rows = {}, {}, requestTracker.summaries()
  local running = {}
  for _, row in ipairs(rows or {}) do
    if row.state == "running" then
      running[#running + 1] = row
      if row.id then byId[row.id] = row end
      if row.label then byLabel[tostring(row.label)] = row end
    end
  end
  for id, row in pairs(manualReservations or {}) do
    if not byId[id] then
      byId[id] = row
      running[#running + 1] = row
    end
  end
  return byId, byLabel, running
end

local function cpuSlotKey(active)
  if not active then return nil end
  if active.cpuIndex ~= nil then return "index:" .. tostring(active.cpuIndex) end
  if active.cpuName ~= nil then return "name:" .. tostring(active.cpuName) end
  return tostring(active)
end

-- A tracked request and a busy CPU witness often describe the same job. Count
-- their union, not their sum: otherwise one normal in-flight request consumes
-- two capacity slots and prevents the next ready CPU from receiving work.
-- Trackers without a matching final-output witness remain reserved so a job
-- that is still computing cannot overbook an unrelated free CPU.
local function trackerReservations(activeRows, activeCrafts)
  local claimed, unreflected = {}, 0
  for _, tracked in ipairs(activeRows or {}) do
    local active = cpuWitness.find(activeCrafts, tracked)
    local key = cpuSlotKey(active)
    if key and not claimed[key] then
      claimed[key] = true
    else
      unreflected = unreflected + 1
    end
  end
  return unreflected
end

local function witnessReservations(activeCrafts)
  local seen, count = {}, 0
  for _, active in ipairs(activeCrafts or {}) do
    -- readyCpus already excludes busy=true rows. A readable final output on a
    -- lagging busy=false row is still occupied and needs one explicit slot.
    if active.cpuBusy ~= true then
      local key = cpuSlotKey(active)
      if key and not seen[key] then seen[key], count = true, count + 1 end
    end
  end
  return count
end

local function capacity(status, activeRows, activeCrafts, options)
  options = options or {}
  status = status or {}
  local cpuCount = tonumber(status.totalCpus) or 0
  local ready = tonumber(status.readyCpus) or 0
  if cpuCount < 0 then cpuCount = 0 end
  if ready > cpuCount then ready = cpuCount end
  if ready < 0 then ready = 0 end
  local busyCpuCount = math.max(0, cpuCount - ready)
  local inFlightCount = #(activeRows or {})
  local unreflected = trackerReservations(activeRows, activeCrafts)
  local witnessOnly = witnessReservations(activeCrafts)
  local availableSlots = math.max(0, cpuCount - busyCpuCount - witnessOnly - unreflected)
  local cap = tonumber(options.maxSubmitsPerCycle)
  if cap == nil then cap = MAX_AUTO_SUBMITS_PER_CYCLE end
  cap = math.floor(cap)
  if cap < 0 then cap = 0 end
  cap = math.min(MAX_AUTO_SUBMITS_PER_CYCLE, cap)
  return {
    detectedCpuCount = cpuCount,
    cpuCount = cpuCount,
    busyCpuCount = busyCpuCount,
    inFlightCount = inFlightCount,
    availableSlots = availableSlots,
    maxSubmits = math.min(availableSlots, cap)
  }
end

local function requestAmount(row)
  local amount = lineContract.requestAmount(row)
  amount = tonumber(amount) or tonumber(row.request) or 0
  if amount < 0 then amount = 0 end
  return amount
end

local function markRowInFlight(row, phase, reason, statusReason)
  if not row then return end
  row.ready = false
  row.reason = reason
  row.requestState = "running"
  row.requestPhase = phase
  row.requestStatusReason = statusReason or reason
end

local function markRowBlocked(row, phase, reason, statusReason)
  if not row then return end
  row.ready = false
  row.reason = reason
  row.requestState = "blocked"
  row.requestPhase = phase
  row.requestStatusReason = statusReason or reason
end

local function updateEntry(queue, row, activeById, activeByLabel, activeCrafts, now)
  local id = dispatch.id(row)
  local memory = queue.state[id] or { attempts = 0 }
  queue.state[id] = memory
  local amount = requestAmount(row)
  local active = activeById[id] or activeByLabel[tostring(row.label or "")]
  local entry = {
    id = id, label = row.label, rawLabel = row.rawLabel, name = row.name, damage = row.damage,
    hasTag = row.hasTag, kind = row.kind, isFluid = row.isFluid, amount = row.amount,
    craftBinding = row.craftBinding,
    current = row.current, min = row.min, stockBelow = row.min, alertBelow = row.alertBelow,
    craftTo = row.craftTo, batch = row.batch, maxRequest = row.maxRequest, lineIntent = row.lineIntent,
    lineAuthority = row.lineAuthority, lineState = row.lineState, lineReason = row.lineReason,
    maxBasis = row.maxBasis, confidence = row.confidence, requestedAmount = amount,
    armed = row.armed == true, queuedAt = memory.queuedAt, lastSubmitAt = memory.lastSubmitAt,
    lastDoneAt = memory.lastDoneAt, lastFailAt = memory.lastFailAt,
    attempts = tonumber(memory.attempts) or 0, nextEligibleAt = tonumber(memory.nextEligibleAt) or now,
    row = row
  }
  if active then
    entry.status, entry.phase, entry.statusReason = "in_flight", active.phase, active.reason
    entry.reason = active.phase and ("AE2 job " .. tostring(active.phase)) or "AE2 job in flight"
    if active.reason then entry.reason = entry.reason .. ": " .. tostring(active.reason) end
    markRowInFlight(row, entry.phase, entry.reason, entry.statusReason)
  elseif not entry.armed then
    entry.status, entry.reason = "blocked", "target disarmed"
  else
    local activeCraft = amount > 0 and cpuWitness.find(activeCrafts, row) or nil
    if activeCraft then
      entry.status, entry.phase, entry.statusReason = "blocked", "cpu_final_output", "AE2 CPU final output matches target"
      entry.reason = "AE2 CPU final output in flight"
      if activeCraft.cpuName then entry.reason = entry.reason .. ": " .. tostring(activeCraft.cpuName) end
      markRowBlocked(row, entry.phase, entry.reason, entry.statusReason)
    elseif entry.nextEligibleAt > now then
      entry.status = "blocked"
      local remaining = tostring(math.ceil(entry.nextEligibleAt - now)) .. "s"
      if resourceBlocked(memory) then
        entry.phase = "missing_resources"
        entry.statusReason = memory.statusReason or memory.lastError or "missing resources"
        entry.reason = tostring(entry.statusReason) .. "; retry in " .. remaining
      else
        local prefix = memory.status == "failed" and "failure backoff " or "cooldown "
        entry.reason = prefix .. remaining
      end
    elseif row.ready and amount > 0 then
      entry.status = "queued"
      entry.reason = row.lineReason or ("stock " .. tostring(row.current or "?") .. " below " .. tostring(row.min or "?"))
      memory.queuedAt = memory.queuedAt or now
      entry.queuedAt = memory.queuedAt
    else
      entry.status, entry.reason = "blocked", row.reason or "not eligible"
    end
  end
  return entry
end

function dispatch.build(queue, report, options)
  options = options or {}
  local now = computer.uptime()
  local activeById, activeByLabel, activeRows = activeMaps(options.manualReservations)
  local activeCrafts = report and report.status and report.status.activeCrafts or {}
  local out = capacity(report and report.status, activeRows, activeCrafts, options)
  out.activeInFlightCount = out.inFlightCount
  out.entries, out.ready, out.queueCount, out.readyQueueCount = {}, {}, 0, 0
  for _, row in ipairs((report and report.targets) or {}) do
    local entry = updateEntry(queue, row, activeById, activeByLabel, activeCrafts, now)
    out.entries[#out.entries + 1] = entry
    if entry.status == "queued" then
      out.queueCount = out.queueCount + 1
      if #out.ready < out.maxSubmits then out.ready[#out.ready + 1] = entry end
    end
  end
  out.readyQueueCount = #out.ready
  return out
end

return dispatch
local serialization = require("serialization")
local readable = require("oc.core.config")

local config = {}

config.path = "/etc/oc/ae2-maintainer-daemon.cfg"
config.minInterval = 600
config.maxInterval = 604800
config.maxPollInterval = 3600
config.defaults = {
  enabled = false,
  interval = 600,
  pollInterval = 600,
  generation = 0,
  forcePlanningSerial = 0
}
local durationSuffixes = { s = 1, m = 60, h = 3600, d = 86400, w = config.maxInterval }

local function clampNumber(value, fallback, min, max)
  value = tonumber(value) or fallback
  value = math.floor(value)
  if value < min then value = min end
  if max and value > max then value = max end
  return value
end

local function optionalNumber(value)
  if value == nil then return nil end
  value = tonumber(value)
  if not value then return nil end
  if value < 0 then value = 0 end
  return value
end

function config.parseDuration(value)
  if type(value) == "number" then return value end
  local text = tostring(value or ""):gsub(",", ""):gsub("%s+", "")
  local suffix = text:match("([SsMmHhDdWw])$")
  if suffix then
    local base = tonumber(text:sub(1, -2))
    if not base then return nil end
    return base * durationSuffixes[suffix:lower()]
  end
  return tonumber(text)
end

local function clampDuration(value, fallback, min, max)
  value = config.parseDuration(value) or fallback
  value = math.floor(value)
  if value < min then value = min end
  if max and value > max then value = max end
  return value
end

function config.clampInterval(value, fallback)
  return clampDuration(value, fallback or config.defaults.interval, config.minInterval, config.maxInterval)
end

function config.clampPollInterval(value, fallback)
  return clampDuration(value, fallback or config.defaults.pollInterval, config.minInterval, config.maxPollInterval)
end

local function normalize(value)
  value = type(value) == "table" and value or {}
  return {
    enabled = value.enabled == true,
    interval = config.clampInterval(value.interval, config.defaults.interval),
    pollInterval = config.clampPollInterval(value.pollInterval, config.defaults.pollInterval),
    generation = clampNumber(value.generation, config.defaults.generation, 0, nil),
    forcePlanningAt = optionalNumber(value.forcePlanningAt),
    forcePlanningSerial = clampNumber(value.forcePlanningSerial, config.defaults.forcePlanningSerial, 0, nil)
  }
end

function config.normalize(value)
  return normalize(value)
end

function config.load()
  local ok, handle = pcall(io.open, config.path, "r")
  if not ok or not handle then return normalize(config.defaults) end
  local text = handle:read("*a") or ""
  handle:close()
  local decodedOk, value = pcall(serialization.unserialize, text)
  if not decodedOk then value = nil end
  return normalize(value)
end

function config.save(value)
  local out = normalize(value)
  local saved, saveReason = readable.save(config.path, out)
  if not saved then return false, saveReason end
  return true, nil, out
end

function config.setEnabled(enabled)
  local out = config.load()
  out.enabled = enabled == true
  out.generation = out.generation + 1
  return config.save(out)
end

function config.enable(expectedGeneration)
  local out = config.load()
  if expectedGeneration ~= nil and (out.enabled == true
      or tonumber(out.generation) ~= tonumber(expectedGeneration)) then
    return false, "daemon ownership changed before conditional enable", out
  end
  out.enabled = true
  out.generation = out.generation + 1
  return config.save(out)
end

function config.setInterval(interval)
  local out = config.load()
  out.interval = interval
  return config.save(out)
end

function config.adjustInterval(delta)
  local out = config.load()
  out.interval = out.interval + (tonumber(delta) or 0)
  return config.save(out)
end

function config.requestForce(now)
  local out = config.load()
  if not out.enabled then
    return false, "turn daemon on before requesting next request now", out
  end
  out.forcePlanningAt = optionalNumber(now) or 0
  out.forcePlanningSerial = out.forcePlanningSerial + 1
  return config.save(out)
end

function config.consumeForce(generation)
  local out = config.load()
  if not out.enabled or out.forcePlanningAt == nil
      or tonumber(out.generation) ~= tonumber(generation) then
    return false, nil, out
  end
  out.forcePlanningAt = nil
  local ok, err, saved = config.save(out)
  if not ok then return false, err, out end
  return true, nil, saved
end

return config
local computer = require("computer")
local event = require("event")
local budget = require("oc.ae2.budget")
local chunkAdapt = require("oc.ae2.chunk_adapt")
local maintainer = require("oc.ae2.maintainer")
local daemonConfig = require("oc.ae2.maintainer_daemon_config")
local maintainerMemory = require("oc.ae2.maintainer_memory")
local maintainerState = require("oc.ae2.maintainer_state")

local daemon = {}
local DEFAULT_TARGET_LIMIT = 8
local DEFAULT_CHUNK_DELAY = 2
local DEFAULT_SUBMIT_GAP = 10
local REQUEST_STATUS_POLL = 2

local function clampFallback(value, fallback, min, max)
  value = tonumber(value) or fallback
  value = math.floor(value)
  if value < min then value = min end
  if max and value > max then value = max end
  return value
end

local function clampInterval(value, fallback)
  if daemonConfig.clampInterval then return daemonConfig.clampInterval(value, fallback) end
  return clampFallback(value, fallback or 600, 600, 604800)
end

local function clampPollInterval(value, fallback)
  if daemonConfig.clampPollInterval then return daemonConfig.clampPollInterval(value, fallback) end
  return clampFallback(value, fallback or 600, 600, 3600)
end

local function configured(options)
  local cfg = daemonConfig.load()
  options = options or {}
  if options.generation ~= nil then
    local expected = tonumber(options.generation)
    if cfg.enabled ~= true or expected == nil or tonumber(cfg.generation) ~= expected then
      return nil, "daemon generation revoked before worker start"
    end
    return cfg
  end
  if options.interval then cfg.interval = clampInterval(options.interval, cfg.interval) end
  if options.pollInterval then cfg.pollInterval = clampPollInterval(options.pollInterval, cfg.pollInterval) end
  if options.enabled ~= false then
    cfg.enabled = true
    cfg.generation = (tonumber(cfg.generation) or 0) + 1
  end
  daemonConfig.save(cfg)
  return daemonConfig.load()
end

local function planningState(options)
  options = options or {}
  local targetLimit = math.max(1, math.floor(tonumber(options.targetLimit) or DEFAULT_TARGET_LIMIT))
  local maxSubmitsPerCycle = tonumber(options.maxSubmitsPerCycle)
  if maxSubmitsPerCycle ~= nil then maxSubmitsPerCycle = math.max(0, math.floor(maxSubmitsPerCycle)) end
  return {
    targetLimit = targetLimit,
    baseTargetLimit = targetLimit,
    chunkDelay = math.max(0.1, tonumber(options.chunkDelay) or DEFAULT_CHUNK_DELAY),
    submitGap = math.max(0.1, tonumber(options.submitGap) or DEFAULT_SUBMIT_GAP),
    maxSubmitsPerCycle = maxSubmitsPerCycle,
    generation = tonumber(options.generation),
    dispatchContinuation = false,
    warming = false
  }
end

local function hasActiveRequests(report)
  local dispatch = type(report) == "table" and report.dispatch or {}
  if (tonumber(dispatch.inFlightCount) or 0) > 0 then return true end
  for _, entry in ipairs(dispatch.entries or {}) do
    if entry.status == "in_flight" then return true end
  end
  for _, attempt in ipairs((type(report) == "table" and report.requestAttempts) or {}) do
    if (attempt.state == "running" and (attempt.ok or attempt.started or attempt.pending)) or attempt.pendingResult then return true end
  end
  return false
end

local function hasPendingAcks(report)
  return type(report) == "table" and type(report.requestAcks) == "table" and #report.requestAcks > 0
end

local function idleReport()
  return {
    message = "idle heartbeat; no in-flight requests",
    dispatch = {
      entries = {},
      queueCount = 0,
      inFlightCount = 0,
      availableSlots = 0,
      maxSubmits = 0,
      pollOnly = true,
      idle = true
    },
    targets = {}
  }
end

local function budgetReport(info)
  return {
    message = "AE2 budget cooling down; planning deferred",
    status = { mode = "armed", complete = false },
    dispatch = {
      entries = {},
      queueCount = 0,
      inFlightCount = 0,
      availableSlots = 0,
      maxSubmits = 0,
      budgetHeld = true,
      nextBudgetIn = info and info.wait
    },
    targets = {}
  }
end

local function hasSubmitAttempt(report)
  for _, attempt in ipairs((type(report) == "table" and report.requestAttempts) or {}) do
    if attempt.ok or attempt.started or attempt.pending or attempt.done
      or attempt.state == "blocked" or attempt.state == "failed" then return true end
  end
  local attempt = type(report) == "table" and report.requestAttempt
  return attempt and (attempt.ok == true or attempt.started or attempt.pending or attempt.done
    or attempt.state == "blocked" or attempt.state == "failed")
end

local function shouldContinueDispatch(report)
  local dispatch = type(report) == "table" and report.dispatch or {}
  local queued = tonumber(dispatch.queueCount) or 0
  local ready = tonumber(dispatch.readyQueueCount) or 0
  local slots = tonumber(dispatch.availableSlots) or 0
  return hasSubmitAttempt(report) and queued > ready and slots > ready
end

local function nextEligibleCycle(report, now, interval)
  local dispatch = type(report) == "table" and report.dispatch or {}
  local best = nil
  for _, entry in ipairs(dispatch.entries or {}) do
    local eligibleAt = tonumber(entry.nextEligibleAt)
    if entry.status == "blocked" and eligibleAt and eligibleAt > now and eligibleAt < now + interval then
      best = best and math.min(best, eligibleAt) or eligibleAt
    end
  end
  return best
end

local function runTick(nextCycle, interval, plan)
  local now = computer.uptime()
  local planning = now >= nextCycle
  if planning then
    local kind = plan.warming and "warm_continuation" or "daemon_dispatch"
    local budgetOk, budgetInfo = budget.trySpend(kind, { now = now })
    if not budgetOk then
      nextCycle = now + math.max(0.1, tonumber(budgetInfo.wait) or 1)
      maintainerState.recordTick(budgetReport(budgetInfo), interval, true, nil, nextCycle, plan.generation)
      return nextCycle, plan
    end
  end
  local cursorBefore = plan.cache and plan.cache.targetCursor or 1
  local targetLimit = planning and chunkAdapt.limit(plan, "Daemon", {
    base = plan.baseTargetLimit,
    reset = not plan.warming and not plan.dispatchContinuation
  }) or plan.targetLimit
  local runOptions = planning and {
    skipObserveSnapshot = true,
    targetLimit = targetLimit,
    cache = plan.cache,
    restart = not plan.warming and not plan.dispatchContinuation,
    maxSubmitsPerCycle = plan.maxSubmitsPerCycle,
    daemonGeneration = plan.generation,
    requireFinalOutputWitness = true
  } or nil
  local ok, report
  local startedAt = computer.uptime()
  if planning then ok, report = pcall(maintainer.run, runOptions)
  elseif plan.pollActive then ok, report = pcall(maintainer.poll)
  else ok, report = true, idleReport() end
  local err = ok and nil or report
  if planning then
    if ok and type(report) == "table" then plan.cache = report.cache or plan.cache end
    local warming = ok and type(report) == "table" and report.status
      and report.status.complete == false and report.cache
    plan.warming = warming and true or false
    if ok then maintainerMemory.remember(report) end
    local continueDispatch = ok and not warming and shouldContinueDispatch(report)
    local status = chunkAdapt.record(plan, "Daemon", {
      base = plan.baseTargetLimit,
      targetLimit = targetLimit,
      duration = math.max(0, computer.uptime() - startedAt),
      ok = ok,
      timeout = not ok,
      complete = ok and type(report) == "table" and report.status and report.status.complete == true,
      cursorBefore = cursorBefore,
      cursorAfter = plan.cache and plan.cache.targetCursor
    })
    plan.targetLimit = status.nextLimit
    plan.dispatchContinuation = continueDispatch == true
    local after = computer.uptime()
    local eligible = ok and not warming and not continueDispatch and nextEligibleCycle(report, after, interval)
    nextCycle = warming and (after + plan.chunkDelay) or continueDispatch and (after + plan.submitGap)
      or eligible or (after + interval)
  end
  local recorded = maintainerState.recordTick(report, interval, ok, err, nextCycle, plan.generation)
  -- A rejected durable write retains terminal tracker rows, so keep the short
  -- poll cadence until the same lifecycle result is safely persisted + acked.
  plan.pollActive = ok and (hasActiveRequests(report) or (recorded ~= true and hasPendingAcks(report)))
  if recorded and ok and type(maintainer.acknowledge) == "function" then maintainer.acknowledge(report) end
  return nextCycle, plan
end

function daemon.run(options)
  options = options or {}
  local cfg, configReason = configured(options)
  if not cfg then return false, configReason end
  local interval = cfg.interval
  local generation = cfg.generation
  local firstDelay = options.deferFirstTick and math.max(0.1, tonumber(options.deferSeconds) or 1) or 0
  local nextCycle = computer.uptime() + firstDelay
  local plan = planningState(options)
  plan.generation = generation
  local ran, runError = pcall(function()
    maintainerState.recordStart(interval, nextCycle, generation)
    while cfg.enabled and cfg.generation == generation do
      cfg = daemonConfig.load()
      interval = cfg.interval
      if not cfg.enabled or cfg.generation ~= generation then break end
      local forced, _, forcedCfg = daemonConfig.consumeForce(generation)
      if forced then
        cfg = forcedCfg or cfg
        interval = cfg.interval
        nextCycle = 0
      end
      nextCycle, plan = runTick(nextCycle, interval, plan)
      local wait = math.min(cfg.pollInterval, math.max(0.1, nextCycle - computer.uptime()))
      if plan.pollActive then wait = math.min(wait, REQUEST_STATUS_POLL) end
      local _, timerCommand = event.pull(wait, "oc_ae2_daemon_timer")
      if timerCommand == "force" then nextCycle = 0 end
    end
  end)
  local finalOk, finalConfig = pcall(daemonConfig.load)
  local stopReason = not ran and "worker_error" or not finalOk and "config_error"
    or finalConfig.enabled ~= true and "desired_off"
    or tonumber(finalConfig.generation) ~= tonumber(generation) and "generation_replaced" or "worker_exit"
  pcall(maintainerState.recordStop, generation, stopReason)
  if not ran then return false, tostring(runError) end
  if not finalOk then return false, tostring(finalConfig) end
  return true
end

return daemon
local computer = require("computer")
local state = require("oc.ae2.maintainer_state")

local memory = { report = nil }

function memory.remember(report)
  if type(report) == "table" and report.status and report.status.complete == true then
    -- Never retain AE2 component proxies, Craftable handles, or chunk caches
    -- in the dashboard handoff. Durable state and live memory use the same
    -- compact operator report shape.
    memory.report = state.compactWarmReport(report, report.savedAt or computer.uptime())
  elseif type(report) == "table" and report.status and report.status.complete == false then
    memory.report = nil
  end
  return memory.report
end

function memory.latest()
  return memory.report
end

return memory
local computer = require("computer")
local daemonConfig = require("oc.ae2.maintainer_daemon_config")
local maintainerMemory = require("oc.ae2.maintainer_memory")
local maintainerState = require("oc.ae2.maintainer_state")

local control = {}
local launchingAt = nil
local launchingUntil = nil
local LAUNCH_GRACE = 5
local MAX_FUTURE_SKEW = 5

local function launchGraceActive(now)
  return launchingAt ~= nil and now < (launchingUntil or (launchingAt + LAUNCH_GRACE))
end

local function deferSeconds(cfg, options)
  options = options or {}
  local value = options.deferSeconds
  if options.deferFirstTick == true and value == nil then value = cfg.interval end
  return math.max(0, tonumber(value) or 0)
end

local function heartbeatFresh(cfg, heartbeat)
  if not (heartbeat and heartbeat.fresh == true) then return false end
  if cfg and cfg.enabled == true then
    return tonumber(heartbeat.generation) ~= nil and tonumber(heartbeat.generation) == tonumber(cfg.generation)
  end
  return true
end

local function reportSignature(report)
  return report and (report.signature or (report.cache and report.cache.signature))
end

local function reportTargetSignature(report)
  return report and (report.targetSignature or (report.cache and report.cache.targetSignature))
end

local function reportStamp(report)
  return tonumber(report and (report.savedAt or report.manualPatchAt
    or (report.cache and report.cache.savedAt)))
end

local function plausibleReportTime(report, now)
  local stamp = reportStamp(report)
  if stamp == nil then return true end
  return stamp == stamp and stamp >= 0 and stamp < math.huge and stamp <= now + MAX_FUTURE_SKEW
end

local function warmReport(heartbeat)
  local disk = heartbeat and heartbeat.warmReport or nil
  local live = maintainerMemory.latest()
  local now = computer.uptime()
  if disk and not plausibleReportTime(disk, now) then disk = nil end
  if live and not plausibleReportTime(live, now) then live = nil end
  if not live then return disk end
  if not disk then return live end
  local diskSignature, liveSignature = reportSignature(disk), reportSignature(live)
  local diskTargets, liveTargets = reportTargetSignature(disk), reportTargetSignature(live)
  if diskSignature and diskSignature ~= liveSignature then return disk end
  if diskTargets and diskTargets ~= liveTargets then return disk end
  local diskAt, liveAt = reportStamp(disk), reportStamp(live)
  if diskAt and (not liveAt or diskAt >= liveAt) then return disk end
  return live
end

local function wakeDaemon(command)
  local ok, event = pcall(require, "event")
  if not (ok and event and event.push) then return end
  if command ~= nil then pcall(event.push, "oc_ae2_daemon_timer", command)
  else pcall(event.push, "oc_ae2_daemon_timer") end
end

local function mergeStatus(cfg, heartbeat)
  heartbeat = heartbeat or {}
  cfg = cfg or daemonConfig.load()
  if cfg.enabled == true and heartbeat.fresh == true and not heartbeatFresh(cfg, heartbeat) then
    heartbeat.generationMismatch = true
    heartbeat.fresh = false
  end
  heartbeat.desiredEnabled = cfg.enabled == true
  heartbeat.configInterval = cfg.interval
  heartbeat.configPollInterval = cfg.pollInterval
  heartbeat.configGeneration = tonumber(cfg.generation)
  heartbeat.running = heartbeat.desiredEnabled and heartbeat.fresh == true
  heartbeat.starting = heartbeat.desiredEnabled and launchingAt ~= nil and not heartbeat.fresh
  if heartbeat.starting then
    local remaining = math.max(0, (launchingUntil or computer.uptime()) - computer.uptime())
    heartbeat.startupUntil = launchingUntil
    heartbeat.startupRemaining = remaining
  else
    heartbeat.startupUntil = nil
    heartbeat.startupRemaining = nil
  end
  heartbeat.warmReport = warmReport(heartbeat)
  return heartbeat
end

local function spawn(cfg, options)
  options = options or {}
  local deferred = deferSeconds(cfg, options)
  local ok, thread = pcall(require, "thread")
  if not ok or not thread or not thread.create then
    return false, "thread library unavailable; run ae2-maintainer --daemon " .. tostring(cfg.interval)
  end
  local daemon = require("oc.ae2.maintainer_daemon")
  local createdOk, handle = pcall(thread.create, function()
    daemon.run({
      interval = cfg.interval,
      pollInterval = cfg.pollInterval,
      generation = cfg.generation,
      deferFirstTick = options.deferFirstTick == true,
      deferSeconds = deferred
    })
  end)
  if not createdOk or not handle then return false, tostring(handle or "thread create failed") end
  if handle.detach then handle:detach() end
  return true
end

local function startThread(cfg, heartbeat, disableOnFail, options)
  local now = computer.uptime()
  if launchGraceActive(now) then
    return true, nil, mergeStatus(cfg, heartbeat)
  end
  launchingAt = now
  -- Foreground pages intentionally defer the first expensive warm pass. Treat
  -- that requested defer window as healthy startup time; otherwise every page
  -- refresh replaces the sleeping worker and creates a daemon launch storm.
  launchingUntil = now + math.max(LAUNCH_GRACE, deferSeconds(cfg, options) + LAUNCH_GRACE)
  local spawned, spawnErr = spawn(cfg, options)
  if not spawned then
    if disableOnFail then
      launchingAt, launchingUntil = nil, nil
      daemonConfig.setEnabled(false)
    end
    return false, spawnErr, mergeStatus(cfg, heartbeat)
  end
  return true, nil, mergeStatus(cfg, heartbeat)
end

function control.status()
  return mergeStatus(daemonConfig.load(), maintainerState.status())
end

function control.ensureRunning(options)
  local cfg = daemonConfig.load()
  local heartbeat = maintainerState.status()
  if not cfg.enabled then return true, nil, mergeStatus(cfg, heartbeat) end
  if heartbeatFresh(cfg, heartbeat) then
    launchingAt, launchingUntil = nil, nil
    return true, nil, mergeStatus(cfg, heartbeat)
  end
  local now = computer.uptime()
  if launchGraceActive(now) then
    return true, nil, mergeStatus(cfg, heartbeat)
  end
  local ok, err, nextCfg = daemonConfig.enable()
  if not ok then return false, err, mergeStatus(cfg, heartbeat) end
  wakeDaemon()
  return startThread(nextCfg, heartbeat, false, options)
end

function control.start(options)
  options = options or {}
  local before = daemonConfig.load()
  local heartbeat = maintainerState.status()
  if options.expectedGeneration ~= nil and (before.enabled == true
      or tonumber(before.generation) ~= tonumber(options.expectedGeneration)) then
    return false, "daemon ownership changed before conditional restore", mergeStatus(before, heartbeat)
  end
  if before.enabled and heartbeatFresh(before, heartbeat) then
    launchingAt, launchingUntil = nil, nil
    return true, nil, mergeStatus(before, heartbeat)
  end
  local now = computer.uptime()
  if launchGraceActive(now) then
    return true, nil, mergeStatus(before, heartbeat)
  end
  local ok, err, cfg = daemonConfig.enable(options.expectedGeneration)
  if not ok then
    launchingAt, launchingUntil = nil, nil
    return false, err, mergeStatus(daemonConfig.load(), heartbeat)
  end
  if before.enabled then wakeDaemon() end
  return startThread(cfg, heartbeat, true, options)
end

function control.stop()
  launchingAt, launchingUntil = nil, nil
  local ok, err, cfg = daemonConfig.setEnabled(false)
  if not ok then return false, err end
  wakeDaemon()
  return true, nil, mergeStatus(cfg, maintainerState.status())
end

function control.toggle()
  local cfg = daemonConfig.load()
  if cfg.enabled then return control.stop() end
  return control.start()
end

function control.nextBatchNow()
  local cfg = daemonConfig.load()
  local heartbeat = maintainerState.status()
  if not cfg.enabled then
    return false, "turn daemon on before requesting next request now", mergeStatus(cfg, heartbeat)
  end
  local forceOk, forceErr, forcedCfg = daemonConfig.requestForce(computer.uptime())
  if not forceOk then
    return false, forceErr, mergeStatus(forcedCfg or cfg, heartbeat)
  end
  cfg = forcedCfg or cfg
  if heartbeatFresh(cfg, heartbeat) then
    wakeDaemon("force")
    local status = mergeStatus(cfg, heartbeat)
    status.nextIn = 0
    status.forceRequested = true
    return true, nil, status
  end
  local starting = launchGraceActive(computer.uptime())
  local ok, err, status = control.ensureRunning({ deferFirstTick = false })
  if ok and status then
    if starting then wakeDaemon("force") end
    status.nextIn = 0
    status.forceRequested = true
  end
  return ok, err, status
end

function control.adjustInterval(delta)
  local cfg = daemonConfig.load()
  return control.setInterval((tonumber(cfg.interval) or 600) + (tonumber(delta) or 0))
end

function control.setInterval(interval)
  local cfg = daemonConfig.load()
  local heartbeat = maintainerState.status()
  if cfg.enabled then
    return false, "turn daemon off before changing interval", mergeStatus(cfg, heartbeat)
  end
  local ok, err, saved = daemonConfig.setInterval(interval)
  if not ok then return false, err, mergeStatus(cfg, heartbeat) end
  return true, nil, mergeStatus(saved, heartbeat)
end

return control
local computer = require("computer")
local stateIdentity = require("oc.ae2.maintainer_state_identity")
local stateReport = require("oc.ae2.maintainer_state_report")
local stateStore = require("oc.ae2.maintainer_state_store")

local state = {}

state.path = "/var/oc/ae2-maintainer.state"
state.manualPath = "/var/oc/ae2-maintainer-manual.state"
state.staleAfter = 90

local function readState() return stateStore.read(state.path) end
local function writeState(value) return stateStore.write(state.path, value) end

function state.recordStart(interval, nextCycleAt, generation)
  local now = computer.uptime()
  local previous = readState()
  local nextGeneration = tonumber(generation)
  local previousGeneration = tonumber(previous.generation)
  if previousGeneration and nextGeneration and previousGeneration > nextGeneration then return true end
  if previousGeneration == nextGeneration and previous.workerState == "stopped"
      and tonumber(previous.stoppedGeneration) == nextGeneration then return true end
  return writeState({
    startedAt = now,
    lastTick = now,
    nextCycleAt = tonumber(nextCycleAt) or now,
    tickCount = 0,
    generation = nextGeneration,
    workerState = "running",
    stoppedGeneration = previous.stoppedGeneration,
    stoppedAt = previous.stoppedAt,
    stopReason = previous.stopReason,
    daemonInterval = tonumber(interval) or 30,
    lastStatus = "daemon started",
    targetStatus = previous.targetStatus,
    warmReport = stateIdentity.scrubStartupWarmReport(previous.warmReport)
  })
end

function state.compactWarmReport(report, now)
  return stateReport.compactWarmReport(report, now)
end

function state.patchTargets(targets, now, policy)
  local out = readState()
  local report = type(out.warmReport) == "table" and out.warmReport or nil
  if not report then return writeState(out) end
  targets = targets or {}
  local existing, used, nextRows = report.targets or {}, {}, {}
  local patchedRows = {}
  for _, target in ipairs(targets or {}) do
    local row = stateIdentity.findWarmRow(existing, target, used) or stateIdentity.placeholderTarget(target)
    stateIdentity.patchPolicy(row, target)
    stateIdentity.refreshPolicyStock(row, "waiting for daemon refresh")
    nextRows[#nextRows + 1] = row
    patchedRows[stateIdentity.targetKey(target)] = row
    patchedRows[stateIdentity.queueId(target)] = row
  end
  report.targets = nextRows
  report.targetSignature = stateIdentity.targetSignature(targets)
  report.signature = stateIdentity.configSignature(targets)
  report.policySignature = stateIdentity.configSignature(targets)
  if type(report.status) == "table" then
    if type(policy) == "table" and policy.autoEnabled ~= nil then
      report.status.autoEnabled = policy.autoEnabled ~= false
    end
    report.status.targetCount = #targets
    report.status.armedTargets = stateIdentity.armedCount(targets)
    report.status.mode = report.status.autoEnabled ~= false and report.status.armedTargets > 0 and "armed" or "observe"
  end
  local keptStatus = {}
  for _, row in ipairs(out.targetStatus or {}) do
    local target = stateIdentity.matchingTarget(targets, row)
    if target then
      keptStatus[#keptStatus + 1] = row
    end
  end
  out.targetStatus = keptStatus
  for _, target in ipairs(targets or {}) do
    local amount = stateIdentity.requestAmount(target)
    for _, row in ipairs(out.targetStatus or {}) do
      if stateIdentity.sameTarget(row, target) then
        if amount > 0 then row.amount = amount end
        local warmRow = patchedRows[stateIdentity.targetKey(target)] or patchedRows[stateIdentity.queueId(target)]
        if row.status == "queued" and warmRow and warmRow.min ~= nil then
          row.reason = "stock " .. tostring(warmRow.current or "?") .. " below " .. tostring(warmRow.min)
        end
      end
    end
  end
  report.savedAt = tonumber(now) or computer.uptime()
  return writeState(out)
end

local function lifecycle(requestReport, source, assumeSubmitted)
  requestReport = type(requestReport) == "table" and requestReport or {}
  local requestState = requestReport.requestState or (assumeSubmitted and "running" or "accepted")
  local requestPhase = requestReport.requestPhase or (assumeSubmitted and "submitted" or nil)
  local reason = requestReport.requestStatusReason
  local prefix = source == "auto" and "auto" or "manual"
  if requestState == "running" and requestPhase == "computing" then
    return requestState, requestPhase, reason, prefix .. " request planning; no CPU assigned yet", false, false
  elseif requestState == "running" and requestPhase == "submitted" then
    return requestState, requestPhase, reason, prefix .. " request accepted by AE2; CPU witness pending", true, false
  elseif requestState == "done" then
    return requestState, requestPhase or "done", reason, prefix .. " request completed", false, false
  elseif requestState == "accepted" then
    return requestState, requestPhase, reason, prefix .. " request returned; confirmation unavailable", false, false
  elseif requestState == "blocked" then
    return requestState, requestPhase or "blocked", reason, prefix .. " request blocked: " .. tostring(reason or "blocked"), false, true
  elseif requestState == "canceled" then
    return requestState, requestPhase or "canceled", reason, prefix .. " request canceled", false, true
  elseif requestState == "failed" then
    return requestState, requestPhase or "failed", reason, prefix .. " request failed: " .. tostring(reason or "unknown"), false, true
  end
  return requestState, requestPhase, reason, prefix .. " request state " .. tostring(requestState), false, false
end

local function recordManualReservation(row, now, requestState, requestPhase, requestReason)
  local workflow = type(row and row.workflow) == "table" and row.workflow or {}
  return stateStore.recordManual(state.manualPath, {
    id = stateIdentity.queueId(row), label = row and row.label, rawLabel = row and row.rawLabel,
    name = row and row.name, damage = row and row.damage, hasTag = row and row.hasTag == true,
    kind = row and row.kind, isFluid = row and row.isFluid == true,
    craftBinding = row and row.craftBinding, amount = stateIdentity.requestAmount(row),
    cooldown = tonumber(row and row.cooldown or workflow.cooldown) or 600,
    state = requestState, phase = requestPhase, reason = requestReason
  }, now)
end

local function recordRequest(row, now, requestReport, source, clearTargetStatus, assumeSubmitted)
  now = tonumber(now) or computer.uptime()
  source = source == "auto" and "auto" or "manual"
  local out = readState()
  local report = type(out.warmReport) == "table" and out.warmReport or nil
  requestReport = type(requestReport) == "table" and requestReport or {}
  local requestState, requestPhase, requestReason, statusText, confirmed, failed =
    lifecycle(requestReport, source, assumeSubmitted)
  if source == "manual" then
    local reserved, reserveReason = recordManualReservation(row, now, requestState, requestPhase, requestReason)
    if reserved ~= true then return false, reserveReason or "manual reservation save failed" end
  end
  if report then
    for _, target in ipairs(report.targets or {}) do
      if stateIdentity.sameTarget(target, row) then
        stateIdentity.patchPolicy(target, row)
        target.request = stateIdentity.requestAmount(row)
        target.requestState = requestState
        target.requestPhase = requestPhase
        target.requestStatusReason = requestReason
        target.requestError = failed and (requestReason or statusText) or nil
        target.error = nil
        target.requested = requestState == "running" or requestState == "accepted"
        target.ready = false
        target.reason = statusText
      end
    end
    report.savedAt = now
  end
  if clearTargetStatus and confirmed then stateIdentity.removeTargetStatus(out, row) end
  out.lastSubmitAttempt = now
  out.lastSubmitTarget = tostring(row and (row.label or row.rawLabel or row.name) or "target")
  out.lastSubmitAmount = stateIdentity.requestAmount(row)
  out.lastSubmitPhase = requestPhase or source
  out.lastSubmitReason = requestReason
  if confirmed then
    out.lastSubmitOk, out.lastError = now, nil
  elseif failed then
    out.lastSubmitFail, out.lastError = now, tostring(requestReason or statusText)
  end
  out.lastStatus = statusText
  return writeState(out)
end

function state.recordManualBatch(row, now, requestReport)
  return recordRequest(row, now, requestReport, "manual", true, true)
end

function state.recordAutoBatch(row, now, requestReport)
  return recordRequest(row, now, requestReport, "auto", false, true)
end

function state.recordAutoStatus(row, now, requestReport)
  return recordRequest(row, now, requestReport, "auto", false, false)
end

function state.recordManualStatus(row, now, requestReport)
  return recordRequest(row, now, requestReport, "manual", false, false)
end

function state.recordTick(report, interval, ok, err, nextCycleAt, generation)
  local now = computer.uptime()
  local out = readState()
  local ownerGeneration, recordedGeneration = tonumber(generation), tonumber(out.generation)
  if recordedGeneration and ownerGeneration and recordedGeneration ~= ownerGeneration then
    return false, "stale daemon generation"
  end
  if out.workerState == "stopped" and tonumber(out.stoppedGeneration) == ownerGeneration then
    return false, "daemon generation already stopped"
  end
  return writeState(stateReport.recordTick(out, report, interval, ok, err, nextCycleAt, generation, now))
end

function state.recordStop(generation, reason)
  local out, now = readState(), computer.uptime()
  local ownerGeneration = tonumber(generation)
  if tonumber(out.generation) ~= ownerGeneration then return true end
  if out.workerState == "stopped" and tonumber(out.stoppedGeneration) == ownerGeneration then return true end
  out.workerState = "stopped"
  out.stoppedGeneration = ownerGeneration
  out.stoppedAt = now
  out.stopReason = tostring(reason or "worker_exit")
  out.nextCycleAt = nil
  out.lastStatus = "daemon stopped: " .. out.stopReason
  return writeState(out)
end

function state.load()
  return readState()
end

function state.status(now)
  local out = readState()
  now = tonumber(now) or computer.uptime()
  if (tonumber(out.tickCount) or 0) == 0 or stateIdentity.startupCarriedWarmReport(out) then
    stateIdentity.scrubStartupWarmReport(out.warmReport)
  end
  if type(out.lastTick) == "number" then
    out.age = now - out.lastTick
    local limit = math.max(state.staleAfter, ((tonumber(out.daemonInterval) or 30) * 2) + 5)
    out.fresh = out.age >= 0 and out.age <= limit
  else
    out.fresh = false
  end
  if out.workerState == "stopped" then out.fresh = false end
  if type(out.nextCycleAt) == "number" then
    out.nextIn = out.nextCycleAt - now
  end
  return out
end

return state
-- Minimal persistence boundary for the maintainer heartbeat state.  Keeping
-- filesystem work here makes the public state API a small, paste-safe facade.
local filesystem = require("filesystem")
local serialization = require("serialization")

local store = {}
local MANUAL_ACTIVE_LEASE = 90
local MANUAL_FAILURE_BACKOFF = 600
local MAX_MANUAL_RESERVATIONS = 64

local function ensureParent(path)
  local parent = filesystem.path(path)
  if parent and parent ~= "" and not filesystem.exists(parent) then filesystem.makeDirectory(parent) end
end

function store.read(path)
  local handle = io.open(path, "r")
  if not handle then return { path = path } end
  local text = handle:read("*a") or ""
  handle:close()
  local ok, value = pcall(serialization.unserialize, text)
  if ok and type(value) == "table" then value.path = path; return value end
  return { path = path, lastError = "state decode failed" }
end

function store.write(path, value)
  value = value or {}
  value.path = path
  ensureParent(path)
  local handle, err = io.open(path, "w")
  if not handle then return false, err or ("could not write " .. path) end
  handle:write(serialization.serialize(value))
  handle:close()
  return true, nil, value
end

local function future(value, now)
  value = tonumber(value)
  return value and value > now and value or nil
end

local function manualCooldown(value)
  value = math.floor(tonumber(value) or 600)
  if value < 600 then value = 600 end
  if value > 604800 then value = 604800 end
  return value
end

function store.recordManual(path, row, now)
  row, now = type(row) == "table" and row or {}, tonumber(now) or 0
  local out = store.read(path)
  if tonumber(out.updatedAt) and tonumber(out.updatedAt) > now then
    out = { path = path, generation = tonumber(out.generation) or 0 }
  end
  out.reservations = type(out.reservations) == "table" and out.reservations or {}
  local id = tostring(row.id or "")
  if id == "" then return false, "manual reservation requires an exact target id" end
  local previous = type(out.reservations[id]) == "table" and out.reservations[id] or {}
  local generation = (tonumber(out.generation) or 0) + 1
  local state, phase = tostring(row.state or "none"), row.phase and tostring(row.phase) or nil
  local cooldownUntil = future(previous.cooldownUntil, now)
  local retryUntil = future(previous.retryUntil, now)
  if state == "running" and phase == "submitted" then
    local alreadySubmitted = previous.state == "running" and previous.phase == "submitted"
    if not alreadySubmitted then
      cooldownUntil = math.max(cooldownUntil or 0, now + manualCooldown(row.cooldown))
    end
    retryUntil = nil
  elseif state == "done" and not cooldownUntil then
    cooldownUntil = now + manualCooldown(row.cooldown)
    retryUntil = nil
  elseif state == "done" then
    retryUntil = nil
  elseif state == "accepted" or state == "blocked" or state == "failed" or state == "canceled" then
    retryUntil = math.max(retryUntil or 0, now + MANUAL_FAILURE_BACKOFF)
  end
  local saved = {}
  for key, value in pairs(row) do saved[key] = value end
  saved.id, saved.state, saved.phase = id, state, phase
  saved.generation, saved.updatedAt = generation, now
  saved.leaseUntil = state == "running" and (now + MANUAL_ACTIVE_LEASE) or now
  saved.cooldownUntil, saved.retryUntil = cooldownUntil, retryUntil
  for key, value in pairs(out.reservations) do
    if key ~= id and not (future(value.leaseUntil, now) or future(value.cooldownUntil, now)
        or future(value.retryUntil, now)) then out.reservations[key] = nil end
  end
  out.schemaVersion, out.generation, out.updatedAt = 1, generation, now
  out.reservations[id] = saved
  local newest = {}
  for key, value in pairs(out.reservations) do
    newest[#newest + 1] = { id = key, generation = tonumber(value.generation) or 0 }
  end
  table.sort(newest, function(a, b)
    if a.generation == b.generation then return a.id < b.id end
    return a.generation > b.generation
  end)
  for index = MAX_MANUAL_RESERVATIONS + 1, #newest do out.reservations[newest[index].id] = nil end
  return store.write(path, out)
end

return store
-- Target identity and warm-report policy patching stay pure: no persistence or
-- AE2 component calls are allowed in this module.
local lineContract = require("oc.ae2.line_contract")

local identity = {}

local function boolText(value) return tostring(value == true) end

local function kindFor(target)
  if not target then return "item" end
  if target.isFluid == true or target.kind == "fluid" then return "fluid" end
  local label = tostring(target.rawLabel or target.label or "")
  if label:find("^[Dd]rops? of%s+") then return "fluid" end
  return target.kind or "item"
end

local function variantLabel(target)
  target = target or {}
  return tostring(target.rawLabel or target.label or target.name or "target"):lower()
end

local function labelKey(target)
  return tostring(target and (target.label or target.rawLabel or target.name) or ""):lower()
end

function identity.targetKey(target)
  target = target or {}
  if target.name then
    return tostring(kindFor(target)) .. ":" .. tostring(target.name) .. ":"
      .. tostring(target.damage or "") .. ":" .. boolText(target.hasTag) .. ":" .. variantLabel(target)
  end
  return tostring(target.label or target.rawLabel or "target"):lower()
end

function identity.queueId(target)
  target = target or {}
  if target.name then
    return tostring(kindFor(target)) .. ":" .. tostring(target.name) .. ":"
      .. tostring(math.floor(tonumber(target.damage) or 0)) .. ":" .. boolText(target.hasTag) .. ":" .. variantLabel(target)
  end
  return tostring(target.label or target.rawLabel or "target"):lower()
end

local function keySet(target)
  local keys = {}
  local function add(key) key = tostring(key or ""); if key ~= "" then keys[key] = true end end
  add(target and target.targetKey)
  add(target and target.id)
  add(identity.targetKey(target))
  add(identity.queueId(target))
  return keys
end

function identity.sameTarget(left, right)
  if not (left and right) then return false end
  if left.name and right.name then
    return tostring(kindFor(left)) == tostring(kindFor(right))
      and tostring(left.name) == tostring(right.name)
      and tostring(left.damage or "") == tostring(right.damage or "")
      and boolText(left.hasTag) == boolText(right.hasTag)
      and variantLabel(left) == variantLabel(right)
  end
  local wanted = keySet(left)
  for key in pairs(keySet(right)) do if wanted[key] then return true end end
  return not (left.name and right.name) and labelKey(left) ~= "" and labelKey(left) == labelKey(right)
end

function identity.workflowValue(target, field)
  local workflow = type(target and target.workflow) == "table" and target.workflow or {}
  if target and target[field] ~= nil then return target[field] end
  if field == "min" then return workflow.min or workflow.minStock end
  if field == "alertBelow" then return workflow.alertBelow or workflow.minStock or workflow.min end
  if field == "maxRequest" then return workflow.maxRequest or workflow.batch end
  return workflow[field]
end

function identity.targetSignature(targets)
  local parts = {}
  for index, target in ipairs(targets or {}) do parts[index] = identity.targetKey(target) end
  return table.concat(parts, "|")
end

function identity.configSignature(targets)
  local parts = {}
  for index, target in ipairs(targets or {}) do
    parts[index] = table.concat({
      identity.targetKey(target), tostring(identity.workflowValue(target, "lineIntent") or ""),
      tostring(identity.workflowValue(target, "lineAuthority") or ""), tostring(identity.workflowValue(target, "alertEnabled")),
      tostring(identity.workflowValue(target, "alertBelow") or identity.workflowValue(target, "min") or ""),
      tostring(identity.workflowValue(target, "maxRequest") or identity.workflowValue(target, "batch") or ""),
      tostring(identity.workflowValue(target, "maxBasis") or ""),
      tostring(identity.workflowValue(target, "confidence") or ""),
      tostring(identity.workflowValue(target, "recipeMax") or ""),
      boolText(identity.workflowValue(target, "dangerUnlocked")),
      boolText(identity.workflowValue(target, "locked")),
      tostring(identity.workflowValue(target, "min") or ""),
      tostring(identity.workflowValue(target, "craftTo") or identity.workflowValue(target, "min") or ""),
      tostring(identity.workflowValue(target, "batch") or ""), tostring(identity.workflowValue(target, "minBatteryRatio") or ""),
      tostring(identity.workflowValue(target, "maxDeficitRatio") or ""), tostring(identity.workflowValue(target, "requireReadyCpu")),
      tostring(identity.workflowValue(target, "cooldown") or ""), boolText(identity.workflowValue(target, "armed"))
    }, ":")
  end
  return table.concat(parts, "|")
end

function identity.armedCount(targets)
  local count = 0
  for _, target in ipairs(targets or {}) do if identity.workflowValue(target, "armed") == true then count = count + 1 end end
  return count
end

local policyFields = {
  "label", "rawLabel", "name", "damage", "hasTag", "kind", "isFluid", "amount", "filter", "craftBinding",
  "lineIntent", "lineAuthority", "alertEnabled", "alertBelow", "maxRequest", "maxBasis", "confidence",
  "recipeMax", "dangerUnlocked", "locked", "min", "craftTo", "batch", "minBatteryRatio",
  "maxDeficitRatio", "requireReadyCpu", "cooldown", "armed"
}
local identityFields = {
  label = true, rawLabel = true, name = true, damage = true, hasTag = true, kind = true, isFluid = true,
  amount = true, filter = true, craftBinding = true
}
local replacePolicyFields = {
  maxBasis = true, confidence = true, recipeMax = true, dangerUnlocked = true, locked = true
}

function identity.patchPolicy(row, target)
  if not (row and target) then return row end
  for _, field in ipairs(policyFields) do
    local value = identity.workflowValue(target, field)
    if value ~= nil or identityFields[field] or replacePolicyFields[field] then row[field] = value end
  end
  row.label = row.label or target.label or target.rawLabel or target.name or "target"
  row.targetKey = identity.targetKey(target)
  return row
end

function identity.requestAmount(target)
  local amount = lineContract.requestAmount(target)
  return tonumber(amount) or 0
end

local function stockDerivedReason(reason)
  local text = tostring(reason or "")
  return text == "stock ready" or text == "stock refreshed; target already satisfied" or text:find("^stock%s+") ~= nil
end

function identity.refreshPolicyStock(row, waitReason)
  if not row then return row end
  local current, min = tonumber(row.current), tonumber(row.min)
  lineContract.annotate(row)
  local amount = tonumber(row.request) or identity.requestAmount(row)
  if current and min then
    amount = current >= min and 0 or amount
    if current < min and stockDerivedReason(row.reason) then
      row.ready, row.reason = false, waitReason or "waiting for daemon refresh"
      if row.requestState == "blocked" and row.requestPhase == "stock_satisfied" then
        row.requestState, row.requestPhase, row.requestStatusReason, row.requestError = "none", nil, nil, nil
      end
    elseif current >= min and stockDerivedReason(row.reason) then
      row.ready, row.reason = false, "stock ready"
    end
  end
  row.request = math.max(0, amount)
  return row
end

local function cpuFinalOutputTransient(row)
  if type(row) ~= "table" then return false end
  return row.requestPhase == "cpu_final_output" or row.phase == "cpu_final_output"
    or row.requestStatusReason == "AE2 CPU final output matches target"
    or tostring(row.reason or ""):find("^AE2 CPU final output in flight", 1, false) ~= nil
end

local function scrubCpuFinalOutputRow(row)
  if not cpuFinalOutputTransient(row) then return row end
  row.requestState, row.requestPhase, row.requestStatusReason, row.requestError, row.error = "none", nil, nil, nil, nil
  row.ready = false
  local current, min = tonumber(row.current), tonumber(row.min)
  row.reason = (current and min and current >= min) and "stock ready" or "waiting for daemon refresh"
  return identity.refreshPolicyStock(row, "waiting for daemon refresh")
end

function identity.scrubStartupWarmReport(report)
  if type(report) == "table" then for _, row in ipairs(report.targets or {}) do scrubCpuFinalOutputRow(row) end end
  return report
end

function identity.startupCarriedWarmReport(out)
  if type(out) ~= "table" or type(out.warmReport) ~= "table" then return false end
  local startedAt = tonumber(out.startedAt)
  if not startedAt then return false end
  local savedAt = tonumber(out.warmReport.savedAt)
  return savedAt == nil or savedAt < startedAt
end

function identity.scrubStartupCarriedWarmReport(out)
  if identity.startupCarriedWarmReport(out) then identity.scrubStartupWarmReport(out.warmReport) end
end

function identity.removeTargetStatus(out, target)
  local kept = {}
  for _, row in ipairs(out.targetStatus or {}) do if not identity.sameTarget(row, target) then kept[#kept + 1] = row end end
  out.targetStatus = kept
end

function identity.matchingTarget(targets, row)
  for _, target in ipairs(targets or {}) do if identity.sameTarget(row, target) then return target end end
  return nil
end

function identity.findWarmRow(rows, target, used)
  for index, row in ipairs(rows or {}) do
    if not used[index] and identity.sameTarget(row, target) then used[index] = true; return row end
  end
  return nil
end

function identity.placeholderTarget(target)
  local row = { label = target and (target.label or target.rawLabel or target.name) or "target", craftable = false,
    ready = false, requestState = "blocked", reason = "waiting for daemon refresh" }
  identity.patchPolicy(row, target)
  row.current, row.request = nil, math.max(0, identity.requestAmount(target))
  return row
end

return identity
-- Compact durable report projection.  It only transforms already-observed
-- maintainer data, so it cannot create component work while persisting state.
local identity = require("oc.ae2.maintainer_state_identity")

local reports = {}

local function firstUsefulRow(report)
  local rows = type(report) == "table" and report.targets or {}
  for _, row in ipairs(rows or {}) do
    if row.requested or row.requestState == "failed" or row.requestState == "blocked" then return row end
  end
  for _, row in ipairs(rows or {}) do if row.armed then return row end end
  return (rows or {})[1]
end

local function dispatchVisible(entry)
  local status = tostring(entry and entry.status or "")
  local amount = tonumber(entry and entry.requestedAmount) or tonumber(entry and entry.amount) or 0
  return amount > 0 and (status == "queued" or status == "in_flight" or status == "failed"
    or (status == "blocked" and entry and entry.phase == "missing_resources"))
end

local function firstVisibleDispatchEntry(report)
  local dispatch = type(report) == "table" and report.dispatch or {}
  for _, entry in ipairs((dispatch and dispatch.entries) or {}) do if dispatchVisible(entry) then return entry end end
  return nil
end

local function dispatchSummary(entry)
  if not entry then return nil end
  local status, reason = tostring(entry.status or ""), tostring(entry.reason or entry.statusReason or entry.phase or "unknown")
  if status == "in_flight" then return "in flight: " .. reason end
  if status == "queued" then return "queued: " .. reason end
  if status == "failed" then return "failed: " .. reason end
  return "blocked: " .. reason
end

local function copyTargetStatus(dispatch)
  local rows = {}
  for _, entry in ipairs((dispatch and dispatch.entries) or {}) do
    if #rows >= 24 then break end
    if dispatchVisible(entry) then
      rows[#rows + 1] = {
        id = entry.id, label = entry.label, amount = entry.requestedAmount,
        current = entry.current or (entry.row and entry.row.current),
        min = entry.min or entry.stockBelow or (entry.row and entry.row.min),
        alertBelow = entry.alertBelow or entry.stockBelow or (entry.row and entry.row.alertBelow),
        maxRequest = entry.maxRequest or (entry.row and entry.row.maxRequest),
        lineIntent = entry.lineIntent or (entry.row and entry.row.lineIntent),
        lineAuthority = entry.lineAuthority or (entry.row and entry.row.lineAuthority),
        lineState = entry.lineState or (entry.row and entry.row.lineState),
        lineReason = entry.lineReason or (entry.row and entry.row.lineReason),
        maxBasis = entry.maxBasis or (entry.row and entry.row.maxBasis), confidence = entry.confidence or (entry.row and entry.row.confidence),
        status = entry.status, reason = entry.reason, phase = entry.phase, statusReason = entry.statusReason,
        nextEligibleAt = entry.nextEligibleAt
      }
    end
  end
  return rows
end

local function copyStatus(status)
  status = status or {}
  local power = type(status.power) == "table" and status.power or {}
  local primary = type(status.ae2Primary) == "table" and status.ae2Primary or nil
  if not (primary and type(primary.address) == "string" and primary.address ~= "") then primary = nil end
  return {
    mode = status.mode, complete = status.complete == true, autoEnabled = status.autoEnabled ~= false,
    ae2Online = status.ae2Online,
    ae2Primary = primary and { address = primary.address, type = primary.type } or nil,
    readyCpus = status.readyCpus, totalCpus = status.totalCpus, cpuPolicy = status.cpuPolicy,
    activeCraftCount = status.activeCraftCount, activeCraftScannedCpus = status.activeCraftScannedCpus,
    activeCraftBusyCpus = status.activeCraftBusyCpus, activeCraftFinalOutputs = status.activeCraftFinalOutputs,
    activeCraftFinalOutputErrors = status.activeCraftFinalOutputErrors, activeCraftFinalOutputError = status.activeCraftFinalOutputError,
    activeCraftFinalOutputErrorCpu = status.activeCraftFinalOutputErrorCpu, craftables = status.craftables,
    requestReady = status.requestReady, armedTargets = status.armedTargets, targetCount = status.targetCount,
    power = { available = power.available, ratio = power.ratio, avgIn = power.avgIn, avgOut = power.avgOut,
      deficit = power.deficit, status = power.status }
  }
end

local function copyTarget(row)
  row = row or {}
  return {
    label = row.label, rawLabel = row.rawLabel, name = row.name, damage = row.damage, hasTag = row.hasTag,
    kind = row.kind, isFluid = row.isFluid, amount = row.maxRequest or row.batch or row.request or row.amount,
    filter = row.filter, craftBinding = row.craftBinding, current = row.current, min = row.min,
    alertBelow = row.alertBelow, craftTo = row.craftTo,
    batch = row.batch, maxRequest = row.maxRequest, lineIntent = row.lineIntent, lineAuthority = row.lineAuthority,
    alertEnabled = row.alertEnabled, lineState = row.lineState, lineReason = row.lineReason, maxBasis = row.maxBasis,
    confidence = row.confidence, recipeMax = row.recipeMax, dangerUnlocked = row.dangerUnlocked, locked = row.locked,
    request = row.request, craftable = row.craftable, minBatteryRatio = row.minBatteryRatio,
    maxDeficitRatio = row.maxDeficitRatio, requireReadyCpu = row.requireReadyCpu, cooldown = row.cooldown,
    armed = row.armed, ready = row.ready, requestState = row.requestState, requestPhase = row.requestPhase,
    requestStatusReason = row.requestStatusReason, requestError = row.requestError, reason = row.reason,
    error = row.error, targetKey = row.targetKey or identity.targetKey(row)
  }
end

function reports.compactWarmReport(report, now)
  if not (report and report.status and report.status.complete == true) then return nil end
  local cache, targets = type(report.cache) == "table" and report.cache or {}, report.targets or {}
  local configuredTargets = type(report.config) == "table" and type(report.config.targets) == "table"
    and report.config.targets or targets
  local out = {
    savedAt = now, signature = cache.signature or identity.configSignature(targets),
    targetSignature = cache.targetSignature or identity.targetSignature(targets),
    -- Rendered rows can contain derived max-basis/confidence values. Sign the
    -- configured authority so Dashboard compares like-for-like policy state.
    policySignature = identity.configSignature(configuredTargets), status = copyStatus(report.status),
    targets = {}, alerts = report.alerts or {}, message = report.message
  }
  for _, row in ipairs(targets) do out.targets[#out.targets + 1] = copyTarget(row) end
  return out
end

function reports.recordTick(out, report, interval, ok, err, nextCycleAt, generation, now)
  identity.scrubStartupCarriedWarmReport(out)
  local reportTable = type(report) == "table" and report or nil
  local dispatch = reportTable and reportTable.dispatch or {}
  local warming = reportTable and reportTable.status and reportTable.status.complete == false
  out.daemonInterval = tonumber(interval) or out.daemonInterval or 30
  out.generation = tonumber(generation) or out.generation
  out.workerState = "running"
  out.tickCount, out.lastTick = (tonumber(out.tickCount) or 0) + 1, now
  out.nextCycleAt = tonumber(nextCycleAt) or (now + out.daemonInterval)
  out.lastMode = reportTable and reportTable.status and reportTable.status.mode or out.lastMode
  out.detectedCpuCount = dispatch.detectedCpuCount or dispatch.cpuCount or out.detectedCpuCount
  out.busyCpuCount = dispatch.busyCpuCount or out.busyCpuCount
  out.inFlightCount = warming and 0 or dispatch.inFlightCount or out.inFlightCount or 0
  out.availableSlots = warming and 0 or dispatch.availableSlots or out.availableSlots or 0
  out.queueCount = warming and 0 or dispatch.queueCount or out.queueCount or 0
  out.targetStatus = warming and {} or copyTargetStatus(dispatch)
  if reportTable and reportTable.status and reportTable.status.complete == true then
    out.warmReport = reports.compactWarmReport(reportTable, now)
  end
  if not ok then
    out.lastSubmitFail, out.lastError, out.lastStatus = now, tostring(err or "daemon tick failed"), "daemon error"
    return out
  end
  local attempts = reportTable and reportTable.requestAttempts
  local attempt = attempts and attempts[#attempts] or reportTable and reportTable.requestAttempt
  if attempt then
    out.lastSubmitAttempt, out.lastSubmitTarget = now, tostring(attempt.label or "target")
    out.lastSubmitAmount, out.lastSubmitPhase = tonumber(attempt.amount) or 0, attempt.phase
    out.lastSubmitReason = attempt.reason or attempt.err
    if attempt.skipped == true or (attempt.state == "blocked" and attempt.phase == "cpu_final_output") then
      out.lastSubmitFail, out.lastError, out.lastStatus = nil, nil, tostring(attempt.message or "auto request skipped")
    elseif attempt.pending == true or attempt.pendingResult == true
      or (attempt.started == true and attempt.state == "running" and attempt.phase == "computing") then
      out.lastError, out.lastStatus = nil, tostring(attempt.message or "auto request planning; no CPU assigned yet")
    elseif attempt.done == true or attempt.state == "done" then
      out.lastError, out.lastStatus = nil, tostring(attempt.message or "auto request completed")
    elseif attempt.uncertain == true or attempt.state == "accepted" then
      out.lastError, out.lastStatus = nil, tostring(attempt.message or "auto request confirmation unavailable")
    elseif attempt.ok then
      out.lastSubmitOk, out.lastError, out.lastStatus = now, nil, tostring(attempt.message or "auto request accepted by AE2")
    else
      out.lastSubmitFail = now
      out.lastError, out.lastStatus = tostring(attempt.message or "auto request failed"), tostring(attempt.message or "auto request failed")
    end
  else
    local entry, row = firstVisibleDispatchEntry(reportTable), nil
    if not entry then row = firstUsefulRow(reportTable) end
    out.lastStatus = dispatchSummary(entry) or (row and ("blocked: " .. tostring(row.reason or row.requestState or "unknown")))
      or tostring(reportTable and reportTable.message or "no maintainer targets")
  end
  return out
end

return reports
local computer = require("computer")

local cacheEpoch = require("oc.ae2.cache_epoch")
-- Request-status polling is the only craft helper this daemon module needs.
-- Importing the old craft facade also loads grid catalog/discovery/probe code,
-- which is dormant but unnecessary resident memory in the long-lived owner.
local craftRequests = require("oc.ae2.craft_requests")
local lineContract = require("oc.ae2.line_contract")
local cpuWitness = require("oc.ae2.maintainer_cpu_witness")
local maintainerLog = require("oc.ae2.maintainer_log")
local maintainerQueue = require("oc.ae2.maintainer_queue")
local requestWitness = require("oc.ae2.maintainer_requests_witness")
local maintainerStateOk, maintainerState = pcall(require, "oc.ae2.maintainer_state")
local requester = require("oc.ae2.requester")
local requestTracker = require("oc.ae2.request_tracker")
local stockMemory = require("oc.ae2.stock_memory")
local time = require("oc.ae2.time")

local requests = {}

local function targetKey(target)
  if type(target) == "table" then return maintainerQueue.id(target) end
  return tostring(target or "")
end

local function targetLabel(target)
  if type(target) == "table" then return tostring(target.label or target.rawLabel or target.name or "") end
  return tostring(target or "")
end

local function fluidLike(row)
  local name = tostring(row and row.name or ""):lower()
  local raw = tostring(row and row.rawLabel or ""):lower()
  return row and (row.isFluid == true or row.kind == "fluid"
    or name:find("fluid", 1, true) ~= nil or raw:find("^drops? of") ~= nil)
end

local function requestReceipt(prefix, row, amount)
  local label = targetLabel(row)
  return time.receipt(prefix, label, amount, fluidLike(row))
end

local function confirmed(report)
  return report and report.requestState == "running" and report.requestPhase == "submitted"
end

local function receiptPrefix(status, report)
  local state, phase = report and report.requestState, report and report.requestPhase
  if state == "running" and phase == "computing" then return "Auto request planning: " end
  if confirmed(report) then return "Auto request accepted by AE2: " end
  if state == "done" then return "Auto request completed: " end
  if state == "accepted" then return "Auto request returned (confirmation unavailable): " end
  if state == "blocked" then return "Auto request blocked: " end
  if state == "canceled" then return "Auto request canceled: " end
  return status and "Auto request accepted: " or "Auto request failed for "
end

local function requestOptions(row, entry, dispatch, now, daemonGeneration)
  return {
    prioritizePower = true,
    daemonGeneration = daemonGeneration,
    maxInFlight = dispatch.cpuCount,
    track = { id = entry.id, amount = entry.requestedAmount, submittedAt = now,
      label = row.label, source = "auto", target = row }
  }
end

local function validateCachedStockBeforeSubmit(row, entry)
  local memory, err = stockMemory.fresh(row)
  if not memory then
    if entry then entry.requestedAmount = 0 end
    if row then
      row.request = 0
      row.requestError = tostring(err or "stock snapshot unavailable")
      row.stockMemoryFresh = false
      row.stockMemoryReason = row.requestError
    end
    return false, requestWitness.blockEntry(row, entry, "stock_snapshot", tostring(err or "stock snapshot unavailable")
      .. "; live AE2 stock scans are disabled", requestReceipt)
  end
  row.current = memory.current
  row.stockMemoryAt, row.stockMemorySource, row.stockMemoryFresh = memory.at, memory.source, true
  row.stockMemoryReason = nil
  row.alertBelow = tonumber(row.alertBelow or row.min or (entry and entry.stockBelow)) or 0
  row.maxRequest = tonumber(row.maxRequest or row.batch or (entry and entry.maxRequest) or (entry and entry.batch) or row.request) or 0
  row.min, row.batch = row.alertBelow, row.maxRequest
  lineContract.annotate(row)
  local amount = tonumber(row.request) or 0
  entry.requestedAmount = amount
  entry.lineState, entry.lineReason = row.lineState, row.lineReason
  if amount <= 0 then
    local phase = row.lineState == "danger_locked" and "danger_locked" or "stock_satisfied"
    local reason = row.lineState == "satisfied" and "stock refreshed; target already satisfied"
      or row.lineReason or "line contract blocked after stock refresh"
    return false, requestWitness.blockEntry(row, entry, phase, reason, requestReceipt)
  end
  return true
end

function requests.state(target, activeRequests)
  local key = targetKey(target)
  local label = targetLabel(target)
  local tracked = requestTracker.status(key)
  if tracked.state == "none" and label ~= "" and label ~= key then tracked = requestTracker.status(label) end
  if tracked.state ~= "none" then return tracked end
  local request = activeRequests and (activeRequests[key] or activeRequests[label])
  if not request then return "none" end
  local status = craftRequests.requestStatus(request)
  if status.done or status.canceled then
    activeRequests[key], activeRequests[label] = nil, nil
    return { state = status.canceled and "canceled" or "done", phase = status.canceled and "canceled" or "done" }
  end
  if status.error then
    activeRequests[key], activeRequests[label] = nil, nil
    return {
      state = status.state == "blocked" and "blocked" or "failed",
      phase = status.phase or (status.state == "blocked" and "missing_resources" or "failed"),
      reason = status.error
    }
  end
  return { state = "running", phase = status.computing and "computing" or "submitted" }
end

function requests.submit(report, activeRequests, lastRequestAt, options)
  report = type(report) == "table" and report or {}
  activeRequests = activeRequests or {}
  lastRequestAt = lastRequestAt or {}
  options = options or {}
  if not (report and report.status and report.status.complete == true) then
    report.dispatch = { entries = {}, ready = {}, queueCount = 0, readyQueueCount = 0, inFlightCount = 0, availableSlots = 0, maxSubmits = 0 }
    report.requestBlocker = { reason = "maintainer status still warming", state = "blocked" }
    return report
  end
  local witnessReady, witnessReason = requestWitness.refresh(report)
  if options.requireFinalOutputWitness == true and not witnessReady then
    return requestWitness.blockReport(report, options, witnessReason)
  end
  local dispatch = maintainerQueue.build(report, options)
  report.dispatch = dispatch
  report.requestAttempts = {}
  if dispatch.availableSlots <= 0 then
    report.requestBlocker = { reason = "no CPU slots available", state = "blocked" }
    return report
  end
  local pending = {}
  for _, entry in ipairs(dispatch.ready or {}) do
    local row = entry.row
    if row and entry.requestedAmount > 0 then
      local refreshed, skipAttempt = validateCachedStockBeforeSubmit(row, entry)
      if not refreshed then
        report.requestAttempts[#report.requestAttempts + 1] = skipAttempt
        report.requestAttempt = skipAttempt
        requestWitness.refreshDispatchCounts(dispatch)
      else
        pending[#pending + 1] = entry
      end
    end
  end
  if #pending > 0 then
    witnessReady, witnessReason = requestWitness.refresh(report)
    local submitReady = {}
    for _, entry in ipairs(pending) do
      local row = entry.row
      local activeCraft = witnessReady and cpuWitness.find(report.status and report.status.activeCrafts, row) or nil
      if options.requireFinalOutputWitness == true and not witnessReady then
        local scanAttempt = requestWitness.blockEntry(row, entry, "cpu_final_output_scan", witnessReason, requestReceipt)
        report.requestAttempts[#report.requestAttempts + 1] = scanAttempt
        report.requestAttempt = scanAttempt
        requestWitness.refreshDispatchCounts(dispatch)
      elseif activeCraft then
        local activeAttempt = requestWitness.blockCpuFinalOutput(row, entry, activeCraft, requestReceipt)
        report.requestAttempts[#report.requestAttempts + 1] = activeAttempt
        report.requestAttempt = activeAttempt
        requestWitness.refreshDispatchCounts(dispatch)
      else
        submitReady[#submitReady + 1] = entry
      end
    end
    local submitted, submitCalls = {}, 0
    for _, entry in ipairs(submitReady) do
      if submitCalls >= dispatch.maxSubmits then break end
      local row = entry.row
      local now = computer.uptime()
      submitCalls = submitCalls + 1
      local status, err, lastReport = requester.requestTarget(row, entry.requestedAmount,
        requestOptions(row, entry, dispatch, now, options.daemonGeneration))
      lastReport = lastReport or requester.lastReport() or {}
      row.requested = status ~= nil
      row.requestError = err
      row.requestState = lastReport.requestState or (status and "running" or "failed")
      row.requestPhase = lastReport.requestPhase
      row.requestStatusReason = lastReport.requestStatusReason
      local attempt = {
        label = row.label,
        amount = entry.requestedAmount,
        ok = confirmed(lastReport),
        started = status ~= nil,
        pending = lastReport.requestPending == true,
        pendingResult = lastReport.pendingResult == true,
        done = row.requestState == "done",
        uncertain = lastReport.requestUnverified == true,
        err = err,
        state = row.requestState,
        phase = row.requestPhase,
        reason = row.requestStatusReason,
        message = requestReceipt(receiptPrefix(status, lastReport), row, entry.requestedAmount)
      }
      report.requestAttempts[#report.requestAttempts + 1] = attempt
      report.requestAttempt = attempt
      if status then
        if lastReport.requestTrackable then activeRequests[entry.id] = status end
        row.ready = false
        if confirmed(lastReport) then
          lastRequestAt[entry.id] = now
          maintainerQueue.markSubmitted(entry, now)
          row.reason = "AE2 accepted request; CPU witness pending"
          entry.reason = row.reason
          cacheEpoch.recordAutoBatch(row, now)
          if maintainerStateOk and maintainerState and maintainerState.recordAutoBatch then
            pcall(maintainerState.recordAutoBatch, row, now, lastReport)
          end
          local logged, logErr = maintainerLog.append(row, now)
          if not logged then row.logError = logErr end
          submitted[#submitted + 1] = { row = row, entry = entry }
        elseif lastReport.requestPending then
          maintainerQueue.markPlanning(entry, now)
          row.reason, entry.reason = "AE2 planning request; no CPU assigned yet", "AE2 planning request; no CPU assigned yet"
        elseif row.requestState == "done" then
          row.requested = false
          maintainerQueue.markDone(entry, now)
          cacheEpoch.recordAutoBatch(row, now)
          row.reason, entry.reason = "AE2 request completed", "AE2 request completed"
        elseif lastReport.requestUnverified then
          row.requested = false
          maintainerQueue.markUnverified(entry, now)
          row.reason, entry.reason = "request returned; confirmation unavailable", "request returned; confirmation unavailable"
        end
      elseif lastReport.pendingResult then
        row.ready, row.reason, entry.reason = false, err, err
      elseif row.requestState == "blocked" or row.requestPhase == "missing_resources" then
        maintainerQueue.markBlocked(entry, err, now, row.requestPhase)
      else
        maintainerQueue.markFailed(entry, err, now)
      end
      requestWitness.refreshDispatchCounts(dispatch)
    end
    if requestWitness.refreshPostSubmit(report, submitted) then requestWitness.refreshDispatchCounts(dispatch) end
  end
  if not report.requestAttempt and dispatch.entries[1] then
    local entry = dispatch.entries[1]
    report.requestBlocker = { label = entry.label, amount = entry.requestedAmount, reason = entry.reason, state = entry.status }
  end
  return report
end

return requests
local computer = require("computer")

local cacheEpoch = require("oc.ae2.cache_epoch")
local maintainerLog = require("oc.ae2.maintainer_log")
local maintainerQueue = require("oc.ae2.maintainer_queue")
local maintainerStateOk, maintainerState = pcall(require, "oc.ae2.maintainer_state")
local requestTracker = require("oc.ae2.request_tracker")
local time = require("oc.ae2.time")

local poll = {}

local function targetFor(row)
  local target = type(row.target) == "table" and row.target or { label = row.label }
  target.request = tonumber(row.amount) or target.request or 0
  target.requestState, target.requestPhase = row.state, row.phase
  target.requestStatusReason = row.reason
  target.requestError = (row.state == "failed" or row.state == "blocked" or row.state == "canceled")
    and (row.reason or row.state) or nil
  return target
end

local function entryFor(row, target)
  return {
    id = row.id or row.label, label = row.label, requestedAmount = tonumber(row.amount) or 0,
    row = target, phase = row.phase, statusReason = row.reason
  }
end

local function reportFor(row)
  return {
    amount = tonumber(row.amount) or 0, requestKey = row.id or row.label,
    requestState = row.state, requestPhase = row.phase, requestStatusReason = row.reason,
    requestTrackable = true, requestConfirmed = row.state == "running" and row.phase == "submitted"
  }
end

local function terminalToken(row)
  return table.concat({ tostring(row.id or row.label or "request"), tostring(row.submittedAt or ""),
    tostring(row.state or ""), tostring(row.phase or "") }, "|")
end

local function receipt(prefix, row, target)
  local fluid = target.isFluid == true or target.kind == "fluid"
  return time.receipt(prefix, tostring(row.label or target.label or "target"), tonumber(row.amount) or 0, fluid)
end

local function recordStatus(target, now, report, logResult)
  local stateSaved = false
  if maintainerStateOk and maintainerState and maintainerState.recordAutoStatus then
    local called, saved = pcall(maintainerState.recordAutoStatus, target, now, report)
    stateSaved = called and saved == true
  end
  if logResult and stateSaved then
    local logged, logErr = maintainerLog.append(target, now)
    if not logged then target.logError = logErr end
  end
  return stateSaved
end

local function terminalAttempt(row, entry, target, now)
  local report = reportFor(row)
  local token = terminalToken(row)
  local attempt = {
    label = row.label, amount = row.amount, ok = false, state = row.state,
    phase = row.phase, reason = row.reason
  }
  if row.state == "done" then
    maintainerQueue.markDone(entry, now, token)
    cacheEpoch.recordAutoBatch(target, now)
    entry.status, entry.reason = "done", "AE2 request completed"
    attempt.done, attempt.message = true, receipt("Auto request completed: ", row, target)
  elseif row.state == "blocked" then
    maintainerQueue.markBlocked(entry, row.reason, now, row.phase, token)
    entry.status, entry.reason = "blocked", tostring(row.reason or "request blocked")
    attempt.message = receipt("Auto request blocked: ", row, target)
  else
    maintainerQueue.markFailed(entry, row.reason or row.state, now, token)
    entry.status, entry.reason = "failed", tostring(row.reason or row.state)
    attempt.message = receipt(row.state == "canceled" and "Auto request canceled: " or "Auto request failed for ", row, target)
  end
  local stateSaved = recordStatus(target, now, report, true)
  attempt.pendingResult = not stateSaved
  return attempt, stateSaved
end

function poll.snapshot(activeRequests, lastRequestAt)
  local now, entries, attempts, acknowledgements = computer.uptime(), {}, {}, {}
  local inFlight = 0
  for _, row in ipairs(requestTracker.summaries() or {}) do
    -- Dashboard owns manual handles. The daemon must never publish or consume
    -- their terminal results, even when both owners share one Lua process.
    if row.source == "auto" then
      local target = targetFor(row)
      local entry = entryFor(row, target)
      if row.state == "running" then
        inFlight = inFlight + 1
        entry.status = "in_flight"
        if row.phase == "submitted" then
          entry.reason = "AE2 accepted request; CPU witness pending"
          local _, changed = maintainerQueue.markSubmitted(entry, now)
          if changed then
            lastRequestAt[entry.id] = now
            local report = reportFor(row)
            cacheEpoch.recordAutoBatch(target, now)
            recordStatus(target, now, report, true)
            attempts[#attempts + 1] = {
              label = row.label, amount = row.amount, ok = true, started = true,
              state = row.state, phase = row.phase, reason = row.reason,
              message = receipt("Auto request accepted by AE2: ", row, target)
            }
          end
        else
          entry.reason = "AE2 planning request; no CPU assigned yet"
          maintainerQueue.markPlanning(entry, now)
        end
      else
        local attempt, stateSaved = terminalAttempt(row, entry, target, now)
        attempts[#attempts + 1] = attempt
        if stateSaved then
          acknowledgements[#acknowledgements + 1] = row.id or row.label
          if activeRequests then activeRequests[row.id or ""], activeRequests[row.label or ""] = nil, nil end
        end
      end
      entries[#entries + 1] = entry
    end
  end
  return {
    message = inFlight > 0 and "poll heartbeat; request lifecycle active"
      or #attempts > 0 and "poll heartbeat; terminal request result observed"
      or "poll heartbeat; no in-flight requests",
    dispatch = { entries = entries, queueCount = 0, inFlightCount = inFlight,
      availableSlots = 0, maxSubmits = 0, pollOnly = true },
    requestAttempts = attempts, requestAcks = acknowledgements, targets = {}
  }
end

function poll.acknowledge(report)
  for _, key in ipairs((report and report.requestAcks) or {}) do requestTracker.acknowledge(key) end
end

return poll
-- Final-output witness handling is a dispatch guard, not a request resolver.
-- Keeping it isolated makes the normal submission path small and prevents an
-- accidental CPU scan from being added to request-state polling.
local adapter = require("oc.ae2.adapter")
local cpuWitness = require("oc.ae2.maintainer_cpu_witness")
local maintainerQueue = require("oc.ae2.maintainer_queue")

local witness = {}

function witness.refreshDispatchCounts(dispatch)
  dispatch = dispatch or {}
  local queued, ready, inFlight = 0, 0, 0
  for _, entry in ipairs(dispatch.entries or {}) do
    if entry.status == "queued" then queued = queued + 1 end
    if entry.status == "in_flight" then inFlight = inFlight + 1 end
  end
  for _, entry in ipairs(dispatch.ready or {}) do
    if entry.status == "queued" then ready = ready + 1 end
  end
  dispatch.queueCount, dispatch.readyQueueCount = queued, ready
  dispatch.inFlightCount = (tonumber(dispatch.activeInFlightCount) or 0) + inFlight
end

local function eachCpu(cpus, fn)
  local seen = {}
  local reported = math.max(tonumber(cpus and cpus.n) or 0, #(cpus or {}))
  for index = 1, reported do
    if cpus[index] ~= nil then seen[index] = true; fn(cpus[index], index) end
  end
  for key, row in pairs(cpus or {}) do
    if key ~= "n" and not seen[key] then fn(row, key) end
  end
end

local function cpuCounts(cpuSummary)
  local ready, observed = 0, 0
  eachCpu(cpuSummary and cpuSummary.cpus or {}, function(row)
    observed = observed + 1
    if not cpuWitness.cpuBusy(row) then ready = ready + 1 end
  end)
  return ready, math.max(observed, tonumber(cpuSummary and cpuSummary.count) or 0)
end

local function publishActiveCrafts(status, activeCrafts)
  local diagnostics = activeCrafts.diagnostics or {}
  status.activeCrafts, status.activeCraftCount = activeCrafts, #activeCrafts
  status.activeCraftScannedCpus = diagnostics.scannedCpus
  status.activeCraftBusyCpus = diagnostics.busyCpus
  status.activeCraftFinalOutputs = diagnostics.finalOutputs
  status.activeCraftFinalOutputErrors = diagnostics.errors
  status.activeCraftFinalOutputError = diagnostics.firstError
  status.activeCraftFinalOutputErrorCpu = diagnostics.firstErrorCpu
end

function witness.refresh(report)
  local status = report and report.status
  local primary = status and status.ae2Primary
  if not (type(primary) == "table" and primary.address) then
    return false, "CPU final-output scan unavailable: missing AE2 primary"
  end
  local ok, cpuSummary = pcall(adapter.cpuSummary, primary)
  if not ok or type(cpuSummary) ~= "table" then
    return false, "CPU final-output scan failed: " .. tostring(ok and "no CPU summary" or cpuSummary)
  end
  local ready, total = cpuCounts(cpuSummary)
  if total > 0 then status.readyCpus, status.totalCpus = ready, total end
  local witnessOk, activeCrafts = pcall(cpuWitness.activeOutputs, cpuSummary)
  if not witnessOk or type(activeCrafts) ~= "table" then
    return false, "CPU final-output scan failed: " .. tostring(activeCrafts)
  end
  publishActiveCrafts(status, activeCrafts)
  local diagnostics = activeCrafts.diagnostics or {}
  if (tonumber(diagnostics.scannedCpus) or 0) > 0 and (tonumber(diagnostics.errors) or 0) > 0 then
    return false, "CPU final-output scan failed: " .. tostring(diagnostics.firstError or "all CPU reads errored")
  end
  return true
end

local function blockedAttempt(row, entry, phase, reason, receipt)
  return {
    label = row and row.label, amount = entry and entry.requestedAmount or 0,
    ok = false, state = "blocked", phase = phase, reason = reason,
    message = receipt("Auto request skipped for ", row, entry and entry.requestedAmount or 0)
  }
end

function witness.blockEntry(row, entry, phase, reason, receipt)
  if row then
    row.ready, row.reason = false, reason
    row.requestState, row.requestPhase, row.requestStatusReason = "blocked", phase, reason
  end
  if entry then entry.status, entry.phase, entry.statusReason, entry.reason = "blocked", phase, reason, reason end
  return blockedAttempt(row, entry, phase, reason, receipt)
end

local function cpuFinalOutputReason(active)
  local reason = "AE2 CPU final output in flight"
  if active and active.cpuName then reason = reason .. ": " .. tostring(active.cpuName) end
  return reason
end

function witness.blockCpuFinalOutput(row, entry, active, receipt)
  local reason = cpuFinalOutputReason(active)
  if row then
    row.ready, row.reason = false, reason
    row.requestState, row.requestPhase, row.requestStatusReason = "blocked", "cpu_final_output", "AE2 CPU final output matches target"
  end
  if entry then
    entry.status, entry.phase, entry.statusReason, entry.reason = "blocked", "cpu_final_output",
      "AE2 CPU final output matches target", reason
  end
  local attempt = blockedAttempt(row, entry, "cpu_final_output", reason, receipt)
  attempt.skipped = true
  return attempt
end

local function markCpuFinalOutputInFlight(row, entry, active)
  local reason = cpuFinalOutputReason(active)
  if row then
    row.ready, row.reason = false, reason
    row.requestState, row.requestPhase, row.requestStatusReason = "running", "cpu_final_output", "AE2 CPU final output matches target"
  end
  if entry then
    entry.status, entry.phase, entry.statusReason, entry.reason = "in_flight", "cpu_final_output",
      "AE2 CPU final output matches target", reason
  end
end

function witness.refreshPostSubmit(report, submitted)
  if not submitted or #submitted <= 0 then return false end
  if not witness.refresh(report) then return false end
  local marked = false
  for _, item in ipairs(submitted) do
    local activeCraft = cpuWitness.find(report.status and report.status.activeCrafts, item.row)
    if activeCraft then markCpuFinalOutputInFlight(item.row, item.entry, activeCraft); marked = true end
  end
  return marked
end

function witness.blockReport(report, options, reason)
  for _, row in ipairs((report and report.targets) or {}) do
    if row.ready then
      row.ready, row.reason = false, reason
      row.requestState, row.requestPhase, row.requestStatusReason = "blocked", "cpu_final_output_scan", reason
    end
  end
  local dispatch = maintainerQueue.build(report, options)
  for _, entry in ipairs(dispatch.entries or {}) do
    if entry.status == "blocked" and entry.reason == reason then
      entry.phase, entry.statusReason = "cpu_final_output_scan", reason
    end
  end
  report.dispatch, report.requestAttempts = dispatch, {}
  report.requestBlocker = { reason = reason, state = "blocked", phase = "cpu_final_output_scan" }
  return report
end

return witness
local computer = require("computer")
local lineContract = require("oc.ae2.line_contract")
local maintainerQueue = require("oc.ae2.maintainer_queue")
local binding = require("oc.ae2.request_binding")

local rules = {}

local function targetNeedsBatteryTelemetry(row)
  row = row or {}
  if row.armed ~= true then return false end
  local minBatteryRatio = tonumber(row.minBatteryRatio) or 0
  local maxDeficitRatio = tonumber(row.maxDeficitRatio) or 1.25
  return not (minBatteryRatio <= 0 and maxDeficitRatio <= 0)
end

local function anyTargetNeedsBatteryTelemetry(targets)
  if targets == nil then return true end
  for _, row in ipairs(targets or {}) do
    if targetNeedsBatteryTelemetry(row) then return true end
  end
  return false
end

function rules.safeToCraft(row, status, config, lastRequestAt)
  row, status, config = row or {}, status or {}, config or {}
  lastRequestAt = lastRequestAt or {}
  local power = status.power or {}
  if not status.ae2Online then return false, "AE2 offline" end
  if config.autoEnabled == false then return false, "global auto off" end
  local minBatteryRatio = tonumber(row.minBatteryRatio or config.minBatteryRatio) or 0
  local maxDeficitRatio = tonumber(row.maxDeficitRatio or config.maxDeficitRatio) or 1.25
  local batteryDisabled = minBatteryRatio <= 0
  local powerDisabled = maxDeficitRatio <= 0
  local powerRatio = tonumber(power.ratio)
  if not power.available and not (batteryDisabled and powerDisabled) then return false, "battery missing" end
  if powerRatio and not batteryDisabled and powerRatio < minBatteryRatio then
    return false, "battery low"
  end
  if not powerDisabled and type(power.avgIn) == "number" and type(power.avgOut) == "number" then
    if power.avgOut > power.avgIn * maxDeficitRatio and (powerRatio or 0) < 0.80 then
      return false, "power deficit"
    end
  end
  local amount, lineReason, lineState = lineContract.requestAmount(row)
  if lineState == "observe" then return false, "observe only" end
  if lineState == "alert" then return false, "alert only" end
  if lineState == "suggest" then return false, "suggest only" end
  if lineState == "manual_only" then return false, "manual only" end
  if lineState == "danger_locked" then return false, "request cap above safe boundary" end
  if not row.armed then return false, "target disarmed" end
  if row.requireReadyCpu ~= false and (tonumber(status.readyCpus) or 0) < 1 then return false, "no ready CPU" end
  local bindErr = binding.error(row)
  if bindErr then return false, bindErr end
  if row.requestMemoryReason then return false, row.requestMemoryReason end
  if row.stockMemoryFresh ~= true then
    return false, row.stockMemoryReason or "stock snapshot unavailable"
  end
  if type(row.current) ~= "number" then return false, "stock unknown" end
  -- Maintain/Recipe lines stop at their stock boundary, but Push Max is
  -- explicitly cooldown-driven. Preserve the familiar stock-ready receipt
  -- only when the shared line contract actually classified the row satisfied.
  if row.current >= row.min and lineState == "satisfied" then return false, "stock ready" end
  if (tonumber(amount) or 0) <= 0 then return false, lineReason or "line contract blocked" end
  local key = maintainerQueue.id(row)
  local last = lastRequestAt[key] or lastRequestAt[row.label]
  if last and computer.uptime() - last < (tonumber(row.cooldown or config.cooldown) or 0) then
    return false, "cooldown"
  end
  if row.requestState == "running" then return false, "already requested" end
  return true, "ready"
end

function rules.alerts(status, targets)
  status = status or {}
  local power = status.power or {}
  local needsBattery = anyTargetNeedsBatteryTelemetry(targets)
  local rows = {}
  if not status.ae2Online then rows[#rows + 1] = "AE2 offline" end
  if needsBattery and not power.available then rows[#rows + 1] = "Battery missing" end
  if needsBattery and type(power.ratio) == "number" and power.ratio < 0.25 then rows[#rows + 1] = "Battery low" end
  if needsBattery and power.deficit then rows[#rows + 1] = "Power deficit" end
  for _, row in ipairs(targets or {}) do
    if row.requestState == "canceled" or row.requestState == "failed" then
      rows[#rows + 1] = "Craft request " .. row.requestState .. ": " .. tostring(row.label)
    end
  end
  if #rows == 0 then rows[1] = "Observe only" end
  return rows
end

return rules
local cacheEpoch = require("oc.ae2.cache_epoch")

local cache = {}

function cache.targetKey(target)
  return cacheEpoch.targetKey(target)
end

function cache.targetSignature(targets)
  return cacheEpoch.targetSignature(targets)
end

function cache.configSignature(config)
  return cacheEpoch.configSignature(config)
end

function cache.prepare(config, options)
  options = options or {}
  local previous = options.cache or {}
  cacheEpoch.recordWorkflow(config, options.restart and "restart" or options.dirty and "workflow_dirty" or "maintainer_prepare")
  local targetSig = cache.targetSignature((config and config.targets) or {})
  local signature = cache.configSignature(config)
  local invalid = cacheEpoch.invalidationFor(previous.epoch)
  local sameTargets = previous.targetSignature == targetSig
  local keepRows = type(previous.rows) == "table" and previous.rows or nil
  if invalid.context and not invalid.targetRows then previous.context = nil end
  if sameTargets and previous.complete == true and not options.restart and not invalid.targetRows then
    previous.signature = signature
    previous.replay = true
    previous.targetCursor = 1
    return previous
  end
  if previous.complete == false and sameTargets and not options.restart and not invalid.targetRows then
    previous.signature, previous.targetSignature, previous.replay = signature, targetSig, nil
    return previous
  end
  if options.restart or not sameTargets or invalid.targetRows or previous.complete ~= false then
    return {
      targetCursor = 1,
      rows = keepRows,
      signature = signature,
      targetSignature = targetSig,
      context = nil,
      stockIndex = nil,
      replay = nil
    }
  end
  previous.signature, previous.targetSignature, previous.replay = signature, targetSig, nil
  return previous
end

return cache
local lineContract = require("oc.ae2.line_contract")
local statusCache = require("oc.ae2.maintainer_status_cache")
local stockMemory = require("oc.ae2.stock_memory")

local rows = {}
local targetKey = statusCache.targetKey

function rows.indexByKey(source)
  local indexed = {}
  for _, row in ipairs(source or {}) do if row.targetKey then indexed[row.targetKey] = row end end
  return indexed
end

function rows.applyPolicy(row, target, requestState)
  target = target or {}
  row.label = target.label or row.label or target.rawLabel or target.name or "target"
  row.rawLabel, row.name = target.rawLabel or row.rawLabel, target.name or row.name
  row.damage = target.damage or row.damage
  row.hasTag = target.hasTag ~= nil and target.hasTag or row.hasTag
  row.kind, row.amount, row.filter = target.kind or row.kind, target.amount or row.amount, target.filter or row.filter
  row.craftBinding = target.craftBinding
  if target.isFluid ~= nil then row.isFluid = target.isFluid end
  row.lineIntent = target.lineIntent or row.lineIntent
  row.lineAuthority = target.lineAuthority or row.lineAuthority
  row.alertEnabled = target.alertEnabled ~= false
  row.alertBelow = tonumber(target.alertBelow or target.min) or tonumber(row.alertBelow or row.min) or 0
  row.maxRequest = tonumber(target.maxRequest or target.batch) or tonumber(row.maxRequest or row.batch) or 1
  -- These controls belong to the current workflow policy. Replacing (rather
  -- than merging) them is what makes a removed recipe ceiling or revoked
  -- danger permission take effect on a same-target cache replay.
  row.maxBasis = target.maxBasis
  row.confidence = target.confidence
  row.recipeMax = target.recipeMax
  row.dangerUnlocked = target.dangerUnlocked == true
  row.locked = target.locked == true
  row.min, row.craftTo = row.alertBelow, tonumber(target.craftTo or row.alertBelow) or row.alertBelow
  row.batch = row.maxRequest
  lineContract.annotate(row)
  row.minBatteryRatio, row.maxDeficitRatio = target.minBatteryRatio, target.maxDeficitRatio
  row.requireReadyCpu, row.cooldown, row.armed = target.requireReadyCpu, target.cooldown, target.armed == true
  row.targetKey = targetKey(target)
  local requestStatus = requestState(row)
  row.requestState = type(requestStatus) == "table" and requestStatus.state or requestStatus
  row.requestPhase = type(requestStatus) == "table" and requestStatus.phase or nil
  row.requestStatusReason = type(requestStatus) == "table" and requestStatus.reason or nil
  row.requestError = type(requestStatus) == "table" and requestStatus.reason or nil
  return row
end

function rows.placeholder(target, requestState)
  target = target or {}
  return rows.applyPolicy({
    label = target.label or target.rawLabel or target.name or "target",
    rawLabel = target.rawLabel, name = target.name, damage = target.damage,
    hasTag = target.hasTag, kind = target.kind, isFluid = target.isFluid,
    amount = target.amount, filter = target.filter, craftBinding = target.craftBinding, craftable = false,
    ready = false, requestState = "none", status = "partial",
    reason = "warming stock/craft status",
    targetKey = targetKey(target)
  }, target, requestState)
end

function rows.target(node, entries, target, requestState, stockIndex, options)
  options = options or {}
  -- The daemon deliberately does not enumerate or resolve the AE2 Craftable
  -- grid while warming status. Exact identity eligibility is applied by the
  -- status layer; a live handle is resolved only for the selected submission.
  local entry = nil
  local stockNode = (entry and entry.source) or node
  local memory = stockNode and stockNode.address
    and stockMemory.lookup(target, { address = stockNode.address }) or nil
  local current, countError, stockFresh, stockAge
  if memory then
    current = memory.current
    stockFresh, countError, stockAge = stockMemory.isFresh(memory, { maxAge = options.stockMaxAge })
  else
    countError = "stock snapshot unavailable; live AE2 stock scans are disabled"
    stockFresh = false
  end
  local min = tonumber(target.min) or 0
  local alertBelow = tonumber(target.alertBelow or target.min) or min
  local craftTo = tonumber(target.craftTo) or alertBelow
  local maxRequest = tonumber(target.maxRequest or target.batch) or craftTo
  local row = {
    label = target.label or (entry and entry.label) or "target",
    rawLabel = entry and entry.rawLabel or target.rawLabel,
    name = entry and entry.name or target.name,
    damage = entry and entry.damage or target.damage,
    hasTag = entry and entry.hasTag ~= nil and entry.hasTag or target.hasTag,
    kind = entry and entry.kind or target.kind,
    isFluid = entry and entry.isFluid or target.isFluid,
    amount = entry and entry.amount or target.amount,
    filter = entry and entry.filter or target.filter,
    craftBinding = target.craftBinding,
    source = entry and entry.source or target.source,
    craftIndex = entry and entry.craftIndex or target.craftIndex,
    rawCraftIndex = entry and (entry.rawCraftIndex or entry.craftIndex) or target.rawCraftIndex,
    current = current,
    min = alertBelow,
    alertBelow = alertBelow,
    craftTo = craftTo,
    batch = maxRequest,
    maxRequest = maxRequest,
    lineIntent = target.lineIntent,
    lineAuthority = target.lineAuthority,
    alertEnabled = target.alertEnabled,
    maxBasis = target.maxBasis,
    confidence = target.confidence,
    recipeMax = target.recipeMax,
    dangerUnlocked = target.dangerUnlocked,
    locked = target.locked,
    craftable = entry ~= nil,
    entry = entry,
    minBatteryRatio = target.minBatteryRatio,
    maxDeficitRatio = target.maxDeficitRatio,
    requireReadyCpu = target.requireReadyCpu,
    cooldown = target.cooldown,
    armed = target.armed == true,
    error = countError,
    stockMemoryFresh = stockFresh == true,
    stockMemoryAge = stockAge,
    stockMemoryReason = countError,
    targetKey = targetKey(target)
  }
  if memory then
    row.stockMemoryAt = memory.at
    row.stockMemorySource = memory.source
  elseif current ~= nil then
    row.stockMemoryAt = memory and memory.at or nil
    row.stockMemorySource = memory and memory.source or nil
  end
  return rows.applyPolicy(row, target, requestState)
end

function rows.applyStockMemory(row, target, node)
  if not (node and node.address) then return row, false end
  return stockMemory.apply(row, target, { address = node.address })
end

return rows
local adapter = require("oc.ae2.adapter")
local cacheEpoch = require("oc.ae2.cache_epoch")
local cpuWitness = require("oc.ae2.maintainer_cpu_witness")
local lineContract = require("oc.ae2.line_contract")
local monitor = require("oc.ae2.monitor")
local binding = require("oc.ae2.request_binding")
local stockDirect = require("oc.ae2.stock_direct")
local statusCache = require("oc.ae2.maintainer_status_cache")
local statusRows = require("oc.ae2.maintainer_status_rows")
local statusSafety = require("oc.ae2.maintainer_status_safety")
local powerMonitor = require("oc.gt_power.monitor")

local status = {}

local function eachCpu(cpus, fn)
  local seen = {}
  local reported = math.max(tonumber(cpus and cpus.n) or 0, #(cpus or {}))
  for index = 1, reported do
    if cpus[index] ~= nil then
      seen[index] = true
      fn(cpus[index], index)
    end
  end
  for key, row in pairs(cpus or {}) do
    if key ~= "n" and not seen[key] then fn(row, key) end
  end
end

local function readyCpus(ae2, activeCrafts)
  local activeCpu = {}
  for _, active in ipairs(activeCrafts or {}) do
    if active.cpuIndex ~= nil then activeCpu[tostring(active.cpuIndex)] = true end
  end
  local ready = 0
  eachCpu((ae2.cpus and ae2.cpus.cpus) or {}, function(cpu, index)
    if not cpuWitness.cpuBusy(cpu) and not activeCpu[tostring(index)] then ready = ready + 1 end
  end)
  return ready
end

function status.powerStatus()
  local ok, snapshot = pcall(powerMonitor.snapshot, { usableOnly = true, limit = 1, sensor = true })
  if not ok or type(snapshot) ~= "table" then
    return { available = false, status = "error: " .. tostring(snapshot) }
  end
  local first = snapshot.readings and snapshot.readings[1] or {}
  local deficit = false
  if type(first.effectiveAvgIn) == "number" and type(first.effectiveAvgOut) == "number" then
    deficit = first.effectiveAvgOut > first.effectiveAvgIn * 1.25 and (first.ratio or 0) < 0.80
  end
  return {
    available = snapshot.available,
    node = first.address and { address = first.address, type = first.type } or nil,
    address = first.address,
    type = first.type,
    ratio = first.ratio,
    avgIn = first.effectiveAvgIn or first.avgIn,
    avgOut = first.effectiveAvgOut or first.avgOut,
    deficit = deficit,
    status = first.status
  }
end

function status.armedTargets(config)
  local count = 0
  for _, target in ipairs((config and config.targets) or {}) do
    if target.armed then count = count + 1 end
  end
  return count
end

local targetKey = statusCache.targetKey
local targetSignature = statusCache.targetSignature
local configSignature = statusCache.configSignature
local prepareChunkCache = statusCache.prepare

local function buildContext(config)
  local ae2 = monitor.snapshot({ detail = false })
  local primary = ae2.available and ae2.primary and { address = ae2.primary.address, type = ae2.primary.type } or adapter.primary()
  local power = status.powerStatus()
  local activeCrafts = cpuWitness.activeOutputs(ae2.cpus)
  local activeDiagnostics = activeCrafts.diagnostics or {}
  local context = {
    ae2 = ae2,
    primary = primary,
    batteryNode = power.node,
    current = {
      mode = config.mode,
      autoEnabled = config.autoEnabled ~= false,
      ae2Online = ae2.available,
      ae2Primary = primary,
      readyCpus = readyCpus(ae2, activeCrafts),
      totalCpus = ae2.cpus and ae2.cpus.count or 0,
      cpuPolicy = "any ready CPU",
      activeCrafts = activeCrafts,
      activeCraftCount = #activeCrafts,
      activeCraftScannedCpus = activeDiagnostics.scannedCpus,
      activeCraftBusyCpus = activeDiagnostics.busyCpus,
      activeCraftFinalOutputs = activeDiagnostics.finalOutputs,
      activeCraftFinalOutputErrors = activeDiagnostics.errors,
      activeCraftFinalOutputError = activeDiagnostics.firstError,
      activeCraftFinalOutputErrorCpu = activeDiagnostics.firstErrorCpu,
      power = power
    }
  }
  cacheEpoch.recordNodes({ ae2Primary = primary, batteryNode = power.node })
  return context
end

local function cloneCurrent(context)
  local current = {}
  for key, value in pairs((context and context.current) or {}) do current[key] = value end
  return current
end

-- Status must never turn an observation pass into a Craftable lookup. This
-- only classifies whether the saved identity is safe to resolve later at the
-- one selected request boundary. `craftable` therefore means locally eligible
-- for an exact direct binding here, not that a live recipe handle is retained.
local function applyExactRequestEligibility(row)
  if not row then return row end
  local bindErr = binding.error(row)
  if bindErr then
    row.craftable = false
    row.requestMemory = "binding-required"
    row.requestMemoryMode = nil
    row.requestMemoryReason = tostring(bindErr)
    return row
  end
  row.craftable = true
  row.requestMemory = "dispatch-direct"
  row.requestMemoryMode = "exact-identity"
  row.requestMemoryReason = nil
  return row
end

function status.targetRow(node, entries, target, requestState, config, stockIndex, options)
  -- `config` is retained in the public wrapper for older callers; row
  -- construction is target-scoped, so pass the actual stock index/options in
  -- their original slots instead of silently dropping stockMaxAge.
  return applyExactRequestEligibility(statusRows.target(node, entries, target, requestState, stockIndex, options))
end

local function refreshExactStock(row, primary)
  if not row or row.status == "partial" then return row end
  local entry, err, report = stockDirect.refresh(row, primary)
  if entry then
    row.current = entry.current
    row.stockMemoryAt, row.stockMemorySource = entry.at, entry.source
    row.stockMemoryFresh, row.stockMemoryAge, row.stockMemoryReason = true, 0, nil
    row.error = nil
    row.stockDirectCalls = report and report.calls or 0
    lineContract.annotate(row)
    return row
  end
  row.stockMemoryFresh, row.stockDirectCalls = false, report and report.calls or 0
  row.stockMemoryReason = tostring(err or "exact stock lookup unavailable")
  row.error = row.stockMemoryReason
  return row
end

local function chunkedRows(config, options, primary, requestState, safeToCraft, current)
  local targets = config.targets or {}
  local cache = options.cache or {}
  local limit = math.max(1, math.floor(tonumber(options.targetLimit) or #targets))
  local first = math.max(1, math.floor(tonumber(cache.targetCursor) or 1))
  if first > #targets then first = 1 end
  local last = math.min(#targets, first + limit - 1)
  local existing = statusRows.indexByKey(cache.rows)
  local refreshed = {}
  local rowOptions = { stockMaxAge = options.stockMaxAge }
  for index = first, last do
    local target = targets[index]
    local row = status.targetRow(primary, {}, target, requestState, config, nil, rowOptions)
    refreshed[targetKey(target)] = row
  end
  local rows = {}
  for _, target in ipairs(targets) do
    local key = targetKey(target)
    local warmed = refreshed[key]
    local row = statusRows.applyPolicy(warmed or existing[key] or statusRows.placeholder(target, requestState), target, requestState)
    applyExactRequestEligibility(row)
    if warmed then
      -- This is the only slice permitted to touch an AE2 reader. Applying it
      -- to every retained row turns an 8-row warm into O(n²) stock calls.
      refreshExactStock(row, primary)
    elseif not options.requestReady then
      statusRows.applyStockMemory(row, target, primary)
    end
    statusSafety.apply(row, current, config, safeToCraft)
    rows[#rows + 1] = row
  end
  local complete = last >= #targets
  cache.rows, cache.signature = rows, configSignature(config)
  cache.targetSignature = targetSignature(targets)
  cache.targetCursor = complete and 1 or last + 1
  cache.complete = complete
  current.complete, current.targetCursor = complete, cache.targetCursor
  current.status = complete and current.status or "partial"
  return rows, cache
end

local function replayRows(config, cache, requestState, safeToCraft, current, options)
  local existing, rows = statusRows.indexByKey(cache.rows), {}
  for _, target in ipairs(config.targets or {}) do
    local row = statusRows.applyPolicy(existing[targetKey(target)] or statusRows.placeholder(target, requestState), target, requestState)
    applyExactRequestEligibility(row)
    if not (options and options.requestReady) then
      statusRows.applyStockMemory(row, target, (cache.context or {}).primary)
    end
    statusSafety.apply(row, current, config, safeToCraft)
    rows[#rows + 1] = row
  end
  cache.rows, cache.complete, cache.targetCursor, cache.replay = rows, true, 1, nil
  current.complete, current.targetCursor = true, 1
  return rows, cache
end

function status.snapshot(config, options, requestState, safeToCraft)
  options = options or {}
  requestState = requestState or function() return "none" end
  local chunked = tonumber(options.targetLimit) ~= nil
  if chunked then options.cache = prepareChunkCache(config, options) end
  local context = chunked and options.cache.context or nil
  if not context then
    context = buildContext(config)
    if chunked then options.cache.context = context end
  end
  local ae2, primary = context.ae2, context.primary
  local current = cloneCurrent(context)
  current.mode, current.autoEnabled = config.mode, config.autoEnabled ~= false
  current.craftables = ae2.counts and ae2.counts.craftables or 0
  current.requestReady, current.armedTargets = options.requestReady == true, status.armedTargets(config)
  current.targetCount, current.complete = #(config.targets or {}), true
  if chunked then
    local rows, cache
    if options.cache.replay then
      rows, cache = replayRows(config, options.cache, requestState, safeToCraft, current, options)
    else
      rows, cache = chunkedRows(config, options, primary, requestState, safeToCraft, current)
    end
    cacheEpoch.stamp(cache, config, context, (current and current.complete) == true, options.now)
    return { config = config, status = current, targets = rows, cache = cache }
  end
  local rowOptions = { stockMaxAge = options.stockMaxAge }
  local rows = {}
  for _, target in ipairs(config.targets or {}) do
    local row = status.targetRow(primary, {}, target, requestState, config, nil, rowOptions)
    refreshExactStock(row, primary)
    statusSafety.apply(row, current, config, safeToCraft)
    rows[#rows + 1] = row
  end
  return { config = config, status = current, targets = rows }
end

return status
-- Passive row safety is shared by fresh and replayed status rows.  It does not
-- read AE2 itself; the surrounding status pass supplies the observed context.
local cpuWitness = require("oc.ae2.maintainer_cpu_witness")

local safety = {}

local function cpuFinalOutputReason(active)
  local reason = "AE2 CPU final output in flight"
  if active and active.cpuName then reason = reason .. ": " .. tostring(active.cpuName) end
  return reason
end

local function applyPassiveCpuWitness(row, current)
  if not (row and current and row.armed == true) or row.ready ~= true then return row end
  if (tonumber(row.request) or 0) <= 0 then return row end
  local active = cpuWitness.find(current.activeCrafts, row)
  if not active then return row end
  row.ready, row.reason = false, cpuFinalOutputReason(active)
  row.requestState, row.requestPhase = "blocked", "cpu_final_output"
  row.requestStatusReason = "AE2 CPU final output matches target"
  return row
end

function safety.apply(row, current, config, safeToCraft)
  if row.status ~= "partial" then
    local ok, reason = safeToCraft(row, current, config)
    row.ready, row.reason = ok, reason
    applyPassiveCpuWitness(row, current)
  end
  return row
end

return safety
local maintainerQueue = require("oc.ae2.maintainer_queue")
local maintainerRequests = require("oc.ae2.maintainer_requests")
local maintainerRules = require("oc.ae2.maintainer_rules")
local maintainerStatus = require("oc.ae2.maintainer_status")
local workflows = require("oc.ae2.workflows")

local maintainer = {}

-- Workflow policy is the sole durable maintainer authority. Older releases
-- wrote a second maintainer config whose target list and mode were immediately
-- overwritten by workflows on load; keeping that shadow writer caused stale,
-- misleading policy files.
maintainer.path = workflows.path
maintainer.defaults = workflows.defaults

local activeRequests = {}
local lastRequestAt = {}

local function requestState(target)
  return maintainerRequests.state(target, activeRequests)
end

local function pruneMap(map, validKeys)
  for key in pairs(map or {}) do
    if not validKeys[key] then map[key] = nil end
  end
end

local function syncTargetMemory(source)
  local queueIds, requestKeys = {}, {}
  for _, row in ipairs((source and source.targets) or {}) do
    local id = maintainerQueue.id(row)
    queueIds[id] = true
    requestKeys[id] = true
    if row.label then requestKeys[tostring(row.label)] = true end
  end
  maintainerQueue.prune(queueIds)
  pruneMap(lastRequestAt, requestKeys)
  pruneMap(activeRequests, requestKeys)
end

local function configRows(config, reason)
  local rows = {}
  for _, target in ipairs((config and config.targets) or {}) do
    local rowReason = type(reason) == "function" and reason(target) or reason
    rows[#rows + 1] = {
      label = target.label,
      rawLabel = target.rawLabel,
      name = target.name,
      damage = target.damage,
      hasTag = target.hasTag,
      kind = target.kind,
      isFluid = target.isFluid,
      amount = target.amount,
      filter = target.filter,
      craftBinding = target.craftBinding,
      min = tonumber(target.min) or 0,
      craftTo = tonumber(target.craftTo or target.min) or 0,
      batch = target.batch,
      minBatteryRatio = target.minBatteryRatio,
      maxDeficitRatio = target.maxDeficitRatio,
      requireReadyCpu = target.requireReadyCpu,
      cooldown = target.cooldown,
      armed = target.armed == true,
      ready = false,
      craftable = false,
      requestState = "blocked",
      reason = rowReason
    }
  end
  return rows
end

local function observeReport(config, options)
  local reason = config.autoEnabled == false and "global auto off" or "target disarmed"
  local rows = configRows(config, reason)
  return {
    config = config,
    status = {
      mode = config.mode,
      autoEnabled = config.autoEnabled ~= false,
      requestReady = options.requestReady == true,
      armedTargets = maintainerStatus.armedTargets(config),
      targetCount = #(config.targets or {})
    },
    targets = rows,
    alerts = { "Observe only" },
    message = "No craft requested; mode is observe"
  }
end

function maintainer.config()
  local flow = workflows.load()
  local defaults = workflows.defaultConditions or {}
  local autoEnabled = workflows.autoEnabled(flow)
  local armedTargets = workflows.armedCount(flow)
  return {
    autoEnabled = autoEnabled,
    mode = autoEnabled and armedTargets > 0 and "armed" or "observe",
    cooldown = defaults.cooldown,
    minBatteryRatio = defaults.minBatteryRatio,
    maxDeficitRatio = defaults.maxDeficitRatio,
    targets = workflows.asTargets(flow)
  }
end

function maintainer.configSnapshot()
  local config = maintainer.config()
  local report = {
    config = config,
    status = {
      mode = config.mode,
      autoEnabled = config.autoEnabled ~= false,
      requestReady = false,
      armedTargets = maintainerStatus.armedTargets(config),
      targetCount = #(config.targets or {})
    },
    targets = configRows(config, "daemon heartbeat owns live status"),
    alerts = {},
    message = "Daemon config snapshot; daemon heartbeat owns live status"
  }
  syncTargetMemory(report)
  return report
end

function maintainer.setMode(mode)
  local active = maintainer.config().mode == "armed"
  if (mode == "armed") == active then return true end
  return false, "workflow arming is authoritative; change workflow targets instead"
end

function maintainer.safeToCraft(row, status, config)
  return maintainerRules.safeToCraft(row, status, config, lastRequestAt)
end

function maintainer.alerts(status, targets)
  return maintainerRules.alerts(status, targets)
end

function maintainer.snapshot(options)
  options = options or {}
  local config = maintainer.config()
  if options.mode then config.mode = options.mode end
  local report = maintainerStatus.snapshot(config, options, requestState, maintainer.safeToCraft)
  syncTargetMemory(report)
  report.alerts = maintainer.alerts(report.status, report.targets)
  return report
end

function maintainer.run(options)
  options = options or {}
  options.requestReady = true
  if options.skipObserveSnapshot then
    local config = maintainer.config()
    if options.mode then config.mode = options.mode end
    if config.mode ~= "armed" then
      local report = observeReport(config, options)
      syncTargetMemory(report)
      return report
    end
  end
  local report = maintainer.snapshot(options)
  local armed = report.status.mode == "armed"
  if not armed then
    report.message = "No craft requested; mode is observe"
    return report
  end
  return maintainerRequests.submit(report, activeRequests, lastRequestAt, options)
end

function maintainer.poll()
  local requestPoll = require("oc.ae2.maintainer_request_poll")
  return requestPoll.snapshot(activeRequests, lastRequestAt)
end

function maintainer.acknowledge(report)
  local requestPoll = require("oc.ae2.maintainer_request_poll")
  return requestPoll.acknowledge(report)
end

function maintainer.print(report)
  report = report or maintainer.run({ mode = "observe" })
  io.write("AE2 maintainer mode: " .. tostring(report.status.mode) .. "\n")
  io.write(string.format("AE2=%s CPUs=%d Battery=%s\n",
    tostring(report.status.ae2Online),
    tonumber(report.status.readyCpus) or 0,
    tostring(report.status.power.status or "unknown")))
  for _, row in ipairs(report.targets or {}) do
    local state = row.requested and "requested" or row.requestState ~= "none" and row.requestState or row.reason
    io.write(string.format("%s stock=%s min=%s request=%s state=%s\n",
      row.label,
      tostring(row.current or "n/a"),
      tostring(row.min),
      tostring(row.request),
      tostring(state)))
  end
end

return maintainer
local model = require("oc.ae2.workflow_model")
local store = require("oc.ae2.workflow_store")

local catalog = {}
catalog.schema = 5

local function resetCache(cache)
  for key in pairs(cache) do cache[key] = nil end
  cache.schema = catalog.schema
  return cache
end

local function normalizeQuery(value)
  return tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", "")
end

local function dropLegacyDiscovery(cache)
  -- Schema 4 kept native allItems iterators in this table. Dropping every
  -- discovery field is intentional: a foreground search must never hold an
  -- AE2 storage listener or a full-grid traversal alive after it is closed.
  cache.scanEntries, cache.cursor, cache.cursors, cache.iterators = nil, nil, nil, nil
  cache.doneNodes, cache.rawCounts, cache.scanned, cache.progress = nil, nil, nil, nil
end

local function clearSearch(cache)
  cache.entries = {}
  dropLegacyDiscovery(cache)
  cache.complete = false
  cache.capped = false
  cache.error = nil
  cache.matched = nil
  cache.rawCount = nil
  cache.craftIds = nil
  cache.nextCraftId = nil
end

local function stableKey(entry)
  return model.keyFor(entry)
end

local function assignCraftIds(cache, entries, pruneMissing)
  local oldIds = cache.craftIds or {}
  local liveIds = pruneMissing and {} or oldIds
  local maxId = 0
  for _, id in pairs(oldIds) do
    id = tonumber(id) or 0
    if id > maxId then maxId = id end
  end
  cache.craftIds = oldIds
  cache.nextCraftId = math.max(tonumber(cache.nextCraftId) or 1, maxId + 1)
  for _, entry in ipairs(entries or {}) do
    local key = stableKey(entry)
    local id = oldIds[key]
    if not id then
      id = cache.nextCraftId
      cache.nextCraftId = id + 1
    end
    liveIds[key] = id
    if id > maxId then maxId = id end
    entry.rawCraftIndex = entry.craftIndex
    entry.craftId = id
    entry.craftIndex = id
  end
  if pruneMissing then
    cache.craftIds = liveIds
    cache.nextCraftId = maxId + 1
  end
  return entries
end

local function replaceEntries(cache, fresh)
  return assignCraftIds(cache, fresh, true)
end

local function localEntries(cache, config)
  local rows = {}
  for configIndex, flow in ipairs((config and config.workflows) or {}) do
    -- Keep the normalized policy alongside a small identity projection. The
    -- old live-grid catalog could look the policy back up by craft identity;
    -- doing that for every local target turns a 5k-target dashboard into an
    -- O(n^2) scan. One normalized flow per configured row is enough.
    local workflow = model.normalize(flow)
    local entry = {
      label = workflow.label,
      rawLabel = workflow.rawLabel,
      name = workflow.name,
      damage = workflow.damage,
      hasTag = workflow.hasTag,
      kind = workflow.kind,
      isFluid = workflow.isFluid,
      amount = workflow.amount,
      filter = workflow.filter,
      craftBinding = workflow.craftBinding,
      configIndex = configIndex,
      workflow = workflow
    }
    entry.craftable = entry.name ~= nil
    rows[#rows + 1] = entry
  end
  table.sort(rows, function(a, b)
    local left, right = tostring(a.label or ""), tostring(b.label or "")
    if left ~= right then return left < right end
    return stableKey(a) < stableKey(b)
  end)
  cache.entries = replaceEntries(cache, rows)
  cache.query = nil
  cache.matched = #cache.entries
  cache.rawCount = nil
  cache.complete = true
  cache.capped = false
  cache.error = #cache.entries == 0
    and "No managed targets. Live AE2 browsing is disabled for server safety." or nil
end

function catalog.catalog(cache, options)
  options = options or {}
  cache = cache or {}
  if cache.schema ~= catalog.schema then resetCache(cache) end
  local config = store.editableConfig()
  local query = normalizeQuery(options.query)
  -- The dashboard is intentionally a local Managed Targets catalog. GTNH's
  -- allItems/getCraftables paths build a whole-grid snapshot before Lua can
  -- apply a chunk limit, so free-text AE2 browsing belongs in a controlled
  -- diagnostic workflow, never in a foreground HMI.
  dropLegacyDiscovery(cache)
  localEntries(cache, config)
  local rows = {}
  for _, entry in ipairs(cache.entries or {}) do
    local flow = entry.workflow
    rows[#rows + 1] = {
      label = entry.label,
      rawLabel = entry.rawLabel,
      name = entry.name,
      damage = entry.damage,
      hasTag = entry.hasTag,
      kind = entry.kind or (entry.isFluid and "fluid" or "item"),
      isFluid = entry.isFluid == true or entry.kind == "fluid",
      amount = entry.amount,
      filter = entry.filter,
      craftBinding = entry.craftBinding,
      source = entry.source,
      configIndex = entry.configIndex,
      craftId = entry.craftId,
      craftIndex = entry.craftId or entry.craftIndex,
      rawCraftIndex = entry.rawCraftIndex,
      craftable = entry.craftable == true,
      mode = flow and flow.mode or "manual",
      workflow = flow
    }
  end
  return { entries = rows, config = config, cache = cache, capped = cache.capped,
    query = query, maxMatches = #rows,
    matched = cache.matched, rawCount = cache.rawCount, cursor = cache.cursor,
    progress = cache.progress, complete = cache.complete == true, error = cache.error or cache.warmError }
end

function catalog.dispose(cache)
  if type(cache) ~= "table" then return true end
  clearSearch(cache)
  cache.schema = catalog.schema
  return true
end

return catalog
-- Public workflow editor facade. Focused helpers own exact binding and typed
-- condition patches; this file owns the canonical config/store transition.
local binding = require("oc.ae2.request_binding")
local choices = require("oc.ae2.workflow_choices")
local conditions = require("oc.ae2.workflow_editor_conditions")
local exact = require("oc.ae2.workflow_editor_binding")
local model = require("oc.ae2.workflow_model")
local store = require("oc.ae2.workflow_store")

local editor = {}

local function editableConfig()
  local config, err = store.editableConfig()
  if not config then return nil, err end
  return config
end

local function workflowFor(config, entry)
  return model.workflowFor(config, entry) or (entry and entry.workflow)
end

local function upsertRow(config, entry, patch)
  if not config then
    local err
    config, err = editableConfig()
    if not config then return nil, err end
  end
  patch = patch or {}
  local row = model.workflowFor(config, entry)
  if row then
    model.copyIdentity(row, entry)
    for key, value in pairs(patch) do row[key] = value end
    return config
  end
  row = model.normalize(entry)
  for key, value in pairs(patch) do row[key] = value end
  config.workflows[#config.workflows + 1] = row
  return config
end

function editor.upsert(config, entry, patch)
  local err
  config, err = upsertRow(config, entry, patch)
  if not config then return false, err end
  return store.saveConfig(config, store.hasPending())
end

function editor.toggleAuto(entry)
  local config, err = editableConfig()
  if not config then return false, err end
  local flow = model.normalize(workflowFor(config, entry) or entry or {})
  if flow.locked then return false, "line contract locked" end
  local mode = flow.mode == "auto" and "manual" or "auto"
  local patch = { mode = mode, lineAuthority = mode == "auto" and "auto" or "observe" }
  if mode == "auto" then
    patch.alertBelow = tonumber(flow.alertBelow or flow.minStock) or 100
    patch.minStock, patch.craftTo = patch.alertBelow, patch.alertBelow
    patch.maxRequest = tonumber(flow.maxRequest or flow.batch) or 1
    patch.batch = patch.maxRequest
  end
  return editor.upsert(config, entry, patch)
end

function editor.toggleArmed(entry)
  local config, err = editableConfig()
  if not config then return false, err end
  local flow = model.normalize(workflowFor(config, entry) or entry or {})
  local nextArmed = not (flow.armed == true)
  if nextArmed then
    local bindErr = binding.error(flow)
    if bindErr then return false, bindErr end
  end
  local patch = { armed = nextArmed, mode = "auto" }
  if nextArmed and flow.mode ~= "auto" and flow.lineAuthority == "observe" then patch.lineAuthority = "auto" end
  return editor.upsert(config, entry, patch)
end

function editor.disarmAll()
  local config, err = editableConfig()
  if not config then return false, err end
  for _, row in ipairs(config.workflows or {}) do row.armed = false end
  return store.saveConfig(config, store.hasPending())
end

function editor.setAllArmed(enabled, options)
  local config, err = editableConfig()
  if not config then return false, err end
  options = options or {}
  local limit = math.max(1, math.floor(tonumber(options.limit) or 8))
  local startIndex = math.max(1, math.floor(tonumber(options.startIndex) or 1))
  local rows, checked, changed, blocked, index = config.workflows or {}, 0, 0, 0, startIndex
  while index <= #rows and checked < limit do
    local row = model.normalize(rows[index])
    if row.mode == "auto" then
      checked = checked + 1
      local bindErr = enabled == true and binding.error(row) or nil
      if bindErr then blocked = blocked + 1 else
        if rows[index].armed ~= (enabled == true) then changed = changed + 1 end
        rows[index].armed = enabled == true
      end
    end
    index = index + 1
  end
  local progress = { startIndex = startIndex, nextIndex = index, limit = limit, checked = checked,
    changed = changed, blocked = blocked, total = #rows, complete = index > #rows }
  progress.complete = progress.complete == true
  if changed == 0 then return true, nil, config, progress end
  local ok, saveErr, saved = store.saveConfig(config, store.hasPending())
  return ok, saveErr, saved or config, progress
end

function editor.toggleGlobalAuto()
  local config, err = editableConfig()
  if not config then return false, err end
  config.autoEnabled = not (config.autoEnabled ~= false)
  return store.saveConfig(config, store.hasPending())
end

function editor.setGlobalAuto(enabled)
  local config, err = editableConfig()
  if not config then return false, err end
  config.autoEnabled = enabled ~= false
  return store.saveConfig(config, store.hasPending())
end

function editor.bindExact(index, kind, name, damage) return exact.bind(index, kind, name, damage) end
function editor.rebindExact(index, kind, name, damage, confirmation)
  return exact.rebind(index, kind, name, damage, confirmation)
end

function editor.adjust(entry, field, delta)
  local loaded, loadErr = editableConfig()
  if not loaded then return false, loadErr end
  local config, err = conditions.adjustedConfig(loaded, entry, field, delta, upsertRow, workflowFor)
  if not config then return false, err end
  return store.saveConfig(config, false)
end

function editor.adjustPending(entry, field, delta)
  local loaded, loadErr = editableConfig()
  if not loaded then return false, loadErr end
  local config, err = conditions.adjustedConfig(loaded, entry, field, delta, upsertRow, workflowFor)
  if not config then return false, err end
  store.setPending(config)
  return true, nil, config
end

function editor.setValue(entry, field, value)
  local patch, err = conditions.valuePatch(field, value)
  if not patch then return false, err end
  local loaded, loadErr = editableConfig()
  if not loaded then return false, loadErr end
  local flow = model.normalize(workflowFor(loaded, entry) or entry)
  if flow.locked and field ~= "locked" then return false, "line contract locked" end
  local config
  config, err = upsertRow(loaded, entry, patch)
  if not config then return false, err end
  return store.saveConfig(config, true)
end

function editor.setChoice(entry, field, value)
  local loaded, loadErr = editableConfig()
  if not loaded then return false, loadErr end
  local flow = model.normalize(workflowFor(loaded, entry) or entry)
  if flow.locked and field ~= "locked" then return false, "line contract locked" end
  local patch, err = choices.patch(field, value, flow)
  if not patch then return false, err end
  local config
  config, err = upsertRow(loaded, entry, patch)
  if not config then return false, err end
  return store.saveConfig(config, true)
end

function editor.delete(entry)
  local loaded, loadErr = editableConfig()
  if not loaded then return false, loadErr end
  local config = model.compactConfig(loaded)
  local target = model.workflowFor(config, entry)
  if not target then return false, "workflow target not found" end
  local rows = {}
  for _, row in ipairs(config.workflows or {}) do if row ~= target then rows[#rows + 1] = row end end
  config.workflows = rows
  return store.saveConfig(config, true)
end

return editor
-- Local exact-identity migration/correction. This module deliberately has no
-- AE2 component dependency: binding is a config write, never discovery.
local binding = require("oc.ae2.request_binding")
local model = require("oc.ae2.workflow_model")
local store = require("oc.ae2.workflow_store")

local exact = {}

local function editableConfig()
  local config, err = store.editableConfig()
  if not config then return nil, err end
  return config
end

local function bindingIndex(value)
  local index = tonumber(value)
  if not index or index < 1 or index ~= math.floor(index) then
    return nil, "workflow index must be a positive whole number"
  end
  return index
end

local function bindingKind(value)
  local kind = tostring(value or ""):lower()
  if kind ~= "item" and kind ~= "fluid" then return nil, "binding kind must be item or fluid" end
  return kind
end

local function bindingName(value)
  local name = tostring(value or "")
  if not name:match("^[a-z0-9_.%-]+:[a-z0-9_./%-]+$") then
    return nil, "registry name must look like namespace:path"
  end
  return name
end

local function bindingDamage(kind, value)
  if kind == "fluid" then
    if value ~= "-" then return nil, "fluid damage must be -" end
    return nil
  end
  local damage = tonumber(value)
  if not damage or damage ~= damage or damage < 0 or damage >= math.huge or damage ~= math.floor(damage) then
    return nil, "item damage must be a non-negative whole number"
  end
  return damage
end

local function bindingEntry(kind, name, damage)
  local filter = { name = name }
  if kind == "item" then filter.damage = damage end
  return { name = name, damage = damage, hasTag = false, kind = kind,
    isFluid = kind == "fluid", filter = filter }
end

local function conflictingExactBinding(config, index, kind, name, damage)
  for otherIndex, other in ipairs((config and config.workflows) or {}) do
    if otherIndex ~= index and not binding.tagged(other) and tostring(other.name or "") == name then
      local normalized = model.normalize(other)
      if normalized.kind == kind and (kind == "fluid" or tonumber(normalized.damage) == damage) then
        return otherIndex
      end
    end
  end
  return nil
end

local function write(index, kind, name, damage, rebind)
  local parsedIndex, indexErr = bindingIndex(index)
  if not parsedIndex then return false, indexErr end
  local parsedKind, kindErr = bindingKind(kind)
  if not parsedKind then return false, kindErr end
  local parsedName, nameErr = bindingName(name)
  if not parsedName then return false, nameErr end
  local parsedDamage, damageErr = bindingDamage(parsedKind, damage)
  if damageErr then return false, damageErr end
  local config, err = editableConfig()
  if not config then return false, err end
  local row = (config.workflows or {})[parsedIndex]
  if not row then return false, "workflow index " .. tostring(parsedIndex) .. " does not exist" end
  if binding.tagged(row) then return false, "tagged workflows cannot be migrated by this command" end
  local normalized = model.normalize(row)
  if normalized.locked then return false, "line contract locked" end
  if normalized.armed then return false, "workflow index " .. tostring(parsedIndex) .. " is armed; disarm it before binding" end
  local hasBinding = row.name and tostring(row.name) ~= ""
  if not rebind and hasBinding then return false, "workflow index " .. tostring(parsedIndex) .. " already has an exact binding" end
  if rebind and not hasBinding then return false, "workflow index " .. tostring(parsedIndex) .. " has no exact binding; use --bind first" end
  local conflict = conflictingExactBinding(config, parsedIndex, parsedKind, parsedName, parsedDamage)
  if conflict then return false, "exact identity already belongs to workflow index " .. tostring(conflict) end
  local entry = bindingEntry(parsedKind, parsedName, parsedDamage)
  model.copyIdentity(row, entry)
  row.damage, row.hasTag = parsedDamage, false
  row.kind, row.isFluid, row.filter = parsedKind, parsedKind == "fluid", entry.filter
  local ok, saveErr, saved = store.saveConfig(config, store.hasPending())
  if not ok then return false, saveErr end
  return true, nil, saved, {
    action = rebind and "rebound" or "bound", index = parsedIndex, label = row.label,
    kind = parsedKind, name = parsedName, damage = parsedDamage
  }
end

function exact.bind(index, kind, name, damage) return write(index, kind, name, damage, false) end

function exact.rebind(index, kind, name, damage, confirmation)
  if confirmation ~= "CONFIRM" then return false, "rebind requires the final CONFIRM token" end
  return write(index, kind, name, damage, true)
end

return exact
-- Workflow condition parsing and patch construction. It has no store access:
-- the editor facade owns the single canonical save/pending-write boundary.
local choices = require("oc.ae2.workflow_choices")
local model = require("oc.ae2.workflow_model")

local conditions = {}

local function adjustNumber(value, delta, step, min, max)
  value = (tonumber(value) or 0) + ((tonumber(delta) or 0) * step)
  if min and value < min then value = min end
  if max and value > max then value = max end
  return value
end

function conditions.valuePatch(field, value)
  local number = (field == "minStock" or field == "batch" or field == "alertBelow" or field == "maxRequest") and model.parseQuantity(value)
    or field == "cooldown" and model.parseDuration(value) or tonumber(value)
  if not number then return nil, "number required" end
  if field == "batch" or field == "maxRequest" then
    number = model.clampQuantity(value, 1)
  elseif field == "cooldown" then
    number = model.clampCooldown(value)
  elseif field == "minStock" or field == "alertBelow" then
    number = model.clampQuantity(value, 0)
  elseif field == "minBatteryRatio" then
    if number < 0 then number = 0 end
    if number > 1 then number = 1 end
  elseif field == "maxDeficitRatio" then
    if number < 0 then number = 0 end
    if number > 10 then number = 10 end
  else
    return nil, "typed edit unsupported"
  end
  if field == "minStock" or field == "alertBelow" then return { alertBelow = number, minStock = number, craftTo = number } end
  if field == "batch" or field == "maxRequest" then return { maxRequest = number, batch = number } end
  return { [field] = number }
end

function conditions.adjustedConfig(config, entry, field, delta, upsert, workflowFor)
  if not entry or not field then return false, "no workflow selected" end
  local flow = model.normalize(workflowFor(config, entry) or entry)
  local patch = {}
  if flow.locked and field ~= "locked" then return false, "line contract locked" end
  if field == "lineIntent" then
    patch.lineIntent = choices.nextIntent(flow.lineIntent, delta)
  elseif field == "lineAuthority" then
    patch.lineAuthority = choices.nextAuthority(flow.lineAuthority, delta)
    patch.mode = patch.lineAuthority == "auto" and "auto" or flow.mode
  elseif field == "alertEnabled" or field == "locked" or field == "dangerUnlocked" then
    patch[field] = not flow[field]
  elseif field == "requireReadyCpu" then
    patch[field] = not flow.requireReadyCpu
  elseif field == "minBatteryRatio" then
    patch[field] = adjustNumber(flow[field], delta, 0.05, 0, 1)
  elseif field == "maxDeficitRatio" then
    patch[field] = adjustNumber(flow[field], delta, 0.05, 0, 10)
  elseif field == "cooldown" then
    patch[field] = adjustNumber(flow[field], delta, 30, model.minimumCooldown, model.maxCooldown)
  elseif field == "batch" or field == "maxRequest" then
    patch.maxRequest = adjustNumber(flow.maxRequest, delta, 10, 1, nil)
    patch.batch = patch.maxRequest
  elseif field == "minStock" or field == "alertBelow" then
    patch.alertBelow = adjustNumber(flow.alertBelow, delta, 10, 0, nil)
    patch.minStock, patch.craftTo = patch.alertBelow, patch.alertBelow
  else
    return false, "unknown condition"
  end
  return upsert(config, entry, patch)
end

return conditions
local choices = {}

choices.intents = { "maintain_buffer", "push_max", "recipe_governed", "manual_only" }
choices.authorities = { "observe", "alert", "suggest", "auto" }

local function contains(values, wanted)
  for _, value in ipairs(values) do
    if value == wanted then return true end
  end
  return false
end

local function nextCycle(values, current, delta)
  local selected = 1
  for index, value in ipairs(values) do
    if value == current then selected = index; break end
  end
  selected = selected + ((tonumber(delta) or 0) < 0 and -1 or 1)
  if selected < 1 then selected = #values end
  if selected > #values then selected = 1 end
  return values[selected]
end

function choices.nextIntent(current, delta)
  return nextCycle(choices.intents, current, delta)
end

function choices.nextAuthority(current, delta)
  return nextCycle(choices.authorities, current, delta)
end

function choices.patch(field, value, flow)
  value = tostring(value or "")
  if field == "lineIntent" then
    if not contains(choices.intents, value) then return nil, "unknown line intent" end
    return { lineIntent = value }
  elseif field == "lineAuthority" then
    if not contains(choices.authorities, value) then return nil, "unknown line authority" end
    return { lineAuthority = value, mode = value == "auto" and "auto" or flow.mode }
  end
  return nil, "direct selector unsupported"
end

return choices
local contract = {}

contract.maxQuantity = 1e15
contract.maxSafeRequest = 2147483647

local quantitySuffixes = { k = 1e3, m = 1e6, b = 1e9, t = 1e12, p = contract.maxQuantity }

local intents = {
  maintain_buffer = true,
  push_max = true,
  recipe_governed = true,
  manual_only = true
}

local intentAliases = {
  maintain = "maintain_buffer",
  maintain_buffer = "maintain_buffer",
  buffer = "maintain_buffer",
  stock = "maintain_buffer",
  max = "push_max",
  max_request = "push_max",
  push_max = "push_max",
  line_max = "push_max",
  recipe = "recipe_governed",
  recipe_governed = "recipe_governed",
  governed = "recipe_governed",
  manual = "manual_only",
  manual_only = "manual_only"
}

local authorities = {
  observe = true,
  alert = true,
  suggest = true,
  auto = true
}

local authorityAliases = {
  off = "observe",
  observe = "observe",
  watch = "observe",
  alert = "alert",
  alarm = "alert",
  suggest = "suggest",
  approve = "suggest",
  auto = "auto",
  submit = "auto",
  automatic = "auto"
}

local function key(value)
  return tostring(value or ""):lower():gsub("[%s%-]+", "_")
end

local function parseQuantity(value)
  if type(value) == "number" then return value end
  local text = tostring(value or ""):gsub(",", ""):gsub("%s+", "")
  local suffix = text:match("([KkMmBbTtPp])$")
  if suffix then
    local base = tonumber(text:sub(1, -2))
    if not base then return nil end
    return base * quantitySuffixes[suffix:lower()]
  end
  return tonumber(text)
end

local function quantity(value, minimum, fallback)
  local number = parseQuantity(value)
  if number == nil then number = fallback end
  number = tonumber(number)
  if number == nil then return fallback end
  number = math.floor(number)
  minimum = minimum or 0
  if number < minimum then number = minimum end
  if number > contract.maxQuantity then number = contract.maxQuantity end
  return number
end

local function canonicalIntent(value)
  local resolved = intentAliases[key(value)]
  return intents[resolved] and resolved or "maintain_buffer"
end

local function canonicalAuthority(value, mode)
  local resolved = authorityAliases[key(value)]
  if authorities[resolved] then return resolved end
  return mode == "auto" and "auto" or "observe"
end

function contract.normalize(row)
  row = row or {}
  local mode = row.mode == "manual" and "manual" or "auto"
  local alertBelow = quantity(row.alertBelow or row.minStock or row.min or row.craftTo, 0, 0)
  local maxRequest = quantity(row.maxRequest or row.batch or row.request or row.craftTo, 1, 1)
  local recipeMax = quantity(row.recipeMax or row.learnedRecipeMax, 1, nil)
  local basis = row.maxBasis
  if basis ~= "recipe_ceiling" and basis ~= "learned_ceiling" and basis ~= "cpu_boundary" then
    basis = "operator_cap"
  end
  return {
    lineIntent = canonicalIntent(row.lineIntent or row.intent),
    lineAuthority = canonicalAuthority(row.lineAuthority or row.authority, mode),
    alertEnabled = row.alertEnabled ~= false,
    alertBelow = alertBelow,
    maxRequest = maxRequest,
    recipeMax = recipeMax,
    maxBasis = basis,
    confidence = tostring(row.confidence or "cap_limited"),
    locked = row.locked == true,
    dangerUnlocked = row.dangerUnlocked == true
  }
end

local function stateForAuthority(authority)
  if authority == "observe" then return "observe", "observe authority; no auto submit" end
  if authority == "alert" then return "alert", "alert authority; no auto submit" end
  if authority == "suggest" then return "suggest", "suggest authority; no auto submit" end
  return nil
end

local function amountFor(line)
  local amount = line.maxRequest
  local basis, confidence = "operator_cap", line.confidence or "cap_limited"
  if line.lineIntent == "recipe_governed" then
    if line.recipeMax and line.recipeMax > 0 then
      amount, basis, confidence = math.min(line.maxRequest, line.recipeMax), "recipe_ceiling", "recipe_known"
    else
      basis, confidence = "operator_cap", "recipe_unknown"
    end
  end
  if amount < 0 then amount = 0 end
  return amount, basis, confidence
end

function contract.requestAmount(row)
  row = row or {}
  local line = contract.normalize(row)
  local authorityState, authorityReason = stateForAuthority(line.lineAuthority)
  if authorityState then return 0, authorityReason, authorityState, line.maxBasis, line.confidence end
  if line.lineIntent == "manual_only" then
    return 0, "manual-only line contract", "manual_only", line.maxBasis, line.confidence
  end
  if line.maxRequest > contract.maxSafeRequest and not line.dangerUnlocked then
    return 0, "request cap above signed-int safety boundary", "danger_locked", "operator_cap", "unsafe_cap"
  end

  local current = tonumber(row.current)
  local boundary = tonumber(row.alertBelow or row.min or row.minStock or line.alertBelow) or line.alertBelow
  local amount, basis, confidence = amountFor(line)
  if line.lineIntent == "recipe_governed" and confidence == "recipe_unknown" then
    return 0, "recipe ceiling unknown; auto blocked", "recipe_unknown", basis, confidence
  end
  if line.lineIntent == "push_max" then
    return amount, "push max cooldown request", "ready", basis, confidence
  end
  if current == nil then
    return amount, "stock unknown; showing request cap", "stock_unknown", basis, confidence
  end
  if current >= boundary then
    return 0, "stock satisfies alert boundary", "satisfied", basis, confidence
  end
  if line.lineIntent == "recipe_governed" then
    return amount, "recipe ceiling below alert boundary", "ready", basis, confidence
  end
  return amount, "below alert boundary", "ready", basis, confidence
end

function contract.summary(row)
  row = row or {}
  local amount = tonumber(row.request or row.maxRequest or row.batch) or 0
  local boundary = tonumber(row.alertBelow or row.min or row.minStock) or 0
  local state = tostring(row.lineState or "unknown")
  return state .. " | max " .. tostring(amount) .. " below " .. tostring(boundary)
end

function contract.annotate(row)
  row = row or {}
  local line = contract.normalize(row)
  for keyName, value in pairs(line) do row[keyName] = value end
  local amount, reason, state, basis, confidence = contract.requestAmount(row)
  row.request = amount
  row.lineReason = reason
  row.lineState = state
  row.maxBasis = basis or row.maxBasis
  row.confidence = confidence or row.confidence
  row.lineSummary = contract.summary(row)
  return row
end

function contract.intentLabel(value)
  value = canonicalIntent(value)
  if value == "push_max" then return "Push Max" end
  if value == "recipe_governed" then return "Recipe Governed" end
  if value == "manual_only" then return "Manual Only" end
  return "Maintain Buffer"
end

function contract.authorityLabel(value)
  value = canonicalAuthority(value)
  if value == "alert" then return "Alert" end
  if value == "suggest" then return "Suggest" end
  if value == "auto" then return "Auto Submit" end
  return "Observe"
end

function contract.intentHint(value)
  value = canonicalIntent(value)
  if value == "push_max" then return "Submit Max Request every cooldown while armed and gated." end
  if value == "recipe_governed" then return "Use Recipe Ceiling; block auto until the ceiling is known." end
  if value == "manual_only" then return "Manual button only; daemon never submits." end
  return "Submit Max Request only when stock is below Alert Below."
end

function contract.authorityHint(value)
  value = canonicalAuthority(value)
  if value == "alert" then return "Alarm only; no craft submit." end
  if value == "suggest" then return "Suggest only; no craft submit." end
  if value == "auto" then return "Daemon may submit when intent gates pass." end
  return "Watch only; no alarm or submit."
end

return contract
-- Public workflow-model facade. Identity, numeric grammar, and compaction are
-- split into cohesive helpers so this deploy file stays safe to paste by hand.
local binding = require("oc.ae2.request_binding")
local compact = require("oc.ae2.workflow_model_compact")
local identity = require("oc.ae2.workflow_model_identity")
local lineContract = require("oc.ae2.line_contract")
local numbers = require("oc.ae2.workflow_model_numbers")

local model = {}

model.path = "/etc/oc-ae2-workflows.cfg"
model.defaults = {
  { label = "Steel Ingot", mode = "auto", lineIntent = "maintain_buffer", lineAuthority = "auto", alertBelow = 100, maxRequest = 100, minStock = 100, craftTo = 100, batch = 100 },
  { label = "Aluminium Ingot", mode = "auto", lineIntent = "maintain_buffer", lineAuthority = "auto", alertBelow = 100, maxRequest = 100, minStock = 100, craftTo = 100, batch = 100 },
  { label = "Stainless Steel Ingot", mode = "auto", lineIntent = "maintain_buffer", lineAuthority = "auto", alertBelow = 100, maxRequest = 100, minStock = 100, craftTo = 100, batch = 100 },
  { label = "Titanium Ingot", mode = "auto", lineIntent = "maintain_buffer", lineAuthority = "auto", alertBelow = 100, maxRequest = 100, minStock = 100, craftTo = 100, batch = 100 },
  { label = "Tungstensteel Ingot", mode = "auto", lineIntent = "maintain_buffer", lineAuthority = "auto", alertBelow = 100, maxRequest = 100, minStock = 100, craftTo = 100, batch = 100 }
}
model.defaultConditions = {
  lineIntent = "maintain_buffer", lineAuthority = "auto", alertEnabled = true,
  minBatteryRatio = 0.25, maxDeficitRatio = 1.25, requireReadyCpu = true, cooldown = 600
}
model.minimumCooldown = 600
model.maxCooldown = 604800
model.maxQuantity = 1e15
model.manualTemplate = { mode = "manual" }
model.conditionFields = {
  "lineIntent", "lineAuthority", "alertBelow", "maxRequest", "alertEnabled",
  "requireReadyCpu", "minBatteryRatio", "maxDeficitRatio", "cooldown", "locked"
}

function model.parseQuantity(value) return numbers.parseQuantity(value, model.maxQuantity) end
function model.clampQuantity(value, minimum) return numbers.clampQuantity(value, minimum, model.maxQuantity) end
function model.parseDuration(value) return numbers.parseDuration(value, model.maxCooldown) end
function model.clampCooldown(value) return numbers.clampCooldown(value, model.minimumCooldown, model.maxCooldown) end

function model.labelKey(value) return identity.labelKey(value) end
function model.keyFor(value) return identity.keyFor(value) end
function model.keysFor(value) return identity.keysFor(value) end
function model.sameKey(left, right) return identity.sameKey(left, right) end
function model.workflowFor(config, entry) return identity.workflowFor(config, entry) end
function model.copyIdentity(row, entry) return identity.copyIdentity(row, entry) end

function model.normalize(row)
  row = row or {}
  local cooldown = model.clampCooldown(row.cooldown or model.defaultConditions.cooldown) or model.defaultConditions.cooldown
  local minSource = row.alertBelow
  if minSource == nil then minSource = row.minStock end
  if minSource == nil then minSource = row.min end
  if minSource == nil then minSource = row.craftTo end
  local alertBelow = model.clampQuantity(minSource or 0, 0) or 0
  local maxRequest = model.clampQuantity(row.maxRequest or row.batch or row.request or row.craftTo or 1, 1) or 1
  local kind, mode = identity.kindFor(row), row.mode == "auto" and "auto" or "manual"
  local line = lineContract.normalize({
    mode = mode, lineIntent = row.lineIntent, intent = row.intent,
    lineAuthority = row.lineAuthority, authority = row.authority,
    alertEnabled = row.alertEnabled, alertBelow = alertBelow, maxRequest = maxRequest,
    maxBasis = row.maxBasis, confidence = row.confidence,
    recipeMax = row.recipeMax or row.learnedRecipeMax, locked = row.locked,
    dangerUnlocked = row.dangerUnlocked
  })
  return {
    label = tostring(row.label or row.name or "unknown"), rawLabel = row.rawLabel,
    name = row.name, damage = row.damage, hasTag = binding.tagged(row.hasTag),
    kind = kind, isFluid = kind == "fluid", amount = row.amount, filter = row.filter,
    craftBinding = binding.copyCapacityBinding(row),
    mode = mode, lineIntent = line.lineIntent, lineAuthority = line.lineAuthority,
    alertEnabled = line.alertEnabled, alertBelow = line.alertBelow, maxRequest = line.maxRequest,
    maxBasis = line.maxBasis, confidence = line.confidence, recipeMax = line.recipeMax,
    dangerUnlocked = line.dangerUnlocked, locked = line.locked,
    minStock = line.alertBelow, craftTo = line.alertBelow, batch = line.maxRequest,
    minBatteryRatio = tonumber(row.minBatteryRatio or model.defaultConditions.minBatteryRatio),
    maxDeficitRatio = tonumber(row.maxDeficitRatio or model.defaultConditions.maxDeficitRatio),
    requireReadyCpu = row.requireReadyCpu ~= false, cooldown = cooldown, armed = row.armed == true
  }
end

function model.defaultConfig()
  local rows = {}
  for index, row in ipairs(model.defaults) do rows[index] = model.normalize(row) end
  return { autoEnabled = true, workflows = rows }
end

function model.compactConfig(config)
  return compact.config(config, model.defaultConfig, model.normalize, identity)
end

function model.byKey(config)
  local map = {}
  for _, row in ipairs((config or model.defaultConfig()).workflows or {}) do
    row = model.normalize(row)
    for _, key in ipairs(model.keysFor(row)) do map[key] = row end
  end
  return map
end

function model.asTargets(config)
  local rows = {}
  for _, row in ipairs((config or model.defaultConfig()).workflows or {}) do
    row = model.normalize(row)
    if row.mode == "auto" then
      rows[#rows + 1] = {
        label = row.label, rawLabel = row.rawLabel, name = row.name, damage = row.damage,
        hasTag = row.hasTag, kind = row.kind, isFluid = row.isFluid, amount = row.amount,
        filter = row.filter, craftBinding = binding.copyCapacityBinding(row),
        min = row.minStock, alertBelow = row.alertBelow,
        craftTo = row.craftTo, batch = row.batch, maxRequest = row.maxRequest,
        lineIntent = row.lineIntent, lineAuthority = row.lineAuthority, alertEnabled = row.alertEnabled,
        maxBasis = row.maxBasis, confidence = row.confidence, recipeMax = row.recipeMax,
        dangerUnlocked = row.dangerUnlocked, locked = row.locked,
        minBatteryRatio = row.minBatteryRatio, maxDeficitRatio = row.maxDeficitRatio,
        requireReadyCpu = row.requireReadyCpu, cooldown = row.cooldown, armed = row.armed
      }
    end
  end
  return rows
end

function model.armedCount(config)
  local count = 0
  for _, row in ipairs((config or model.defaultConfig()).workflows or {}) do
    row = model.normalize(row)
    if row.mode == "auto" and row.armed then count = count + 1 end
  end
  return count
end

function model.autoEnabled(config) return config == nil or config.autoEnabled ~= false end

return model
-- Numeric parsing is deliberately independent from workflow identity/policy.
-- This lets the public workflow model stay small enough for reliable OpenOS
-- paste/deploy while retaining its compact quantity and duration grammar.
local numbers = {}

function numbers.parseQuantity(value, maxQuantity)
  if type(value) == "number" then return value end
  local text = tostring(value or ""):gsub(",", ""):gsub("%s+", "")
  local suffix = text:match("([KkMmBbTtPp])$")
  if suffix then
    local base = tonumber(text:sub(1, -2))
    if not base then return nil end
    local factors = { k = 1e3, m = 1e6, b = 1e9, t = 1e12, p = maxQuantity }
    return base * factors[suffix:lower()]
  end
  return tonumber(text)
end

function numbers.clampQuantity(value, minimum, maxQuantity)
  local number = numbers.parseQuantity(value, maxQuantity)
  if not number then return nil end
  number = math.floor(number)
  minimum = minimum or 0
  if number < minimum then number = minimum end
  if number > maxQuantity then number = maxQuantity end
  return number
end

function numbers.parseDuration(value, maxCooldown)
  if type(value) == "number" then return value end
  local text = tostring(value or ""):gsub(",", ""):gsub("%s+", "")
  local suffix = text:match("([SsMmHhDdWw])$")
  if suffix then
    local base = tonumber(text:sub(1, -2))
    if not base then return nil end
    local factors = { s = 1, m = 60, h = 3600, d = 86400, w = maxCooldown }
    return base * factors[suffix:lower()]
  end
  return tonumber(text)
end

function numbers.clampCooldown(value, minimumCooldown, maxCooldown)
  local number = numbers.parseDuration(value, maxCooldown)
  if not number then return nil end
  number = math.floor(number)
  if number < minimumCooldown then number = minimumCooldown end
  if number > maxCooldown then number = maxCooldown end
  return number
end

return numbers
-- Exact workflow identity and legacy-label reconciliation live together so
-- policy editing never needs to duplicate item/fluid/tag comparison rules.
local binding = require("oc.ae2.request_binding")

local identity = {}

function identity.labelKey(value)
  return tostring(value and (value.label or value.rawLabel or value.name) or ""):lower()
end

local function variantLabel(value) return identity.labelKey(value) end
local function fluidProxy(value)
  return tostring(value and (value.rawLabel or value.label or value.name) or ""):find("^[Dd]rops? of%s+") ~= nil
end

function identity.kindFor(value)
  return value and (fluidProxy(value) and "fluid" or value.kind or (value.isFluid and "fluid" or "item")) or "item"
end

function identity.keyFor(value)
  if value and value.name then
    return tostring(identity.kindFor(value)) .. ":" .. tostring(value.name) .. ":"
      .. tostring(value.damage or "") .. ":" .. tostring(binding.tagged(value.hasTag)) .. ":" .. variantLabel(value)
  end
  return identity.labelKey(value)
end

local function addKey(out, seen, key)
  key = tostring(key or "")
  if key ~= "" and not seen[key] then seen[key], out[#out + 1] = true, key end
end

function identity.keysFor(value)
  local out, seen = {}, {}
  if value and value.name then addKey(out, seen, identity.keyFor(value)) else addKey(out, seen, identity.labelKey(value)) end
  return out
end

function identity.explicitKind(value)
  return value and (fluidProxy(value) and "fluid" or value.kind or (value.isFluid and "fluid" or nil)) or nil
end

function identity.sameKey(left, right)
  if left and right and left.name and right.name then return identity.keyFor(left) == identity.keyFor(right) end
  local leftKind, rightKind = identity.explicitKind(left), identity.explicitKind(right)
  if leftKind and rightKind and leftKind ~= rightKind then return false end
  local wanted = {}
  for _, key in ipairs(identity.keysFor(left)) do wanted[key] = true end
  for _, key in ipairs(identity.keysFor(right)) do if wanted[key] then return true end end
  return false
end

function identity.compatibleFlow(flow, entry)
  local flowKind, entryKind = identity.explicitKind(flow), identity.explicitKind(entry)
  return not (flowKind and entryKind and flowKind ~= entryKind)
end

function identity.workflowFor(config, entry)
  if not entry then return nil end
  local fallback, fallbackCount = nil, 0
  for _, row in ipairs((config or {}).workflows or {}) do
    if identity.sameKey(row, entry) then return row, "exact" end
    if entry.name and not row.name and identity.compatibleFlow(row, entry)
      and identity.labelKey(row) == identity.labelKey(entry) then
      fallback, fallbackCount = row, fallbackCount + 1
    end
  end
  if fallbackCount == 1 then return fallback, "legacy_label" end
  return nil
end

function identity.copyIdentity(row, entry)
  if not (row and entry) then return row end
  row.label = entry.label or row.label
  if entry.rawLabel ~= nil then row.rawLabel = entry.rawLabel end
  if entry.name ~= nil then row.name = entry.name end
  if entry.damage ~= nil then row.damage = entry.damage end
  if entry.hasTag ~= nil then row.hasTag = binding.tagged(entry.hasTag) end
  if entry.kind ~= nil or entry.isFluid ~= nil or entry.name ~= nil or fluidProxy(entry) then
    local kind = identity.kindFor(entry)
    row.kind, row.isFluid = kind, kind == "fluid"
  end
  if entry.amount ~= nil then row.amount = entry.amount end
  if entry.filter ~= nil then row.filter = entry.filter end
  local marker = binding.copyCapacityBinding(entry)
  if marker then row.craftBinding = marker
  else row.craftBinding = nil end
  return row
end

return identity
-- Canonical config compaction is isolated because it is the one workflow
-- operation that must reconcile exact rows and legacy label-only rows.
local compact = {}

local policyFields = {
  "mode", "lineIntent", "lineAuthority", "alertEnabled", "alertBelow", "maxRequest",
  "maxBasis", "confidence", "recipeMax", "dangerUnlocked", "locked",
  "minStock", "craftTo", "batch", "minBatteryRatio", "maxDeficitRatio",
  "requireReadyCpu", "cooldown", "armed"
}

local function copyPolicy(target, source)
  for _, key in ipairs(policyFields) do target[key] = source[key] end
  return target
end

local function compactIndex(row) return tonumber(row and row._compactIndex) or 0 end

function compact.config(config, defaultConfig, normalize, identity)
  config = config or defaultConfig()
  local exact, exactByLabel, legacy, keep = {}, {}, {}, {}
  for index, row in ipairs(config.workflows or {}) do
    row = normalize(row)
    row._compactIndex = index
    if row.name then
      local key = identity.keyFor(row)
      if exact[key] then
        if index > compactIndex(exact[key]) then
          identity.copyIdentity(exact[key], row)
          copyPolicy(exact[key], row)
          exact[key]._compactIndex = index
        end
      else
        exact[key], keep[#keep + 1] = row, row
      end
    else
      legacy[#legacy + 1] = row
    end
  end
  for _, row in pairs(exact) do
    local key = identity.labelKey(row)
    exactByLabel[key] = exactByLabel[key] or {}
    exactByLabel[key][#exactByLabel[key] + 1] = row
  end
  local legacyByKey = {}
  for _, row in ipairs(legacy) do
    local candidates = {}
    for _, candidate in ipairs(exactByLabel[identity.labelKey(row)] or {}) do
      if identity.compatibleFlow(row, candidate) then candidates[#candidates + 1] = candidate end
    end
    if #candidates == 1 then
      local exactRow, legacyIndex = candidates[1], compactIndex(row)
      if legacyIndex > compactIndex(exactRow) then copyPolicy(exactRow, row); exactRow._compactIndex = legacyIndex end
    else
      local key = tostring(identity.explicitKind(row) or "") .. "|" .. identity.labelKey(row)
      if legacyByKey[key] then
        copyPolicy(legacyByKey[key], row)
        legacyByKey[key]._compactIndex = compactIndex(row)
      else
        legacyByKey[key], keep[#keep + 1] = row, row
      end
    end
  end
  table.sort(keep, function(a, b) return compactIndex(a) < compactIndex(b) end)
  local rows = {}
  for _, row in ipairs(keep) do row._compactIndex = nil; rows[#rows + 1] = normalize(row) end
  return { autoEnabled = config.autoEnabled ~= false, workflows = rows }
end

return compact
-- Guarded recipe onboarding is deliberately separate from the normal local
-- workflow catalog. Metadata scanning is an explicit maintenance operation;
-- committing one result performs only exact Craftable-handle verification and
-- never submits a craft request. Older bridges use one filtered compatibility
-- lookup at this explicit, daemon-quiesced boundary.
local binding = require("oc.ae2.request_binding")
local discovery = require("oc.ae2.craft_discovery")
local model = require("oc.ae2.workflow_model")
local store = require("oc.ae2.workflow_store")
local authority = require("oc.ae2.workflow_onboarding_authority")

local onboarding = {}

local sessionKind = "ae2_workflow_onboarding_v1"
local defaultScanLimit, maxScanLimit = 64, 384
local defaultCandidateLimit, maxCandidateLimit = 64, 128

local function trim(value)
  return tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", "")
end

local function boundedInteger(value, fallback, maximum)
  value = math.floor(tonumber(value) or fallback)
  if value < 1 then value = 1 end
  if value > maximum then value = maximum end
  return value
end

local function maintenanceReady(receipt, expectedGeneration)
  if type(receipt) ~= "table" then return false, "prepare onboarding maintenance before craft discovery" end
  if expectedGeneration ~= nil
      and tonumber(receipt.maintenanceGeneration) ~= tonumber(expectedGeneration) then
    return false, "maintenance ownership changed; prepare onboarding again"
  end
  local ok, ready, reason, status = pcall(authority.poll, receipt)
  if not ok then return false, "could not verify onboarding maintenance: " .. tostring(ready) end
  if ready ~= true then return false, reason or (status and status.reason) or "daemon is still stopping" end
  return true, nil, status
end

local function pendingClear()
  if type(store.hasPending) ~= "function" then return true end
  local ok, pending = pcall(store.hasPending)
  if not ok then return false, "could not verify pending workflow edits: " .. tostring(pending) end
  if pending then
    return false, "save or discard the pending workflow edit before craft onboarding"
  end
  return true
end

local function workflowIndex(value)
  if value == nil then return nil end
  local index = tonumber(value)
  if not index or index < 1 or index ~= math.floor(index) then
    return nil, "workflow index must be a positive whole number"
  end
  return index
end

local function editableConfig()
  local ok, config, reason = pcall(store.editableConfig)
  if not ok then return nil, tostring(config) end
  if type(config) ~= "table" or type(config.workflows) ~= "table" then
    return nil, reason or "workflow config is unavailable"
  end
  return config
end

local function copyMap(source)
  local out = {}
  for key, value in pairs(type(source) == "table" and source or {}) do out[key] = value end
  return out
end

local function compactCandidate(entry)
  entry = type(entry) == "table" and entry or {}
  local out = {}
  model.copyIdentity(out, entry)
  out.label = tostring(out.label or entry.label or entry.rawLabel or entry.name or "unknown")
  out.rawLabel = entry.rawLabel and tostring(entry.rawLabel) or nil
  out.name = entry.name and tostring(entry.name) or nil
  out.hasTag = binding.tagged(entry.hasTag)
  out.kind = (out.kind == "fluid" or out.isFluid == true) and "fluid" or "item"
  out.isFluid = out.kind == "fluid"
  out.damage = out.isFluid and nil or entry.damage
  out.amount = entry.amount
  if out.name then
    out.filter = { name = out.name }
    if not out.isFluid and out.damage ~= nil then out.filter.damage = out.damage end
  end
  if type(entry.source) == "table" then
    out.source = {
      address = entry.source.address, type = entry.source.type, mode = entry.source.mode
    }
  end
  return out
end

local function candidateKey(entry)
  if entry and entry.name and entry.name ~= "" then
    local parts = {
      tostring(entry.kind or (entry.isFluid and "fluid" or "item")),
      tostring(entry.name), tostring(entry.damage or ""), tostring(binding.tagged(entry.hasTag))
    }
    if binding.tagged(entry.hasTag) then parts[#parts + 1] = model.labelKey(entry) end
    return table.concat(parts, "|")
  end
  return "label|" .. model.keyFor(entry)
end

local function candidateLess(left, right)
  local leftLabel, rightLabel = tostring(left.label or ""):lower(), tostring(right.label or ""):lower()
  if leftLabel ~= rightLabel then return leftLabel < rightLabel end
  return candidateKey(left) < candidateKey(right)
end

local function release(session)
  session.candidates, session.candidateKeys = nil, nil
  session.cursors, session.iterators, session.doneNodes, session.rawCounts = nil, nil, nil, nil
  if type(collectgarbage) == "function" then pcall(collectgarbage, "collect") end
end

local function activeSession(session)
  if type(session) ~= "table" or session.kind ~= sessionKind then
    return false, "onboarding session is not active"
  end
  if session.state == "disposed" or session.state == "committed" then
    return false, "onboarding session is not active: " .. tostring(session.state)
  end
  return true
end

local function progressReport(session)
  return {
    session = session,
    candidates = session.candidates or {},
    scanned = tonumber(session.scanned) or 0,
    matched = tonumber(session.matched) or 0,
    complete = session.complete == true,
    capped = session.capped == true,
    error = session.error,
    errors = session.errors or {},
    progress = {
      state = session.state, scanned = tonumber(session.scanned) or 0,
      matched = tonumber(session.matched) or 0,
      candidates = #(session.candidates or {}), limit = session.maxCandidates,
      complete = session.complete == true, capped = session.capped == true
    }
  }
end

function onboarding.begin(query, targetConfigIndex, maintenanceReceipt)
  query = trim(query)
  if #query < 2 then return nil, "craft search requires at least 2 characters" end
  if #query > 96 then return nil, "craft search is limited to 96 characters" end
  local index, indexReason = workflowIndex(targetConfigIndex)
  if targetConfigIndex ~= nil and not index then return nil, indexReason end
  local ready, readyReason = maintenanceReady(maintenanceReceipt)
  if not ready then return nil, readyReason end
  local clear, clearReason = pendingClear()
  if not clear then return nil, clearReason end
  if index then
    local config, configReason = editableConfig()
    if not config then return nil, configReason end
    if not config.workflows[index] then
      return nil, "workflow index " .. tostring(index) .. " does not exist"
    end
  end
  return {
    kind = sessionKind, state = "ready", query = query, targetConfigIndex = index,
    maintenanceReceipt = maintenanceReceipt,
    maintenanceGeneration = tonumber(maintenanceReceipt.maintenanceGeneration),
    candidates = {}, candidateKeys = {}, cursors = {}, iterators = {}, doneNodes = {}, rawCounts = {},
    scanned = 0, matched = 0, complete = false, capped = false, errors = {}
  }
end

function onboarding.step(session, options)
  local active, activeReason = activeSession(session)
  if not active then return nil, activeReason end
  local ready, readyReason = maintenanceReady(session.maintenanceReceipt, session.maintenanceGeneration)
  if not ready then return nil, readyReason end
  if session.complete then return progressReport(session) end

  options = options or {}
  local scanLimit = boundedInteger(options.scanLimit, defaultScanLimit, maxScanLimit)
  session.maxCandidates = session.maxCandidates
    or boundedInteger(options.maxCandidates, defaultCandidateLimit, maxCandidateLimit)
  local remaining = math.max(0, session.maxCandidates - #(session.candidates or {}))
  if remaining == 0 then
    session.complete, session.capped, session.state = true, true, "capped"
    return progressReport(session)
  end

  session.state = "scanning"
  local ok, report = pcall(discovery.discoverAllMetadata, nil, {
    query = session.query, scanAll = true, scanLimit = scanLimit,
    maxEntries = remaining, stopAfterMaxEntries = true,
    cursors = session.cursors, iterators = session.iterators,
    doneNodes = session.doneNodes, rawCounts = session.rawCounts
  })
  if not ok or type(report) ~= "table" then
    session.state, session.error = "error", "craft metadata scan failed: " .. tostring(report)
    return progressReport(session)
  end

  session.scanned = session.scanned + (tonumber(report.scanned) or 0)
  session.matched = session.matched + (tonumber(report.matched) or #(report.entries or {}))
  session.cursors, session.iterators = copyMap(report.cursors), copyMap(report.iterators)
  session.doneNodes, session.rawCounts = copyMap(report.doneNodes), copyMap(report.rawCounts)
  for _, entry in ipairs(report.entries or {}) do
    local candidate = compactCandidate(entry)
    local key = candidateKey(candidate)
    if not session.candidateKeys[key] and #session.candidates < session.maxCandidates then
      session.candidateKeys[key] = true
      session.candidates[#session.candidates + 1] = candidate
    end
  end
  table.sort(session.candidates, candidateLess)

  session.errors = {}
  for _, value in ipairs(report.errors or {}) do session.errors[#session.errors + 1] = tostring(value) end
  session.error = report.error and tostring(report.error) or nil
  if #(session.candidates or {}) > 0 then session.error = nil end
  session.capped = report.capped == true or #session.candidates >= session.maxCandidates
  session.complete = report.complete == true or session.capped
  if session.capped then session.state = "capped"
  elseif session.complete then session.state = "complete"
  elseif session.error then session.state = "error"
  else session.state = "ready" end
  return progressReport(session)
end

function onboarding.commit(session, candidateIndex)
  return require("oc.ae2.workflow_onboarding_commit").run(session, candidateIndex, {
    activeSession = activeSession, maintenanceReady = maintenanceReady, pendingClear = pendingClear,
    editableConfig = editableConfig, release = release
  })
end

function onboarding.dispose(session)
  if type(session) ~= "table" or session.kind ~= sessionKind then return false end
  if session.state ~= "committed" then session.state = "disposed" end
  release(session)
  return true
end

return onboarding
-- Exclusive daemon authority transaction for guarded recipe onboarding.
-- A ticket owns one disabled config generation, so stale UI receipts cannot
-- pass after an off/on/off ABA cycle or restore somebody else's ownership.
local computer = require("computer")
local daemonConfig = require("oc.ae2.maintainer_daemon_config")
local daemonControl = require("oc.ae2.maintainer_daemon_control")
local maintainerState = require("oc.ae2.maintainer_state")

local authority = {}
local ticketKind = "ae2_onboarding_maintenance_v1"

local function validTicket(ticket)
  if type(ticket) ~= "table" or ticket.kind ~= ticketKind
      or tonumber(ticket.maintenanceGeneration) == nil then
    return false, "onboarding maintenance ticket is invalid"
  end
  return true
end

local function statusFor(ticket, worker, state, ready, reason)
  worker = type(worker) == "table" and worker or {}
  local out = {
    ready = ready == true,
    quiescent = ready == true,
    state = state,
    reason = reason,
    ownerGeneration = tonumber(ticket and ticket.ownerGeneration),
    maintenanceGeneration = tonumber(ticket and ticket.maintenanceGeneration),
    restoreRequired = ticket and ticket.restoreRequired == true,
    acknowledgementRequired = ticket and ticket.acknowledgementRequired == true,
    workerState = worker.workerState,
    stoppedGeneration = tonumber(worker.stoppedGeneration),
    stoppedAt = tonumber(worker.stoppedAt),
    stopReason = worker.stopReason
  }
  if ready then
    if out.acknowledgementRequired then
      out.proof = "worker exit generation " .. tostring(out.ownerGeneration) .. " acknowledged"
    else
      out.proof = "no active worker in generation " .. tostring(out.ownerGeneration)
    end
  end
  return out
end

local function ownership(ticket)
  local cfg = daemonConfig.load()
  if cfg.enabled == true or tonumber(cfg.generation) ~= tonumber(ticket.maintenanceGeneration) then
    local reason = "maintenance ownership changed; prepare onboarding again"
    return nil, reason, statusFor(ticket, maintainerState.status(), "stop_failed", false, reason)
  end
  return cfg
end

function authority.poll(ticket)
  local valid, validReason = validTicket(ticket)
  if not valid then return false, validReason, { ready = false, state = "stop_failed", reason = validReason } end
  local cfg, ownerReason, ownerStatus = ownership(ticket)
  if not cfg then return false, ownerReason, ownerStatus end
  local worker = maintainerState.status()
  local acknowledged = ticket.acknowledgementRequired ~= true
    or (worker.workerState == "stopped"
      and tonumber(worker.stoppedGeneration) == tonumber(ticket.ownerGeneration))
  if acknowledged then return true, nil, statusFor(ticket, worker, "quiescent", true) end
  return false, nil, statusFor(ticket, worker, "stopping", false,
    "waiting for daemon generation " .. tostring(ticket.ownerGeneration) .. " to exit")
end

function authority.prepare()
  local beforeConfig = daemonConfig.load()
  local beforeStatus = daemonControl.status()
  local ownerGeneration = tonumber(beforeConfig.generation) or 0
  local ownerObserved = tonumber(beforeStatus.generation) == ownerGeneration
    and (beforeStatus.workerState == "running" or beforeStatus.fresh == true)
  local stopped, stopReason = daemonControl.stop()
  if not stopped then
    return nil, stopReason, { ready = false, state = "stop_failed", reason = stopReason }
  end
  local disabled = daemonConfig.load()
  local ticket = {
    kind = ticketKind,
    ownerGeneration = ownerGeneration,
    maintenanceGeneration = tonumber(disabled.generation),
    restoreRequired = beforeConfig.enabled == true,
    acknowledgementRequired = ownerObserved == true,
    preparedAt = computer.uptime()
  }
  local ready, reason, status = authority.poll(ticket)
  status.ready = ready == true
  return ticket, reason, status
end

function authority.restore(ticket)
  local valid, validReason = validTicket(ticket)
  if not valid then return false, validReason, { state = "restore_failed", reason = validReason } end
  if ticket.restoredGeneration ~= nil then
    local cfg = daemonConfig.load()
    if cfg.enabled == true and tonumber(cfg.generation) == tonumber(ticket.restoredGeneration) then
      local status = daemonControl.status()
      status.restored, status.state = true, "restored"
      return true, nil, status
    end
    local reason = "daemon ownership changed after onboarding restore"
    return false, reason, { state = "restore_failed", reason = reason }
  end
  local ready, reason, preparation = authority.poll(ticket)
  if not ready then return false, reason or preparation.reason, preparation end
  if ticket.restoreRequired ~= true then
    ticket.restored = true
    preparation.restored, preparation.state = false, "left_off"
    preparation.desiredEnabled = false
    return true, nil, preparation
  end
  local ok, startReason, status = daemonControl.start({
    expectedGeneration = ticket.maintenanceGeneration,
    deferFirstTick = true
  })
  if not ok then
    status = status or {}
    status.state, status.reason = "restore_failed", startReason
    return false, startReason, status
  end
  local cfg = daemonConfig.load()
  ticket.restored, ticket.restoredGeneration = true, tonumber(cfg.generation)
  status = status or daemonControl.status()
  status.restored, status.state = true, "restored"
  return true, nil, status
end

return authority
-- Exact candidate verification and durable binding for guarded onboarding.
-- Session lifecycle and metadata scanning remain in workflow_onboarding.lua.
local binding = require("oc.ae2.request_binding")
local direct = require("oc.ae2.request_direct")
local model = require("oc.ae2.workflow_model")
local store = require("oc.ae2.workflow_store")

local commit = {}

local function exactSame(left, right)
  if not (left and right and left.name and right.name) then return false end
  local leftFlow, rightFlow = model.normalize(left), model.normalize(right)
  if binding.tagged(leftFlow.hasTag) ~= binding.tagged(rightFlow.hasTag) then return false end
  if leftFlow.kind ~= rightFlow.kind or tostring(leftFlow.name) ~= tostring(rightFlow.name) then return false end
  if leftFlow.kind == "fluid" then return true end
  if tonumber(leftFlow.damage) ~= tonumber(rightFlow.damage) then return false end
  if binding.tagged(leftFlow.hasTag) then
    local leftMarker = binding.makeCapacityBinding(leftFlow)
    local rightMarker = binding.makeCapacityBinding(rightFlow)
    return leftMarker ~= nil and rightMarker ~= nil and leftMarker.label == rightMarker.label
  end
  return true
end

local function destination(config, candidate, targetConfigIndex)
  for index, row in ipairs(config.workflows or {}) do
    if index ~= targetConfigIndex and exactSame(row, candidate) then
      return nil, "exact target is already managed by workflow index " .. tostring(index)
    end
  end

  if targetConfigIndex then
    local row = config.workflows[targetConfigIndex]
    if not row then return nil, "workflow index " .. tostring(targetConfigIndex) .. " does not exist" end
    local replacingTagged = binding.tagged(row.hasTag)
    local normalized = model.normalize(row)
    if normalized.locked then return nil, "line contract locked" end
    if row.name and tostring(row.name) ~= "" and not replacingTagged then
      return nil, "workflow index " .. tostring(targetConfigIndex)
        .. " already has a different exact binding; use the explicit rebind command"
    end
    -- A tagged persisted identity cannot be queried safely, but protected Bind
    -- Recipe may replace it after the operator selects an untagged candidate
    -- and the exact server-side verification below succeeds.
    return { action = "bound", index = targetConfigIndex, row = row, replacedTagged = replacingTagged }
  end

  local matchedIndex, matchedCount = nil, 0
  for index, row in ipairs(config.workflows or {}) do
    if not row.name and model.labelKey(row) == model.labelKey(candidate) then
      local rowKind = model.normalize(row).kind
      if rowKind == candidate.kind then matchedIndex, matchedCount = index, matchedCount + 1 end
    end
  end
  if matchedCount > 1 then
    return nil, "multiple label-only workflows match; select the policy row to bind"
  end
  if matchedIndex then
    local row = config.workflows[matchedIndex]
    if binding.tagged(row.hasTag) then return nil, "tagged workflows cannot be bound by onboarding" end
    if model.normalize(row).locked then return nil, "line contract locked" end
    return { action = "bound", index = matchedIndex, row = row }
  end
  return { action = "added", index = #config.workflows + 1 }
end

local function verify(candidate)
  local ok, entry, reason, report = pcall(direct.resolve, candidate, {
    directNodeLimit = 3,
    onboardingCapacity = binding.capacityCell(candidate),
    compatibilityFallback = true,
    compatibilityNodeLimit = 1,
    compatibilityCallLimit = 1,
    compatibilityHandleLimit = 16,
    remember = false
  })
  if not ok then return nil, tostring(entry), { direct = true, error = tostring(entry) } end
  return entry, reason, report
end

function commit.run(session, candidateIndex, support)
  local active, activeReason = support.activeSession(session)
  if not active then return false, activeReason end
  local ready, readyReason = support.maintenanceReady(session.maintenanceReceipt, session.maintenanceGeneration)
  if not ready then return false, readyReason end
  local clear, clearReason = support.pendingClear()
  if not clear then return false, clearReason end

  local index = tonumber(candidateIndex)
  if not index or index < 1 or index ~= math.floor(index) then
    return false, "candidate index must be a positive whole number"
  end
  local candidate = session.candidates and session.candidates[index]
  if not candidate then return false, "candidate index " .. tostring(index) .. " does not exist" end
  local bindReason = binding.onboardingError(candidate)
  if bindReason then return false, bindReason end

  local config, configReason = support.editableConfig()
  if not config then return false, configReason end
  local planned, planReason = destination(config, candidate, session.targetConfigIndex)
  if not planned then return false, planReason end

  local exact, exactReason, verification = verify(candidate)
  if not exact then
    return false, exactReason or "exact recipe verification failed", {
      action = "blocked", label = candidate.label, name = candidate.name,
      damage = candidate.damage, kind = candidate.kind, verification = verification
    }
  end
  if binding.tagged(candidate) then
    candidate.craftBinding = binding.copyCapacityBinding(exact)
    if not candidate.craftBinding then
      return false, "BIND EXACT TARGET REQUIRED: tagged capacity verification did not return a durable binding", {
        action = "blocked", label = candidate.label, name = candidate.name,
        damage = candidate.damage, kind = candidate.kind, verification = verification
      }
    end
  else
    candidate.craftBinding = nil
  end

  ready, readyReason = support.maintenanceReady(session.maintenanceReceipt, session.maintenanceGeneration)
  if not ready then return false, readyReason end
  clear, clearReason = support.pendingClear()
  if not clear then return false, clearReason end
  config, configReason = support.editableConfig()
  if not config then return false, configReason end
  planned, planReason = destination(config, candidate, session.targetConfigIndex)
  if not planned then return false, planReason end

  local row
  if planned.action == "added" then
    row = model.normalize(candidate)
    row.mode, row.lineAuthority, row.armed = "manual", "observe", false
    config.workflows[#config.workflows + 1] = row
  else
    row = planned.row
    model.copyIdentity(row, candidate)
    if candidate.kind == "fluid" or candidate.isFluid == true then
      row.damage = nil
    else
      row.damage = candidate.damage
    end
    row.hasTag, row.armed = binding.tagged(candidate.hasTag), false
  end

  local saveCalled, saved, saveReason = pcall(store.saveConfig, config, true)
  if not saveCalled then return false, tostring(saved) end
  if not saved then return false, saveReason end

  local cacheWarm, cacheReason = false, nil
  local cacheLoaded, cache = pcall(require, "oc.ae2.request_cache")
  if cacheLoaded and cache and type(cache.remember) == "function" then
    local rememberCalled, remembered, rememberReason = pcall(cache.remember, exact)
    cacheWarm = rememberCalled and remembered ~= nil
    if cacheWarm then
      cacheReason = nil
    elseif not rememberCalled then
      cacheReason = tostring(remembered)
    elseif rememberReason ~= nil then
      cacheReason = tostring(rememberReason)
    else
      cacheReason = "verified handle could not be retained"
    end
  elseif not cacheLoaded then
    cacheReason = tostring(cache)
  end
  local receipt = {
    action = planned.action, index = planned.index, configIndex = planned.index,
    label = candidate.label, name = candidate.name, damage = candidate.damage,
    kind = candidate.kind, armed = false, replacedTagged = planned.replacedTagged == true,
    verification = verification,
    cacheWarm = cacheWarm,
    cacheReason = cacheReason
  }
  session.state, session.complete = "committed", true
  support.release(session)
  return true, nil, receipt
end

return commit
local store = require("oc.ae2.workflow_store")
local model = require("oc.ae2.workflow_model")
local binding = require("oc.ae2.request_binding")

local printer = {}

local function tagged(row) return binding.tagged(row) end

local function bindingText(row)
  row = row or {}
  if tagged(row) then return "BLOCKED tagged variant" end
  local kind = (row.kind == "fluid" or row.isFluid == true) and "fluid" or "item"
  if not row.name or tostring(row.name) == "" then return "BIND REQUIRED" end
  if kind == "item" and row.damage == nil then return "BIND REQUIRED item damage" end
  return string.format("BOUND %s %s dmg=%s", kind, tostring(row.name),
    kind == "fluid" and "-" or tostring(row.damage))
end

function printer.print()
  local config = store.load()
  io.write("AE2 workflows (config index)\n")
  for i, row in ipairs(config.workflows or {}) do
    io.write(string.format("#%02d %s %s intent=%s authority=%s below=%s max=%s\n",
      i, row.mode, row.label, row.lineIntent, row.lineAuthority, row.alertBelow or row.minStock, row.maxRequest or row.batch))
  end
end

function printer.printBindings()
  local config = store.load()
  io.write("AE2 exact bindings (no AE2 query)\n")
  for index, row in ipairs(config.workflows or {}) do
    local normalized = model.normalize(row)
    io.write(string.format("%02d %-24s %s\n", index, tostring(normalized.label), bindingText(row)))
  end
  printer.printBindHelp()
end

function printer.printBindHelp()
  io.write("bind: ae2-workflow --bind <index> <item|fluid> <namespace:path> <damage|->\n")
  io.write("rebind: ae2-workflow --rebind <index> <item|fluid> <namespace:path> <damage|-> CONFIRM\n")
  io.write("item requires non-negative damage; fluid requires -. Binding preserves policy and refuses armed, locked, tagged, or already-owned identities.\n")
  io.write("index is the current config row from --list/--show-bind; recheck it after deleting or editing workflows.\n")
  io.write("--bind is first migration only; --rebind corrects an existing exact identity and requires CONFIRM.\n")
end

return printer
local computer = require("computer")

local budget = require("oc.ae2.budget")
local cacheEpoch = require("oc.ae2.cache_epoch")
local maintainerLog = require("oc.ae2.maintainer_log")
local maintainerQueue = require("oc.ae2.maintainer_queue")
local maintainerStateOk, maintainerState = pcall(require, "oc.ae2.maintainer_state")
local requestCache = require("oc.ae2.request_cache")
local requester = require("oc.ae2.requester")

local requests = {}

local function confirmed(report)
  return report and report.requestState == "running" and report.requestPhase == "submitted"
end

local function terminal(report)
  local state = report and report.requestState
  return state == "done" or state == "blocked" or state == "failed" or state == "canceled"
end

local function failed(report)
  local state = report and report.requestState
  return state == "blocked" or state == "failed" or state == "canceled"
end

local function applyReport(entry, amount, report)
  if not entry then return end
  entry.request = amount
  entry.requestState = report and report.requestState
  entry.requestPhase = report and report.requestPhase
  entry.requestStatusReason = report and report.requestStatusReason
  entry.requestError = failed(report) and (entry.requestStatusReason or entry.requestState) or nil
end

function requests.observeManual(entry, report, now)
  report = type(report) == "table" and report or {}
  now = tonumber(now) or computer.uptime()
  local amount = tonumber(report.amount) or tonumber(entry and entry.request) or 1
  applyReport(entry, amount, report)
  if not maintainerStateOk or type(maintainerState) ~= "table" then
    return nil, "maintainer lifecycle state unavailable: " .. tostring(maintainerState)
  end
  local recorder = confirmed(report) and maintainerState.recordManualBatch or maintainerState.recordManualStatus
  if type(recorder) ~= "function" then return nil, "maintainer lifecycle recorder unavailable" end
  local called, saved, saveErr = pcall(recorder, entry, now, report)
  if not called then return nil, tostring(saved) end
  if saved ~= true then return nil, tostring(saveErr or "maintainer lifecycle save failed") end
  if confirmed(report) and report.manualConfirmed ~= true then
    cacheEpoch.recordManualBatch(entry, now)
    maintainerQueue.markManual(entry, now)
    report.manualConfirmed = true
  end
  if (confirmed(report) or terminal(report)) and report.manualLogged ~= true then
    local logged, logErr = maintainerLog.append(entry, now)
    if not logged then entry.logError = logErr end
    report.manualLogged = true
  end
  return true
end

function requests.requestManual(entry)
  local workflow = entry and entry.workflow
  local amount = tonumber(workflow and (workflow.maxRequest or workflow.batch))
    or tonumber(entry and (entry.maxRequest or entry.batch or entry.request)) or 1
  if not (entry and entry.label) then return nil, "no craft selected" end
  local bindErr = requestCache.bindingError(entry)
  if bindErr then return nil, bindErr, { bindingRequired = true, scans = 0, handles = 0 } end
  budget.trySpend("manual_action", { borrow = true })
  local now = computer.uptime()
  local status, err, report = requester.requestTarget(entry, amount, {
    prioritizePower = true,
    track = { id = maintainerQueue.id(entry), amount = amount, submittedAt = now,
      label = entry.label, source = "manual", target = entry }
  })
  report = type(report) == "table" and report or {}
  report.amount = tonumber(report.amount) or amount
  if report.requestState then
    local called, observed, observeErr = pcall(requests.observeManual, entry, report, now)
    if not called then observeErr, observed = observed, nil end
    report.recordPending = observed ~= true
    report.observationError = observeErr
  end
  return status, err, report
end

return requests
local cacheEpoch = require("oc.ae2.cache_epoch")
local maintainerStateOk, maintainerState = pcall(require, "oc.ae2.maintainer_state")
local model = require("oc.ae2.workflow_model")
local storeIo = require("oc.ae2.workflow_store_io")

local store = {}
local pendingConfig = nil

store.path = model.path
store.backupPath = model.path .. ".bak"

local function readAt(path)
  local text, readReason, present = storeIo.read(path)
  if text == nil then return nil, readReason, present end
  local value, decodeReason = storeIo.decode(path, text)
  if type(value) ~= "table" or type(value.workflows) ~= "table" then
    return nil, "invalid workflow config: " .. path, true
  end
  return model.compactConfig({ autoEnabled = value.autoEnabled ~= false, workflows = value.workflows }), nil, true, {
    text = text, value = value, oneLine = storeIo.oneLine(text)
  }
end

local function readExisting()
  local config, err, exists = readAt(store.path)
  if config then return config end
  -- If promotion stopped after primary -> .previous, the prior policy is the
  -- only confirmed authority. Read it without silently promoting/deleting it.
  local recovery = storeIo.recoveryStatus(store.path)
  if exists == false and (recovery.state == "restore_previous" or recovery.state == "promote_staged") then
    local prior, priorErr = readAt(store.path .. ".previous")
    if prior then return prior end
    err = err or priorErr
  end
  -- A backup is useful only when the canonical path is absent. If a primary
  -- exists but cannot be parsed, treating an old backup as live authority can
  -- keep automation running against policy the operator can no longer audit.
  -- Return the error so store.load falls back to disarmed defaults instead.
  if exists == true then return nil, err, true end
  local backup, backupErr, backupExists = readAt(store.backupPath)
  if backup then return backup end
  return nil, err or backupErr, exists or backupExists
end

local function writeSerialized(path, config)
  local ok, reason = storeIo.writeReadable(path, config)
  if not ok then return false, reason end
  return true, nil, config
end

local function patchMaintainerState(saved)
  if maintainerStateOk and maintainerState and maintainerState.patchTargets then
    pcall(function()
      maintainerState.patchTargets(model.asTargets(saved), nil, { autoEnabled = model.autoEnabled(saved) })
    end)
  end
end

function store.load()
  local config = readExisting()
  return config or model.defaultConfig()
end

function store.migrationStatus()
  local recovery = storeIo.recoveryStatus(store.path)
  if recovery.state ~= "clean" then
    return {
      path = store.path, state = recovery.state, exists = recovery.primary.present == true,
      reason = recovery.reason or recovery.state, recovery = recovery
    }
  end
  local config, err, exists, source = readAt(store.path)
  if not exists then return { path = store.path, state = "missing", exists = false } end
  if not config then return { path = store.path, state = "invalid", exists = true, reason = err } end
  local rows, unbound, tagged = #(config.workflows or {}), 0, 0
  for _, row in ipairs(config.workflows or {}) do
    if not row.name or row.name == "" then unbound = unbound + 1 end
    if row.hasTag == true then tagged = tagged + 1 end
  end
  local sourceRows = type(source and source.value and source.value.workflows) == "table"
    and #source.value.workflows or rows
  return {
    path = store.path, state = source and source.oneLine and "legacy_one_line" or "readable",
    exists = true, bytes = #(source and source.text or ""), sourceRows = sourceRows, rows = rows,
    compacted = math.max(0, sourceRows - rows), unbound = unbound, tagged = tagged,
    config = config, raw = source and source.text or nil, rawValue = source and source.value or nil,
    preserved = true
  }
end

function store.recoveryStatus()
  return storeIo.recoveryStatus(store.path)
end

function store.recover()
  return storeIo.recover(store.path)
end

function store.migrate()
  if pendingConfig then return false, "flush or discard the pending workflow edit before migration" end
  local status = store.migrationStatus()
  if status.state == "missing" or status.state == "readable" then return true, nil, status end
  if status.state ~= "legacy_one_line" then return false, status.reason or "workflow config requires recovery or is invalid", status end
  local archive = store.path .. ".pre-migrate.bak"
  local archived, archiveReason = storeIo.writeRawNew(archive, status.raw)
  if not archived then return false, archiveReason, status end
  -- Formatting must preserve every parsed key and row exactly. Canonical
  -- compaction belongs to an explicit future maintenance action, never to a
  -- readability conversion.
  local saved, saveReason = writeSerialized(store.path, status.rawValue)
  if not saved then return false, saveReason, status end
  status.state, status.converted, status.archive = "converted", true, archive
  return true, nil, status
end

function store.loadForEdit()
  local config, err, exists = readExisting()
  if config then return config end
  if exists then return nil, err or ("could not load " .. store.path) end
  return model.defaultConfig()
end

function store.save(config)
  local recovery = storeIo.recoveryStatus(store.path)
  if recovery.state ~= "clean" then
    return false, "workflow config requires recovery before saving: " .. tostring(recovery.state)
  end
  config = model.compactConfig(config)
  local rows = {}
  for i, row in ipairs(config.workflows or {}) do rows[i] = model.normalize(row) end
  local saved = { autoEnabled = config.autoEnabled ~= false, workflows = rows }
  local previous, previousReason, primaryExists = readAt(store.path)
  if primaryExists == nil then return false, previousReason end
  if primaryExists and not previous then
    return false, "refusing to overwrite unreadable existing workflow config: " .. tostring(previousReason)
  end
  if previous then
    local backedUp, backupReason = writeSerialized(store.backupPath, previous)
    if not backedUp then return false, "could not preserve prior workflow config: " .. tostring(backupReason) end
  end
  return writeSerialized(store.path, saved)
end

local function editableConfig()
  if pendingConfig then return pendingConfig end
  return store.loadForEdit()
end

function store.editableConfig()
  return editableConfig()
end

function store.saveConfig(config, preserveOnFailure)
  if not config then return false, "no workflow config to save" end
  local ok, err, saved = store.save(config)
  if ok then
    pendingConfig = nil
    cacheEpoch.recordWorkflow(saved or config, "workflow_save")
    patchMaintainerState(saved or config)
  elseif preserveOnFailure then
    pendingConfig = config
  end
  return ok, err, saved
end

function store.setPending(config)
  pendingConfig = config
  return pendingConfig
end

function store.pending()
  return pendingConfig
end

function store.flushPending()
  if not pendingConfig then return true, nil, nil end
  local config = pendingConfig
  pendingConfig = nil
  local ok, err, saved = store.saveConfig(config, false)
  if not ok then pendingConfig = config end
  return ok, err, saved
end

function store.hasPending()
  return pendingConfig ~= nil
end

return store
-- Transactional readable persistence for the workflow authority file.  The
-- normal runtime only reads this file; writes are explicit editor/migration
-- actions and must leave a recoverable primary if OpenOS is interrupted.
local filesystem = require("filesystem")
local serialization = require("serialization")
local readable = require("oc.core.config")

local ioStore = {}

local function exists(path)
  local ok, found, reason = pcall(filesystem.exists, path)
  if not ok then return nil, tostring(found) end
  if type(found) ~= "boolean" then return nil, tostring(reason or "could not inspect " .. tostring(path)) end
  return found
end

local function remove(path)
  local found, existsReason = exists(path)
  if found == nil then return false, existsReason end
  if not found then return true end
  local ok, result, reason = pcall(filesystem.remove, path)
  if not ok or result ~= true then return false, tostring(reason or result or "remove failed") end
  return true
end

local function rename(from, to)
  local ok, result, reason = pcall(filesystem.rename, from, to)
  if not ok or result ~= true then return false, tostring(reason or result or "rename failed") end
  return true
end

function ioStore.exists(path) return exists(path) end

function ioStore.read(path)
  local present, presentReason = exists(path)
  if present == nil then return nil, presentReason, nil end
  if not present then return nil, nil, false end
  local opened, handle, openReason = pcall(io.open, path, "r")
  if not opened then return nil, tostring(handle), true end
  if not handle then return nil, tostring(openReason or "could not open " .. tostring(path)), true end
  local readOk, text, readReason = pcall(function() return handle:read("*a") end)
  local closeOk, closed, closeReason = pcall(function() return handle:close() end)
  if not readOk then return nil, tostring(readReason or text), true end
  if not closeOk or closed == false then return nil, tostring(closeReason or closed or "could not close " .. tostring(path)), true end
  return text or "", nil, true
end

function ioStore.decode(path, text)
  local ok, value = pcall(serialization.unserialize, text or "")
  if not ok or type(value) ~= "table" then return nil, "invalid workflow config: " .. tostring(path) end
  return value
end

local function decodedFile(path)
  local text, readReason, present = ioStore.read(path)
  if present ~= true then return { path = path, present = present, reason = readReason } end
  local value, decodeReason = ioStore.decode(path, text)
  if type(value) ~= "table" or type(value.workflows) ~= "table" then
    return { path = path, present = true, raw = text, reason = decodeReason or "workflow table is missing" }
  end
  return { path = path, present = true, raw = text, value = value }
end

-- A write either finishes with a primary only, or leaves enough named files
-- for a human-confirmed resolver. Runtime readers never silently promote a
-- staged candidate.
function ioStore.recoveryStatus(path)
  local primary = decodedFile(path)
  local staged = decodedFile(path .. ".new")
  local previous = decodedFile(path .. ".previous")
  local status = { path = path, primary = primary, staged = staged, previous = previous }
  if primary.present == nil or staged.present == nil or previous.present == nil then
    status.state, status.reason = "io_error", primary.reason or staged.reason or previous.reason
  elseif staged.present ~= true and previous.present ~= true then
    if primary.present == true and not primary.value then
      status.state, status.reason = "invalid_primary", primary.reason
    else
      status.state = "clean"
    end
  elseif primary.value and previous.value and staged.present ~= true then
    status.state, status.action = "cleanup_previous", "cleanup_previous"
  elseif primary.present ~= true and previous.value and staged.present ~= true then
    status.state, status.action = "restore_previous", "restore_previous"
  elseif primary.present ~= true and staged.value and (previous.present ~= true or previous.value) then
    status.state, status.action = "promote_staged", "promote_staged"
  else
    status.state = "manual_recovery"
    status.reason = "staged workflow files are ambiguous or invalid"
  end
  return status
end

function ioStore.recover(path)
  local status = ioStore.recoveryStatus(path)
  if status.state == "clean" then return true, nil, status end
  if status.state == "cleanup_previous" then
    local cleaned, reason = remove(path .. ".previous")
    if not cleaned then return false, reason, status end
  elseif status.state == "restore_previous" then
    local restored, reason = rename(path .. ".previous", path)
    if not restored then return false, reason, status end
  elseif status.state == "promote_staged" then
    local promoted, reason = rename(path .. ".new", path)
    if not promoted then return false, reason, status end
    if status.previous.present == true then
      local cleaned, cleanupReason = remove(path .. ".previous")
      if not cleaned then return false, cleanupReason, ioStore.recoveryStatus(path) end
    end
  else
    return false, status.reason or "manual recovery required", status
  end
  local after = ioStore.recoveryStatus(path)
  if after.state ~= "clean" then return false, "recovery remains unresolved: " .. tostring(after.state), after end
  return true, nil, after
end

local function write(path, body)
  local opened, handle, openReason = pcall(io.open, path, "w")
  if not opened then return false, tostring(handle) end
  if not handle then return false, tostring(openReason or "could not write " .. tostring(path)) end
  local writeOk, wrote, writeReason = pcall(function() return handle:write(body) end)
  local closeOk, closed, closeReason = pcall(function() return handle:close() end)
  if not writeOk or wrote == nil or wrote == false then return false, tostring(writeReason or wrote or "write failed") end
  if not closeOk or closed == false then return false, tostring(closeReason or closed or "close failed") end
  return true
end

local function stagedBody(path, value)
  local body, renderReason = readable.render(value)
  if not body then return nil, renderReason end
  local staged = path .. ".new"
  local stagedPresent, stagedReason = exists(staged)
  if stagedPresent == nil then return nil, stagedReason end
  if stagedPresent then return nil, "workflow config has an unpromoted staged file at " .. staged end
  local wrote, writeReason = write(staged, body .. "\n")
  if not wrote then remove(staged); return nil, writeReason end
  local verified = decodedFile(staged)
  if not verified.value then
    remove(staged)
    return nil, "staged workflow verification failed: " .. tostring(verified.reason or "could not re-read staged workflow config")
  end
  return staged
end

function ioStore.writeReadable(path, value)
  local recovery = ioStore.recoveryStatus(path)
  if recovery.state ~= "clean" then
    return false, "workflow config requires recovery before saving: " .. tostring(recovery.state)
  end
  local staged, stageReason = stagedBody(path, value)
  if not staged then return false, stageReason end
  local previous = path .. ".previous"
  local previousPresent, previousReason = exists(previous)
  if previousPresent == nil then
    remove(staged)
    return false, previousReason
  end
  if previousPresent then
    remove(staged)
    return false, "workflow config has an unresolved prior file at " .. previous
  end
  local moved = false
  if recovery.primary.present == true then
    local moveOk, moveReason = rename(path, previous)
    if not moveOk then remove(staged); return false, "could not preserve workflow config: " .. tostring(moveReason) end
    moved = true
  end
  local promoteOk, promoteReason = rename(staged, path)
  if not promoteOk then
    if moved then rename(previous, path) end
    remove(staged)
    return false, "could not promote staged workflow config: " .. tostring(promoteReason)
  end
  if moved then
    local cleaned, cleanupReason = remove(previous)
    if not cleaned then
      return false, "workflow config promoted but prior cleanup requires recovery: " .. tostring(cleanupReason)
    end
  end
  return true
end

function ioStore.writeRawNew(path, body)
  local existing, existingReason, present = ioStore.read(path)
  if present == nil then return false, existingReason end
  if present then
    if existing == (body or "") then return true, nil, "reused" end
    return false, "refusing to overwrite a different migration archive " .. path
  end
  local wrote, reason = write(path, body or "")
  if not wrote then return false, reason end
  local verified, verifyReason = ioStore.read(path)
  if verified ~= (body or "") then
    remove(path)
    return false, verifyReason or "migration archive verification failed"
  end
  return true
end

function ioStore.oneLine(text)
  if type(text) ~= "string" then return false end
  local logical = text:gsub("[\r\n]+$", "")
  return not logical:find("[\r\n]")
end

return ioStore
local catalog = require("oc.ae2.workflow_catalog")
local editor = require("oc.ae2.workflow_editor")
local model = require("oc.ae2.workflow_model")
local printer = require("oc.ae2.workflow_print")
local requests = require("oc.ae2.workflow_requests")
local store = require("oc.ae2.workflow_store")

local workflows = {}

workflows.path = model.path
workflows.backupPath = store.backupPath
workflows.defaults = model.defaults
workflows.defaultConditions = model.defaultConditions
workflows.manualTemplate = model.manualTemplate
workflows.conditionFields = model.conditionFields
workflows.minimumCooldown = model.minimumCooldown
workflows.maxCooldown = model.maxCooldown
function workflows.defaultConfig() return model.defaultConfig() end
function workflows.load() return store.load() end
function workflows.save(config) return store.save(config) end
function workflows.migrationStatus() return store.migrationStatus() end
function workflows.migrate() return store.migrate() end
function workflows.recoveryStatus() return store.recoveryStatus() end
function workflows.recover() return store.recover() end
function workflows.catalog(cache, options) return catalog.catalog(cache, options) end
function workflows.disposeCatalog(cache)
  if type(catalog.dispose) == "function" then return catalog.dispose(cache) end
  return true
end
function workflows.prepareOnboarding()
  return require("oc.ae2.workflow_onboarding_authority").prepare()
end
function workflows.pollOnboardingPreparation(ticket)
  return require("oc.ae2.workflow_onboarding_authority").poll(ticket)
end
function workflows.restoreOnboarding(ticket)
  return require("oc.ae2.workflow_onboarding_authority").restore(ticket)
end
function workflows.beginOnboarding(query, targetConfigIndex, ticket)
  return require("oc.ae2.workflow_onboarding").begin(query, targetConfigIndex, ticket)
end
function workflows.stepOnboarding(session, options)
  return require("oc.ae2.workflow_onboarding").step(session, options)
end
function workflows.commitOnboarding(session, candidateIndex)
  return require("oc.ae2.workflow_onboarding").commit(session, candidateIndex)
end
function workflows.disposeOnboarding(session)
  return require("oc.ae2.workflow_onboarding").dispose(session)
end
function workflows.upsert(config, entry, patch) return editor.upsert(config, entry, patch) end
function workflows.bindExact(index, kind, name, damage) return editor.bindExact(index, kind, name, damage) end
function workflows.rebindExact(index, kind, name, damage, confirmation)
  return editor.rebindExact(index, kind, name, damage, confirmation)
end
function workflows.toggleAuto(entry) return editor.toggleAuto(entry) end
function workflows.toggleArmed(entry) return editor.toggleArmed(entry) end
function workflows.disarmAll() return editor.disarmAll() end
function workflows.setAllArmed(enabled, options) return editor.setAllArmed(enabled, options) end
function workflows.toggleGlobalAuto() return editor.toggleGlobalAuto() end
function workflows.setGlobalAuto(enabled) return editor.setGlobalAuto(enabled) end
function workflows.autoEnabled(config) return model.autoEnabled(config or store.editableConfig()) end
function workflows.armedCount(config) return model.armedCount(config or store.editableConfig()) end
function workflows.requestManual(entry)
  if type(requests.requestManual) ~= "function" then
    return nil, "workflow_requests.lua is missing requestManual; redeploy the full AE2 system and restart dashboard"
  end
  local ok, status, err, report = pcall(requests.requestManual, entry)
  if not ok then return nil, tostring(status) end
  return status, err, report
end
function workflows.observeManual(entry, report, now)
  if type(requests.observeManual) ~= "function" then
    return nil, "workflow_requests.lua is missing observeManual; redeploy the full AE2 system and restart dashboard"
  end
  local ok, result, err = pcall(requests.observeManual, entry, report, now)
  if not ok then return nil, tostring(result) end
  return result, err
end
function workflows.adjust(entry, field, delta) return editor.adjust(entry, field, delta) end
function workflows.adjustPending(entry, field, delta) return editor.adjustPending(entry, field, delta) end
function workflows.setValue(entry, field, value) return editor.setValue(entry, field, value) end
function workflows.setChoice(entry, field, value) return editor.setChoice(entry, field, value) end
function workflows.delete(entry) return editor.delete(entry) end
function workflows.workflowFor(config, entry) return model.workflowFor(config or store.editableConfig(), entry) end
function workflows.flushPending() return store.flushPending() end
function workflows.hasPending() return store.hasPending() end
function workflows.asTargets(config) return model.asTargets(config or store.editableConfig()) end
function workflows.print() return printer.print() end
function workflows.printBindings() return printer.printBindings() end
function workflows.printBindHelp() return printer.printBindHelp() end

return workflows
local component = require("component")
local adapter = require("oc.ae2.adapter")

local probe = {}

probe.methods = {
  "getCpus",
  "getItemsInNetwork",
  "getFluidsInNetwork",
  "getCraftables",
  "getItemInNetwork",
  "getFluidInNetwork",
  "getCraftable",
  "getStoredPower",
  "getMaxStoredPower",
  "getAvgPowerUsage",
  "getAvgPowerInjection",
  "getIdlePowerUsage",
  "getEnergyStored",
  "getMaxEnergyStored"
}

probe.bulkGridMethods = {
  getItemsInNetwork = true,
  getFluidsInNetwork = true,
  getCraftables = true
}

probe.exactTargetMethods = {
  getItemInNetwork = true,
  getFluidInNetwork = true,
  getCraftable = true
}

local function summarize(value)
  local valueType = type(value)
  if valueType == "table" then
    return "table#" .. tostring(#value)
  elseif valueType == "number" or valueType == "boolean" or valueType == "string" then
    return tostring(value)
  elseif value == nil then
    return "nil"
  end
  return valueType
end

local function hasMethod(address, methodName)
  local ok, methods = pcall(component.methods, address)
  return ok and type(methods) == "table" and methods[methodName] ~= nil
end

local function call(address, methodName)
  if not hasMethod(address, methodName) then
    return { method = methodName, status = "missing" }
  end
  if probe.bulkGridMethods[methodName] then
    return { method = methodName, status = "available", detail = "not invoked; grid enumeration is offline-only" }
  end
  if probe.exactTargetMethods[methodName] then
    return { method = methodName, status = "available", detail = "not invoked; requires an exact configured identity" }
  end

  local ok, value = pcall(component.invoke, address, methodName)
  if not ok then
    return { method = methodName, status = "error", detail = tostring(value) }
  end
  return { method = methodName, status = "ok", detail = summarize(value) }
end

local function probeNode(node)
  local results = {}
  for _, methodName in ipairs(probe.methods) do
    results[#results + 1] = call(node.address, methodName)
  end
  return { address = node.address, type = node.type, results = results }
end

function probe.run()
  local components = adapter.components()
  -- A normal status path stays on known AE2 component types. The probe is an
  -- intentional diagnostic, so it may make one broader method-capability
  -- pass if a mod exposes the network under an unexpected component type.
  if #components == 0 then components = adapter.components({ includeUnknown = true }) end
  if #components == 0 then
    local _, reason = adapter.primary()
    return { available = false, reason = reason, results = {}, components = {} }
  end

  local rows = {}
  for _, node in ipairs(components) do rows[#rows + 1] = probeNode(node) end
  return {
    available = true,
    primary = { address = components[1].address, type = components[1].type },
    results = rows[1].results,
    components = rows,
    componentCount = #rows
  }
end

function probe.print(report)
  report = report or probe.run()
  if not report.available then
    io.write("AE2 unavailable: " .. tostring(report.reason) .. "\n")
    return
  end

  io.write(string.format("AE2 probe: %d visible AE2 component(s)\n", tonumber(report.componentCount) or 1))
  for _, node in ipairs(report.components or { report.primary }) do
    io.write(string.format("%s %s\n", node.type, node.address))
    for _, result in ipairs(node.results or report.results or {}) do
      if result.detail then
        io.write(string.format("  %s: %s %s\n", result.method, result.status, result.detail))
      else
        io.write(string.format("  %s: %s\n", result.method, result.status))
      end
    end
  end
end

return probe
#!/bin/lua
local monitor = require("oc.ae2.monitor")
local args = {...}
local offline = args[1] == "--offline"
monitor.print(nil, { offlineGrid = offline })
if not offline then
  io.write("Live AE2 grid counts are disabled; use ae2-scan --offline only during planned diagnostics.\n")
end
