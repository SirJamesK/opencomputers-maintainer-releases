local function exists(path)
  local ok, value = pcall(filesystem.exists, path)
  return ok and value == true
end

local function clip(value, width)
  value = tostring(value or "")
  if #value <= width then return value end
  if width <= 3 then return value:sub(1, width) end
  return value:sub(1, width - 3) .. "..."
end

local function matches(entry, filter)
  if not filter or filter == "" or filter == "--all" then return true end
  return entry.system == filter or entry.name == filter
end

function catalog.list(filter)
  local rows = {}
  for _, entry in ipairs(catalog.entries) do
    if matches(entry, filter) then
      rows[#rows + 1] = entry
    end
  end
  return rows
end

local function printHelp()
  io.write("usage: commands [filter]\n")
  io.write("filter may be a system or command name\n")
  io.write("systems: commands core ae2 gt_power dashboard\n")
  io.write("examples: commands ae2 | commands oc-config-migrate\n")
end

local function printRow(entry)
  local state = exists(entry.path) and "ok" or "missing"
  io.write(string.format("%-7s %-13s %-28s %s\n",
    state,
    clip(entry.name, 13),
    clip(entry.usage, 28),
    clip(entry.summary, 26)))
end

function catalog.print(filter)
  if filter == "-h" or filter == "--help" then
    printHelp()
    return
  end

  local rows = catalog.list(filter)
  if #rows == 0 then
    io.write("no managed commands matching " .. tostring(filter) .. "\n")
    printHelp()
    return
  end

  io.write("managed OpenOS commands\n")
  io.write("status  command       usage                        purpose\n")
  for _, entry in ipairs(rows) do
    printRow(entry)
    if filter == entry.name and type(entry.notes) == "table" then
      for _, note in ipairs(entry.notes) do
        io.write("        " .. note .. "\n")
      end
    end
  end
end

return catalog
#!/bin/lua
local catalog = require("oc.commands.catalog")
local args = {...}

catalog.print(args[1])
